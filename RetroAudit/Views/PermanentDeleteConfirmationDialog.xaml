<Window x:Class="RetroAudit.Views.PermanentDeleteConfirmationDialog"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Kalıcı Sil" Height="380" Width="360" WindowStartupLocation="CenterOwner"
        ResizeMode="NoResize">

    <Grid Background="{StaticResource Brush.Background.Base}">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
            <RowDefinition Height="Auto" />
        </Grid.RowDefinitions>

        <StackPanel Grid.Row="0" Margin="16,14,16,0">
            <TextBlock FontSize="14" FontWeight="Bold">
                <Run Text="&quot;" /><Run Text="{Binding GameTitle, Mode=OneWay}" /><Run Text="&quot; çöp kutusundan kalıcı olarak silinsin mi?" />
            </TextBlock>
            <TextBlock Text="Bu işlem geri alınamaz. Aşağıda işaretli dosya türleri Windows Çöp Kutusu'na taşınır."
                       TextWrapping="Wrap" Foreground="{StaticResource Brush.Text.Secondary}" FontSize="11" Margin="0,4,0,0" />
        </StackPanel>

        <StackPanel Grid.Row="1" Margin="16,16">
            <CheckBox Content="ROM Dosyaları" IsChecked="{Binding DeleteRom}" Margin="0,0,0,12" FontSize="13" />
            <CheckBox Content="Box (Kapak)" IsChecked="{Binding DeleteBox}" Margin="0,0,0,12" FontSize="13" />
            <CheckBox Content="SS (Ekran Görüntüsü / Arkaplan)" IsChecked="{Binding DeleteScreenshot}" Margin="0,0,0,12" FontSize="13" />
            <CheckBox Content="Logo" IsChecked="{Binding DeleteLogo}" Margin="0,0,0,12" FontSize="13" />
        </StackPanel>

        <Border Grid.Row="2" Background="{StaticResource Brush.Background.Panel}"
                BorderBrush="{StaticResource Brush.Border}" BorderThickness="0,1,0,0" Padding="16,10">
            <StackPanel Orientation="Horizontal" HorizontalAlignment="Right">
                <Button Content="İptal" Command="{Binding CancelCommand}" Width="90" Margin="0,0,8,0" />
                <Button Content="Kalıcı Sil" Command="{Binding DeleteCommand}" Width="100" Style="{StaticResource LaunchButton}" />
            </StackPanel>
        </Border>
    </Grid>
</Window>
