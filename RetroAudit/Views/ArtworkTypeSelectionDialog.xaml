<Window x:Class="RetroAudit.Views.ArtworkTypeSelectionDialog"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:vm="clr-namespace:RetroAudit.ViewModels"
        Title="Görsel Getir" Height="320" Width="340" WindowStartupLocation="CenterOwner"
        ResizeMode="NoResize">

    <Grid Background="{StaticResource Brush.Background.Base}">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
            <RowDefinition Height="Auto" />
        </Grid.RowDefinitions>

        <StackPanel Grid.Row="0" Margin="16,14,16,0">
            <TextBlock Text="Hangi görseller indirilsin?" FontSize="14" FontWeight="Bold" />
            <TextBlock Text="Seçilen türler, seçili oyun(lar) için mevcutsa indirilir." TextWrapping="Wrap"
                       Foreground="{StaticResource Brush.Text.Secondary}" FontSize="11" Margin="0,4,0,0" />
        </StackPanel>

        <StackPanel Grid.Row="1" Margin="16,16">
            <CheckBox Content="Box" IsChecked="{Binding IncludeBox}" Margin="0,0,0,12" FontSize="13" />
            <CheckBox Content="Clear Logo" IsChecked="{Binding IncludeClearLogo}" Margin="0,0,0,12" FontSize="13" />
            <CheckBox Content="Gameplay" IsChecked="{Binding IncludeGameplay}" Margin="0,0,0,12" FontSize="13" />
        </StackPanel>

        <Border Grid.Row="2" Background="{StaticResource Brush.Background.Panel}"
                BorderBrush="{StaticResource Brush.Border}" BorderThickness="0,1,0,0" Padding="16,10">
            <StackPanel Orientation="Horizontal" HorizontalAlignment="Right">
                <Button Content="İptal" Command="{Binding CancelCommand}" Width="90" Margin="0,0,8,0" />
                <Button Content="İndir" Command="{Binding DownloadCommand}" IsEnabled="{Binding HasAnySelected}"
                        Width="90" Style="{StaticResource LaunchButton}" />
            </StackPanel>
        </Border>
    </Grid>
</Window>
