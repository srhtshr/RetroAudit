<Window x:Class="RetroAudit.Views.MediaSearchWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:wv2="clr-namespace:Microsoft.Web.WebView2.Wpf;assembly=Microsoft.Web.WebView2.Wpf"
        Title="RetroAudit - Gorsel Ara" Height="820" Width="1200" WindowStartupLocation="CenterOwner">

    <Window.Resources>
        <Storyboard x:Key="PulseAnim" RepeatBehavior="Forever" AutoReverse="True">
            <DoubleAnimation Storyboard.TargetProperty="Opacity"
                             From="0.25" To="1.0" Duration="0:0:0.4" />
        </Storyboard>
    </Window.Resources>

    <Grid Background="{StaticResource Brush.Background.Base}">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
        </Grid.RowDefinitions>

        <Border Grid.Row="0" Background="#FF164F85" Padding="10,8"
                BorderBrush="{StaticResource Brush.Border}" BorderThickness="0,0,0,1">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto" />
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="Auto" />
                </Grid.ColumnDefinitions>

                <StackPanel Grid.Column="0" Orientation="Horizontal" VerticalAlignment="Center" Margin="0,0,14,0">
                    <Button x:Name="BackButton" Click="BackButton_Click"
                            Width="30" Height="30" Margin="0,0,4,0" ToolTip="Geri" Cursor="Hand"
                            Background="Transparent" BorderThickness="0">
                        <Button.Template>
                            <ControlTemplate TargetType="Button">
                                <Border x:Name="Bg" Background="{TemplateBinding Background}" CornerRadius="4">
                                    <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                </Border>
                                <ControlTemplate.Triggers>
                                    <Trigger Property="IsMouseOver" Value="True">
                                        <Setter TargetName="Bg" Property="Background" Value="#30FFFFFF"/>
                                    </Trigger>
                                    <Trigger Property="IsEnabled" Value="False">
                                        <Setter Property="Opacity" Value="0.35"/>
                                    </Trigger>
                                </ControlTemplate.Triggers>
                            </ControlTemplate>
                        </Button.Template>
                        <Canvas Width="14" Height="14">
                            <Polyline Points="9,2 3,7 9,12" Stroke="White" StrokeThickness="2"
                                      StrokeLineJoin="Round" StrokeStartLineCap="Round" StrokeEndLineCap="Round"/>
                        </Canvas>
                    </Button>
                    <Button x:Name="ForwardButton" Click="ForwardButton_Click"
                            Width="30" Height="30" ToolTip="Ileri" Cursor="Hand"
                            Background="Transparent" BorderThickness="0">
                        <Button.Template>
                            <ControlTemplate TargetType="Button">
                                <Border x:Name="Bg" Background="{TemplateBinding Background}" CornerRadius="4">
                                    <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                </Border>
                                <ControlTemplate.Triggers>
                                    <Trigger Property="IsMouseOver" Value="True">
                                        <Setter TargetName="Bg" Property="Background" Value="#30FFFFFF"/>
                                    </Trigger>
                                    <Trigger Property="IsEnabled" Value="False">
                                        <Setter Property="Opacity" Value="0.35"/>
                                    </Trigger>
                                </ControlTemplate.Triggers>
                            </ControlTemplate>
                        </Button.Template>
                        <Canvas Width="14" Height="14">
                            <Polyline Points="5,2 11,7 5,12" Stroke="White" StrokeThickness="2"
                                      StrokeLineJoin="Round" StrokeStartLineCap="Round" StrokeEndLineCap="Round"/>
                        </Canvas>
                    </Button>
                </StackPanel>

                <TextBlock Grid.Column="1" HorizontalAlignment="Center" VerticalAlignment="Center"
                           FontSize="11" FontWeight="SemiBold" Foreground="#88FFFFFF">
                    <Run Text="Gorsele sag tikla  ·  " />
                    <Run Text="YouTube'dayken Videoyu Kaydet aktiflesir" />
                </TextBlock>

                <StackPanel Grid.Column="2" Orientation="Horizontal" VerticalAlignment="Center" Margin="8,0,0,0">

                    <Button x:Name="SaveImageButton" Click="SaveImageButton_Click"
                            ToolTip="Bu URL'deki resmi RetroAudit'e kaydet (resim sayfasindayken aktif)"
                            Cursor="Hand" Opacity="0.25" IsEnabled="False"
                            Margin="0,0,6,0" Padding="8,5" BorderThickness="1">
                        <Button.Template>
                            <ControlTemplate TargetType="Button">
                                <Border x:Name="Bg" CornerRadius="4" Padding="{TemplateBinding Padding}"
                                        Background="#22FFFFFF" BorderBrush="#44FFFFFF"
                                        BorderThickness="{TemplateBinding BorderThickness}">
                                    <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center" />
                                </Border>
                                <ControlTemplate.Triggers>
                                    <Trigger Property="IsMouseOver" Value="True">
                                        <Setter TargetName="Bg" Property="Background" Value="#40FFFFFF" />
                                    </Trigger>
                                </ControlTemplate.Triggers>
                            </ControlTemplate>
                        </Button.Template>
                        <StackPanel Orientation="Horizontal">
                            <TextBlock Text="&#xE8B9;" FontFamily="Segoe MDL2 Assets" FontSize="14"
                                       Foreground="White" VerticalAlignment="Center" Margin="0,0,5,0"/>
                            <TextBlock Text="Resmi Kaydet" FontSize="11" FontWeight="SemiBold"
                                       Foreground="White" VerticalAlignment="Center"/>
                        </StackPanel>
                    </Button>

                    <Button x:Name="SaveVideoButton" Click="SaveVideoButton_Click"
                            ToolTip="Bu YouTube videosunu RetroAudit'e kaydet (YouTube Watch sayfasindayken aktif)"
                            Cursor="Hand" Opacity="0.25" IsEnabled="False"
                            Margin="0,0,6,0" Padding="8,5" BorderThickness="1">
                        <Button.Template>
                            <ControlTemplate TargetType="Button">
                                <Border x:Name="Bg" CornerRadius="4" Padding="{TemplateBinding Padding}"
                                        Background="#22FFFFFF" BorderBrush="#44FFFFFF"
                                        BorderThickness="{TemplateBinding BorderThickness}">
                                    <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center" />
                                </Border>
                                <ControlTemplate.Triggers>
                                    <Trigger Property="IsMouseOver" Value="True">
                                        <Setter TargetName="Bg" Property="Background" Value="#40FFFFFF" />
                                    </Trigger>
                                </ControlTemplate.Triggers>
                            </ControlTemplate>
                        </Button.Template>
                        <StackPanel Orientation="Horizontal">
                            <Path Data="M10,16.5V7.5L16,12M12,2A10,10 0 0,0 2,12A10,10 0 0,0 12,22A10,10 0 0,0 22,12A10,10 0 0,0 12,2Z"
                                  Fill="White" Width="14" Height="14" Stretch="Uniform"
                                  VerticalAlignment="Center" Margin="0,0,5,0"/>
                            <TextBlock Text="Videoyu Kaydet" FontSize="11" FontWeight="SemiBold"
                                       Foreground="White" VerticalAlignment="Center"/>
                        </StackPanel>
                    </Button>

                    <Button x:Name="CopyUrlButton" Click="CopyUrlButton_Click"
                            ToolTip="Mevcut sayfanin URL'sini panoya kopyala"
                            Cursor="Hand" Padding="8,5"
                            Background="#22FFFFFF" BorderBrush="#44FFFFFF" BorderThickness="1"
                            Foreground="White" FontSize="11" FontWeight="SemiBold" VerticalAlignment="Center">
                        <Button.Template>
                            <ControlTemplate TargetType="Button">
                                <Border x:Name="Bg"
                                        Background="{TemplateBinding Background}"
                                        BorderBrush="{TemplateBinding BorderBrush}"
                                        BorderThickness="{TemplateBinding BorderThickness}"
                                        CornerRadius="4" Padding="{TemplateBinding Padding}">
                                    <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center" />
                                </Border>
                                <ControlTemplate.Triggers>
                                    <Trigger Property="IsMouseOver" Value="True">
                                        <Setter TargetName="Bg" Property="Background" Value="#40FFFFFF" />
                                    </Trigger>
                                </ControlTemplate.Triggers>
                            </ControlTemplate>
                        </Button.Template>
                        <StackPanel Orientation="Horizontal">
                            <TextBlock Text="&#xE8C8;" FontFamily="Segoe MDL2 Assets" FontSize="13"
                                       Foreground="White" VerticalAlignment="Center" Margin="0,0,5,0"/>
                            <TextBlock x:Name="CopyUrlText" Text="URL Kopyala"
                                       FontSize="11" FontWeight="SemiBold" Foreground="White" VerticalAlignment="Center"/>
                        </StackPanel>
                    </Button>
                </StackPanel>
            </Grid>
        </Border>

        <Border x:Name="ProgressPanel" Grid.Row="1"
                Visibility="Collapsed"
                Background="#FF0F3A5E"
                BorderBrush="{StaticResource Brush.Border}"
                BorderThickness="0,0,0,1"
                Padding="14,6">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto" />
                    <ColumnDefinition Width="*" />
                </Grid.ColumnDefinitions>
                <TextBlock x:Name="ProgressStatusText"
                           Grid.Column="0" VerticalAlignment="Center"
                           FontSize="11" FontWeight="SemiBold"
                           Foreground="#FF64D2FF" Margin="0,0,12,0"
                           Text="&#x23F3;  Indiriliyor..." />
                <ProgressBar Grid.Column="1" Height="4"
                             IsIndeterminate="True"
                             Foreground="#FF3EA6FF" Background="#22FFFFFF"
                             BorderThickness="0" VerticalAlignment="Center" />
            </Grid>
        </Border>

        <wv2:WebView2 Grid.Row="2" x:Name="Browser" />
    </Grid>
</Window>