<Window x:Class="RetroAudit.Views.MediaProviderWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:vm="clr-namespace:RetroAudit.ViewModels"
        xmlns:models="clr-namespace:RetroAudit.Models"
        Title="Media Provider" Height="700" Width="1150" WindowStartupLocation="CenterOwner">

    <Window.DataContext>
        <vm:MediaProviderViewModel />
    </Window.DataContext>

    <Grid Background="{StaticResource Brush.Background.Base}">
        <Grid.RowDefinitions>
            <RowDefinition Height="*" />
            <RowDefinition Height="Auto" />
        </Grid.RowDefinitions>

        <Grid Grid.Row="0">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="220" />
                <ColumnDefinition Width="1" />
                <ColumnDefinition Width="320" />
                <ColumnDefinition Width="1" />
                <ColumnDefinition Width="*" />
            </Grid.ColumnDefinitions>

            <!-- Left: platform + media type filters -->
            <Border Grid.Column="0" Background="{StaticResource Brush.Background.Panel}">
                <DockPanel Margin="10">
                    <TextBlock DockPanel.Dock="Top" Text="Platformlar" FontWeight="Bold" Margin="0,0,0,8" />
                    <StackPanel DockPanel.Dock="Bottom" Margin="0,10,0,0">
                        <TextBlock Text="Eksik Medya Türü" FontWeight="Bold" Margin="0,0,0,6" />
                        <ComboBox ItemsSource="{Binding MediaTypeFilters}" SelectedItem="{Binding SelectedMediaTypeFilter}" />
                    </StackPanel>
                    <ListBox ItemsSource="{Binding Platforms}" SelectedItem="{Binding SelectedPlatform}">
                        <ListBox.ItemTemplate>
                            <DataTemplate DataType="{x:Type models:Platform}">
                                <TextBlock Text="{Binding Name}" Margin="2" />
                            </DataTemplate>
                        </ListBox.ItemTemplate>
                    </ListBox>
                </DockPanel>
            </Border>

            <Rectangle Grid.Column="1" Fill="{StaticResource Brush.Border}" />

            <!-- Center: missing items -->
            <Border Grid.Column="2" Background="{StaticResource Brush.Background.Base}">
                <DockPanel Margin="10">
                    <TextBlock DockPanel.Dock="Top" Text="Eksik Öğeler" FontWeight="Bold" Margin="0,0,0,8" />
                    <ListBox ItemsSource="{Binding MissingItems}" SelectedItem="{Binding SelectedMissingItem}">
                        <ListBox.ItemTemplate>
                            <DataTemplate DataType="{x:Type vm:MissingMediaItem}">
                                <StackPanel Margin="2,4">
                                    <TextBlock Text="{Binding Title}" FontWeight="SemiBold" />
                                    <TextBlock Foreground="{StaticResource Brush.Text.Secondary}" FontSize="11">
                                        <Run Text="{Binding Platform}" /><Run Text=" • " /><Run Text="{Binding MissingType}" />
                                    </TextBlock>
                                </StackPanel>
                            </DataTemplate>
                        </ListBox.ItemTemplate>
                    </ListBox>
                </DockPanel>
            </Border>

            <Rectangle Grid.Column="3" Fill="{StaticResource Brush.Border}" />

            <!-- Right: search result cards -->
            <Border Grid.Column="4" Background="{StaticResource Brush.Background.Base}">
                <DockPanel Margin="10">
                    <TextBlock DockPanel.Dock="Top" Text="Arama Sonuçları" FontWeight="Bold" Margin="0,0,0,8" />
                    <ScrollViewer VerticalScrollBarVisibility="Auto">
                        <ItemsControl ItemsSource="{Binding SearchResults}">
                            <ItemsControl.ItemsPanel>
                                <ItemsPanelTemplate>
                                    <WrapPanel />
                                </ItemsPanelTemplate>
                            </ItemsControl.ItemsPanel>
                            <ItemsControl.ItemTemplate>
                                <DataTemplate DataType="{x:Type vm:MediaSearchResult}">
                                    <Border Width="150" Height="170" Margin="6" CornerRadius="4"
                                            Background="{StaticResource Brush.Background.Panel}"
                                            BorderBrush="{StaticResource Brush.Border}" BorderThickness="1">
                                        <Grid Margin="6">
                                            <Grid.RowDefinitions>
                                                <RowDefinition Height="*" />
                                                <RowDefinition Height="Auto" />
                                            </Grid.RowDefinitions>
                                            <Border Grid.Row="0" Background="{StaticResource Brush.Background.Elevated}" CornerRadius="3">
                                                <Border Background="{StaticResource Brush.Accent.Amber}" CornerRadius="8"
                                                        Padding="5,1" HorizontalAlignment="Right" VerticalAlignment="Top" Margin="4">
                                                    <TextBlock Text="{Binding Resolution}" FontSize="9"
                                                               Foreground="{StaticResource Brush.Accent.AmberText}" />
                                                </Border>
                                            </Border>
                                            <TextBlock Grid.Row="1" Text="{Binding Source}" HorizontalAlignment="Center"
                                                       Margin="0,6,0,0" FontSize="10"
                                                       Foreground="{StaticResource Brush.Text.Secondary}" />
                                        </Grid>
                                    </Border>
                                </DataTemplate>
                            </ItemsControl.ItemTemplate>
                        </ItemsControl>
                    </ScrollViewer>
                </DockPanel>
            </Border>
        </Grid>

        <Border Grid.Row="1" Background="{StaticResource Brush.Background.Panel}"
                BorderBrush="{StaticResource Brush.Border}" BorderThickness="0,1,0,0" Padding="10">
            <StackPanel Orientation="Horizontal" HorizontalAlignment="Right">
                <Button Content="Atla" Command="{Binding SkipItemCommand}" Margin="0,0,8,0" />
                <Button Content="Uygula" Command="{Binding ApplySelectedResultCommand}" />
            </StackPanel>
        </Border>
    </Grid>
</Window>
