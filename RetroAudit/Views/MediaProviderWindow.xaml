<Window x:Class="RetroAudit.Views.MediaProviderWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:vm="clr-namespace:RetroAudit.ViewModels"
        xmlns:models="clr-namespace:RetroAudit.Models"
        xmlns:conv="clr-namespace:RetroAudit.Converters"
        Title="Media Provider"
        Height="760"
        Width="1520"
        MinWidth="1280"
        MinHeight="720"
        WindowStartupLocation="CenterOwner">
    <Window.Resources>
        <conv:InverseBooleanConverter x:Key="InverseBoolean" />
        <conv:PercentageToWidthConverter x:Key="PercentageToWidth" />
        <conv:BoolToVisibilityConverter x:Key="BoolToVisibility" />

        <Style x:Key="ViewToggleRadioButtonStyle" TargetType="RadioButton">
            <Setter Property="Width" Value="28" />
            <Setter Property="Height" Value="24" />
            <Setter Property="Background" Value="Transparent" />
            <Setter Property="BorderThickness" Value="0" />
            <Setter Property="Foreground" Value="{StaticResource Brush.Text.Secondary}" />
            <Setter Property="Cursor" Value="Hand" />
            <Setter Property="Margin" Value="2,0" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="RadioButton">
                        <Border x:Name="Bg" Background="{TemplateBinding Background}" CornerRadius="4">
                            <TextBlock Text="{TemplateBinding Content}"
                                       FontFamily="Segoe MDL2 Assets"
                                       FontSize="11"
                                       HorizontalAlignment="Center"
                                       VerticalAlignment="Center"
                                       Foreground="{TemplateBinding Foreground}" />
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsChecked" Value="True">
                                <Setter TargetName="Bg" Property="Background" Value="#FF232328" />
                                <Setter Property="Foreground" Value="White" />
                            </Trigger>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="Bg" Property="Background" Value="#FF1B1B1E" />
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="ProviderSwitchButtonStyle" TargetType="Button" BasedOn="{StaticResource {x:Type Button}}">
            <Setter Property="MinWidth" Value="106" />
            <Setter Property="Padding" Value="14,7" />
            <Setter Property="Margin" Value="0,0,8,0" />
            <Setter Property="Foreground" Value="{StaticResource Brush.Text.Primary}" />
            <Setter Property="Background" Value="{StaticResource Brush.Background.Elevated}" />
            <Setter Property="BorderBrush" Value="{StaticResource Brush.Border}" />
            <Setter Property="BorderThickness" Value="1" />
            <Setter Property="Cursor" Value="Hand" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="Root"
                                Background="{StaticResource Brush.Background.Elevated}"
                                BorderBrush="{StaticResource Brush.Border}"
                                BorderThickness="1"
                                CornerRadius="4">
                            <ContentPresenter HorizontalAlignment="Center"
                                              VerticalAlignment="Center"
                                              Margin="{TemplateBinding Padding}" />
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsEnabled" Value="True">
                                <Setter TargetName="Root" Property="Background" Value="{Binding Background, RelativeSource={RelativeSource TemplatedParent}}" />
                                <Setter TargetName="Root" Property="BorderBrush" Value="{Binding BorderBrush, RelativeSource={RelativeSource TemplatedParent}}" />
                                <Setter TargetName="Root" Property="BorderThickness" Value="{Binding BorderThickness, RelativeSource={RelativeSource TemplatedParent}}" />
                            </Trigger>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="Root" Property="BorderBrush" Value="#FF525762" />
                            </Trigger>
                            <Trigger Property="IsPressed" Value="True">
                                <Setter TargetName="Root" Property="Opacity" Value="0.9" />
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="ActiveProviderSwitchButtonStyle" TargetType="Button" BasedOn="{StaticResource ProviderSwitchButtonStyle}">
            <Setter Property="Background" Value="{StaticResource Brush.Accent}" />
            <Setter Property="BorderBrush" Value="{StaticResource Brush.Accent}" />
            <Setter Property="Foreground" Value="White" />
            <Setter Property="Cursor" Value="Arrow" />
        </Style>
        <Style x:Key="TableSearchButtonStyle" TargetType="Button" BasedOn="{StaticResource {x:Type Button}}">
            <Setter Property="Width" Value="24" />
            <Setter Property="Height" Value="24" />
            <Setter Property="Background" Value="Transparent" />
            <Setter Property="BorderThickness" Value="0" />
            <Setter Property="Padding" Value="0" />
            <Setter Property="Cursor" Value="Hand" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="Bg" Background="{TemplateBinding Background}" CornerRadius="3">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center" />
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="Bg" Property="Background" Value="#FF232328" />
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="CardFilterBadgeToggle" TargetType="ToggleButton">
            <Setter Property="Background" Value="#FF1B1B1E" />
            <Setter Property="BorderThickness" Value="0" />
            <Setter Property="Foreground" Value="{StaticResource Brush.Text.Secondary}" />
            <Setter Property="Padding" Value="8,3" />
            <Setter Property="Margin" Value="0,0,10,4" />
            <Setter Property="Cursor" Value="Hand" />
            <Setter Property="FontSize" Value="11.5" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="ToggleButton">
                        <Border x:Name="Root"
                                Background="{TemplateBinding Background}"
                                BorderThickness="0"
                                CornerRadius="4">
                            <ContentPresenter Margin="{TemplateBinding Padding}"
                                              HorizontalAlignment="Center"
                                              VerticalAlignment="Center" />
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsChecked" Value="True">
                                <Setter TargetName="Root" Property="Background" Value="#FF0078D4" />
                                <Setter Property="Foreground" Value="White" />
                                <Setter Property="FontWeight" Value="SemiBold" />
                            </Trigger>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="Root" Property="Background" Value="#FF232328" />
                                <Setter Property="Foreground" Value="{StaticResource Brush.Text.Primary}" />
                            </Trigger>
                            <MultiTrigger>
                                <MultiTrigger.Conditions>
                                    <Condition Property="IsChecked" Value="True" />
                                    <Condition Property="IsMouseOver" Value="True" />
                                </MultiTrigger.Conditions>
                                <Setter TargetName="Root" Property="Background" Value="#FF1084E3" />
                                <Setter Property="Foreground" Value="White" />
                                <Setter Property="FontWeight" Value="SemiBold" />
                            </MultiTrigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="SearchTextBoxStyle" TargetType="TextBox">
            <Setter Property="Padding" Value="10,8" />
            <Setter Property="FontSize" Value="13" />
            <Setter Property="Background" Value="Transparent" />
            <Setter Property="BorderThickness" Value="0" />
            <Setter Property="Foreground" Value="{StaticResource Brush.Text.Primary}" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="TextBox">
                        <Grid>
                            <ScrollViewer x:Name="PART_ContentHost" />
                            <TextBlock x:Name="Placeholder"
                                       Margin="10,0,0,0"
                                       VerticalAlignment="Center"
                                       Foreground="{StaticResource Brush.Text.Secondary}"
                                       IsHitTestVisible="False"
                                       Text="Oyun ad&#x0131;na g&#x00F6;re ara..." />
                        </Grid>
                        <ControlTemplate.Triggers>
                            <Trigger Property="Text" Value="">
                                <Setter TargetName="Placeholder" Property="Visibility" Value="Visible" />
                            </Trigger>
                            <Trigger Property="Text" Value="{x:Null}">
                                <Setter TargetName="Placeholder" Property="Visibility" Value="Visible" />
                            </Trigger>
                            <Trigger Property="IsKeyboardFocused" Value="True">
                                <Setter TargetName="Placeholder" Property="Visibility" Value="Collapsed" />
                            </Trigger>
                            <Trigger Property="Text" Value=" ">
                                <Setter TargetName="Placeholder" Property="Visibility" Value="Collapsed" />
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
    </Window.Resources>

    <Grid Background="{StaticResource Brush.Background.Base}">
        <Grid.RowDefinitions>
            <RowDefinition Height="*" />
            <RowDefinition Height="Auto" />
        </Grid.RowDefinitions>

        <Grid Grid.Row="0" Margin="10,10,10,0">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="780" />
                <ColumnDefinition Width="12" />
                <ColumnDefinition Width="*" />
            </Grid.ColumnDefinitions>

            <Border Grid.Column="0"
                    Background="{StaticResource Brush.Background.Panel}"
                    BorderBrush="{StaticResource Brush.Border}"
                    BorderThickness="1"
                    CornerRadius="6">
                <DockPanel LastChildFill="True">
                    <StackPanel DockPanel.Dock="Top" Margin="10,10,10,8">
                        <TextBlock FontSize="16" FontWeight="Bold" Text="Media Audit" />
                        <WrapPanel Margin="0,12,0,0">
                            <Button Content="Metadata Provider"
                                    Click="OpenMetadataProvider_Click"
                                    Style="{StaticResource ProviderSwitchButtonStyle}" />
                            <Button Content="Media Provider"
                                    IsHitTestVisible="False"
                                    Focusable="False"
                                    Style="{StaticResource ActiveProviderSwitchButtonStyle}" />
                        </WrapPanel>
                    </StackPanel>



                    <ListBox Margin="10,0,10,0"
                             Padding="0,0,12,0"
                             ItemsSource="{Binding PlatformAuditSummaries}"
                             SelectedItem="{Binding SelectedPlatformSummary}"
                             Background="Transparent"
                             BorderThickness="0"
                             ScrollViewer.HorizontalScrollBarVisibility="Disabled"
                             ScrollViewer.VerticalScrollBarVisibility="Auto">
                        <ListBox.ItemContainerStyle>
                            <Style TargetType="ListBoxItem">
                                 <Setter Property="Padding" Value="0" />
                                <Setter Property="Margin" Value="0,0,0,8" />
                                <Setter Property="HorizontalContentAlignment" Value="Stretch" />
                                <EventSetter Event="RequestBringIntoView" Handler="ListBoxItem_RequestBringIntoView" />
                                <Setter Property="Template">
                                    <Setter.Value>
                                        <ControlTemplate TargetType="ListBoxItem">
                                            <Border x:Name="CardBorder"
                                                    Padding="12,8"
                                                    Background="{StaticResource Brush.Background.Elevated}"
                                                    BorderBrush="{StaticResource Brush.Border}"
                                                    BorderThickness="1"
                                                    CornerRadius="8">
                                                <ContentPresenter />
                                            </Border>
                                            <ControlTemplate.Triggers>
                                                <Trigger Property="IsSelected" Value="True">
                                                    <Setter TargetName="CardBorder" Property="BorderBrush" Value="{StaticResource Brush.Accent}" />
                                                </Trigger>
                                            </ControlTemplate.Triggers>
                                        </ControlTemplate>
                                    </Setter.Value>
                                </Setter>
                            </Style>
                        </ListBox.ItemContainerStyle>
                        <ListBox.ItemTemplate>
                            <DataTemplate DataType="{x:Type models:PlatformAuditSummary}">
                                <Grid>
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="110" />
                                        <ColumnDefinition Width="110" />
                                        <ColumnDefinition Width="90" />
                                        <ColumnDefinition Width="Auto" />
                                        <ColumnDefinition Width="*" />
                                    </Grid.ColumnDefinitions>
                                    <Border Grid.Column="0" Width="100" Height="62" Padding="6" Background="#FF1F1F22" CornerRadius="6" VerticalAlignment="Center">
                                        <Image Source="{Binding PlatformLogoPath, Mode=OneWay}" Stretch="Uniform" RenderOptions.BitmapScalingMode="HighQuality" />
                                    </Border>

                                    <StackPanel Grid.Column="1" VerticalAlignment="Center" Margin="10,0">
                                        <TextBlock FontSize="18" FontWeight="Bold" Foreground="White" Text="{Binding HealthPercent, StringFormat=% {0}, Mode=OneWay}" />
                                        <Border Width="90" Height="6" Margin="0,5,0,0" HorizontalAlignment="Left" Background="#FF202022" CornerRadius="3">
                                            <Border Width="{Binding HealthPercent, Converter={StaticResource PercentageToWidth}, ConverterParameter=90}" HorizontalAlignment="Left" Background="#FF4A9BFF" CornerRadius="3" />
                                        </Border>
                                    </StackPanel>

                                    <StackPanel Grid.Column="2" VerticalAlignment="Center" Margin="4,0">
                                        <Border Margin="0,0,0,4" Padding="8,3" Background="#FF1F1F22" BorderBrush="{StaticResource Brush.Border}" BorderThickness="1" CornerRadius="10" HorizontalAlignment="Left">
                                            <StackPanel Orientation="Horizontal">
                                                <TextBlock Margin="0,0,6,0"
                                                           Foreground="#FF32D74B"
                                                           FontFamily="Segoe MDL2 Assets"
                                                           FontSize="10"
                                                           Text="&#xE73E;" />
                                                <TextBlock FontWeight="SemiBold" Text="{Binding TotalGames, StringFormat={}{0:N0}, Mode=OneWay}" />
                                            </StackPanel>
                                        </Border>
                                        <Border Padding="8,3" Background="#FF1F1F22" BorderBrush="{StaticResource Brush.Border}" BorderThickness="1" CornerRadius="10" HorizontalAlignment="Left">
                                            <StackPanel Orientation="Horizontal">
                                                <TextBlock Margin="0,0,6,0"
                                                           Foreground="#FFDB4C4C"
                                                           FontFamily="Segoe MDL2 Assets"
                                                           FontSize="10"
                                                           Text="&#xE711;" />
                                                <TextBlock FontWeight="SemiBold" Text="{Binding UnmatchedCount, StringFormat={}{0:N0}, Mode=OneWay}" />
                                            </StackPanel>
                                        </Border>
                                    </StackPanel>

                                    <Border Grid.Column="3"
                                            Width="1"
                                            Height="46"
                                            Margin="4,0,8,0"
                                            Background="{StaticResource Brush.Border}"
                                            VerticalAlignment="Center" />

                                    <StackPanel Grid.Column="4" VerticalAlignment="Center" Margin="0">
                                        <WrapPanel>
                                            <ToggleButton Style="{StaticResource CardFilterBadgeToggle}"
                                                          IsChecked="{Binding DataContext.ShowMissingLogo, RelativeSource={RelativeSource AncestorType=Window}}"
                                                          PreviewMouseLeftButtonDown="FilterBadge_PreviewMouseLeftButtonDown">
                                                <StackPanel HorizontalAlignment="Center">
                                                    <StackPanel Orientation="Horizontal" HorizontalAlignment="Center">
                                                        <TextBlock FontFamily="Segoe MDL2 Assets" FontSize="10.5" Text="&#xE114;" Foreground="#FFFF9F0A" Margin="0,0,4,0" VerticalAlignment="Center" />
                                                        <TextBlock Text="Logo" />
                                                    </StackPanel>
                                                    <TextBlock Text="{Binding MissingLogoCount, StringFormat={}{0:N0}, Mode=OneWay}" FontWeight="SemiBold" Foreground="{StaticResource Brush.Text.Primary}" HorizontalAlignment="Center" Margin="0,2,0,0" />
                                                </StackPanel>
                                            </ToggleButton>
                                            <ToggleButton Style="{StaticResource CardFilterBadgeToggle}"
                                                          IsChecked="{Binding DataContext.ShowMissingBox, RelativeSource={RelativeSource AncestorType=Window}}"
                                                          PreviewMouseLeftButtonDown="FilterBadge_PreviewMouseLeftButtonDown">
                                                <StackPanel HorizontalAlignment="Center">
                                                    <StackPanel Orientation="Horizontal" HorizontalAlignment="Center">
                                                        <TextBlock FontFamily="Segoe MDL2 Assets" FontSize="10.5" Text="&#xE7B8;" Foreground="#FFBF5AF2" Margin="0,0,4,0" VerticalAlignment="Center" />
                                                        <TextBlock Text="Box" />
                                                    </StackPanel>
                                                    <TextBlock Text="{Binding MissingBoxCount, StringFormat={}{0:N0}, Mode=OneWay}" FontWeight="SemiBold" Foreground="{StaticResource Brush.Text.Primary}" HorizontalAlignment="Center" Margin="0,2,0,0" />
                                                </StackPanel>
                                            </ToggleButton>
                                            <ToggleButton Style="{StaticResource CardFilterBadgeToggle}"
                                                          IsChecked="{Binding DataContext.ShowMissingScreenshot, RelativeSource={RelativeSource AncestorType=Window}}"
                                                          PreviewMouseLeftButtonDown="FilterBadge_PreviewMouseLeftButtonDown">
                                                <StackPanel HorizontalAlignment="Center">
                                                    <StackPanel Orientation="Horizontal" HorizontalAlignment="Center">
                                                        <TextBlock FontFamily="Segoe MDL2 Assets" FontSize="10.5" Text="&#xE914;" Foreground="#FF30D158" Margin="0,0,4,0" VerticalAlignment="Center" />
                                                        <TextBlock Text="SS" />
                                                    </StackPanel>
                                                    <TextBlock Text="{Binding MissingScreenshotCount, StringFormat={}{0:N0}, Mode=OneWay}" FontWeight="SemiBold" Foreground="{StaticResource Brush.Text.Primary}" HorizontalAlignment="Center" Margin="0,2,0,0" />
                                                </StackPanel>
                                            </ToggleButton>
                                            <ToggleButton Style="{StaticResource CardFilterBadgeToggle}"
                                                          IsChecked="{Binding DataContext.ShowMissingVideo, RelativeSource={RelativeSource AncestorType=Window}}"
                                                          PreviewMouseLeftButtonDown="FilterBadge_PreviewMouseLeftButtonDown">
                                                <StackPanel HorizontalAlignment="Center">
                                                    <StackPanel Orientation="Horizontal" HorizontalAlignment="Center">
                                                        <TextBlock FontFamily="Segoe MDL2 Assets" FontSize="10.5" Text="&#xE714;" Foreground="#FFFF453A" Margin="0,0,4,0" VerticalAlignment="Center" />
                                                        <TextBlock Text="Video" />
                                                    </StackPanel>
                                                    <TextBlock Text="{Binding MissingVideoCount, StringFormat={}{0:N0}, Mode=OneWay}" FontWeight="SemiBold" Foreground="{StaticResource Brush.Text.Primary}" HorizontalAlignment="Center" Margin="0,2,0,0" />
                                                </StackPanel>
                                            </ToggleButton>
                                            <ToggleButton Style="{StaticResource CardFilterBadgeToggle}"
                                                          IsChecked="{Binding DataContext.ShowMissingWiki, RelativeSource={RelativeSource AncestorType=Window}}"
                                                          PreviewMouseLeftButtonDown="FilterBadge_PreviewMouseLeftButtonDown">
                                                <StackPanel HorizontalAlignment="Center">
                                                    <StackPanel Orientation="Horizontal" HorizontalAlignment="Center">
                                                        <TextBlock FontFamily="Segoe MDL2 Assets" FontSize="10.5" Text="&#xE8F2;" Foreground="#FF0A84FF" Margin="0,0,4,0" VerticalAlignment="Center" />
                                                        <TextBlock Text="Wiki" />
                                                    </StackPanel>
                                                    <TextBlock Text="{Binding MissingWikipediaCount, StringFormat={}{0:N0}, Mode=OneWay}" FontWeight="SemiBold" Foreground="{StaticResource Brush.Text.Primary}" HorizontalAlignment="Center" Margin="0,2,0,0" />
                                                </StackPanel>
                                            </ToggleButton>
                                        </WrapPanel>
                                        <StackPanel Orientation="Horizontal" Margin="0,4,0,0" Opacity="0.6">
                                            <TextBlock FontFamily="Segoe MDL2 Assets" FontSize="11" Text="&#xE9A1;" VerticalAlignment="Center" Margin="0,0,6,0" />
                                            <TextBlock FontSize="11" Text="{Binding TotalGames, StringFormat=Toplam {0:N0} oyun, Mode=OneWay}" VerticalAlignment="Center" />
                                        </StackPanel>
                                    </StackPanel>
                                </Grid>
                            </DataTemplate>
                        </ListBox.ItemTemplate>
                    </ListBox>
                </DockPanel>
            </Border>

            <Border Grid.Column="2"
                    Padding="0"
                    Background="Transparent"
                    BorderThickness="0">
                <DockPanel LastChildFill="True">
                    <StackPanel DockPanel.Dock="Top" Margin="18,16,18,8">
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*" />
                                <ColumnDefinition Width="Auto" />
                            </Grid.ColumnDefinitions>
                            <TextBlock Grid.Column="0" FontSize="16" FontWeight="Bold" Text="{Binding MissingItems.Count, StringFormat=Eksik &#x00D6;&#x011F;eler ({0})}" VerticalAlignment="Center" />
                            <StackPanel Grid.Column="1" Orientation="Horizontal" VerticalAlignment="Center">
                                <RadioButton x:Name="ViewAsListButton" Style="{StaticResource ViewToggleRadioButtonStyle}" IsChecked="{Binding ShowAsList, Mode=TwoWay}" Content="&#xE292;" ToolTip="Liste Görünümü" />
                                <RadioButton x:Name="ViewAsTableButton" Style="{StaticResource ViewToggleRadioButtonStyle}" IsChecked="{Binding ShowAsTable, Mode=TwoWay}" Content="&#xE29A;" ToolTip="Tablo Görünümü" />
                            </StackPanel>
                        </Grid>
                        <Border Margin="0,12,0,0"
                                Background="{StaticResource Brush.Background.Elevated}"
                                BorderBrush="{StaticResource Brush.Border}"
                                BorderThickness="1"
                                CornerRadius="4">
                            <TextBox Style="{StaticResource SearchTextBoxStyle}"
                                     Text="{Binding SearchText, UpdateSourceTrigger=PropertyChanged}" />
                        </Border>
                        <!-- Kullanıcı isteği: "uygun bir yere junkları filtreleme ekle junklar
                             dahil yansıyor provider a ... yüzde hesaplamalarınıda junklar seçiliyse
                             ona göre ver seçili değilse ona göre ver" — ana tablodaki Released/Junk
                             ayrımıyla AYNI Game.Version alanı; varsayılan KAPALI (ana tablonun
                             varsayılan görünümüyle AYNI), hem bu listeyi hem sol paneldeki platform
                             kartlarının % sağlık hesaplamasını etkiler (bkz. MediaProviderViewModel.
                             ShowJunk). -->
                        <CheckBox Content="Junk oyunları dahil et" Margin="2,10,0,0" FontSize="11.5"
                                  Foreground="{StaticResource Brush.Text.Secondary}"
                                  IsChecked="{Binding ShowJunk}" />
                    </StackPanel>

                    <Grid Margin="18,8,10,10">
                        <!-- Kullanıcı isteği: "toplu seçimlerede uygun olacak" — Ctrl/Shift ile
                             birden fazla satır seçilebilsin diye SelectionMode="Extended" (bkz.
                             MediaProviderWindow.xaml.cs AutoDownloadButton_Click). -->
                        <ListBox x:Name="MissingItemsList"
                                 Background="Transparent"
                                 BorderThickness="0"
                                 SelectionMode="Extended"
                                 ItemsSource="{Binding MissingItems}"
                                 MouseDoubleClick="MissingItemsList_MouseDoubleClick"
                                 SelectedItem="{Binding SelectedMissingItem}"
                                 Visibility="{Binding IsChecked, ElementName=ViewAsListButton, Converter={StaticResource BoolToVisibility}}">
                            <ListBox.ItemContainerStyle>
                                <Style TargetType="ListBoxItem">
                                    <Setter Property="Padding" Value="0" />
                                    <Setter Property="HorizontalContentAlignment" Value="Stretch" />
                                    <Setter Property="Background" Value="Transparent" />
                                    <Setter Property="BorderThickness" Value="0" />
                                    <Setter Property="Margin" Value="0,0,0,8" />
                                </Style>
                            </ListBox.ItemContainerStyle>
                            <ListBox.ItemTemplate>
                                <DataTemplate DataType="{x:Type vm:MissingMediaItem}">
                                    <Grid>
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="Auto" />
                                            <ColumnDefinition Width="*" />
                                        </Grid.ColumnDefinitions>
                                        <Button Grid.Column="0"
                                                Style="{StaticResource TableSearchButtonStyle}"
                                                Click="SearchItem_Click"
                                                VerticalAlignment="Center"
                                                Margin="0,0,10,0">
                                            <Grid Width="14" Height="14">
                                                <Ellipse Width="9" Height="9" Stroke="{StaticResource Brush.Text.Secondary}"
                                                         StrokeThickness="1.5" HorizontalAlignment="Left" VerticalAlignment="Top" />
                                                <Line X1="8" Y1="8" X2="13" Y2="13" Stroke="{StaticResource Brush.Text.Secondary}" StrokeThickness="1.5" />
                                            </Grid>
                                        </Button>
                                        <StackPanel Grid.Column="1">
                                            <TextBlock FontSize="12"
                                                       FontWeight="SemiBold"
                                                       Text="{Binding Title, Mode=OneWay}" />
                                            <TextBlock Margin="0,1,0,0"
                                                       FontSize="10.5"
                                                       Foreground="{StaticResource Brush.Text.Secondary}">
                                                <Run Text="{Binding Platform, Mode=OneWay}" />
                                                <Run Text=" &#x2022; " />
                                                <Run Text="{Binding MissingTypeLabel, Mode=OneWay}" />
                                            </TextBlock>
                                            <TextBlock Margin="0,1,0,0"
                                                       FontSize="10.5"
                                                       Foreground="{StaticResource Brush.Text.Secondary}">
                                                <Run Text="CRC32: " />
                                                <Run Text="{Binding Crc32, Mode=OneWay}" />
                                            </TextBlock>
                                        </StackPanel>
                                    </Grid>
                                </DataTemplate>
                            </ListBox.ItemTemplate>
                        </ListBox>

                        <DataGrid x:Name="MissingItemsGrid"
                                  Background="Transparent"
                                  BorderThickness="0"
                                  SelectionMode="Extended"
                                  ItemsSource="{Binding MissingItems}"
                                  SelectedItem="{Binding SelectedMissingItem}"
                                  MouseDoubleClick="MissingItemsList_MouseDoubleClick"
                                  AutoGenerateColumns="False"
                                  CanUserAddRows="False"
                                  IsReadOnly="True"
                                  GridLinesVisibility="None"
                                  HeadersVisibility="Column"
                                  FontSize="11.5"
                                  Visibility="{Binding IsChecked, ElementName=ViewAsTableButton, Converter={StaticResource BoolToVisibility}}">
                            <DataGrid.Columns>
                                <DataGridTemplateColumn Width="32">
                                    <DataGridTemplateColumn.CellTemplate>
                                        <DataTemplate DataType="{x:Type vm:MissingMediaItem}">
                                            <Button Style="{StaticResource TableSearchButtonStyle}"
                                                    Click="SearchItem_Click"
                                                    HorizontalAlignment="Center"
                                                    VerticalAlignment="Center"
                                                    ToolTip="Görsel Ara">
                                                <Grid Width="14" Height="14">
                                                    <Ellipse Width="9" Height="9" Stroke="{StaticResource Brush.Text.Secondary}"
                                                             StrokeThickness="1.5" HorizontalAlignment="Left" VerticalAlignment="Top" />
                                                    <Line X1="8" Y1="8" X2="13" Y2="13" Stroke="{StaticResource Brush.Text.Secondary}" StrokeThickness="1.5" />
                                                </Grid>
                                            </Button>
                                        </DataTemplate>
                                    </DataGridTemplateColumn.CellTemplate>
                                </DataGridTemplateColumn>
                                <DataGridTextColumn Header="Başlık" Binding="{Binding Title}" Width="2*" />
                                <DataGridTextColumn Header="Platform" Binding="{Binding Platform}" Width="1.2*" />
                                <DataGridTextColumn Header="Eksik Olan" Binding="{Binding MissingTypeLabel}" Width="1*" />
                                <DataGridTextColumn Header="CRC32" Binding="{Binding Crc32}" Width="0.8*" />
                            </DataGrid.Columns>
                        </DataGrid>
                    </Grid>
                </DockPanel>
            </Border>
        </Grid>

        <Border Grid.Row="1"
                Margin="10"
                Padding="10"
                Background="{StaticResource Brush.Background.Panel}"
                BorderBrush="{StaticResource Brush.Border}"
                BorderThickness="1"
                CornerRadius="6">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="Auto" />
                </Grid.ColumnDefinitions>

                <!-- Kullanıcı isteği: "şu indirme barı ... providerın içinde gözükse" — bu pencereden
                     tetiklenen indirme aslında MainViewModel'de (bkz. AutoDownloadButton_Click ->
                     MainViewModel.BulkFetchArtworkForGamesAsync) yürüyor, ilerlemesi eskiden sadece
                     MainWindow'un alt çubuğunda görünüyordu (bu pencerenin ARKASINDA kalıyordu).
                     DataContext burada MediaProviderViewModel olduğu için MainVm (bkz.
                     MediaProviderWindow.xaml.cs) üzerinden AncestorType=Window ile MainViewModel'in
                     property'lerine erişiliyor. "Hepsini Seç"/"Otomatik İndir"in SOLUNDAKİ boş alanda
                     (kullanıcı isteği: "onların solundaki boş alanda") gösteriliyor. -->
                <Grid Grid.Column="0" Margin="0,0,12,0"
                      Visibility="{Binding MainVm.IsArtworkDownloadInProgress, RelativeSource={RelativeSource AncestorType=Window}, Converter={StaticResource BoolToVisibility}}">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="Auto" />
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="Auto" />
                        <ColumnDefinition Width="Auto" />
                    </Grid.ColumnDefinitions>
                    <TextBlock Grid.Column="0" Text="Görsel indiriliyor..." VerticalAlignment="Center"
                               FontSize="11" Foreground="{StaticResource Brush.Text.Secondary}" Margin="0,0,10,0" />
                    <ProgressBar Grid.Column="1" Minimum="0" Maximum="100" VerticalAlignment="Center"
                                 Value="{Binding MainVm.ArtworkDownloadProgress, RelativeSource={RelativeSource AncestorType=Window}, Mode=OneWay}" />
                    <TextBlock Grid.Column="2" VerticalAlignment="Center" FontSize="11" Width="34" TextAlignment="Right"
                               Margin="10,0,0,0" Foreground="{StaticResource Brush.Text.Secondary}"
                               Text="{Binding MainVm.ArtworkDownloadProgress, RelativeSource={RelativeSource AncestorType=Window}, StringFormat={}{0:0}%}" />
                    <Button Grid.Column="3" Content="Durdur" Margin="10,0,0,0" Padding="10,3" FontSize="11"
                            Command="{Binding MainVm.CancelArtworkDownloadCommand, RelativeSource={RelativeSource AncestorType=Window}}" />
                </Grid>

                <StackPanel Grid.Column="1" Orientation="Horizontal" HorizontalAlignment="Right">
                    <!-- Kullanıcı isteği: "otomatik indir butonuna basıyorum indirmiyor ... görsel
                         getir butonu varya ona bağlıcan ... toplu seçimlerede uygun olacak" — artık
                         Command binding YOK, code-behind (bkz. AutoDownloadButton_Click) seçili satır(lar)ı
                         toplayıp MainViewModel.BulkFetchArtworkForGamesAsync'i çağırıyor (ana tablonun
                         "Görsel Getir"iyle AYNI mekanizma). -->
                    <!-- Kullanıcı isteği: "videolar ile ilgili filtre tek başına filtrelendiğinde
                         veya seçilen satırın eksiği video olduğunda o komut pasif gözükmeli" — bkz.
                         MediaProviderViewModel.CanAutoDownload. -->
                    <!-- Kullanıcı isteği: "otomatik indirin yanına hepsini seç butonu koy" — hangi
                         görünüm (Liste/Tablo) aktifse o görünür ama ikisinin de SelectAll'ı çağrılıyor
                         (bkz. MediaProviderWindow.xaml.cs SelectAllButton_Click) — o an görünmeyen
                         kontrolde seçim yapmak zararsız, ikisi de AYNI MissingItems'a bağlı. -->
                    <!-- GEÇİCİ: kullanıcı isteği "sayıları dışarı aktarmak için bişey ekle oraya
                         geçici not defterine atsın" — platform audit rakamlarını (Logo/Box/SS/Video/
                         Wiki eksik sayıları) elle toplayıp doğrulayabilmek için (bkz.
                         MediaProviderWindow.xaml.cs ExportPlatformSummariesButton_Click). Kaldırılabilir. -->
                    <!-- Kullanıcı isteği: "media providera da aynı mantıkta dışa aktarma ekle,
                         chatgpt'ye onlara baktırayım dışarı aktarıp" — Metadata Provider'daki
                         "Listeyi Dışa Aktar" ile AYNI (bkz. ExportMissingItemsButton_Click):
                         eksik görsel öğe listesini (başlık/platform/tür/CRC32) düz metin olarak
                         dışa aktarır, araştırma için LLM'e yapıştırılabilir. -->
                    <Button Padding="14,7" Margin="0,0,8,0" Click="ExportPlatformSummariesButton_Click" Content="Dışa Aktar" />
                    <Button Padding="14,7" Margin="0,0,8,0" Click="ExportMissingItemsButton_Click" Content="Listeyi Dışa Aktar" />
                    <Button Padding="14,7" Margin="0,0,8,0" Click="SelectAllButton_Click" Content="Hepsini Seç" />
                    <Button Padding="14,7" Click="AutoDownloadButton_Click" Content="Otomatik &#x0130;ndir" IsEnabled="{Binding CanAutoDownload}" />
                </StackPanel>
            </Grid>
        </Border>
    </Grid>
</Window>
