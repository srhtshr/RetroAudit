<Window x:Class="RetroAudit.Views.MediaProviderWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:vm="clr-namespace:RetroAudit.ViewModels"
        xmlns:models="clr-namespace:RetroAudit.Models"
        xmlns:conv="clr-namespace:RetroAudit.Converters"
        Title="Media Provider" Height="700" Width="950" WindowStartupLocation="CenterOwner">

    <Window.Resources>
        <conv:InverseBooleanConverter x:Key="InverseBoolean" />
    </Window.Resources>

    <Grid Background="{StaticResource Brush.Background.Base}">
        <Grid.RowDefinitions>
            <RowDefinition Height="*" />
            <RowDefinition Height="Auto" />
        </Grid.RowDefinitions>

        <Grid Grid.Row="0">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="220" />
                <ColumnDefinition Width="1" />
                <ColumnDefinition Width="*" />
                <ColumnDefinition Width="1" />
                <ColumnDefinition Width="260" />
            </Grid.ColumnDefinitions>

            <!-- Sol: platform + eksik medya türü filtresi -->
            <Border Grid.Column="0" Background="{StaticResource Brush.Background.Panel}">
                <DockPanel Margin="10">
                    <TextBlock DockPanel.Dock="Top" Text="Platformlar" FontWeight="Bold" Margin="0,0,0,8" />
                    <StackPanel DockPanel.Dock="Bottom" Margin="0,10,0,0">
                        <TextBlock Text="Eksik Medya Türü" FontWeight="Bold" Margin="0,0,0,6" />
                        <ComboBox ItemsSource="{Binding MediaTypeFilters}" SelectedItem="{Binding SelectedMediaTypeFilter}" />
                    </StackPanel>
                    <ListBox ItemsSource="{Binding Platforms}" SelectedItem="{Binding SelectedPlatform}">
                        <ListBox.ItemTemplate>
                            <DataTemplate DataType="{x:Type models:Platform}">
                                <TextBlock Text="{Binding Name}" Margin="2" />
                            </DataTemplate>
                        </ListBox.ItemTemplate>
                    </ListBox>
                </DockPanel>
            </Border>

            <Rectangle Grid.Column="1" Fill="{StaticResource Brush.Border}" />

            <!-- Orta: eksik öğeler (gerçek kütüphaneden, bkz. MediaProviderViewModel.RebuildMissingItems) -->
            <Border Grid.Column="2" Background="{StaticResource Brush.Background.Base}">
                <DockPanel Margin="10">
                    <TextBlock DockPanel.Dock="Top" FontWeight="Bold" Margin="0,0,0,8">
                        <Run Text="Eksik Öğeler" /><Run Text=" (" /><Run Text="{Binding MissingItems.Count, Mode=OneWay}" /><Run Text=")" />
                    </TextBlock>
                    <ListBox ItemsSource="{Binding MissingItems}" SelectedItem="{Binding SelectedMissingItem}">
                        <ListBox.ItemTemplate>
                            <DataTemplate DataType="{x:Type vm:MissingMediaItem}">
                                <StackPanel Margin="2,4">
                                    <TextBlock Text="{Binding Title}" FontWeight="SemiBold" />
                                    <TextBlock Foreground="{StaticResource Brush.Text.Secondary}" FontSize="11">
                                        <Run Text="{Binding Platform}" /><Run Text=" • " /><Run Text="{Binding MissingTypeLabel}" />
                                    </TextBlock>
                                </StackPanel>
                            </DataTemplate>
                        </ListBox.ItemTemplate>
                    </ListBox>
                </DockPanel>
            </Border>

            <Rectangle Grid.Column="3" Fill="{StaticResource Brush.Border}" />

            <!-- Sağ: seçili öğe detayı -->
            <Border Grid.Column="4" Background="{StaticResource Brush.Background.Base}">
                <DockPanel Margin="10">
                    <TextBlock DockPanel.Dock="Top" Text="Seçili Öğe" FontWeight="Bold" Margin="0,0,0,8" />

                    <Grid>
                        <StackPanel DataContext="{Binding SelectedMissingItem}">
                            <StackPanel.Style>
                                <Style TargetType="StackPanel">
                                    <Setter Property="Visibility" Value="Visible" />
                                    <Style.Triggers>
                                        <DataTrigger Binding="{Binding}" Value="{x:Null}">
                                            <Setter Property="Visibility" Value="Collapsed" />
                                        </DataTrigger>
                                    </Style.Triggers>
                                </Style>
                            </StackPanel.Style>
                            <TextBlock Text="{Binding Title}" FontWeight="Bold" FontSize="14" TextWrapping="Wrap" />
                            <TextBlock Text="{Binding Platform}" Foreground="{StaticResource Brush.Text.Secondary}" Margin="0,2,0,0" />
                            <TextBlock Margin="0,10,0,0" FontSize="11" Foreground="{StaticResource Brush.Text.Secondary}" TextWrapping="Wrap">
                                <Run Text="Eksik: " /><Run Text="{Binding MissingTypeLabel}" FontWeight="SemiBold" />
                            </TextBlock>
                        </StackPanel>

                        <TextBlock Text="Soldan bir öğe seçin." Foreground="{StaticResource Brush.Text.Secondary}">
                            <TextBlock.Style>
                                <Style TargetType="TextBlock">
                                    <Setter Property="Visibility" Value="Collapsed" />
                                    <Style.Triggers>
                                        <DataTrigger Binding="{Binding SelectedMissingItem}" Value="{x:Null}">
                                            <Setter Property="Visibility" Value="Visible" />
                                        </DataTrigger>
                                    </Style.Triggers>
                                </Style>
                            </TextBlock.Style>
                        </TextBlock>
                    </Grid>
                </DockPanel>
            </Border>
        </Grid>

        <Border Grid.Row="1" Background="{StaticResource Brush.Background.Panel}"
                BorderBrush="{StaticResource Brush.Border}" BorderThickness="0,1,0,0" Padding="10">
            <StackPanel Orientation="Horizontal" HorizontalAlignment="Right">
                <Button Content="Atla" Command="{Binding SkipItemCommand}" Margin="0,0,8,0" Padding="12,6" />
                <Button Content="Ara" Command="{Binding SearchSelectedCommand}" Margin="0,0,8,0" Padding="12,6" />
                <Button Content="Otomatik İndir" Padding="12,6"
                        Command="{Binding FetchSelectedAsyncCommand}" IsEnabled="{Binding IsBusy, Converter={StaticResource InverseBoolean}}" />
            </StackPanel>
        </Border>
    </Grid>
</Window>
