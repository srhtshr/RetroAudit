<Window x:Class="RetroAudit.Views.ManualLinkWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:conv="clr-namespace:RetroAudit.Converters"
        Title="Bir Oyuna Bağla" Height="520" Width="480" WindowStartupLocation="CenterOwner">

    <Window.Resources>
        <conv:BoolToVisibilityConverter x:Key="BoolToVisibility" />
    </Window.Resources>

    <Grid Background="{StaticResource Brush.Background.Base}">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
        </Grid.RowDefinitions>

        <StackPanel Grid.Row="0" Margin="16,14,16,0">
            <TextBlock Text="Bir Oyuna Bağla" FontSize="14" FontWeight="Bold" />
            <TextBlock Text="Bu dosyayı kataloktaki bir oyunun bir sürümüne manuel bağlarsın — o sürüm 'Sürümler' listesinde yeni bir kart olarak görünür, oyunun mevcut BAŞLAT dosyasını DEĞİŞTİRMEZ."
                       TextWrapping="Wrap" Foreground="{StaticResource Brush.Text.Secondary}" FontSize="11" Margin="0,4,0,0" />
        </StackPanel>

        <Grid Grid.Row="1" Margin="16,10,16,0">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*" />
                <ColumnDefinition Width="Auto" />
            </Grid.ColumnDefinitions>
            <TextBox Grid.Column="0" Text="{Binding SearchText, UpdateSourceTrigger=PropertyChanged}" VerticalContentAlignment="Center" />
            <ToggleButton Grid.Column="1" Content="Diğer Platformlar" IsChecked="{Binding ShowAllPlatforms}" Margin="8,0,0,0" Padding="8,3" />
        </Grid>

        <ListBox Grid.Row="2" Margin="16,10,16,0" ItemsSource="{Binding FilteredGames}" SelectedItem="{Binding SelectedGame}">
            <ListBox.ItemTemplate>
                <DataTemplate>
                    <!-- Kullanıcı isteği: "unknown değilde manuel bağlamaya yönlendirebilirsin ...
                         aynı yani" — "+ Yeni Oyun" (bkz. ManualLinkViewModel.NewGameSentinelKey),
                         kataloktaki gerçek oyunlardan ayırt edilsin diye sürüm listesindeki "+ Yeni"
                         ile AYNI Amber stille. -->
                    <TextBlock>
                        <TextBlock.Style>
                            <Style TargetType="TextBlock">
                                <Setter Property="Text" Value="{Binding Title}" />
                                <Style.Triggers>
                                    <DataTrigger Binding="{Binding GameKey}" Value="__new_custom_game__">
                                        <Setter Property="Text" Value="{Binding Title, StringFormat='+ Yeni Oyun: {0}'}" />
                                        <Setter Property="Foreground" Value="{StaticResource Brush.Accent.Amber}" />
                                        <Setter Property="FontWeight" Value="SemiBold" />
                                    </DataTrigger>
                                </Style.Triggers>
                            </Style>
                        </TextBlock.Style>
                    </TextBlock>
                </DataTemplate>
            </ListBox.ItemTemplate>
        </ListBox>

        <StackPanel Grid.Row="3" Margin="16,10,16,0" Visibility="{Binding HasSelectedGame, Converter={StaticResource BoolToVisibility}}">
            <TextBlock Text="Hangi sürüme bağlanacak:" VerticalAlignment="Center" FontSize="11"
                       Foreground="{StaticResource Brush.Text.Secondary}" />
            <ListBox Height="120" Margin="0,6,0,0" ItemsSource="{Binding SelectedGameVersions}" SelectedItem="{Binding SelectedVersion}">
                <ListBox.ItemTemplate>
                    <DataTemplate>
                        <!-- Kullanıcı isteği: "yeni olsun bi tane ona tıklayınca dosya ismi neyse
                             onunla açsın" — kataloktaki gerçek sürümlerden ayırt edilsin diye "+ Yeni:"
                             önekiyle ve Amber renkle (bkz. GameVersion.IsCustomEntry). -->
                        <TextBlock>
                            <TextBlock.Style>
                                <Style TargetType="TextBlock">
                                    <Setter Property="Text" Value="{Binding RawDatName}" />
                                    <Style.Triggers>
                                        <DataTrigger Binding="{Binding IsCustomEntry}" Value="True">
                                            <Setter Property="Text" Value="{Binding RawDatName, StringFormat='+ Yeni: {0}'}" />
                                            <Setter Property="Foreground" Value="{StaticResource Brush.Accent.Amber}" />
                                            <Setter Property="FontWeight" Value="SemiBold" />
                                        </DataTrigger>
                                    </Style.Triggers>
                                </Style>
                            </TextBlock.Style>
                        </TextBlock>
                    </DataTemplate>
                </ListBox.ItemTemplate>
            </ListBox>
        </StackPanel>

        <Border Grid.Row="4" Background="{StaticResource Brush.Background.Panel}"
                BorderBrush="{StaticResource Brush.Border}" BorderThickness="0,1,0,0" Padding="16,10" Margin="0,10,0,0">
            <StackPanel Orientation="Horizontal" HorizontalAlignment="Right">
                <Button Content="İptal" Command="{Binding CancelCommand}" Width="90" Margin="0,0,8,0" />
                <Button Content="Bağla" Command="{Binding LinkCommand}" IsEnabled="{Binding CanConfirm}" Width="90" Style="{StaticResource LaunchButton}" />
            </StackPanel>
        </Border>
    </Grid>
</Window>
