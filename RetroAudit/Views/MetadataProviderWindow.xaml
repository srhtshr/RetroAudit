<Window x:Class="RetroAudit.Views.MetadataProviderWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:vm="clr-namespace:RetroAudit.ViewModels"
        xmlns:models="clr-namespace:RetroAudit.Models"
        xmlns:conv="clr-namespace:RetroAudit.Converters"
        Title="Metadata Provider"
        Height="760"
        Width="1520"
        MinWidth="1280"
        MinHeight="720"
        WindowStartupLocation="CenterOwner">
    <Window.Resources>
        <conv:PercentageToWidthConverter x:Key="PercentageToWidth" />
        <conv:BoolToVisibilityConverter x:Key="BoolToVisibility" />

        <Style x:Key="ViewToggleRadioButtonStyle" TargetType="RadioButton">
            <Setter Property="Width" Value="28" />
            <Setter Property="Height" Value="24" />
            <Setter Property="Background" Value="Transparent" />
            <Setter Property="BorderThickness" Value="0" />
            <Setter Property="Foreground" Value="{StaticResource Brush.Text.Secondary}" />
            <Setter Property="Cursor" Value="Hand" />
            <Setter Property="Margin" Value="2,0" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="RadioButton">
                        <Border x:Name="Bg" Background="{TemplateBinding Background}" CornerRadius="4">
                            <TextBlock Text="{TemplateBinding Content}"
                                       FontFamily="Segoe MDL2 Assets"
                                       FontSize="11"
                                       HorizontalAlignment="Center"
                                       VerticalAlignment="Center"
                                       Foreground="{TemplateBinding Foreground}" />
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsChecked" Value="True">
                                <Setter TargetName="Bg" Property="Background" Value="#FF232328" />
                                <Setter Property="Foreground" Value="White" />
                            </Trigger>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="Bg" Property="Background" Value="#FF1B1B1E" />
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="ProviderSwitchButtonStyle" TargetType="Button" BasedOn="{StaticResource {x:Type Button}}">
            <Setter Property="MinWidth" Value="106" />
            <Setter Property="Padding" Value="14,7" />
            <Setter Property="Margin" Value="0,0,8,0" />
            <Setter Property="Foreground" Value="{StaticResource Brush.Text.Primary}" />
            <Setter Property="Background" Value="{StaticResource Brush.Background.Elevated}" />
            <Setter Property="BorderBrush" Value="{StaticResource Brush.Border}" />
            <Setter Property="BorderThickness" Value="1" />
            <Setter Property="Cursor" Value="Hand" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="Root"
                                Background="{StaticResource Brush.Background.Elevated}"
                                BorderBrush="{StaticResource Brush.Border}"
                                BorderThickness="1"
                                CornerRadius="4">
                            <ContentPresenter HorizontalAlignment="Center"
                                              VerticalAlignment="Center"
                                              Margin="{TemplateBinding Padding}" />
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsEnabled" Value="True">
                                <Setter TargetName="Root" Property="Background" Value="{Binding Background, RelativeSource={RelativeSource TemplatedParent}}" />
                                <Setter TargetName="Root" Property="BorderBrush" Value="{Binding BorderBrush, RelativeSource={RelativeSource TemplatedParent}}" />
                                <Setter TargetName="Root" Property="BorderThickness" Value="{Binding BorderThickness, RelativeSource={RelativeSource TemplatedParent}}" />
                            </Trigger>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="Root" Property="BorderBrush" Value="#FF525762" />
                            </Trigger>
                            <Trigger Property="IsPressed" Value="True">
                                <Setter TargetName="Root" Property="Opacity" Value="0.9" />
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="ActiveProviderSwitchButtonStyle" TargetType="Button" BasedOn="{StaticResource ProviderSwitchButtonStyle}">
            <Setter Property="Background" Value="{StaticResource Brush.Accent}" />
            <Setter Property="BorderBrush" Value="{StaticResource Brush.Accent}" />
            <Setter Property="Foreground" Value="White" />
            <Setter Property="Cursor" Value="Arrow" />
        </Style>

        <Style x:Key="TableSearchButtonStyle" TargetType="Button" BasedOn="{StaticResource {x:Type Button}}">
            <Setter Property="Width" Value="24" />
            <Setter Property="Height" Value="24" />
            <Setter Property="Background" Value="Transparent" />
            <Setter Property="BorderThickness" Value="0" />
            <Setter Property="Padding" Value="0" />
            <Setter Property="Cursor" Value="Hand" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="Bg" Background="{TemplateBinding Background}" CornerRadius="3">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center" />
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="Bg" Property="Background" Value="#FF232328" />
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="CardFilterBadgeToggle" TargetType="ToggleButton">
            <Setter Property="Background" Value="#FF1B1B1E" />
            <Setter Property="BorderThickness" Value="0" />
            <Setter Property="Foreground" Value="{StaticResource Brush.Text.Secondary}" />
            <Setter Property="Padding" Value="8,3" />
            <Setter Property="Margin" Value="0,0,10,4" />
            <Setter Property="Cursor" Value="Hand" />
            <Setter Property="FontSize" Value="11.5" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="ToggleButton">
                        <Border x:Name="Root"
                                Background="{TemplateBinding Background}"
                                BorderThickness="0"
                                CornerRadius="4">
                            <ContentPresenter Margin="{TemplateBinding Padding}"
                                              HorizontalAlignment="Center"
                                              VerticalAlignment="Center" />
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsChecked" Value="True">
                                <Setter TargetName="Root" Property="Background" Value="#FF0078D4" />
                                <Setter Property="Foreground" Value="White" />
                                <Setter Property="FontWeight" Value="SemiBold" />
                            </Trigger>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="Root" Property="Background" Value="#FF232328" />
                                <Setter Property="Foreground" Value="{StaticResource Brush.Text.Primary}" />
                            </Trigger>
                            <MultiTrigger>
                                <MultiTrigger.Conditions>
                                    <Condition Property="IsChecked" Value="True" />
                                    <Condition Property="IsMouseOver" Value="True" />
                                </MultiTrigger.Conditions>
                                <Setter TargetName="Root" Property="Background" Value="#FF1084E3" />
                                <Setter Property="Foreground" Value="White" />
                                <Setter Property="FontWeight" Value="SemiBold" />
                            </MultiTrigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="SearchTextBoxStyle" TargetType="TextBox">
            <Setter Property="Padding" Value="10,8" />
            <Setter Property="FontSize" Value="13" />
            <Setter Property="Background" Value="Transparent" />
            <Setter Property="BorderThickness" Value="0" />
            <Setter Property="Foreground" Value="{StaticResource Brush.Text.Primary}" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="TextBox">
                        <Grid>
                            <ScrollViewer x:Name="PART_ContentHost" />
                            <TextBlock x:Name="Placeholder"
                                       Margin="10,0,0,0"
                                       VerticalAlignment="Center"
                                       Foreground="{StaticResource Brush.Text.Secondary}"
                                       IsHitTestVisible="False"
                                       Text="Oyun ad&#x0131;na g&#x00F6;re ara..." />
                        </Grid>
                        <ControlTemplate.Triggers>
                            <Trigger Property="Text" Value="">
                                <Setter TargetName="Placeholder" Property="Visibility" Value="Visible" />
                            </Trigger>
                            <Trigger Property="Text" Value="{x:Null}">
                                <Setter TargetName="Placeholder" Property="Visibility" Value="Visible" />
                            </Trigger>
                            <Trigger Property="IsKeyboardFocused" Value="True">
                                <Setter TargetName="Placeholder" Property="Visibility" Value="Collapsed" />
                            </Trigger>
                            <Trigger Property="Text" Value=" ">
                                <Setter TargetName="Placeholder" Property="Visibility" Value="Collapsed" />
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
    </Window.Resources>

    <Grid Background="{StaticResource Brush.Background.Base}">
        <Grid.RowDefinitions>
            <RowDefinition Height="*" />
            <RowDefinition Height="Auto" />
        </Grid.RowDefinitions>

        <Grid Grid.Row="0" Margin="10,10,10,0">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="780" />
                <ColumnDefinition Width="12" />
                <ColumnDefinition Width="*" />
            </Grid.ColumnDefinitions>

            <Border Grid.Column="0"
                    Background="{StaticResource Brush.Background.Panel}"
                    BorderBrush="{StaticResource Brush.Border}"
                    BorderThickness="1"
                    CornerRadius="6">
                <DockPanel LastChildFill="True">
                    <StackPanel DockPanel.Dock="Top" Margin="10,10,10,8">
                        <TextBlock FontSize="16" FontWeight="Bold" Text="Metadata Audit" />
                        <WrapPanel Margin="0,12,0,0">
                            <Button Content="Metadata Provider"
                                    IsHitTestVisible="False"
                                    Focusable="False"
                                    Style="{StaticResource ActiveProviderSwitchButtonStyle}" />
                            <Button Content="Media Provider"
                                    Click="OpenMediaProvider_Click"
                                    Style="{StaticResource ProviderSwitchButtonStyle}" />
                        </WrapPanel>
                    </StackPanel>



                    <ListBox Margin="10,0,10,0"
                             Padding="0,0,12,0"
                             ItemsSource="{Binding PlatformAuditSummaries}"
                             SelectedItem="{Binding SelectedPlatformSummary}"
                             Background="Transparent"
                             BorderThickness="0"
                             ScrollViewer.HorizontalScrollBarVisibility="Disabled"
                             ScrollViewer.VerticalScrollBarVisibility="Auto">
                        <ListBox.ItemContainerStyle>
                            <Style TargetType="ListBoxItem">
                                 <Setter Property="Padding" Value="0" />
                                <Setter Property="Margin" Value="0,0,0,8" />
                                <Setter Property="HorizontalContentAlignment" Value="Stretch" />
                                <EventSetter Event="RequestBringIntoView" Handler="ListBoxItem_RequestBringIntoView" />
                                <Setter Property="Template">
                                    <Setter.Value>
                                        <ControlTemplate TargetType="ListBoxItem">
                                            <Border x:Name="CardBorder"
                                                    Padding="12,8"
                                                    Background="{StaticResource Brush.Background.Elevated}"
                                                    BorderBrush="{StaticResource Brush.Border}"
                                                    BorderThickness="1"
                                                    CornerRadius="8">
                                                <ContentPresenter />
                                            </Border>
                                            <ControlTemplate.Triggers>
                                                <Trigger Property="IsSelected" Value="True">
                                                    <Setter TargetName="CardBorder" Property="BorderBrush" Value="{StaticResource Brush.Accent}" />
                                                </Trigger>
                                            </ControlTemplate.Triggers>
                                        </ControlTemplate>
                                    </Setter.Value>
                                </Setter>
                            </Style>
                        </ListBox.ItemContainerStyle>
                        <ListBox.ItemTemplate>
                            <DataTemplate DataType="{x:Type models:PlatformMetadataAuditSummary}">
                                <Grid>
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="110" />
                                        <ColumnDefinition Width="110" />
                                        <ColumnDefinition Width="90" />
                                        <ColumnDefinition Width="Auto" />
                                        <ColumnDefinition Width="*" />
                                    </Grid.ColumnDefinitions>
                                    <Border Grid.Column="0" Width="100" Height="62" Padding="6" Background="#FF1F1F22" CornerRadius="6" VerticalAlignment="Center">
                                        <Image Source="{Binding PlatformLogoPath, Mode=OneWay}" Stretch="Uniform" RenderOptions.BitmapScalingMode="HighQuality" />
                                    </Border>

                                    <StackPanel Grid.Column="1" VerticalAlignment="Center" Margin="10,0">
                                        <TextBlock FontSize="18" FontWeight="Bold" Foreground="White" Text="{Binding HealthPercent, StringFormat=% {0}, Mode=OneWay}" />
                                        <Border Width="90" Height="6" Margin="0,5,0,0" HorizontalAlignment="Left" Background="#FF202022" CornerRadius="3">
                                            <Border Width="{Binding HealthPercent, Converter={StaticResource PercentageToWidth}, ConverterParameter=90}" HorizontalAlignment="Left" Background="#FF4A9BFF" CornerRadius="3" />
                                        </Border>
                                    </StackPanel>

                                    <StackPanel Grid.Column="2" VerticalAlignment="Center" Margin="4,0">
                                        <Border Margin="0,0,0,4" Padding="8,3" Background="#FF1F1F22" BorderBrush="{StaticResource Brush.Border}" BorderThickness="1" CornerRadius="10" HorizontalAlignment="Left">
                                            <StackPanel Orientation="Horizontal">
                                                <TextBlock Margin="0,0,6,0"
                                                           Foreground="#FF32D74B"
                                                           FontFamily="Segoe MDL2 Assets"
                                                           FontSize="10"
                                                           Text="&#xE73E;" />
                                                <TextBlock FontWeight="SemiBold" Text="{Binding TotalGames, StringFormat={}{0:N0}, Mode=OneWay}" />
                                            </StackPanel>
                                        </Border>
                                        <Border Padding="8,3" Background="#FF1F1F22" BorderBrush="{StaticResource Brush.Border}" BorderThickness="1" CornerRadius="10" HorizontalAlignment="Left">
                                            <StackPanel Orientation="Horizontal">
                                                <TextBlock Margin="0,0,6,0"
                                                           Foreground="#FFDB4C4C"
                                                           FontFamily="Segoe MDL2 Assets"
                                                           FontSize="10"
                                                           Text="&#xE711;" />
                                                <TextBlock FontWeight="SemiBold" Text="{Binding UnmatchedCount, StringFormat={}{0:N0}, Mode=OneWay}" />
                                            </StackPanel>
                                        </Border>
                                    </StackPanel>

                                    <Border Grid.Column="3"
                                            Width="1"
                                            Height="46"
                                            Margin="4,0,8,0"
                                            Background="{StaticResource Brush.Border}"
                                            VerticalAlignment="Center" />

                                    <StackPanel Grid.Column="4" VerticalAlignment="Center" Margin="0">
                                        <WrapPanel>
                                            <ToggleButton Style="{StaticResource CardFilterBadgeToggle}"
                                                          IsChecked="{Binding DataContext.ShowMissingGenres, RelativeSource={RelativeSource AncestorType=Window}}"
                                                          PreviewMouseLeftButtonDown="FilterBadge_PreviewMouseLeftButtonDown">
                                                <StackPanel HorizontalAlignment="Center">
                                                    <StackPanel Orientation="Horizontal" HorizontalAlignment="Center">
                                                        <TextBlock FontFamily="Segoe MDL2 Assets" FontSize="10.5" Text="&#xE8EC;" Foreground="#FFA970FF" Margin="0,0,4,0" VerticalAlignment="Center" />
                                                        <TextBlock Text="Tür" />
                                                    </StackPanel>
                                                    <TextBlock Text="{Binding MissingGenresCount, StringFormat={}{0:N0}, Mode=OneWay}" FontWeight="SemiBold" Foreground="{StaticResource Brush.Text.Primary}" HorizontalAlignment="Center" Margin="0,2,0,0" />
                                                </StackPanel>
                                            </ToggleButton>
                                            <ToggleButton Style="{StaticResource CardFilterBadgeToggle}"
                                                          IsChecked="{Binding DataContext.ShowMissingPublisher, RelativeSource={RelativeSource AncestorType=Window}}"
                                                          PreviewMouseLeftButtonDown="FilterBadge_PreviewMouseLeftButtonDown">
                                                <StackPanel HorizontalAlignment="Center">
                                                    <StackPanel Orientation="Horizontal" HorizontalAlignment="Center">
                                                        <TextBlock FontFamily="Segoe MDL2 Assets" FontSize="10.5" Text="&#xE77B;" Foreground="#FFFF9F0A" Margin="0,0,4,0" VerticalAlignment="Center" />
                                                        <TextBlock Text="Yayıncı" />
                                                    </StackPanel>
                                                    <TextBlock Text="{Binding MissingPublisherCount, StringFormat={}{0:N0}, Mode=OneWay}" FontWeight="SemiBold" Foreground="{StaticResource Brush.Text.Primary}" HorizontalAlignment="Center" Margin="0,2,0,0" />
                                                </StackPanel>
                                            </ToggleButton>
                                            <ToggleButton Style="{StaticResource CardFilterBadgeToggle}"
                                                          IsChecked="{Binding DataContext.ShowMissingDescription, RelativeSource={RelativeSource AncestorType=Window}}"
                                                          PreviewMouseLeftButtonDown="FilterBadge_PreviewMouseLeftButtonDown">
                                                <StackPanel HorizontalAlignment="Center">
                                                    <StackPanel Orientation="Horizontal" HorizontalAlignment="Center">
                                                        <TextBlock FontFamily="Segoe MDL2 Assets" FontSize="10.5" Text="&#xE7C3;" Foreground="#FF30B0C7" Margin="0,0,4,0" VerticalAlignment="Center" />
                                                        <TextBlock Text="Açıklama" />
                                                    </StackPanel>
                                                    <TextBlock Text="{Binding MissingDescriptionCount, StringFormat={}{0:N0}, Mode=OneWay}" FontWeight="SemiBold" Foreground="{StaticResource Brush.Text.Primary}" HorizontalAlignment="Center" Margin="0,2,0,0" />
                                                </StackPanel>
                                            </ToggleButton>
                                            <ToggleButton Style="{StaticResource CardFilterBadgeToggle}"
                                                          IsChecked="{Binding DataContext.ShowMissingYear, RelativeSource={RelativeSource AncestorType=Window}}"
                                                          PreviewMouseLeftButtonDown="FilterBadge_PreviewMouseLeftButtonDown">
                                                <StackPanel HorizontalAlignment="Center">
                                                    <StackPanel Orientation="Horizontal" HorizontalAlignment="Center">
                                                        <TextBlock FontFamily="Segoe MDL2 Assets" FontSize="10.5" Text="&#xE787;" Foreground="#FF64D2FF" Margin="0,0,4,0" VerticalAlignment="Center" />
                                                        <TextBlock Text="Yıl" />
                                                    </StackPanel>
                                                    <TextBlock Text="{Binding MissingYearCount, StringFormat={}{0:N0}, Mode=OneWay}" FontWeight="SemiBold" Foreground="{StaticResource Brush.Text.Primary}" HorizontalAlignment="Center" Margin="0,2,0,0" />
                                                </StackPanel>
                                            </ToggleButton>
                                            <ToggleButton Style="{StaticResource CardFilterBadgeToggle}"
                                                          IsChecked="{Binding DataContext.ShowMissingVersion, RelativeSource={RelativeSource AncestorType=Window}}"
                                                          PreviewMouseLeftButtonDown="FilterBadge_PreviewMouseLeftButtonDown">
                                                <StackPanel HorizontalAlignment="Center">
                                                    <StackPanel Orientation="Horizontal" HorizontalAlignment="Center">
                                                        <TextBlock FontFamily="Segoe MDL2 Assets" FontSize="10.5" Text="&#xE81E;" Foreground="#FF0A84FF" Margin="0,0,4,0" VerticalAlignment="Center" />
                                                        <TextBlock Text="Sürüm" />
                                                    </StackPanel>
                                                    <TextBlock Text="{Binding MissingVersionCount, StringFormat={}{0:N0}, Mode=OneWay}" FontWeight="SemiBold" Foreground="{StaticResource Brush.Text.Primary}" HorizontalAlignment="Center" Margin="0,2,0,0" />
                                                </StackPanel>
                                            </ToggleButton>
                                        </WrapPanel>
                                        <StackPanel Orientation="Horizontal" Margin="0,4,0,0" Opacity="0.6">
                                            <TextBlock FontFamily="Segoe MDL2 Assets" FontSize="11" Text="&#xE9A1;" VerticalAlignment="Center" Margin="0,0,6,0" />
                                            <TextBlock FontSize="11" Text="{Binding TotalGames, StringFormat=Toplam {0:N0} oyun, Mode=OneWay}" VerticalAlignment="Center" />
                                        </StackPanel>
                                    </StackPanel>
                                </Grid>
                            </DataTemplate>
                        </ListBox.ItemTemplate>
                    </ListBox>
                </DockPanel>
            </Border>
            <Border Grid.Column="2"
                    Padding="0"
                    Background="Transparent"
                    BorderThickness="0">
                <DockPanel LastChildFill="True">
                    <StackPanel DockPanel.Dock="Top" Margin="18,16,18,8">
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*" />
                                <ColumnDefinition Width="Auto" />
                            </Grid.ColumnDefinitions>
                            <TextBlock Grid.Column="0" FontSize="16" FontWeight="Bold" Text="{Binding MissingItems.Count, StringFormat=Eksik &#x00D6;&#x011F;eler ({0})}" VerticalAlignment="Center" />
                            <StackPanel Grid.Column="1" Orientation="Horizontal" VerticalAlignment="Center">
                                <RadioButton x:Name="ViewAsListButton" Style="{StaticResource ViewToggleRadioButtonStyle}" IsChecked="{Binding ShowAsList, Mode=TwoWay}" Content="&#xE292;" ToolTip="Liste Görünümü" />
                                <RadioButton x:Name="ViewAsTableButton" Style="{StaticResource ViewToggleRadioButtonStyle}" IsChecked="{Binding ShowAsTable, Mode=TwoWay}" Content="&#xE29A;" ToolTip="Tablo Görünümü" />
                            </StackPanel>
                        </Grid>
                        <Border Margin="0,12,0,0"
                                Background="{StaticResource Brush.Background.Elevated}"
                                BorderBrush="{StaticResource Brush.Border}"
                                BorderThickness="1"
                                CornerRadius="4">
                            <TextBox Style="{StaticResource SearchTextBoxStyle}"
                                     Text="{Binding SearchText, UpdateSourceTrigger=PropertyChanged}" />
                        </Border>
                    </StackPanel>

                    <Grid Margin="18,8,10,10">
                        <ListBox x:Name="MissingItemsList"
                                 Background="Transparent"
                                 BorderThickness="0"
                                 ItemsSource="{Binding MissingItems}"
                                 MouseDoubleClick="MissingItemsList_MouseDoubleClick"
                                 SelectedItem="{Binding SelectedMissingItem}"
                                 Visibility="{Binding IsChecked, ElementName=ViewAsListButton, Converter={StaticResource BoolToVisibility}}">
                            <ListBox.ItemContainerStyle>
                                <Style TargetType="ListBoxItem">
                                    <Setter Property="Padding" Value="0" />
                                    <Setter Property="HorizontalContentAlignment" Value="Stretch" />
                                    <Setter Property="Background" Value="Transparent" />
                                    <Setter Property="BorderThickness" Value="0" />
                                    <Setter Property="Margin" Value="0,0,0,8" />
                                </Style>
                            </ListBox.ItemContainerStyle>
                            <ListBox.ItemTemplate>
                                <DataTemplate DataType="{x:Type vm:MissingMetadataItem}">
                                    <Grid>
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="Auto" />
                                            <ColumnDefinition Width="*" />
                                        </Grid.ColumnDefinitions>
                                        <Button Grid.Column="0"
                                                Style="{StaticResource TableSearchButtonStyle}"
                                                Click="SearchItem_Click"
                                                VerticalAlignment="Center"
                                                Margin="0,0,10,0"
                                                ToolTip="Görsel Ara">
                                            <Grid Width="14" Height="14">
                                                <Ellipse Width="9" Height="9" Stroke="{StaticResource Brush.Text.Secondary}"
                                                         StrokeThickness="1.5" HorizontalAlignment="Left" VerticalAlignment="Top" />
                                                <Line X1="8" Y1="8" X2="13" Y2="13" Stroke="{StaticResource Brush.Text.Secondary}" StrokeThickness="1.5" />
                                            </Grid>
                                        </Button>
                                        <StackPanel Grid.Column="1">
                                            <TextBlock FontSize="12"
                                                       FontWeight="SemiBold"
                                                       Text="{Binding Title, Mode=OneWay}" />
                                            <TextBlock Margin="0,1,0,0"
                                                       FontSize="10.5"
                                                       Foreground="{StaticResource Brush.Text.Secondary}">
                                                <Run Text="{Binding Platform, Mode=OneWay}" />
                                                <Run Text=" &#x2022; " />
                                                <Run Text="{Binding MissingTypeLabel, Mode=OneWay}" />
                                            </TextBlock>
                                            <TextBlock Margin="0,1,0,0"
                                                       FontSize="10.5"
                                                       Foreground="{StaticResource Brush.Text.Secondary}">
                                                <Run Text="CRC32: " />
                                                <Run Text="{Binding Crc32, Mode=OneWay}" />
                                            </TextBlock>
                                        </StackPanel>
                                    </Grid>
                                </DataTemplate>
                            </ListBox.ItemTemplate>
                        </ListBox>

                        <DataGrid x:Name="MissingItemsGrid"
                                  Background="Transparent"
                                  BorderThickness="0"
                                  ItemsSource="{Binding MissingItems}"
                                  SelectedItem="{Binding SelectedMissingItem}"
                                  MouseDoubleClick="MissingItemsList_MouseDoubleClick"
                                  AutoGenerateColumns="False"
                                  CanUserAddRows="False"
                                  IsReadOnly="True"
                                  GridLinesVisibility="None"
                                  HeadersVisibility="Column"
                                  FontSize="11.5"
                                  Visibility="{Binding IsChecked, ElementName=ViewAsTableButton, Converter={StaticResource BoolToVisibility}}">
                            <DataGrid.Columns>
                                <DataGridTemplateColumn Width="32">
                                    <DataGridTemplateColumn.CellTemplate>
                                        <DataTemplate DataType="{x:Type vm:MissingMetadataItem}">
                                            <Button Style="{StaticResource TableSearchButtonStyle}"
                                                    Click="SearchItem_Click"
                                                    HorizontalAlignment="Center"
                                                    VerticalAlignment="Center"
                                                    ToolTip="Arama Yap">
                                                <Grid Width="14" Height="14">
                                                    <Ellipse Width="9" Height="9" Stroke="{StaticResource Brush.Text.Secondary}"
                                                             StrokeThickness="1.5" HorizontalAlignment="Left" VerticalAlignment="Top" />
                                                    <Line X1="8" Y1="8" X2="13" Y2="13" Stroke="{StaticResource Brush.Text.Secondary}" StrokeThickness="1.5" />
                                                </Grid>
                                            </Button>
                                        </DataTemplate>
                                    </DataGridTemplateColumn.CellTemplate>
                                </DataGridTemplateColumn>
                                <DataGridTextColumn Header="Başlık" Binding="{Binding Title}" Width="2*" />
                                <DataGridTextColumn Header="Platform" Binding="{Binding Platform}" Width="1.2*" />
                                <DataGridTextColumn Header="Eksik Olan" Binding="{Binding MissingTypeLabel}" Width="1*" />
                                <DataGridTextColumn Header="CRC32" Binding="{Binding Crc32}" Width="0.8*" />
                            </DataGrid.Columns>
                        </DataGrid>
                    </Grid>
                </DockPanel>
            </Border>
        </Grid>

        <Border Grid.Row="1"
                Margin="10"
                Padding="10"
                Background="{StaticResource Brush.Background.Panel}"
                BorderBrush="{StaticResource Brush.Border}"
                BorderThickness="1"
                CornerRadius="6">
            <StackPanel Orientation="Horizontal" HorizontalAlignment="Right">
                <Button Margin="0,0,8,0" Padding="14,7" Command="{Binding EditSelectedCommand}" Content="D&#x00FC;zenle" />
                <Button Padding="14,7" Command="{Binding ReMatchSelectedCommand}" Content="Yeniden E&#x015F;le&#x015F;tir" />
            </StackPanel>
        </Border>
    </Grid>
</Window>
