<Window x:Class="RetroAudit.Views.MainWindow"
        x:Name="RootWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:conv="clr-namespace:RetroAudit.Converters"
        xmlns:vm="clr-namespace:RetroAudit.ViewModels"
        xmlns:models="clr-namespace:RetroAudit.Models"
        xmlns:views="clr-namespace:RetroAudit.Views"
        Title="RetroAudit" Height="820" Width="1400" WindowStartupLocation="CenterScreen">

    <Window.DataContext>
        <vm:MainViewModel />
    </Window.DataContext>

    <Window.Resources>
        <conv:BoolToStatusBrushConverter x:Key="BoolToStatusBrush" />
        <conv:BoolToStatusGlyphConverter x:Key="BoolToStatusGlyph" />
        <conv:BoolToGridLengthConverter x:Key="BoolToGridLength" />

        <!-- DataGridColumn.Header gibi görsel-ağaç-dışı alanların ViewModel'e erişebilmesi için
             (bkz. BindingProxy.cs) — Data, Window'un DataContext'ine (MainViewModel) bağlanır. -->
        <views:BindingProxy x:Key="ViewModelProxy" Data="{Binding}" />

        <!-- DataGrid sütun başlıklarında kullanılan ortak "joystick filtre" şablonu. Header'a bir
             ColumnFilterViewModel atandığında (DataGridColumn.Header, ViewModelProxy üzerinden
             bağlanıyor — bkz. DataGrid.Columns) HeaderTemplate'in DataContext'i otomatik olarak bu
             nesne olur. Başlık metni sol üstte, joystick ikonu hücrenin sağ alt köşesinde;
             tıklanınca hemen altında değer+sayı listeli bir dropdown açılır (Temizle/OK/Cancel ile).
             İkon emoji değil vektör şekil (Rectangle+Ellipse) — böylece font desteğine bağlı kalmaz. -->
        <DataTemplate x:Key="FilterableColumnHeader" DataType="{x:Type models:ColumnFilterViewModel}">
            <!-- Grid.ColumnDefinitions kullanılıyor (mutlak konumlandırma/overlay değil): ikon
                 kendi Auto genişlikli sütununda akış içinde yer alıyor, böylece toplam genişlik
                 her zaman hücrenin gerçek genişliğine sığıyor ve sütun ayırıcı çizgisiyle asla
                 çakışmıyor — önceki sağa-hizalı overlay yaklaşımı dar sütunlarda çizgiyle üst üste
                 biniyordu. -->
            <Grid MinHeight="30">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="Auto" />
                </Grid.ColumnDefinitions>
                <TextBlock Grid.Column="0" Text="{Binding HeaderText}" VerticalAlignment="Center" HorizontalAlignment="Left"
                           Margin="0,0,4,0" TextTrimming="CharacterEllipsis" />

                <Button Grid.Column="1" x:Name="FilterIconButton" VerticalAlignment="Center" HorizontalAlignment="Center"
                        Padding="4" Margin="0,0,4,0" Background="Transparent" BorderThickness="0"
                        Cursor="Hand" Command="{Binding OpenCommand}" ToolTip="Filtrele">
                    <Polygon Points="0,0 10,0 6.5,5 6.5,9 3.5,9 3.5,5" Stretch="Uniform" Width="10" Height="10">
                        <Polygon.Style>
                            <Style TargetType="Polygon">
                                <Setter Property="Fill" Value="{StaticResource Brush.Text.Secondary}" />
                                <Style.Triggers>
                                    <DataTrigger Binding="{Binding IsActive}" Value="True">
                                        <Setter Property="Fill" Value="{StaticResource Brush.Accent.Amber}" />
                                    </DataTrigger>
                                </Style.Triggers>
                            </Style>
                        </Polygon.Style>
                    </Polygon>
                </Button>

                <Popup PlacementTarget="{Binding ElementName=FilterIconButton}" IsOpen="{Binding IsPopupOpen}"
                       StaysOpen="False" Placement="Bottom" AllowsTransparency="True" PopupAnimation="Fade">
                    <Border Background="{StaticResource Brush.Background.Elevated}"
                            BorderBrush="{StaticResource Brush.Border}" BorderThickness="1"
                            CornerRadius="4" Padding="6" MinWidth="200" MaxHeight="360">
                        <DockPanel>
                            <!-- Alttaki tek düğme hem "Temizle" hem "Hepsini Seç" işlevini görür,
                                 mevcut seçim durumuna göre etiketi/işlevi otomatik değişir
                                 (bkz. ColumnFilterViewModel.ToggleAllLabel/ToggleAllCommand). -->
                            <StackPanel DockPanel.Dock="Bottom" Orientation="Horizontal"
                                        HorizontalAlignment="Right" Margin="0,6,0,0">
                                <Button Content="{Binding ToggleAllLabel}" Command="{Binding ToggleAllCommand}" FontSize="10" Margin="0,0,4,0" />
                                <Button Content="OK" Command="{Binding ApplyFilterCommand}" FontSize="10" Margin="0,0,4,0" />
                                <Button Content="Cancel" Command="{Binding CancelFilterCommand}" FontSize="10" />
                            </StackPanel>

                            <!-- Değer listesini daraltan arama kutusu (bkz. ColumnFilterViewModel.
                                 SearchText/OptionsView). -->
                            <TextBox DockPanel.Dock="Top" Margin="0,0,0,4" FontSize="11"
                                     Text="{Binding SearchText, UpdateSourceTrigger=PropertyChanged}" />

                            <ScrollViewer VerticalScrollBarVisibility="Auto" MaxHeight="260">
                                <ItemsControl ItemsSource="{Binding OptionsView}">
                                    <ItemsControl.ItemTemplate>
                                        <DataTemplate DataType="{x:Type models:FilterOption}">
                                            <!-- Fare üstündeyken satırın hangi değere karşılık geldiğini
                                                 belli etmek için hover vurgusu (Brush.Background.Hover). -->
                                            <Border Padding="3,2" CornerRadius="2">
                                                <Border.Style>
                                                    <Style TargetType="Border">
                                                        <Setter Property="Background" Value="Transparent" />
                                                        <Style.Triggers>
                                                            <Trigger Property="IsMouseOver" Value="True">
                                                                <Setter Property="Background" Value="{StaticResource Brush.Background.Hover}" />
                                                            </Trigger>
                                                        </Style.Triggers>
                                                    </Style>
                                                </Border.Style>
                                                <CheckBox IsChecked="{Binding IsChecked}" FontSize="11">
                                                    <TextBlock FontSize="11">
                                                        <Run Text="{Binding Value, Mode=OneWay}" />
                                                        <Run Text=" (" /><Run Text="{Binding Count, Mode=OneWay}" /><Run Text=")" />
                                                    </TextBlock>
                                                </CheckBox>
                                            </Border>
                                        </DataTemplate>
                                    </ItemsControl.ItemTemplate>
                                </ItemsControl>
                            </ScrollViewer>
                        </DockPanel>
                    </Border>
                </Popup>
            </Grid>
        </DataTemplate>

        <!-- Kapsül sağ tık menüsündeki her dairesel ikon düğmesi için ortak şablon: hover'da
             (Brush.Background.Hover) yuvarlak bir vurgu belirir — bkz. plan referans ekran görüntüsü. -->
        <Style x:Key="ContextMenuIconButton" TargetType="Button">
            <Setter Property="Background" Value="Transparent" />
            <Setter Property="BorderThickness" Value="0" />
            <Setter Property="Cursor" Value="Hand" />
            <Setter Property="Margin" Value="3,0" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="Bg" CornerRadius="20" Width="40" Height="40" Background="Transparent">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center" />
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="Bg" Property="Background" Value="{StaticResource Brush.Background.Hover}" />
                            </Trigger>
                            <Trigger Property="IsEnabled" Value="False">
                                <Setter Property="Opacity" Value="0.35" />
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <!-- IconOnly modunda etiket metni gizlenir (bkz. Ayarlar > Arayüz, ContextMenuDisplayMode). -->
        <Style x:Key="ContextMenuLabelText" TargetType="TextBlock">
            <Setter Property="FontSize" Value="9" />
            <Setter Property="HorizontalAlignment" Value="Center" />
            <Setter Property="Margin" Value="0,2,0,0" />
            <Setter Property="Foreground" Value="{StaticResource Brush.Text.Secondary}" />
            <Style.Triggers>
                <DataTrigger Binding="{Binding DataContext.ContextMenuDisplayMode, RelativeSource={RelativeSource AncestorType=Window}}" Value="IconOnly">
                    <Setter Property="Visibility" Value="Collapsed" />
                </DataTrigger>
            </Style.Triggers>
        </Style>

        <Style x:Key="ContextMenuGlyphText" TargetType="TextBlock">
            <Setter Property="FontFamily" Value="Segoe MDL2 Assets" />
            <Setter Property="FontSize" Value="17" />
            <Setter Property="HorizontalAlignment" Value="Center" />
            <Setter Property="Foreground" Value="{StaticResource Brush.Text.Primary}" />
        </Style>
    </Window.Resources>

    <Grid Background="{StaticResource Brush.Background.Base}">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
        </Grid.RowDefinitions>

        <!-- ===================== Toolbar ===================== -->
        <Border Grid.Row="0" Background="{StaticResource Brush.Background.Panel}"
                BorderBrush="{StaticResource Brush.Border}" BorderThickness="0,0,0,1" Padding="8">
            <DockPanel>
                <StackPanel DockPanel.Dock="Right" Orientation="Horizontal" VerticalAlignment="Center">
                    <TextBlock Text="Satır:" VerticalAlignment="Center" Margin="12,0,4,0" Foreground="{StaticResource Brush.Text.Secondary}" />
                    <Slider Minimum="20" Maximum="60" Width="90" VerticalAlignment="Center" Value="{Binding RowHeight}" />
                    <TextBlock Text="{Binding RowHeight, StringFormat={}{0:0}}" Width="24" VerticalAlignment="Center" Margin="4,0,12,0" />
                    <TextBlock Text="Obsidyen" VerticalAlignment="Center" Foreground="{StaticResource Brush.Text.Secondary}" FontStyle="Italic" />
                </StackPanel>

                <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                    <Button Content="Import" Command="{Binding ImportCommand}" Margin="0,0,6,0" />
                    <Button Content="Rescan" Command="{Binding RescanCommand}" Margin="0,0,6,0" />
                    <Button Content="Temizle" Command="{Binding ClearFiltersCommand}" Margin="0,0,6,0" />
                    <Button Content="Refresh Media" Command="{Binding RefreshMediaCommand}" Margin="0,0,6,0" />
                    <Button Content="Metadata Yenile" Command="{Binding MetadataRefreshCommand}" Margin="0,0,6,0" />
                    <Button Content="Kütüphaneye Taşı" Command="{Binding MoveToLibraryCommand}" Margin="0,0,14,0" />

                    <!-- "Tools" menüsü bir seçim kutusu gibi görünse de aslında bir eylem tetikleyicisi:
                         seçilen öğe MainViewModel.OnSelectedToolActionChanged içinde işlenip ilgili
                         pencere açılır, ardından seçim otomatik olarak "Tools" placeholder'ına döner. -->
                    <ComboBox Width="90" Margin="0,0,6,0" ItemsSource="{Binding ToolMenuItems}"
                              SelectedItem="{Binding SelectedToolAction}" />
                    <ComboBox Width="110" Margin="0,0,14,0" SelectedIndex="0">
                        <ComboBoxItem Content="Filter: All" />
                        <ComboBoxItem Content="Filter: Missing Box" />
                        <ComboBoxItem Content="Filter: Missing BG" />
                        <ComboBoxItem Content="Filter: Missing SS" />
                    </ComboBox>

                    <!-- WPF TextBox'ın yerleşik bir "placeholder" özelliği olmadığından, arama kutusu
                         boşken üzerine bindirilen bir TextBlock ile "Ara..." ipucu simüle ediliyor.
                         TextBlock IsHitTestVisible="False" olduğu için fare tıklamalarını etkilemez. -->
                    <Grid Width="220" Margin="0,0,14,0">
                        <TextBox VerticalContentAlignment="Center"
                                 Text="{Binding SearchText, UpdateSourceTrigger=PropertyChanged}" />
                        <TextBlock Text="Ara... (Boş alan için)" IsHitTestVisible="False"
                                   VerticalAlignment="Center" Margin="10,0,0,0"
                                   Foreground="{StaticResource Brush.Text.Secondary}">
                            <TextBlock.Style>
                                <Style TargetType="TextBlock">
                                    <Setter Property="Visibility" Value="Collapsed" />
                                    <Style.Triggers>
                                        <DataTrigger Binding="{Binding SearchText}" Value="">
                                            <Setter Property="Visibility" Value="Visible" />
                                        </DataTrigger>
                                    </Style.Triggers>
                                </Style>
                            </TextBlock.Style>
                        </TextBlock>
                    </Grid>

                    <ToggleButton Content="Released" IsChecked="{Binding ShowReleased}" Margin="0,0,4,0" />
                    <ToggleButton Content="Junk" IsChecked="{Binding ShowJunk}" Margin="0,0,14,0" />

                    <Button Content="Apply Resolver" Command="{Binding ApplyResolverCommand}" Margin="0,0,14,0" />

                    <!-- Sütun seçici: hangi ek metadata sütununun (Geliştirici/Yayıncı/Yıl/Bölge/
                         Kaynak/...) DataGrid'de görüneceğini seçer. DataGridColumn görsel ağacın
                         parçası olmadığından XAML binding ile doğrudan gizlenemiyor; bu yüzden
                         her satırın IsVisible değişimi kod-arkasında (MainWindow.xaml.cs) ilgili
                         sütunu bulup Visibility'sini günceller. -->
                    <ToggleButton x:Name="ColumnsToggle" Content="Sütunlar ▾" />
                    <Popup PlacementTarget="{Binding ElementName=ColumnsToggle}" IsOpen="{Binding IsChecked, ElementName=ColumnsToggle}"
                           StaysOpen="False" Placement="Bottom" AllowsTransparency="True" PopupAnimation="Fade">
                        <Border Background="{StaticResource Brush.Background.Elevated}"
                                BorderBrush="{StaticResource Brush.Border}" BorderThickness="1"
                                CornerRadius="4" Padding="8" MinWidth="160">
                            <ItemsControl ItemsSource="{Binding ColumnOptions}">
                                <ItemsControl.ItemTemplate>
                                    <DataTemplate DataType="{x:Type models:ColumnVisibilityOption}">
                                        <CheckBox Content="{Binding Header}" IsChecked="{Binding IsVisible}" Margin="2" />
                                    </DataTemplate>
                                </ItemsControl.ItemTemplate>
                            </ItemsControl>
                        </Border>
                    </Popup>
                </StackPanel>
            </DockPanel>
        </Border>

        <!-- ===================== Stats bar ===================== -->
        <Border Grid.Row="1" Background="{StaticResource Brush.Background.Base}"
                BorderBrush="{StaticResource Brush.Border}" BorderThickness="0,0,0,1" Padding="10,4">
            <TextBlock Foreground="{StaticResource Brush.Text.Secondary}" FontSize="11">
                <Run Text="Görünen:" /><Run Text=" " /><Run Text="{Binding VisibleCount, Mode=OneWay}" />
                <Run Text="  |  Toplam:" /><Run Text=" " /><Run Text="{Binding TotalCount, Mode=OneWay}" />
            </TextBlock>
        </Border>

        <!-- ===================== Playlist chip şeridi ===================== -->
        <Border Grid.Row="2" Background="{StaticResource Brush.Background.Base}"
                BorderBrush="{StaticResource Brush.Border}" BorderThickness="0,0,0,1" Padding="10,6">
            <StackPanel Orientation="Horizontal">
            <ItemsControl ItemsSource="{Binding PlaylistChips}">
                <ItemsControl.ItemsPanel>
                    <ItemsPanelTemplate>
                        <StackPanel Orientation="Horizontal" />
                    </ItemsPanelTemplate>
                </ItemsControl.ItemsPanel>
                <ItemsControl.ItemTemplate>
                    <DataTemplate DataType="{x:Type models:PlaylistChip}">
                        <!-- Chip'e tıklamak SelectChipCommand'ı tetikler (aynı chip'e tekrar
                             tıklamak seçimi kaldırır — bkz. MainViewModel.SelectChip). Seçili
                             chip'in kenarlığı kendi rengiyle vurgulanır. -->
                        <Button Command="{Binding DataContext.SelectChipCommand, RelativeSource={RelativeSource AncestorType=Window}}"
                                CommandParameter="{Binding}" Margin="0,0,6,0" Cursor="Hand"
                                Background="Transparent" BorderThickness="0" Padding="0">
                            <Border CornerRadius="10" Padding="10,4" Background="{StaticResource Brush.Background.Elevated}">
                                <Border.Style>
                                    <Style TargetType="Border">
                                        <Setter Property="BorderThickness" Value="1" />
                                        <Setter Property="BorderBrush" Value="{StaticResource Brush.Border}" />
                                        <Style.Triggers>
                                            <DataTrigger Binding="{Binding IsSelected}" Value="True">
                                                <Setter Property="BorderBrush" Value="{Binding Color}" />
                                                <Setter Property="BorderThickness" Value="2" />
                                            </DataTrigger>
                                        </Style.Triggers>
                                    </Style>
                                </Border.Style>
                                <StackPanel Orientation="Horizontal">
                                    <!-- Renkli nokta: sadece kullanıcının kendi oluşturduğu playlist'lerde
                                         (Favorites/Hidden/Recycle Bin sabit ikon kullanıyor, aşağıda). -->
                                    <Ellipse Width="8" Height="8" Fill="{Binding Color}" VerticalAlignment="Center" Margin="0,0,5,0">
                                        <Ellipse.Style>
                                            <Style TargetType="Ellipse">
                                                <Setter Property="Visibility" Value="Visible" />
                                                <Style.Triggers>
                                                    <DataTrigger Binding="{Binding IsBuiltIn}" Value="True">
                                                        <Setter Property="Visibility" Value="Collapsed" />
                                                    </DataTrigger>
                                                </Style.Triggers>
                                            </Style>
                                        </Ellipse.Style>
                                    </Ellipse>

                                    <!-- Sabit chip'lerin ikonu — sağ tık menüsündekiyle aynı Segoe MDL2
                                         glyph'ler (Favorites=yıldız, Hidden=göz, Recycle Bin=çöp kutusu). -->
                                    <TextBlock FontFamily="Segoe MDL2 Assets" FontSize="12" Margin="0,0,5,0"
                                               VerticalAlignment="Center" Foreground="{Binding Color}">
                                        <TextBlock.Style>
                                            <Style TargetType="TextBlock">
                                                <Setter Property="Visibility" Value="Collapsed" />
                                                <Setter Property="Text" Value="&#xE734;" />
                                                <Style.Triggers>
                                                    <DataTrigger Binding="{Binding IsBuiltIn}" Value="True">
                                                        <Setter Property="Visibility" Value="Visible" />
                                                    </DataTrigger>
                                                    <DataTrigger Binding="{Binding Kind}" Value="Hidden">
                                                        <Setter Property="Text" Value="&#xE7B3;" />
                                                    </DataTrigger>
                                                    <DataTrigger Binding="{Binding Kind}" Value="RecycleBin">
                                                        <Setter Property="Text" Value="&#xE74D;" />
                                                    </DataTrigger>
                                                </Style.Triggers>
                                            </Style>
                                        </TextBlock.Style>
                                    </TextBlock>

                                    <!-- "#" öneki de sadece kullanıcı playlist'lerinde. -->
                                    <TextBlock Text="#" FontSize="11" Foreground="{StaticResource Brush.Text.Primary}">
                                        <TextBlock.Style>
                                            <Style TargetType="TextBlock">
                                                <Setter Property="Visibility" Value="Visible" />
                                                <Style.Triggers>
                                                    <DataTrigger Binding="{Binding IsBuiltIn}" Value="True">
                                                        <Setter Property="Visibility" Value="Collapsed" />
                                                    </DataTrigger>
                                                </Style.Triggers>
                                            </Style>
                                        </TextBlock.Style>
                                    </TextBlock>
                                    <TextBlock Text="{Binding Name, Mode=OneWay}" FontSize="11" Foreground="{StaticResource Brush.Text.Primary}" />
                                </StackPanel>
                            </Border>
                        </Button>
                    </DataTemplate>
                </ItemsControl.ItemTemplate>
            </ItemsControl>

            <!-- "+ Yeni Playlist" — tıklanınca inline bir textbox'a dönüşür (bkz.
                 IsCreatingPlaylist/NewPlaylistName), Enter ile CommitCreatePlaylistCommand'ı
                 tetikler. Kullanıcı kararı: sabit playlist adı yok, hepsi burada oluşturuluyor. -->
            <Button Command="{Binding BeginCreatePlaylistCommand}" Cursor="Hand"
                    Background="Transparent" BorderThickness="0" Content="+ Yeni Playlist"
                    Foreground="{StaticResource Brush.Text.Secondary}" FontSize="11">
                <Button.Style>
                    <Style TargetType="Button" BasedOn="{StaticResource {x:Type Button}}">
                        <Setter Property="Visibility" Value="Visible" />
                        <Style.Triggers>
                            <DataTrigger Binding="{Binding IsCreatingPlaylist}" Value="True">
                                <Setter Property="Visibility" Value="Collapsed" />
                            </DataTrigger>
                        </Style.Triggers>
                    </Style>
                </Button.Style>
            </Button>
            <TextBox Width="120" FontSize="11" VerticalContentAlignment="Center"
                     Text="{Binding NewPlaylistName, UpdateSourceTrigger=PropertyChanged}">
                <TextBox.Style>
                    <Style TargetType="TextBox">
                        <Setter Property="Visibility" Value="Collapsed" />
                        <Style.Triggers>
                            <DataTrigger Binding="{Binding IsCreatingPlaylist}" Value="True">
                                <Setter Property="Visibility" Value="Visible" />
                            </DataTrigger>
                        </Style.Triggers>
                    </Style>
                </TextBox.Style>
                <TextBox.InputBindings>
                    <KeyBinding Key="Enter" Command="{Binding CommitCreatePlaylistCommand}" />
                </TextBox.InputBindings>
            </TextBox>
            </StackPanel>
        </Border>

        <!-- ===================== Body ===================== -->
        <Grid Grid.Row="3">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="220" />
                <ColumnDefinition Width="Auto" />
                <ColumnDefinition Width="*" />
                <!-- Sürgülü sağ panel: IsDetailPanelExpanded false iken 0'a iner. Aç/kapa artık
                     kenarda ayrı bir sütun/düğme değil — üst istatistik çubuğundaki tam ekran
                     genişletme ikonu (bkz. "Görünen/Toplam" satırı) bu komutu tetikliyor; kenardaki
                     düğme hem scrollbar'la görsel dikiş hem de (eski GridSplitter'la) Binding
                     çakışması sorunlarına yol açıyordu. -->
                <ColumnDefinition Width="{Binding IsDetailPanelExpanded, Converter={StaticResource BoolToGridLength}, ConverterParameter=340}" />
            </Grid.ColumnDefinitions>

            <!-- Left: Platforms -->
            <Border Grid.Column="0" Background="{StaticResource Brush.Background.Panel}">
                <DockPanel>
                    <TextBlock DockPanel.Dock="Top" Text="Platforms" FontWeight="Bold" Margin="10,10,10,6"
                               Foreground="{StaticResource Brush.Text.Primary}" />

                    <!-- Tek bir ListBox içinde hem kategori başlıkları (CONSOLES/HANDHELDS/ARCADE/
                         COMPUTERS/CLASSIC/OTHERS) hem platform satırları var (bkz. PlatformListItem).
                         WPF'in doğal grup desteği "bir grubu kapalı, diğerlerini açık" göstermeye uygun
                         olmadığından, görünür satır listesi ViewModel'de (RebuildPlatformListItems)
                         elle kuruluyor: "OTHERS" kapalıyken o kategorinin platform satırları listeye
                         hiç eklenmiyor. ItemContainerStyle ile normal başlıklar tıklanamaz hale
                         getiriliyor; "OTHERS" başlığı ise DataTemplate içindeki bir buton üzerinden
                         ToggleOthersCommand'ı tetikliyor. -->
                    <ListBox ItemsSource="{Binding PlatformListItems}" SelectedItem="{Binding SelectedListItem}"
                             ScrollViewer.HorizontalScrollBarVisibility="Disabled">
                        <ListBox.ItemContainerStyle>
                            <Style TargetType="ListBoxItem" BasedOn="{StaticResource {x:Type ListBoxItem}}">
                                <Setter Property="Padding" Value="8,3" />
                                <Style.Triggers>
                                    <DataTrigger Binding="{Binding IsNonInteractiveHeader}" Value="True">
                                        <Setter Property="IsHitTestVisible" Value="False" />
                                        <Setter Property="Focusable" Value="False" />
                                    </DataTrigger>
                                </Style.Triggers>
                            </Style>
                        </ListBox.ItemContainerStyle>
                        <ListBox.ItemTemplate>
                            <DataTemplate DataType="{x:Type models:PlatformListItem}">
                                <Grid>
                                    <!-- Kategori başlığı satırı -->
                                    <Grid Margin="4,10,4,4">
                                        <Grid.Style>
                                            <Style TargetType="Grid">
                                                <Setter Property="Visibility" Value="Collapsed" />
                                                <Style.Triggers>
                                                    <DataTrigger Binding="{Binding IsHeader}" Value="True">
                                                        <Setter Property="Visibility" Value="Visible" />
                                                    </DataTrigger>
                                                </Style.Triggers>
                                            </Style>
                                        </Grid.Style>

                                        <!-- Sabit (tıklanamaz) başlık: CONSOLES/HANDHELDS/ARCADE/COMPUTERS/CLASSIC -->
                                        <TextBlock Text="{Binding HeaderText}" FontWeight="Bold" FontSize="10"
                                                   Foreground="{StaticResource Brush.Text.Secondary}">
                                            <TextBlock.Style>
                                                <Style TargetType="TextBlock">
                                                    <Setter Property="Visibility" Value="Visible" />
                                                    <Style.Triggers>
                                                        <DataTrigger Binding="{Binding IsCollapsibleHeader}" Value="True">
                                                            <Setter Property="Visibility" Value="Collapsed" />
                                                        </DataTrigger>
                                                    </Style.Triggers>
                                                </Style>
                                            </TextBlock.Style>
                                        </TextBlock>

                                        <!-- Tıklanabilir başlık: sadece OTHERS, aç/kapa oku ile -->
                                        <Button Background="Transparent" BorderThickness="0" Padding="0" Cursor="Hand"
                                                HorizontalContentAlignment="Stretch"
                                                Command="{Binding DataContext.ToggleOthersCommand, RelativeSource={RelativeSource AncestorType=Window}}">
                                            <Button.Style>
                                                <Style TargetType="Button" BasedOn="{StaticResource {x:Type Button}}">
                                                    <Setter Property="Visibility" Value="Collapsed" />
                                                    <Style.Triggers>
                                                        <DataTrigger Binding="{Binding IsCollapsibleHeader}" Value="True">
                                                            <Setter Property="Visibility" Value="Visible" />
                                                        </DataTrigger>
                                                    </Style.Triggers>
                                                </Style>
                                            </Button.Style>
                                            <Button.Template>
                                                <ControlTemplate TargetType="Button">
                                                    <Grid Background="Transparent">
                                                        <Grid.ColumnDefinitions>
                                                            <ColumnDefinition Width="*" />
                                                            <ColumnDefinition Width="Auto" />
                                                        </Grid.ColumnDefinitions>
                                                        <TextBlock Grid.Column="0" Text="{Binding HeaderText}" FontWeight="Bold" FontSize="10"
                                                                   Foreground="{StaticResource Brush.Text.Secondary}" />
                                                        <TextBlock Grid.Column="1" Text="{Binding ExpandGlyph}" FontSize="9"
                                                                   Foreground="{StaticResource Brush.Text.Secondary}" />
                                                    </Grid>
                                                </ControlTemplate>
                                            </Button.Template>
                                        </Button>
                                    </Grid>

                                    <!-- Platform satırı -->
                                    <Grid>
                                        <Grid.Style>
                                            <Style TargetType="Grid">
                                                <Setter Property="Visibility" Value="Visible" />
                                                <Style.Triggers>
                                                    <DataTrigger Binding="{Binding IsHeader}" Value="True">
                                                        <Setter Property="Visibility" Value="Collapsed" />
                                                    </DataTrigger>
                                                </Style.Triggers>
                                            </Style>
                                        </Grid.Style>
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="26" />
                                            <ColumnDefinition Width="*" />
                                            <ColumnDefinition Width="Auto" />
                                        </Grid.ColumnDefinitions>
                                        <Border Grid.Column="0" Width="22" Height="22" CornerRadius="4"
                                                Background="{StaticResource Brush.Background.Elevated}">
                                            <TextBlock Text="{Binding Platform.IconGlyph}" FontSize="7" FontWeight="Bold"
                                                       HorizontalAlignment="Center" VerticalAlignment="Center"
                                                       Foreground="{StaticResource Brush.Text.Secondary}" />
                                        </Border>
                                        <TextBlock Grid.Column="1" Text="{Binding Platform.Name}" VerticalAlignment="Center"
                                                   Margin="6,0,4,0" TextTrimming="CharacterEllipsis" />
                                        <Border Grid.Column="2" Background="{StaticResource Brush.Background.Elevated}"
                                                BorderBrush="{StaticResource Brush.Border}" BorderThickness="1"
                                                CornerRadius="8" Padding="6,1" VerticalAlignment="Center">
                                            <TextBlock Text="{Binding Platform.GameCount}" FontSize="10"
                                                       Foreground="{StaticResource Brush.Text.Secondary}" />
                                        </Border>
                                    </Grid>
                                </Grid>
                            </DataTemplate>
                        </ListBox.ItemTemplate>
                    </ListBox>
                </DockPanel>
            </Border>

            <GridSplitter Grid.Column="1" Width="1" HorizontalAlignment="Stretch"
                          Background="{StaticResource Brush.Border}" />

            <!-- Center: Game grid.
                 Sanallaştırma (virtualization) özellikleri, binlerce satırlık gerçek verilerle
                 kullanıldığında kaydırma sırasında kasmayı önlemek için bilinçli olarak açık:
                 sadece ekranda görünen satırlar için UI elemanı oluşturulur, kaydırırken
                 elemanlar oluşturulup atılmak yerine "Recycling" moduyla yeniden kullanılır.
                 Aradaki 4px boşluk kaldırıldı: scrollbar artık kendi (Elevated) arkaplanıyla zaten
                 net bir şekilde ayırt edilebiliyor (bkz. ObsidianDark.xaml ScrollBar Style), bu
                 yüzden sağ paneldeki aç/kapa tutamacıyla arasına ayrıca boşluk bırakmaya gerek
                 kalmadı — tutamaç artık scrollbar'a bitişik duruyor. -->
            <DataGrid x:Name="GamesGrid" Grid.Column="2"
                      ItemsSource="{Binding Games}"
                      SelectedItem="{Binding SelectedGame}"
                      RowHeight="{Binding RowHeight}"
                      EnableRowVirtualization="True"
                      EnableColumnVirtualization="True"
                      VirtualizingPanel.IsVirtualizing="True"
                      VirtualizingPanel.VirtualizationMode="Recycling"
                      ScrollViewer.CanContentScroll="True"
                      ScrollViewer.HorizontalScrollBarVisibility="Auto"
                      PreviewMouseRightButtonUp="GamesGrid_PreviewMouseRightButtonUp">
                <DataGrid.Columns>
                    <DataGridTemplateColumn Header="{Binding Data.MatchedFilter, Source={StaticResource ViewModelProxy}}"
                                             HeaderTemplate="{StaticResource FilterableColumnHeader}" Width="34">
                        <DataGridTemplateColumn.CellTemplate>
                            <DataTemplate DataType="{x:Type models:Game}">
                                <TextBlock Text="{Binding StatusOk, Converter={StaticResource BoolToStatusGlyph}}"
                                           FontFamily="Segoe MDL2 Assets"
                                           Foreground="{Binding StatusOk, Converter={StaticResource BoolToStatusBrush}}"
                                           HorizontalAlignment="Center" />
                            </DataTemplate>
                        </DataGridTemplateColumn.CellTemplate>
                    </DataGridTemplateColumn>

                    <DataGridTemplateColumn Header="Logo" Width="44">
                        <DataGridTemplateColumn.CellTemplate>
                            <DataTemplate DataType="{x:Type models:Game}">
                                <Border Width="28" Height="28" CornerRadius="3" Background="{StaticResource Brush.Background.Elevated}" />
                            </DataTemplate>
                        </DataGridTemplateColumn.CellTemplate>
                    </DataGridTemplateColumn>

                    <!-- Favori yıldızı: her satırda tıklanabilir, IsFavorite'e göre dolu (★)/boş (☆).
                         Düz Unicode karakter kullanılıyor (emoji değil) — sütun başlığındaki ★'ın
                         bu ortamda sorunsuz render olduğu zaten doğrulandı; ilk denemede kullanılan
                         elle çizilmiş Polygon şekli 34px'lik hücrede bozuk görünüyordu. -->
                    <DataGridTemplateColumn Header="{Binding Data.FavoriteFilter, Source={StaticResource ViewModelProxy}}"
                                             HeaderTemplate="{StaticResource FilterableColumnHeader}" Width="34">
                        <DataGridTemplateColumn.CellTemplate>
                            <DataTemplate DataType="{x:Type models:Game}">
                                <!-- Padding="0": genel Button stilinin varsayılan 10,5 iç boşluğu bu
                                     34px'lik dar sütunda yıldızı neredeyse görünmez hale getiriyordu. -->
                                <Button Command="{Binding DataContext.ToggleFavoriteCommand, RelativeSource={RelativeSource AncestorType=Window}}"
                                        CommandParameter="{Binding}" Background="Transparent" BorderThickness="0" Padding="0"
                                        Cursor="Hand" ToolTip="Favorilere ekle/çıkar" HorizontalContentAlignment="Center">
                                    <TextBlock FontSize="17" VerticalAlignment="Center">
                                        <TextBlock.Style>
                                            <Style TargetType="TextBlock">
                                                <Setter Property="Text" Value="☆" />
                                                <Setter Property="Foreground" Value="{StaticResource Brush.Text.Secondary}" />
                                                <Style.Triggers>
                                                    <DataTrigger Binding="{Binding IsFavorite}" Value="True">
                                                        <Setter Property="Text" Value="★" />
                                                        <Setter Property="Foreground" Value="{StaticResource Brush.Accent.Amber}" />
                                                    </DataTrigger>
                                                </Style.Triggers>
                                            </Style>
                                        </TextBlock.Style>
                                    </TextBlock>
                                </Button>
                            </DataTemplate>
                        </DataGridTemplateColumn.CellTemplate>
                    </DataGridTemplateColumn>

                    <!-- ROM'u bulunamayan oyunlarda görünen "web'de ara" büyüteci — ROM mevcutsa
                         (HasLocalFile) hiç gösterilmiyor, kullanıcı isteğiyle sadece eksik olanlarda. -->
                    <DataGridTemplateColumn Header="{Binding Data.HasLocalFileFilter, Source={StaticResource ViewModelProxy}}"
                                             HeaderTemplate="{StaticResource FilterableColumnHeader}" Width="34">
                        <DataGridTemplateColumn.CellTemplate>
                            <DataTemplate DataType="{x:Type models:Game}">
                                <Button Command="{Binding DataContext.SearchWebCommand, RelativeSource={RelativeSource AncestorType=Window}}"
                                        CommandParameter="{Binding}" Background="Transparent" BorderThickness="0" Padding="0"
                                        Cursor="Hand" ToolTip="Eksik ROM'u web'de ara">
                                    <!-- BasedOn şart: yoksa bu Style genel (koyu temalı hover'lı) Button
                                         stilinin YERİNE geçip WPF'in varsayılan (beyaz) chrome'una
                                         düşüyordu — bu yüzden hover beyaz görünüyordu. -->
                                    <Button.Style>
                                        <Style TargetType="Button" BasedOn="{StaticResource {x:Type Button}}">
                                            <Setter Property="Visibility" Value="Collapsed" />
                                            <Style.Triggers>
                                                <DataTrigger Binding="{Binding HasLocalFile}" Value="False">
                                                    <Setter Property="Visibility" Value="Visible" />
                                                </DataTrigger>
                                            </Style.Triggers>
                                        </Style>
                                    </Button.Style>
                                    <Grid Width="14" Height="14">
                                        <Ellipse Width="9" Height="9" Stroke="{StaticResource Brush.Text.Secondary}"
                                                 StrokeThickness="1.5" HorizontalAlignment="Left" VerticalAlignment="Top" />
                                        <Line X1="8" Y1="8" X2="13" Y2="13" Stroke="{StaticResource Brush.Text.Secondary}" StrokeThickness="1.5" />
                                    </Grid>
                                </Button>
                            </DataTemplate>
                        </DataGridTemplateColumn.CellTemplate>
                    </DataGridTemplateColumn>

                    <!-- Sütunlar artık oransal (*) değil sabit piksel genişlikte — DataGrid'in
                         kendi yatay kaydırma çubuğunun devreye girmesi (sütunların sıkışıp
                         küçülmesi yerine) için bu şart: "*" ile genişlik her zaman mevcut alana
                         göre yeniden dağıtılır ve taşma/scroll hiç oluşmaz. -->
                    <DataGridTextColumn Header="{Binding Data.TitleFilter, Source={StaticResource ViewModelProxy}}"
                                         HeaderTemplate="{StaticResource FilterableColumnHeader}"
                                         Binding="{Binding Title}" Width="220" />

                    <DataGridTemplateColumn Header="{Binding Data.BoxFilter, Source={StaticResource ViewModelProxy}}"
                                             HeaderTemplate="{StaticResource FilterableColumnHeader}" Width="40">
                        <DataGridTemplateColumn.CellTemplate>
                            <DataTemplate DataType="{x:Type models:Game}">
                                <Ellipse Width="10" Height="10" Fill="{Binding HasBox, Converter={StaticResource BoolToStatusBrush}}" />
                            </DataTemplate>
                        </DataGridTemplateColumn.CellTemplate>
                    </DataGridTemplateColumn>

                    <DataGridTemplateColumn Header="{Binding Data.BackgroundFilter, Source={StaticResource ViewModelProxy}}"
                                             HeaderTemplate="{StaticResource FilterableColumnHeader}" Width="40">
                        <DataGridTemplateColumn.CellTemplate>
                            <DataTemplate DataType="{x:Type models:Game}">
                                <Ellipse Width="10" Height="10" Fill="{Binding HasBackground, Converter={StaticResource BoolToStatusBrush}}" />
                            </DataTemplate>
                        </DataGridTemplateColumn.CellTemplate>
                    </DataGridTemplateColumn>

                    <DataGridTemplateColumn Header="{Binding Data.ScreenshotFilter, Source={StaticResource ViewModelProxy}}"
                                             HeaderTemplate="{StaticResource FilterableColumnHeader}" Width="40">
                        <DataGridTemplateColumn.CellTemplate>
                            <DataTemplate DataType="{x:Type models:Game}">
                                <Ellipse Width="10" Height="10" Fill="{Binding HasScreenshot, Converter={StaticResource BoolToStatusBrush}}" />
                            </DataTemplate>
                        </DataGridTemplateColumn.CellTemplate>
                    </DataGridTemplateColumn>

                    <DataGridTextColumn Header="{Binding Data.FileFilter, Source={StaticResource ViewModelProxy}}"
                                         HeaderTemplate="{StaticResource FilterableColumnHeader}"
                                         Binding="{Binding File}" Width="200" />
                    <DataGridTextColumn Header="{Binding Data.PlatformFilter, Source={StaticResource ViewModelProxy}}" HeaderTemplate="{StaticResource FilterableColumnHeader}"
                                         Binding="{Binding Platform}" Width="160" />
                    <DataGridTextColumn Header="{Binding Data.StatusFilter, Source={StaticResource ViewModelProxy}}" HeaderTemplate="{StaticResource FilterableColumnHeader}"
                                         Binding="{Binding Version}" Width="90" />
                    <DataGridTextColumn Header="{Binding Data.GenresFilter, Source={StaticResource ViewModelProxy}}" HeaderTemplate="{StaticResource FilterableColumnHeader}"
                                         Binding="{Binding Genres}" Width="150" />

                    <!-- Aşağıdaki sütunlar varsayılan gizli (bkz. ColumnOptions) — "Sütunlar" düğmesiyle
                         açılıp kapanır, kod-arkası (MainWindow.xaml.cs) x:Name üzerinden yönetir. -->
                    <DataGridTextColumn x:Name="DeveloperColumn" Header="{Binding Data.DeveloperFilter, Source={StaticResource ViewModelProxy}}"
                                         HeaderTemplate="{StaticResource FilterableColumnHeader}"
                                         Binding="{Binding Developer}" Width="140" Visibility="Collapsed" />
                    <DataGridTextColumn x:Name="PublisherColumn" Header="{Binding Data.PublisherFilter, Source={StaticResource ViewModelProxy}}"
                                         HeaderTemplate="{StaticResource FilterableColumnHeader}"
                                         Binding="{Binding Publisher}" Width="140" Visibility="Collapsed" />
                    <DataGridTextColumn x:Name="ReleaseYearColumn" Header="{Binding Data.ReleaseYearFilter, Source={StaticResource ViewModelProxy}}"
                                         HeaderTemplate="{StaticResource FilterableColumnHeader}"
                                         Binding="{Binding ReleaseYear}" Width="70" Visibility="Collapsed" />
                    <DataGridTextColumn x:Name="MaxPlayersColumn" Header="{Binding Data.MaxPlayersFilter, Source={StaticResource ViewModelProxy}}"
                                         HeaderTemplate="{StaticResource FilterableColumnHeader}"
                                         Binding="{Binding MaxPlayers}" Width="90" Visibility="Collapsed" />
                    <DataGridTextColumn x:Name="RegionColumn" Header="{Binding Data.RegionFilter, Source={StaticResource ViewModelProxy}}"
                                         HeaderTemplate="{StaticResource FilterableColumnHeader}"
                                         Binding="{Binding Region}" Width="90" Visibility="Collapsed" />
                    <DataGridTextColumn x:Name="SourceColumn" Header="{Binding Data.SourceFilter, Source={StaticResource ViewModelProxy}}"
                                         HeaderTemplate="{StaticResource FilterableColumnHeader}"
                                         Binding="{Binding SourceDat}" Width="90" Visibility="Collapsed" />
                    <DataGridTextColumn x:Name="MatchMethodColumn" Header="{Binding Data.MatchMethodFilter, Source={StaticResource ViewModelProxy}}"
                                         HeaderTemplate="{StaticResource FilterableColumnHeader}"
                                         Binding="{Binding MatchMethod}" Width="130" Visibility="Collapsed" />
                </DataGrid.Columns>
            </DataGrid>

            <!-- Tabloyu tam genişliğe getirme (sağ detay panelini gizleme/gösterme) ikonu.
                 DataGrid'in kendi köşesinde, sütun başlıklarının bittiği ile dikey scrollbar'ın
                 başladığı yerde zaten boş/kullanılmayan küçük bir alan var (klasik DataGrid köşe
                 hücresi) — ayrı bir sütun/satır açmadan, aynı Grid hücresine (Grid.Column="2")
                 DataGrid'den SONRA eklenip üstüne bindiriliyor, o boş köşeye tam oturuyor.
                 Arkaplanı başlık rengiyle eşleştirme denemesi (Border + Elevated) geri alındı —
                 gerçek başlık yüksekliğini bilmeden bir sızıntı kalmadan tam oturtmak mümkün
                 olmadı; düğme arkaplansız (Transparent) bırakıldı. -->
            <Button x:Name="DetailPanelToggleButton" Grid.Column="2" Command="{Binding ToggleDetailPanelCommand}"
                    Width="14" Height="40" HorizontalAlignment="Right" VerticalAlignment="Top"
                    Background="Transparent" Padding="0" Cursor="Hand"
                    ToolTip="Tabloyu tam genişliğe getir / geri al">
                <!-- Arkaplan hover'ı (rengi değişen bir kutu) bu küçük köşe hücresinde her zaman
                     "yarım" duruyordu — hücre sınırlarıyla tam örtüşmüyor, komşu scrollbar
                     arkaplanıyla hizası bozuk görünüyordu. Onun yerine arkaplan hiç değişmiyor,
                     sadece ikonun kendisi (aşağıdaki TextBlock) hover'da renk değiştiriyor. -->
                <Button.Template>
                    <ControlTemplate TargetType="{x:Type Button}">
                        <Border Background="{TemplateBinding Background}">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center" />
                        </Border>
                    </ControlTemplate>
                </Button.Template>
                <TextBlock FontFamily="Segoe MDL2 Assets" FontSize="10"
                           HorizontalAlignment="Center" VerticalAlignment="Center">
                    <TextBlock.Style>
                        <Style TargetType="TextBlock">
                            <Setter Property="Text" Value="&#xE740;" />
                            <Setter Property="Foreground" Value="{StaticResource Brush.Text.Secondary}" />
                            <Style.Triggers>
                                <DataTrigger Binding="{Binding IsDetailPanelExpanded}" Value="False">
                                    <Setter Property="Text" Value="&#xE73F;" />
                                </DataTrigger>
                                <DataTrigger Binding="{Binding IsMouseOver, ElementName=DetailPanelToggleButton}" Value="True">
                                    <Setter Property="Foreground" Value="{StaticResource Brush.Text.Primary}" />
                                </DataTrigger>
                            </Style.Triggers>
                        </Style>
                    </TextBlock.Style>
                </TextBlock>
            </Button>

            <!-- ===================== Kapsül sağ tık menüsü ===================== -->
            <!-- MainWindow.xaml.cs GamesGrid_PreviewMouseRightButtonDown ile açılır (satırı bulup
                 ContextMenuGame'i ayarlar). Placement="MousePoint" fare imlecinin üstünde açılmasını
                 sağlar. Popup normal görsel ağacın bir parçası olduğu için (DataGridColumn.Header'ın
                 aksine) DataContext'i doğrudan Window'dan miras alıyor, ekstra bir BindingProxy'ye
                 gerek yok. -->
            <Popup x:Name="ContextMenuPopup" Placement="MousePoint" IsOpen="{Binding IsContextMenuOpen}"
                   StaysOpen="False" AllowsTransparency="True" PopupAnimation="None">
                <Border x:Name="ContextMenuBorder" CornerRadius="24" Padding="8,6"
                        Background="{StaticResource Brush.Background.Elevated}"
                        BorderBrush="{StaticResource Brush.Border}" BorderThickness="1"
                        RenderTransformOrigin="0.5,0.5">
                    <Border.Effect>
                        <DropShadowEffect BlurRadius="16" ShadowDepth="2" Opacity="0.4" Color="Black" />
                    </Border.Effect>
                    <Border.RenderTransform>
                        <ScaleTransform ScaleX="1" ScaleY="1" />
                    </Border.RenderTransform>
                    <!-- Border tek çocuk kabul ettiği için tekil/toplu mod StackPanel'leri (aşağıda,
                         mutually exclusive Visibility ile) bu Grid'in içinde üst üste duruyor. -->
                    <Grid>
                    <!-- Tekil mod: bir tek oyuna özel eylemler. Birden fazla satır seçiliyken
                         (bkz. IsBulkContextMenu) tamamen gizlenir — Edit/Versions/Folder/Re-match/
                         Search Web gibi eylemler toplu seçimde ya anlamsız ya da çakışır. -->
                    <StackPanel Orientation="Horizontal" DataContext="{Binding ContextMenuGame}">
                        <StackPanel.Style>
                            <Style TargetType="StackPanel">
                                <Setter Property="Visibility" Value="Visible" />
                                <Style.Triggers>
                                    <DataTrigger Binding="{Binding DataContext.IsBulkContextMenu, RelativeSource={RelativeSource AncestorType=Window}}" Value="True">
                                        <Setter Property="Visibility" Value="Collapsed" />
                                    </DataTrigger>
                                </Style.Triggers>
                            </Style>
                        </StackPanel.Style>
                        <Button Style="{StaticResource ContextMenuIconButton}"
                                Command="{Binding DataContext.EditMetadataCommand, RelativeSource={RelativeSource AncestorType=Window}}"
                                CommandParameter="{Binding}" ToolTip="Edit Metadata">
                            <StackPanel>
                                <TextBlock Text="&#xE70F;" Style="{StaticResource ContextMenuGlyphText}" />
                                <TextBlock Text="Edit" Style="{StaticResource ContextMenuLabelText}" />
                            </StackPanel>
                        </Button>

                        <Button Style="{StaticResource ContextMenuIconButton}"
                                Command="{Binding DataContext.FocusVersionsCommand, RelativeSource={RelativeSource AncestorType=Window}}"
                                ToolTip="Versions">
                            <StackPanel>
                                <TextBlock Text="&#xE8F1;" Style="{StaticResource ContextMenuGlyphText}" />
                                <TextBlock Text="Versions" Style="{StaticResource ContextMenuLabelText}" />
                            </StackPanel>
                        </Button>

                        <!-- Hide/Unhide: aynı ikon, IsHidden'a göre komut ve etiket değişir. -->
                        <Button ToolTip="Hide/Unhide">
                            <StackPanel>
                                <TextBlock Text="&#xE7B3;" Style="{StaticResource ContextMenuGlyphText}" />
                                <TextBlock>
                                    <TextBlock.Style>
                                        <Style TargetType="TextBlock" BasedOn="{StaticResource ContextMenuLabelText}">
                                            <Setter Property="Text" Value="Hide" />
                                            <Style.Triggers>
                                                <DataTrigger Binding="{Binding IsHidden}" Value="True">
                                                    <Setter Property="Text" Value="Unhide" />
                                                </DataTrigger>
                                            </Style.Triggers>
                                        </Style>
                                    </TextBlock.Style>
                                </TextBlock>
                            </StackPanel>
                            <Button.Style>
                                <Style TargetType="Button" BasedOn="{StaticResource ContextMenuIconButton}">
                                    <Setter Property="Command" Value="{Binding DataContext.HideGameCommand, RelativeSource={RelativeSource AncestorType=Window}}" />
                                    <Setter Property="CommandParameter" Value="{Binding}" />
                                    <Style.Triggers>
                                        <DataTrigger Binding="{Binding IsHidden}" Value="True">
                                            <Setter Property="Command" Value="{Binding DataContext.UnhideGameCommand, RelativeSource={RelativeSource AncestorType=Window}}" />
                                        </DataTrigger>
                                    </Style.Triggers>
                                </Style>
                            </Button.Style>
                        </Button>

                        <Button Style="{StaticResource ContextMenuIconButton}"
                                Command="{Binding DataContext.OpenFileLocationCommand, RelativeSource={RelativeSource AncestorType=Window}}"
                                CommandParameter="{Binding}" IsEnabled="{Binding HasLocalFile}" ToolTip="Open File Location">
                            <StackPanel>
                                <TextBlock Text="&#xE838;" Style="{StaticResource ContextMenuGlyphText}" />
                                <TextBlock Text="Folder" Style="{StaticResource ContextMenuLabelText}" />
                            </StackPanel>
                        </Button>

                        <!-- Delete / Restore: Recycle Bin dışında Delete (çöp kutusuna taşı), Recycle
                             Bin chip'i içindeyken Restore. Kalıcı silme ayrı bir düğme (sadece çöp
                             kutusundayken görünür), onay MainWindow.xaml.cs'te MessageBox ile alınır. -->
                        <Button ToolTip="Delete/Restore">
                            <StackPanel>
                                <TextBlock Text="&#xE74D;" Style="{StaticResource ContextMenuGlyphText}" />
                                <TextBlock>
                                    <TextBlock.Style>
                                        <Style TargetType="TextBlock" BasedOn="{StaticResource ContextMenuLabelText}">
                                            <Setter Property="Text" Value="Delete" />
                                            <Style.Triggers>
                                                <DataTrigger Binding="{Binding IsDeleted}" Value="True">
                                                    <Setter Property="Text" Value="Restore" />
                                                </DataTrigger>
                                            </Style.Triggers>
                                        </Style>
                                    </TextBlock.Style>
                                </TextBlock>
                            </StackPanel>
                            <Button.Style>
                                <Style TargetType="Button" BasedOn="{StaticResource ContextMenuIconButton}">
                                    <Setter Property="Command" Value="{Binding DataContext.DeleteGameCommand, RelativeSource={RelativeSource AncestorType=Window}}" />
                                    <Setter Property="CommandParameter" Value="{Binding}" />
                                    <Style.Triggers>
                                        <DataTrigger Binding="{Binding IsDeleted}" Value="True">
                                            <Setter Property="Command" Value="{Binding DataContext.RestoreGameCommand, RelativeSource={RelativeSource AncestorType=Window}}" />
                                        </DataTrigger>
                                    </Style.Triggers>
                                </Style>
                            </Button.Style>
                        </Button>

                        <Button Command="{Binding DataContext.RequestPermanentDeleteCommand, RelativeSource={RelativeSource AncestorType=Window}}"
                                CommandParameter="{Binding}" ToolTip="Delete Permanently">
                            <Button.Style>
                                <Style TargetType="Button" BasedOn="{StaticResource ContextMenuIconButton}">
                                    <Setter Property="Visibility" Value="Collapsed" />
                                    <Style.Triggers>
                                        <DataTrigger Binding="{Binding IsDeleted}" Value="True">
                                            <Setter Property="Visibility" Value="Visible" />
                                        </DataTrigger>
                                    </Style.Triggers>
                                </Style>
                            </Button.Style>
                            <StackPanel>
                                <TextBlock Text="&#xE74D;" Style="{StaticResource ContextMenuGlyphText}" Foreground="Firebrick" />
                                <TextBlock Text="Delete Perm." Style="{StaticResource ContextMenuLabelText}" />
                            </StackPanel>
                        </Button>

                        <!-- Overflow (>): Re-match Metadata + Add to Playlist gibi daha az kullanılan
                             eylemleri ikinci bir satırda gösterir, kapsülü kompakt tutar. -->
                        <Button Style="{StaticResource ContextMenuIconButton}"
                                Command="{Binding DataContext.ToggleContextMenuOverflowCommand, RelativeSource={RelativeSource AncestorType=Window}}"
                                ToolTip="Daha fazla">
                            <TextBlock Text="&#xE76C;" Style="{StaticResource ContextMenuGlyphText}" />
                        </Button>

                        <Separator Width="1" Margin="4,6" Background="{StaticResource Brush.Border}" />

                        <Button Style="{StaticResource ContextMenuIconButton}"
                                Command="{Binding DataContext.SearchWebCommand, RelativeSource={RelativeSource AncestorType=Window}}"
                                CommandParameter="{Binding}" ToolTip="Search Web">
                            <TextBlock Text="&#xE721;" Style="{StaticResource ContextMenuGlyphText}" />
                        </Button>
                    </StackPanel>

                    <!-- Toplu mod: birden fazla satır seçiliyken sadece bunlar görünür (kullanıcı
                         kararı: "sadece silme ve gizleme ve playlist oluşturma playliste ekleme
                         favoriye ekleme gözüksün"). -->
                    <StackPanel Orientation="Horizontal">
                        <StackPanel.Style>
                            <Style TargetType="StackPanel">
                                <Setter Property="Visibility" Value="Collapsed" />
                                <Style.Triggers>
                                    <DataTrigger Binding="{Binding IsBulkContextMenu}" Value="True">
                                        <Setter Property="Visibility" Value="Visible" />
                                    </DataTrigger>
                                </Style.Triggers>
                            </Style>
                        </StackPanel.Style>

                        <Button Style="{StaticResource ContextMenuIconButton}"
                                Command="{Binding BulkAddToFavoritesCommand}" ToolTip="Favorilere Ekle">
                            <StackPanel>
                                <TextBlock Text="&#xE734;" Style="{StaticResource ContextMenuGlyphText}" />
                                <TextBlock Text="Favorite" Style="{StaticResource ContextMenuLabelText}" />
                            </StackPanel>
                        </Button>

                        <Button Style="{StaticResource ContextMenuIconButton}"
                                Command="{Binding ToggleAddToPlaylistPopupCommand}" ToolTip="Add to Playlist">
                            <StackPanel>
                                <TextBlock Text="&#xE710;" Style="{StaticResource ContextMenuGlyphText}" />
                                <TextBlock Text="Playlist" Style="{StaticResource ContextMenuLabelText}" />
                            </StackPanel>
                        </Button>

                        <Button Style="{StaticResource ContextMenuIconButton}"
                                Command="{Binding BulkHideCommand}" ToolTip="Hide">
                            <StackPanel>
                                <TextBlock Text="&#xE7B3;" Style="{StaticResource ContextMenuGlyphText}" />
                                <TextBlock Text="Hide" Style="{StaticResource ContextMenuLabelText}" />
                            </StackPanel>
                        </Button>

                        <Button Style="{StaticResource ContextMenuIconButton}"
                                Command="{Binding BulkDeleteCommand}" ToolTip="Delete">
                            <StackPanel>
                                <TextBlock Text="&#xE74D;" Style="{StaticResource ContextMenuGlyphText}" />
                                <TextBlock Text="Delete" Style="{StaticResource ContextMenuLabelText}" />
                            </StackPanel>
                        </Button>
                    </StackPanel>
                    </Grid>
                </Border>
            </Popup>

            <!-- İkinci satır (overflow): Re-match Metadata + Playlist'e Ekle. Ayrı bir Popup —
                 birinci kapsülün altına, aynı fare noktasına göre açılır. -->
            <Popup Placement="MousePoint" IsOpen="{Binding IsContextMenuOverflowOpen}"
                   StaysOpen="False" AllowsTransparency="True" VerticalOffset="52">
                <Border CornerRadius="24" Padding="8,6" Background="{StaticResource Brush.Background.Elevated}"
                        BorderBrush="{StaticResource Brush.Border}" BorderThickness="1">
                    <Border.Effect>
                        <DropShadowEffect BlurRadius="16" ShadowDepth="2" Opacity="0.4" Color="Black" />
                    </Border.Effect>
                    <StackPanel Orientation="Horizontal" DataContext="{Binding ContextMenuGame}">
                        <Button Style="{StaticResource ContextMenuIconButton}"
                                Command="{Binding DataContext.ReMatchMetadataCommand, RelativeSource={RelativeSource AncestorType=Window}}"
                                CommandParameter="{Binding}" ToolTip="Re-match Metadata">
                            <StackPanel>
                                <TextBlock Text="&#xE72C;" Style="{StaticResource ContextMenuGlyphText}" />
                                <TextBlock Text="Re-match" Style="{StaticResource ContextMenuLabelText}" />
                            </StackPanel>
                        </Button>
                        <Button Style="{StaticResource ContextMenuIconButton}"
                                Command="{Binding DataContext.ToggleAddToPlaylistPopupCommand, RelativeSource={RelativeSource AncestorType=Window}}"
                                ToolTip="Add to Playlist">
                            <StackPanel>
                                <TextBlock Text="&#xE710;" Style="{StaticResource ContextMenuGlyphText}" />
                                <TextBlock Text="Playlist" Style="{StaticResource ContextMenuLabelText}" />
                            </StackPanel>
                        </Button>
                    </StackPanel>
                </Border>
            </Popup>

            <!-- "Playlist'e Ekle" alt popup'ı: mevcut playlist'lerin checklist'i (chip filtre
                 dropdown'larıyla aynı görsel dil). -->
            <Popup Placement="MousePoint" IsOpen="{Binding IsAddToPlaylistPopupOpen}" StaysOpen="False"
                   AllowsTransparency="True" VerticalOffset="52">
                <Border CornerRadius="8" Padding="8" MinWidth="170" Background="{StaticResource Brush.Background.Elevated}"
                        BorderBrush="{StaticResource Brush.Border}" BorderThickness="1">
                    <StackPanel>
                        <ItemsControl ItemsSource="{Binding PlaylistChips}">
                            <ItemsControl.ItemTemplate>
                                <DataTemplate DataType="{x:Type models:PlaylistChip}">
                                    <Button Command="{Binding DataContext.AddGameToPlaylistCommand, RelativeSource={RelativeSource AncestorType=Window}}"
                                            CommandParameter="{Binding}"
                                            Background="Transparent" BorderThickness="0" HorizontalContentAlignment="Left"
                                            Padding="4,3" Cursor="Hand">
                                        <Button.Style>
                                            <Style TargetType="Button" BasedOn="{StaticResource {x:Type Button}}">
                                                <Setter Property="Visibility" Value="Visible" />
                                                <Style.Triggers>
                                                    <DataTrigger Binding="{Binding Kind}" Value="Hidden">
                                                        <Setter Property="Visibility" Value="Collapsed" />
                                                    </DataTrigger>
                                                    <DataTrigger Binding="{Binding Kind}" Value="RecycleBin">
                                                        <Setter Property="Visibility" Value="Collapsed" />
                                                    </DataTrigger>
                                                </Style.Triggers>
                                            </Style>
                                        </Button.Style>
                                        <StackPanel Orientation="Horizontal">
                                            <Ellipse Width="8" Height="8" Fill="{Binding Color}" VerticalAlignment="Center" Margin="0,0,6,0" />
                                            <TextBlock Text="{Binding Name}" FontSize="11" Foreground="{StaticResource Brush.Text.Primary}" />
                                        </StackPanel>
                                    </Button>
                                </DataTemplate>
                            </ItemsControl.ItemTemplate>
                        </ItemsControl>

                        <!-- "+ Yeni Playlist": oluşturur ve o anki seçimi (tekil/toplu) hemen içine
                             ekler — bkz. MainViewModel.CreatePlaylistAndAddSelectionCommand. -->
                        <Separator Margin="0,4" Background="{StaticResource Brush.Border}" />
                        <Grid Margin="2">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*" />
                                <ColumnDefinition Width="Auto" />
                            </Grid.ColumnDefinitions>
                            <TextBox Grid.Column="0" FontSize="11" Margin="0,0,4,0"
                                     Text="{Binding NewPlaylistName, UpdateSourceTrigger=PropertyChanged}">
                                <TextBox.InputBindings>
                                    <KeyBinding Key="Enter" Command="{Binding CreatePlaylistAndAddSelectionCommand}" />
                                </TextBox.InputBindings>
                            </TextBox>
                            <Button Grid.Column="1" Content="+ Yeni" FontSize="10" Padding="6,2"
                                    Command="{Binding CreatePlaylistAndAddSelectionCommand}" />
                        </Grid>
                    </StackPanel>
                </Border>
            </Popup>

            <!-- Right: Detail pane. Ayrı bir Visibility binding'ine gerek yok — Grid.Column="3"
                 genişliği 0'a indiğinde (bkz. ColumnDefinition) içerik zaten tamamen kırpılıyor.
                 Aç/kapa artık üst istatistik çubuğundaki tam ekran ikonuyla yapılıyor. -->
            <Border Grid.Column="3" Background="{StaticResource Brush.Background.Panel}">
                <Grid Margin="12">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="*" />
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="140" />
                        <RowDefinition Height="Auto" />
                    </Grid.RowDefinitions>

                    <Border Grid.Row="0" Height="200" CornerRadius="4" Background="{StaticResource Brush.Background.Elevated}">
                        <TextBlock Text="{Binding SelectedGame.Title}" TextWrapping="Wrap" TextAlignment="Center"
                                   FontSize="20" FontWeight="Bold" VerticalAlignment="Center" Margin="16" />
                    </Border>

                    <StackPanel Grid.Row="1" Orientation="Horizontal" HorizontalAlignment="Center" Margin="0,8,0,10">
                        <TextBlock Text="{Binding SelectedGame.StatusOk, Converter={StaticResource BoolToStatusGlyph}}"
                                   FontFamily="Segoe MDL2 Assets"
                                   Foreground="{Binding SelectedGame.StatusOk, Converter={StaticResource BoolToStatusBrush}}"
                                   Margin="0,0,8,0" />
                        <TextBlock Text="{Binding SelectedGame.HasBox, Converter={StaticResource BoolToStatusGlyph}}"
                                   FontFamily="Segoe MDL2 Assets"
                                   Foreground="{Binding SelectedGame.HasBox, Converter={StaticResource BoolToStatusBrush}}"
                                   Margin="0,0,8,0" />
                        <TextBlock Text="{Binding SelectedGame.HasBackground, Converter={StaticResource BoolToStatusGlyph}}"
                                   FontFamily="Segoe MDL2 Assets"
                                   Foreground="{Binding SelectedGame.HasBackground, Converter={StaticResource BoolToStatusBrush}}"
                                   Margin="0,0,8,0" />
                        <TextBlock Text="{Binding SelectedGame.HasScreenshot, Converter={StaticResource BoolToStatusGlyph}}"
                                   FontFamily="Segoe MDL2 Assets"
                                   Foreground="{Binding SelectedGame.HasScreenshot, Converter={StaticResource BoolToStatusBrush}}" />
                    </StackPanel>

                    <ScrollViewer Grid.Row="2" VerticalScrollBarVisibility="Auto">
                        <StackPanel>
                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="100" />
                                    <ColumnDefinition Width="*" />
                                </Grid.ColumnDefinitions>
                                <Grid.RowDefinitions>
                                    <RowDefinition Height="Auto" />
                                    <RowDefinition Height="Auto" />
                                    <RowDefinition Height="Auto" />
                                    <RowDefinition Height="Auto" />
                                    <RowDefinition Height="Auto" />
                                    <RowDefinition Height="Auto" />
                                    <RowDefinition Height="Auto" />
                                    <RowDefinition Height="Auto" />
                                    <RowDefinition Height="Auto" />
                                    <RowDefinition Height="Auto" />
                                </Grid.RowDefinitions>

                                <Label Grid.Row="0" Grid.Column="0" Content="Başlık" />
                                <TextBlock Grid.Row="0" Grid.Column="1" Text="{Binding SelectedGame.Title}" Margin="0,3" TextWrapping="Wrap" />

                                <Label Grid.Row="1" Grid.Column="0" Content="Platform" />
                                <TextBlock Grid.Row="1" Grid.Column="1" Text="{Binding SelectedGame.Platform}" Margin="0,3" />

                                <Label Grid.Row="2" Grid.Column="0" Content="Çıkış Tarihi" />
                                <TextBlock Grid.Row="2" Grid.Column="1" Text="{Binding SelectedGame.ReleaseYear}" Margin="0,3" />

                                <Label Grid.Row="3" Grid.Column="0" Content="Geliştirici" />
                                <TextBlock Grid.Row="3" Grid.Column="1" Text="{Binding SelectedGame.Developer}" Margin="0,3" />

                                <Label Grid.Row="4" Grid.Column="0" Content="Yayıncı" />
                                <TextBlock Grid.Row="4" Grid.Column="1" Text="{Binding SelectedGame.Publisher}" Margin="0,3" />

                                <Label Grid.Row="5" Grid.Column="0" Content="Tür" />
                                <TextBlock Grid.Row="5" Grid.Column="1" Text="{Binding SelectedGame.Genres}" Margin="0,3" TextWrapping="Wrap" />

                                <Label Grid.Row="6" Grid.Column="0" Content="Oyun modu" />
                                <TextBlock Grid.Row="6" Grid.Column="1" Text="{Binding SelectedGame.GameMode}" Margin="0,3" />

                                <Label Grid.Row="7" Grid.Column="0" Content="Maks. Oyuncu" />
                                <TextBlock Grid.Row="7" Grid.Column="1" Text="{Binding SelectedGame.MaxPlayers}" Margin="0,3" />

                                <Label Grid.Row="8" Grid.Column="0" Content="Sürüm" />
                                <TextBlock Grid.Row="8" Grid.Column="1" Text="{Binding SelectedGame.Version}" Margin="0,3" />

                                <Label Grid.Row="9" Grid.Column="0" Content="File" />
                                <TextBlock Grid.Row="9" Grid.Column="1" Text="{Binding SelectedGame.File}" Margin="0,3" TextWrapping="Wrap" />
                            </Grid>

                            <TextBlock Text="{Binding SelectedGame.Description}" TextWrapping="Wrap" Margin="0,10,0,0"
                                       Foreground="{StaticResource Brush.Text.Secondary}" FontSize="11" />

                            <TextBlock Text="Sürümler (Region)" FontWeight="Bold" Margin="0,14,0,4"
                                       Foreground="{StaticResource Brush.Text.Secondary}" FontSize="11" />
                            <ItemsControl ItemsSource="{Binding SelectedGameVersions}">
                                <ItemsControl.ItemTemplate>
                                    <DataTemplate>
                                        <Border Background="{StaticResource Brush.Background.Elevated}"
                                                CornerRadius="4" Padding="8" Margin="0,0,0,6">
                                            <StackPanel>
                                                <StackPanel Orientation="Horizontal">
                                                    <TextBlock Text="{Binding Region}" FontWeight="Bold" FontSize="11" />
                                                    <TextBlock Text="{Binding VersionLabel}" Margin="6,0,0,0" FontSize="11"
                                                               Foreground="{StaticResource Brush.Text.Secondary}" />
                                                    <TextBlock Text="★ Preferred" Margin="6,0,0,0" FontSize="10">
                                                        <TextBlock.Style>
                                                            <Style TargetType="TextBlock">
                                                                <Setter Property="Visibility" Value="Collapsed" />
                                                                <Style.Triggers>
                                                                    <DataTrigger Binding="{Binding IsPreferred}" Value="True">
                                                                        <Setter Property="Visibility" Value="Visible" />
                                                                    </DataTrigger>
                                                                </Style.Triggers>
                                                            </Style>
                                                        </TextBlock.Style>
                                                    </TextBlock>

                                                    <!-- Zaten preferred olan sürümde gösterilmiyor — RetroAuditUserData.db'ye
                                                         yazan override (bkz. MainViewModel.SetPreferredVersionCommand). -->
                                                    <Button Content="Preferred yap" FontSize="9" Padding="4,1" Margin="8,0,0,0"
                                                            Command="{Binding DataContext.SetPreferredVersionCommand, RelativeSource={RelativeSource AncestorType=Window}}"
                                                            CommandParameter="{Binding}">
                                                        <Button.Style>
                                                            <Style TargetType="Button" BasedOn="{StaticResource {x:Type Button}}">
                                                                <Setter Property="Visibility" Value="Visible" />
                                                                <Style.Triggers>
                                                                    <DataTrigger Binding="{Binding IsPreferred}" Value="True">
                                                                        <Setter Property="Visibility" Value="Collapsed" />
                                                                    </DataTrigger>
                                                                </Style.Triggers>
                                                            </Style>
                                                        </Button.Style>
                                                    </Button>
                                                </StackPanel>
                                                <TextBlock Text="{Binding SourceDat}" FontSize="10" Margin="0,2,0,0"
                                                           Foreground="{StaticResource Brush.Text.Secondary}" />
                                                <ItemsControl ItemsSource="{Binding Hashes}" Margin="0,4,0,0">
                                                    <ItemsControl.ItemTemplate>
                                                        <DataTemplate>
                                                            <TextBlock FontSize="10" TextWrapping="Wrap"
                                                                       Foreground="{StaticResource Brush.Text.Secondary}">
                                                                <Run Text="{Binding FileName, Mode=OneWay}" />
                                                                <Run Text=" · CRC32: " />
                                                                <Run Text="{Binding Crc32, Mode=OneWay}" />
                                                            </TextBlock>
                                                        </DataTemplate>
                                                    </ItemsControl.ItemTemplate>
                                                </ItemsControl>
                                            </StackPanel>
                                        </Border>
                                    </DataTemplate>
                                </ItemsControl.ItemTemplate>
                            </ItemsControl>
                        </StackPanel>
                    </ScrollViewer>

                    <Border Grid.Row="4" CornerRadius="4" Background="{StaticResource Brush.Background.Elevated}" Margin="0,10">
                        <TextBlock Text="Oynanış Önizleme" HorizontalAlignment="Center" VerticalAlignment="Center"
                                   Foreground="{StaticResource Brush.Text.Secondary}" FontSize="11" />
                    </Border>

                    <Button Grid.Row="5" Content="BAŞLAT" Style="{StaticResource LaunchButton}"
                            Command="{Binding LaunchCommand}" />
                </Grid>
            </Border>
        </Grid>
    </Grid>
</Window>
