<Window x:Class="RetroAudit.Views.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:conv="clr-namespace:RetroAudit.Converters"
        xmlns:vm="clr-namespace:RetroAudit.ViewModels"
        xmlns:models="clr-namespace:RetroAudit.Models"
        Title="RetroAudit" Height="820" Width="1400" WindowStartupLocation="CenterScreen">

    <Window.DataContext>
        <vm:MainViewModel />
    </Window.DataContext>

    <Window.Resources>
        <conv:BoolToStatusBrushConverter x:Key="BoolToStatusBrush" />
        <conv:BoolToStatusGlyphConverter x:Key="BoolToStatusGlyph" />
    </Window.Resources>

    <Grid Background="{StaticResource Brush.Background.Base}">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
        </Grid.RowDefinitions>

        <!-- ===================== Toolbar ===================== -->
        <Border Grid.Row="0" Background="{StaticResource Brush.Background.Panel}"
                BorderBrush="{StaticResource Brush.Border}" BorderThickness="0,0,0,1" Padding="8">
            <DockPanel>
                <StackPanel DockPanel.Dock="Right" Orientation="Horizontal" VerticalAlignment="Center">
                    <TextBlock Text="Satır:" VerticalAlignment="Center" Margin="12,0,4,0" Foreground="{StaticResource Brush.Text.Secondary}" />
                    <Slider Minimum="20" Maximum="60" Width="90" VerticalAlignment="Center" Value="{Binding RowHeight}" />
                    <TextBlock Text="{Binding RowHeight, StringFormat={}{0:0}}" Width="24" VerticalAlignment="Center" Margin="4,0,12,0" />
                    <TextBlock Text="Obsidyen" VerticalAlignment="Center" Foreground="{StaticResource Brush.Text.Secondary}" FontStyle="Italic" />
                </StackPanel>

                <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                    <Button Content="Import" Command="{Binding ImportCommand}" Margin="0,0,6,0" />
                    <Button Content="Rescan" Command="{Binding RescanCommand}" Margin="0,0,6,0" />
                    <Button Content="Temizle" Command="{Binding ClearFiltersCommand}" Margin="0,0,6,0" />
                    <Button Content="Refresh Media" Command="{Binding RefreshMediaCommand}" Margin="0,0,6,0" />
                    <Button Content="Metadata Yenile" Command="{Binding MetadataRefreshCommand}" Margin="0,0,6,0" />
                    <Button Content="LB Taşı" Command="{Binding LbTasiCommand}" Margin="0,0,14,0" />

                    <!-- "Tools" menüsü bir seçim kutusu gibi görünse de aslında bir eylem tetikleyicisi:
                         seçilen öğe MainViewModel.OnSelectedToolActionChanged içinde işlenip ilgili
                         pencere açılır, ardından seçim otomatik olarak "Tools" placeholder'ına döner. -->
                    <ComboBox Width="90" Margin="0,0,6,0" ItemsSource="{Binding ToolMenuItems}"
                              SelectedItem="{Binding SelectedToolAction}" />
                    <ComboBox Width="110" Margin="0,0,14,0" SelectedIndex="0">
                        <ComboBoxItem Content="Filter: All" />
                        <ComboBoxItem Content="Filter: Missing Box" />
                        <ComboBoxItem Content="Filter: Missing BG" />
                        <ComboBoxItem Content="Filter: Missing SS" />
                    </ComboBox>

                    <!-- WPF TextBox'ın yerleşik bir "placeholder" özelliği olmadığından, arama kutusu
                         boşken üzerine bindirilen bir TextBlock ile "Ara..." ipucu simüle ediliyor.
                         TextBlock IsHitTestVisible="False" olduğu için fare tıklamalarını etkilemez. -->
                    <Grid Width="220" Margin="0,0,14,0">
                        <TextBox VerticalContentAlignment="Center"
                                 Text="{Binding SearchText, UpdateSourceTrigger=PropertyChanged}" />
                        <TextBlock Text="Ara... (Boş alan için)" IsHitTestVisible="False"
                                   VerticalAlignment="Center" Margin="10,0,0,0"
                                   Foreground="{StaticResource Brush.Text.Secondary}">
                            <TextBlock.Style>
                                <Style TargetType="TextBlock">
                                    <Setter Property="Visibility" Value="Collapsed" />
                                    <Style.Triggers>
                                        <DataTrigger Binding="{Binding SearchText}" Value="">
                                            <Setter Property="Visibility" Value="Visible" />
                                        </DataTrigger>
                                    </Style.Triggers>
                                </Style>
                            </TextBlock.Style>
                        </TextBlock>
                    </Grid>

                    <ToggleButton Content="Released" IsChecked="{Binding ShowReleased}" Margin="0,0,4,0" />
                    <ToggleButton Content="Junk" IsChecked="{Binding ShowJunk}" Margin="0,0,14,0" />

                    <Button Content="Apply Resolver" Command="{Binding ApplyResolverCommand}" />
                </StackPanel>
            </DockPanel>
        </Border>

        <!-- ===================== Stats bar ===================== -->
        <Border Grid.Row="1" Background="{StaticResource Brush.Background.Base}"
                BorderBrush="{StaticResource Brush.Border}" BorderThickness="0,0,0,1" Padding="10,4">
            <TextBlock Foreground="{StaticResource Brush.Text.Secondary}" FontSize="11">
                <Run Text="Görünen:" /><Run Text=" " /><Run Text="{Binding VisibleCount, Mode=OneWay}" />
                <Run Text="  |  Toplam:" /><Run Text=" " /><Run Text="{Binding TotalCount, Mode=OneWay}" />
            </TextBlock>
        </Border>

        <!-- ===================== Body ===================== -->
        <Grid Grid.Row="2">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="220" />
                <ColumnDefinition Width="Auto" />
                <ColumnDefinition Width="*" />
                <ColumnDefinition Width="Auto" />
                <ColumnDefinition Width="340" />
            </Grid.ColumnDefinitions>

            <!-- Left: Platforms -->
            <Border Grid.Column="0" Background="{StaticResource Brush.Background.Panel}">
                <DockPanel>
                    <TextBlock DockPanel.Dock="Top" Text="Platforms" FontWeight="Bold" Margin="10,10,10,6"
                               Foreground="{StaticResource Brush.Text.Primary}" />
                    <ListBox ItemsSource="{Binding Platforms}" SelectedItem="{Binding SelectedPlatform}"
                             ScrollViewer.HorizontalScrollBarVisibility="Disabled">
                        <ListBox.ItemTemplate>
                            <DataTemplate DataType="{x:Type models:Platform}">
                                <Grid>
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="34" />
                                        <ColumnDefinition Width="*" />
                                        <ColumnDefinition Width="Auto" />
                                    </Grid.ColumnDefinitions>
                                    <Border Grid.Column="0" Width="28" Height="28" CornerRadius="4"
                                            Background="{StaticResource Brush.Background.Elevated}">
                                        <TextBlock Text="{Binding IconGlyph}" FontSize="8" FontWeight="Bold"
                                                   HorizontalAlignment="Center" VerticalAlignment="Center"
                                                   Foreground="{StaticResource Brush.Text.Secondary}" />
                                    </Border>
                                    <TextBlock Grid.Column="1" Text="{Binding Name}" VerticalAlignment="Center"
                                               Margin="8,0,4,0" TextTrimming="CharacterEllipsis" />
                                    <Border Grid.Column="2" Background="{StaticResource Brush.Background.Elevated}"
                                            CornerRadius="8" Padding="6,1" VerticalAlignment="Center">
                                        <TextBlock Text="{Binding GameCount}" FontSize="10"
                                                   Foreground="{StaticResource Brush.Text.Secondary}" />
                                    </Border>
                                </Grid>
                            </DataTemplate>
                        </ListBox.ItemTemplate>
                    </ListBox>
                </DockPanel>
            </Border>

            <GridSplitter Grid.Column="1" Width="1" HorizontalAlignment="Stretch"
                          Background="{StaticResource Brush.Border}" />

            <!-- Center: Game grid.
                 Sanallaştırma (virtualization) özellikleri, binlerce satırlık gerçek verilerle
                 kullanıldığında kaydırma sırasında kasmayı önlemek için bilinçli olarak açık:
                 sadece ekranda görünen satırlar için UI elemanı oluşturulur, kaydırırken
                 elemanlar oluşturulup atılmak yerine "Recycling" moduyla yeniden kullanılır. -->
            <DataGrid Grid.Column="2"
                      ItemsSource="{Binding Games}"
                      SelectedItem="{Binding SelectedGame}"
                      RowHeight="{Binding RowHeight}"
                      EnableRowVirtualization="True"
                      EnableColumnVirtualization="True"
                      VirtualizingPanel.IsVirtualizing="True"
                      VirtualizingPanel.VirtualizationMode="Recycling"
                      ScrollViewer.CanContentScroll="True">
                <DataGrid.Columns>
                    <DataGridTemplateColumn Header="" Width="34">
                        <DataGridTemplateColumn.CellTemplate>
                            <DataTemplate DataType="{x:Type models:Game}">
                                <TextBlock Text="{Binding StatusOk, Converter={StaticResource BoolToStatusGlyph}}"
                                           FontFamily="Segoe MDL2 Assets"
                                           Foreground="{Binding StatusOk, Converter={StaticResource BoolToStatusBrush}}"
                                           HorizontalAlignment="Center" />
                            </DataTemplate>
                        </DataGridTemplateColumn.CellTemplate>
                    </DataGridTemplateColumn>

                    <DataGridTemplateColumn Header="Logo" Width="44">
                        <DataGridTemplateColumn.CellTemplate>
                            <DataTemplate DataType="{x:Type models:Game}">
                                <Border Width="28" Height="28" CornerRadius="3" Background="{StaticResource Brush.Background.Elevated}" />
                            </DataTemplate>
                        </DataGridTemplateColumn.CellTemplate>
                    </DataGridTemplateColumn>

                    <DataGridTextColumn Header="Başlık" Binding="{Binding Title}" Width="2*" />

                    <DataGridTemplateColumn Header="Box" Width="40">
                        <DataGridTemplateColumn.CellTemplate>
                            <DataTemplate DataType="{x:Type models:Game}">
                                <Ellipse Width="10" Height="10" Fill="{Binding HasBox, Converter={StaticResource BoolToStatusBrush}}" />
                            </DataTemplate>
                        </DataGridTemplateColumn.CellTemplate>
                    </DataGridTemplateColumn>

                    <DataGridTemplateColumn Header="BG" Width="40">
                        <DataGridTemplateColumn.CellTemplate>
                            <DataTemplate DataType="{x:Type models:Game}">
                                <Ellipse Width="10" Height="10" Fill="{Binding HasBackground, Converter={StaticResource BoolToStatusBrush}}" />
                            </DataTemplate>
                        </DataGridTemplateColumn.CellTemplate>
                    </DataGridTemplateColumn>

                    <DataGridTemplateColumn Header="SS" Width="40">
                        <DataGridTemplateColumn.CellTemplate>
                            <DataTemplate DataType="{x:Type models:Game}">
                                <Ellipse Width="10" Height="10" Fill="{Binding HasScreenshot, Converter={StaticResource BoolToStatusBrush}}" />
                            </DataTemplate>
                        </DataGridTemplateColumn.CellTemplate>
                    </DataGridTemplateColumn>

                    <DataGridTextColumn Header="File" Binding="{Binding File}" Width="2*" />
                    <DataGridTextColumn Header="Platform" Binding="{Binding Platform}" Width="1.2*" />
                    <DataGridTextColumn Header="Sürüm" Binding="{Binding Version}" Width="1*" />
                    <DataGridTextColumn Header="Türler" Binding="{Binding Genres}" Width="1.6*" />
                </DataGrid.Columns>
            </DataGrid>

            <GridSplitter Grid.Column="3" Width="1" HorizontalAlignment="Stretch"
                          Background="{StaticResource Brush.Border}" />

            <!-- Right: Detail pane -->
            <Border Grid.Column="4" Background="{StaticResource Brush.Background.Panel}">
                <Grid Margin="12">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="*" />
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="140" />
                        <RowDefinition Height="Auto" />
                    </Grid.RowDefinitions>

                    <Border Grid.Row="0" Height="200" CornerRadius="4" Background="{StaticResource Brush.Background.Elevated}">
                        <TextBlock Text="{Binding SelectedGame.Title}" TextWrapping="Wrap" TextAlignment="Center"
                                   FontSize="20" FontWeight="Bold" VerticalAlignment="Center" Margin="16" />
                    </Border>

                    <StackPanel Grid.Row="1" Orientation="Horizontal" HorizontalAlignment="Center" Margin="0,8,0,10">
                        <TextBlock Text="{Binding SelectedGame.StatusOk, Converter={StaticResource BoolToStatusGlyph}}"
                                   FontFamily="Segoe MDL2 Assets"
                                   Foreground="{Binding SelectedGame.StatusOk, Converter={StaticResource BoolToStatusBrush}}"
                                   Margin="0,0,8,0" />
                        <TextBlock Text="{Binding SelectedGame.HasBox, Converter={StaticResource BoolToStatusGlyph}}"
                                   FontFamily="Segoe MDL2 Assets"
                                   Foreground="{Binding SelectedGame.HasBox, Converter={StaticResource BoolToStatusBrush}}"
                                   Margin="0,0,8,0" />
                        <TextBlock Text="{Binding SelectedGame.HasBackground, Converter={StaticResource BoolToStatusGlyph}}"
                                   FontFamily="Segoe MDL2 Assets"
                                   Foreground="{Binding SelectedGame.HasBackground, Converter={StaticResource BoolToStatusBrush}}"
                                   Margin="0,0,8,0" />
                        <TextBlock Text="{Binding SelectedGame.HasScreenshot, Converter={StaticResource BoolToStatusGlyph}}"
                                   FontFamily="Segoe MDL2 Assets"
                                   Foreground="{Binding SelectedGame.HasScreenshot, Converter={StaticResource BoolToStatusBrush}}" />
                    </StackPanel>

                    <ScrollViewer Grid.Row="2" VerticalScrollBarVisibility="Auto">
                        <StackPanel>
                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="100" />
                                    <ColumnDefinition Width="*" />
                                </Grid.ColumnDefinitions>
                                <Grid.RowDefinitions>
                                    <RowDefinition Height="Auto" />
                                    <RowDefinition Height="Auto" />
                                    <RowDefinition Height="Auto" />
                                    <RowDefinition Height="Auto" />
                                    <RowDefinition Height="Auto" />
                                    <RowDefinition Height="Auto" />
                                    <RowDefinition Height="Auto" />
                                    <RowDefinition Height="Auto" />
                                    <RowDefinition Height="Auto" />
                                    <RowDefinition Height="Auto" />
                                </Grid.RowDefinitions>

                                <Label Grid.Row="0" Grid.Column="0" Content="Başlık" />
                                <TextBlock Grid.Row="0" Grid.Column="1" Text="{Binding SelectedGame.Title}" Margin="0,3" TextWrapping="Wrap" />

                                <Label Grid.Row="1" Grid.Column="0" Content="Platform" />
                                <TextBlock Grid.Row="1" Grid.Column="1" Text="{Binding SelectedGame.Platform}" Margin="0,3" />

                                <Label Grid.Row="2" Grid.Column="0" Content="Çıkış Tarihi" />
                                <TextBlock Grid.Row="2" Grid.Column="1" Text="{Binding SelectedGame.ReleaseYear}" Margin="0,3" />

                                <Label Grid.Row="3" Grid.Column="0" Content="Geliştirici" />
                                <TextBlock Grid.Row="3" Grid.Column="1" Text="{Binding SelectedGame.Developer}" Margin="0,3" />

                                <Label Grid.Row="4" Grid.Column="0" Content="Yayıncı" />
                                <TextBlock Grid.Row="4" Grid.Column="1" Text="{Binding SelectedGame.Publisher}" Margin="0,3" />

                                <Label Grid.Row="5" Grid.Column="0" Content="Tür" />
                                <TextBlock Grid.Row="5" Grid.Column="1" Text="{Binding SelectedGame.Genres}" Margin="0,3" TextWrapping="Wrap" />

                                <Label Grid.Row="6" Grid.Column="0" Content="Oyun modu" />
                                <TextBlock Grid.Row="6" Grid.Column="1" Text="{Binding SelectedGame.GameMode}" Margin="0,3" />

                                <Label Grid.Row="7" Grid.Column="0" Content="Maks. Oyuncu" />
                                <TextBlock Grid.Row="7" Grid.Column="1" Text="{Binding SelectedGame.MaxPlayers}" Margin="0,3" />

                                <Label Grid.Row="8" Grid.Column="0" Content="Sürüm" />
                                <TextBlock Grid.Row="8" Grid.Column="1" Text="{Binding SelectedGame.Version}" Margin="0,3" />

                                <Label Grid.Row="9" Grid.Column="0" Content="File" />
                                <TextBlock Grid.Row="9" Grid.Column="1" Text="{Binding SelectedGame.File}" Margin="0,3" TextWrapping="Wrap" />
                            </Grid>

                            <TextBlock Text="{Binding SelectedGame.Description}" TextWrapping="Wrap" Margin="0,10,0,0"
                                       Foreground="{StaticResource Brush.Text.Secondary}" FontSize="11" />
                        </StackPanel>
                    </ScrollViewer>

                    <Border Grid.Row="4" CornerRadius="4" Background="{StaticResource Brush.Background.Elevated}" Margin="0,10">
                        <TextBlock Text="Oynanış Önizleme" HorizontalAlignment="Center" VerticalAlignment="Center"
                                   Foreground="{StaticResource Brush.Text.Secondary}" FontSize="11" />
                    </Border>

                    <Button Grid.Row="5" Content="BAŞLAT" Style="{StaticResource LaunchButton}"
                            Command="{Binding LaunchCommand}" />
                </Grid>
            </Border>
        </Grid>
    </Grid>
</Window>
