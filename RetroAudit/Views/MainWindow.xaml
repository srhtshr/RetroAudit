<Window x:Class="RetroAudit.Views.MainWindow"
        x:Name="RootWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:conv="clr-namespace:RetroAudit.Converters"
        xmlns:vm="clr-namespace:RetroAudit.ViewModels"
        xmlns:models="clr-namespace:RetroAudit.Models"
        xmlns:views="clr-namespace:RetroAudit.Views"
        xmlns:shell="clr-namespace:System.Windows.Shell;assembly=PresentationFramework"
        xmlns:wv2="clr-namespace:Microsoft.Web.WebView2.Wpf;assembly=Microsoft.Web.WebView2.Wpf"
        Title="RetroAudit" Height="820" Width="1400" WindowStartupLocation="CenterScreen"
        Background="{StaticResource Brush.Background.Base}">

    <!-- Özel (custom-drawn) başlık çubuğu: Windows 10'da native title bar'ı uygulamanın kendi
         Obsidian rengiyle (#252526) boyayan bir DWM API'si yok (DWMWA_CAPTION_COLOR sadece
         Windows 11 22H2+'ta var — bkz. DarkTitleBarHelper.cs), bu yüzden kullanıcı kararıyla
         başlık çubuğu elle çiziliyor. WindowChrome, WindowStyle="None" GEREKMEDEN native
         chrome'un render'ını bastırıp CaptionHeight kadarlık üst şeridi Win32'nin kendi
         "caption" hit-test bölgesi yapıyor — bu sayede sürükle-taşı, çift tık ile büyüt/eski
         hâle getir, sağ tık sistem menüsü ve Aero Snap TAMAMEN NATIVE Win32 mekanizmasıyla
         (elle yeniden yazılmadan) çalışmaya devam ediyor. UseAeroCaptionButtons="False": aksi
         halde WindowChrome kendi min/maks/kapat düğmelerini de üstüne bindirmeye çalışırdı.
         Aşağıdaki CustomTitleBarButton düğmeleri WindowChrome.IsHitTestVisibleInChrome="True"
         ile bu caption bölgesinden hariç tutuluyor ki tıklanabilir kalsınlar. -->
    <shell:WindowChrome.WindowChrome>
        <shell:WindowChrome CaptionHeight="32" ResizeBorderThickness="6"
                             GlassFrameThickness="0" CornerRadius="0"
                             UseAeroCaptionButtons="False" />
    </shell:WindowChrome.WindowChrome>

    <Window.DataContext>
        <vm:MainViewModel />
    </Window.DataContext>

    <Window.Resources>
        <conv:BoolToStatusBrushConverter x:Key="BoolToStatusBrush" />
        <conv:BoolToStatusGlyphConverter x:Key="BoolToStatusGlyph" />
        <conv:BoolToVisibilityConverter x:Key="BoolToVisibility" />
        <conv:CountToVisibilityConverter x:Key="CountToVisibility" />
        <conv:PercentageToWidthConverter x:Key="PercentageToWidth" />
        <conv:RegionToFlagConverter x:Key="RegionToFlag" />
        <conv:ThumbnailImageConverter x:Key="ThumbnailImage" />

        <!-- NOT: Aşağıdaki üç stil (ActionsIconButton/DarkMenuItem/CapsuleContextMenu) BİLİNÇLİ
             OLARAK burada, dosyanın en başında tanımlı — VersionCardItemTemplate (birazdan
             aşağıda) bunları kullanıyor ve WPF, StaticResource için AYNI ResourceDictionary
             içinde GERİYE referans (forward reference) kabul etmiyor; DataTemplate/ControlTemplate
             içeriği gibi ERTELENMİŞ (deferred) XAML'de bu, sadece şablon gerçekten UYGULANDIĞINDA
             (ör. Sürümler listesi ilk kez render edilince) bir XamlParseException olarak patlıyor
             — derleme sırasında YAKALANMIYOR. Bu üç stil daha aşağıda (orijinal, temaya uygun
             yerlerinde) TEKRAR tanımlanmıyor; sadece BURAYA taşındı.
             (Kullanıcı geri bildirimi: "program kapanıyor / açılmıyor" — kök neden buydu.) -->
        <!-- Kullanıcı bulgusu: "tam ekranken ... takılma" — bu buton her satırda 3-4 kez (Favori/
             Görsel Getir/Ara-Başlat) oluşuyor; Focusable/IsTabStop kapatmak (bkz. GenreBadgeButton'daki
             AYNI gerekçe) WPF'in klavye gezinme/odak kapsamı hesaplarındaki gereksiz yükü azaltıyor. -->
        <Style x:Key="ActionsIconButton" TargetType="Button">
            <Setter Property="Background" Value="Transparent" />
            <Setter Property="BorderThickness" Value="0" />
            <Setter Property="Padding" Value="0" />
            <Setter Property="Cursor" Value="Hand" />
            <Setter Property="Width" Value="22" />
            <Setter Property="Height" Value="22" />
            <Setter Property="Focusable" Value="False" />
            <Setter Property="IsTabStop" Value="False" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="Bg" CornerRadius="11" Background="Transparent">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center" />
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="Bg" Property="Background" Value="{StaticResource Brush.Background.Hover}" />
                            </Trigger>
                            <Trigger Property="IsEnabled" Value="False">
                                <Setter Property="Opacity" Value="0.35" />
                                <Setter Property="Cursor" Value="Arrow" />
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="DarkMenuItem" TargetType="MenuItem">
            <Setter Property="Foreground" Value="{StaticResource Brush.Text.Primary}" />
            <Setter Property="Padding" Value="10,7" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="MenuItem">
                        <Border x:Name="Bg" CornerRadius="8" Background="Transparent" Padding="{TemplateBinding Padding}">
                            <StackPanel Orientation="Horizontal">
                                <ContentPresenter ContentSource="Icon" VerticalAlignment="Center" Margin="0,0,8,0" />
                                <ContentPresenter ContentSource="Header" VerticalAlignment="Center" RecognizesAccessKey="True"
                                                  TextElement.Foreground="{TemplateBinding Foreground}" />
                            </StackPanel>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsHighlighted" Value="True">
                                <Setter TargetName="Bg" Property="Background" Value="{StaticResource Brush.Background.Hover}" />
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="CapsuleContextMenu" TargetType="ContextMenu">
            <Setter Property="OverridesDefaultStyle" Value="True" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="ContextMenu">
                        <Border CornerRadius="24" Padding="8,6"
                                Background="{StaticResource Brush.Background.Elevated}"
                                BorderBrush="{StaticResource Brush.Border}" BorderThickness="1">
                            <Border.Effect>
                                <DropShadowEffect BlurRadius="16" ShadowDepth="2" Opacity="0.4" Color="Black" />
                            </Border.Effect>
                            <StackPanel IsItemsHost="True" />
                        </Border>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <!-- "YouTube'da İzle"/"Wikipedia" düğmelerindeki ikonlar — açık kaynak Material Design
             Icons setinden (Apache 2.0), sabit 24x24 viewbox'ta vektör path verisi. Raster
             (PNG) yerine vektör kullanmak DPI'dan bağımsız keskinlik sağlıyor ve ek dosya
             yönetimi gerektirmiyor. -->
        <Geometry x:Key="Icon.YouTube">M21.582,6.186c-0.23-0.86-0.908-1.538-1.768-1.768C18.254,4,12,4,12,4S5.746,4,4.186,4.418 c-0.86,0.23-1.538,0.908-1.768,1.768C2,7.746,2,12,2,12s0,4.254,0.418,5.814c0.23,0.86,0.908,1.538,1.768,1.768 C5.746,20,12,20,12,20s6.254,0,7.814-0.418c0.861-0.23,1.538-0.908,1.768-1.768C22,16.254,22,12,22,12S22,7.746,21.582,6.186z M10,14.598V9.402c0-0.385,0.417-0.625,0.75-0.433l4.5,2.598c0.333,0.192,0.333,0.674,0,0.866l-4.5,2.598 C10.417,15.224,10,14.983,10,14.598z</Geometry>
        <Geometry x:Key="Icon.Wikipedia">M19,3H5C3.9,3,3,3.9,3,5v14c0,1.1,0.9,2,2,2h14c1.1,0,2-0.9,2-2V5C21,3.9,20.1,3,19,3z M19.8,8.6c0,0.1-0.1,0.2-0.2,0.2h-0.9l-4.3,9.1c0,0.1-0.1,0.1-0.2,0.1c0,0,0,0,0,0c-0.1,0-0.1,0-0.2-0.1l-2-4l-2.2,4C9.9,18,9.8,18,9.8,18c-0.1,0-0.1,0-0.2-0.1L5.3,8.8h-1c-0.1,0-0.2-0.1-0.2-0.2V8.2C4.2,8.1,4.2,8,4.3,8h3.5C7.9,8,8,8.1,8,8.2v0.5c0,0.1-0.1,0.2-0.2,0.2H7.1l3,6.9l1.6-2.9l-2-4H9.2C9.1,8.8,9,8.7,9,8.6V8.2C9,8.1,9.1,8,9.2,8h2.6c0.1,0,0.2,0.1,0.2,0.2v0.5c0,0.1-0.1,0.2-0.2,0.2h-0.5l1.1,2.5l1.3-2.5h-0.8c-0.1,0-0.2-0.1-0.2-0.2V8.2c0-0.1,0.1-0.2,0.2-0.2h2.5c0.1,0,0.2,0.1,0.2,0.2v0.5c0,0.1-0.1,0.2-0.2,0.2h-0.5l-2,3.6l1.6,3.3l3.1-6.9h-1c-0.1,0-0.2-0.1-0.2-0.2V8.2c0-0.1,0.1-0.2,0.2-0.2h3c0.1,0,0.2,0.1,0.2,0.2V8.6z</Geometry>

        <!-- DataGridColumn.Header gibi görsel-ağaç-dışı alanların ViewModel'e erişebilmesi için
             (bkz. BindingProxy.cs) — Data, Window'un DataContext'ine (MainViewModel) bağlanır. -->
        <views:BindingProxy x:Key="ViewModelProxy" Data="{Binding}" />

        <!-- Sürüm kartı (GameVersion) görünümü — hem sağ detay panelindeki hem de sağ tık
             kapsülündeki "Versions" düğmesiyle açılan popup'taki ListBox'lar tarafından paylaşılır
             (bkz. MainWindow.xaml.cs VersionsList_MouseDoubleClick, ikisi de aynı handler'ı kullanır).
             Varsayılan ListBoxItem mavi seçim dikdörtgeni tamamen kaldırılıp seçim vurgusu karttaki
             Border'a bırakılıyor (bkz. IsSelected DataTrigger aşağıda). -->
        <Style x:Key="VersionCardItemContainerStyle" TargetType="ListBoxItem">
            <Setter Property="Padding" Value="0" />
            <Setter Property="Margin" Value="0,0,0,6" />
            <Setter Property="HorizontalContentAlignment" Value="Stretch" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="ListBoxItem">
                        <ContentPresenter />
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <DataTemplate x:Key="VersionCardItemTemplate">
            <Border Background="{StaticResource Brush.Background.Elevated}"
                    CornerRadius="4" Padding="8" Cursor="Hand">
                <Border.Style>
                    <Style TargetType="Border">
                        <Setter Property="BorderThickness" Value="0" />
                        <Style.Triggers>
                            <DataTrigger Binding="{Binding RelativeSource={RelativeSource AncestorType=ListBoxItem}, Path=IsSelected}" Value="True">
                                <Setter Property="BorderThickness" Value="2" />
                                <Setter Property="BorderBrush" Value="{StaticResource Brush.Accent.SelectedBorder}" />
                            </DataTrigger>
                        </Style.Triggers>
                    </Style>
                </Border.Style>
                <StackPanel>
                    <!-- Kompakt hale getirildi (kullanıcı isteği): SourceDat ("no-intro" vb.) artık
                         kendi satırı yerine bu üst satırın sağ üst köşesinde — Grid ile sol taraf
                         (ikon/Region/VersionLabel/Preferred) ve sağdaki SourceDat aynı satırda. -->
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="Auto" />
                        </Grid.ColumnDefinitions>
                        <StackPanel Grid.Column="0" Orientation="Horizontal">
                            <!-- Bu sürümün dosyası diskte var mı — mavi Play / kırmızı çarpı (bkz.
                                 MainViewModel.IsVersionOwned). Grid'deki Play/Search sütunuyla aynı
                                 mavi rengi kullanıyor, tutarlılık için. -->
                            <TextBlock FontFamily="Segoe MDL2 Assets" FontSize="11" Margin="0,0,4,0" VerticalAlignment="Center">
                                <TextBlock.ToolTip>
                                    <TextBlock Text="Manuel Bağlantı (Linked, doğrulanmamış)" Visibility="{Binding IsManuallyLinked, Converter={StaticResource BoolToVisibility}}" />
                                </TextBlock.ToolTip>
                                <TextBlock.Style>
                                    <Style TargetType="TextBlock">
                                        <Setter Property="Text" Value="&#xE711;" />
                                        <Setter Property="Foreground" Value="{StaticResource Brush.Status.Missing}" />
                                        <Style.Triggers>
                                            <DataTrigger Binding="{Binding IsOwned}" Value="True">
                                                <Setter Property="Text" Value="&#xE768;" />
                                                <Setter Property="Foreground" Value="{StaticResource Brush.Accent.SelectedBorder}" />
                                            </DataTrigger>
                                            <!-- Kullanıcı isteği: "manuel bağlanan kayıtlar ... detay
                                                 panelinde açıkça rozet gösterilsin" — bu sürüm
                                                 SPESİFİK olarak manuel bağlandıysa (bkz.
                                                 Game.IsManuallyLinked/GameVersion.IsManuallyLinked)
                                                 aynı ikon Amber'e döner, CRC doğrulanmış mavi ile
                                                 KARIŞTIRILMASIN diye. -->
                                            <DataTrigger Binding="{Binding IsManuallyLinked}" Value="True">
                                                <Setter Property="Foreground" Value="{StaticResource Brush.Accent.Amber}" />
                                            </DataTrigger>
                                        </Style.Triggers>
                                    </Style>
                                </TextBlock.Style>
                            </TextBlock>
                            <!-- Bölge bayrağı (bkz. FlagResolver/RegionToFlagConverter) — eşleşen bir
                                 bayrak dosyası yoksa Source null olur, Image basitçe boş kalır. -->
                            <Image Source="{Binding Region, Converter={StaticResource RegionToFlag}}"
                                   Width="14" Height="14" Margin="0,0,4,0" VerticalAlignment="Center"
                                   RenderOptions.BitmapScalingMode="HighQuality" />
                            <TextBlock Text="{Binding Region}" FontWeight="Bold" FontSize="11">
                                <TextBlock.Style>
                                    <Style TargetType="TextBlock">
                                        <Setter Property="Foreground" Value="{StaticResource Brush.Text.Primary}" />
                                        <Style.Triggers>
                                            <DataTrigger Binding="{Binding IsOwned}" Value="False">
                                                <Setter Property="Foreground" Value="{StaticResource Brush.Text.Secondary}" />
                                            </DataTrigger>
                                        </Style.Triggers>
                                    </Style>
                                </TextBlock.Style>
                            </TextBlock>
                            <TextBlock Text="{Binding VersionLabel}" Margin="6,0,0,0" FontSize="11"
                                       Foreground="{StaticResource Brush.Text.Secondary}" />
                            <TextBlock Text="★ Preferred" Margin="6,0,0,0" FontSize="10">
                                <TextBlock.Style>
                                    <Style TargetType="TextBlock">
                                        <Setter Property="Visibility" Value="Collapsed" />
                                        <Style.Triggers>
                                            <DataTrigger Binding="{Binding IsPreferred}" Value="True">
                                                <Setter Property="Visibility" Value="Visible" />
                                            </DataTrigger>
                                        </Style.Triggers>
                                    </Style>
                                </TextBlock.Style>
                            </TextBlock>
                        </StackPanel>
                        <StackPanel Grid.Column="1" Orientation="Horizontal" VerticalAlignment="Top">
                            <!-- Kullanıcı isteği: "manuel yazısını da play icondaki gibi sarı yap" —
                                 "manuel" etiketi (bkz. MainViewModel.LoadSelectedGameVersions,
                                 SourceDat="manuel" sadece manuel bağlanan sentetik kartlarda) Amber,
                                 diğer TÜM gerçek kartlardaki "no-intro" vb. gri kalır. -->
                            <TextBlock Text="{Binding SourceDat}" FontSize="10" Margin="6,0,0,0">
                                <TextBlock.Style>
                                    <Style TargetType="TextBlock">
                                        <Setter Property="Foreground" Value="{StaticResource Brush.Text.Secondary}" />
                                        <Style.Triggers>
                                            <DataTrigger Binding="{Binding IsManuallyLinked}" Value="True">
                                                <Setter Property="Foreground" Value="{StaticResource Brush.Accent.Amber}" />
                                            </DataTrigger>
                                        </Style.Triggers>
                                    </Style>
                                </TextBlock.Style>
                            </TextBlock>
                            <!-- Ayır (kullanıcı isteği: "kart içine ayırma butonu ekle bide kendi
                                 kartının üstünde olsun bağlı olanın") — SADECE bu sürüm manuel
                                 bağlandıysa görünür (bkz. MainViewModel.RemoveVersionLink), gerçek
                                 katalog eşleşmesi olan sıradan kartlarda hiç gösterilmez. -->
                            <Button Style="{StaticResource ActionsIconButton}" Width="20" Height="20" Margin="4,0,0,0"
                                    ToolTip="Ayır (bu bağlantıyı kaldır)"
                                    Visibility="{Binding IsManuallyLinked, Converter={StaticResource BoolToVisibility}}"
                                    Command="{Binding Data.RemoveVersionLinkCommand, Source={StaticResource ViewModelProxy}}"
                                    CommandParameter="{Binding}">
                                <TextBlock Text="&#xE738;" FontFamily="Segoe MDL2 Assets" FontSize="11" Foreground="{StaticResource Brush.Accent.Amber}" />
                            </Button>
                            <!-- ROM ara (bu SÜRÜME özgü) — kullanıcı isteği: "xyz sürümünü aradım,
                                 indirirken otomatik o isimle kayıt etsin" — bkz. MainViewModel.
                                 SearchRomForVersion, RomSearchWindow'un forcedFileName parametresi.
                                 DataContext burada zaten GameVersion olduğu için CommandParameter
                                 düz {Binding}; Command ise MainViewModel'de olduğundan ViewModelProxy
                                 üzerinden (bu Button normal görsel ağaçta, ContextMenu değil — ama
                                 DataContext'i yine de GameVersion'a scoped, MainViewModel'e değil). -->
                            <Button Style="{StaticResource ActionsIconButton}" Width="20" Height="20" Margin="4,0,0,0"
                                    ToolTip="ROM ara"
                                    Command="{Binding Data.SearchRomForVersionCommand, Source={StaticResource ViewModelProxy}}"
                                    CommandParameter="{Binding}">
                                <TextBlock Text="&#xE721;" FontFamily="Segoe MDL2 Assets" FontSize="11" Foreground="{StaticResource Brush.Text.Primary}" />
                            </Button>
                        </StackPanel>
                    </Grid>
                    <ItemsControl ItemsSource="{Binding Hashes}" Margin="0,4,0,0">
                        <ItemsControl.ItemTemplate>
                            <DataTemplate>
                                <TextBlock FontSize="10" TextWrapping="Wrap" Foreground="{StaticResource Brush.Text.Secondary}">
                                    <Run Text="{Binding FileName, Mode=OneWay}" />
                                    <Run Text=" · CRC32: " FontSize="8" />
                                    <Run Text="{Binding Crc32, Mode=OneWay}" FontSize="8" />
                                </TextBlock>
                            </DataTemplate>
                        </ItemsControl.ItemTemplate>
                    </ItemsControl>
                </StackPanel>
            </Border>
        </DataTemplate>

        <!-- Kullanıcı isteği: "filtreleme menüsünüde badge gibi yap text gibi değilde tıklamalı
             olsun ... gene aynı mantık" — filtre dropdown'larındaki (Durum, Platform, Türler, Actions
             popup'ındaki Favori/Durum grupları — hepsi) checkbox+metin satırlarının ORTAK yerini alan
             tıklanabilir hap/rozet şablonu. Tıklama mantığı ColumnFilterViewModel.ToggleOption'da (bkz.
             o yorum): el değmemişken (hepsi işaretli) tıklanan TEK başına kalır, sonraki tıklamalar
             diğerlerine dokunmadan çoklu seçime izin verir, hiçbiri kalmazsa hepsi geri işaretlenir.
             Border HorizontalAlignment="Stretch" ile popup genişliğini dolduruyor — önceden her rozet
             kendi metin uzunluğuna göre farklı genişlikte görünüyordu (kullanıcı isteği: "badge
             genişliklerini ayarla"), artık hepsi tekdüze. Command, DataContext'i FilterOption olan bu
             şablondan ItemsControl'ün KENDİ DataContext'ine (ilgili ColumnFilterViewModel örneği)
             AncestorType ile ulaşıyor — Actions popup'ındaki iki alt grup (Favori/Durum) için
             ItemsControl'ün DataContext'i doğrudan o alt filtreye bağlanmış olmalı (bkz. kullanım
             yerleri). -->
        <DataTemplate x:Key="FilterOptionBadgeTemplate" DataType="{x:Type models:FilterOption}">
            <Button Cursor="Hand" Margin="0,2" HorizontalAlignment="Stretch"
                    Command="{Binding DataContext.ToggleOptionCommand, RelativeSource={RelativeSource AncestorType=ItemsControl}}"
                    CommandParameter="{Binding}">
                <Button.Template>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="badge" CornerRadius="10" Padding="8,3"
                                Background="{StaticResource Brush.Background.Base}"
                                BorderBrush="{StaticResource Brush.Border}" BorderThickness="1">
                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*" />
                                    <ColumnDefinition Width="Auto" />
                                </Grid.ColumnDefinitions>
                                <TextBlock x:Name="badgeText" Grid.Column="0" FontSize="11" FontWeight="SemiBold"
                                           MaxWidth="140" TextTrimming="CharacterEllipsis"
                                           Foreground="{StaticResource Brush.Text.Secondary}"
                                           ToolTip="{Binding Value, Mode=OneWay}">
                                    <Run Text="{Binding Value, Mode=OneWay}" />
                                    <Run Text=" (" /><Run Text="{Binding Count, Mode=OneWay}" /><Run Text=")" />
                                </TextBlock>
                                <StackPanel Grid.Column="1" Margin="8,0,0,0" Width="54">
                                    <StackPanel.Style>
                                        <Style TargetType="StackPanel">
                                            <Setter Property="Visibility" Value="Collapsed" />
                                            <Style.Triggers>
                                                <DataTrigger Binding="{Binding HasHealthPercent}" Value="True">
                                                    <Setter Property="Visibility" Value="Visible" />
                                                </DataTrigger>
                                            </Style.Triggers>
                                        </Style>
                                    </StackPanel.Style>
                                    <TextBlock HorizontalAlignment="Right" FontSize="10" FontWeight="SemiBold"
                                               Foreground="{StaticResource Brush.Text.Secondary}">
                                        <Run Text="%" />
                                        <Run Text="{Binding HealthPercent}" />
                                    </TextBlock>
                                    <ProgressBar Minimum="0" Maximum="100" Height="4" Margin="0,4,0,0"
                                                 Value="{Binding HealthPercent}"
                                                 Foreground="{StaticResource Brush.Accent.SelectedBorder}"
                                                 Background="{StaticResource Brush.Background.Base}" />
                                </StackPanel>
                            </Grid>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="badge" Property="Background" Value="{StaticResource Brush.Background.Hover}" />
                            </Trigger>
                            <DataTrigger Binding="{Binding IsChecked}" Value="True">
                                <Setter TargetName="badge" Property="Background" Value="{StaticResource Brush.Accent.Launch}" />
                                <Setter TargetName="badge" Property="BorderThickness" Value="0" />
                                <Setter TargetName="badgeText" Property="Foreground" Value="White" />
                            </DataTrigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Button.Template>
            </Button>
        </DataTemplate>

        <!-- DataGrid sütun başlıklarında kullanılan ortak filtre şablonu. Header'a bir
             ColumnFilterViewModel atandığında (DataGridColumn.Header, ViewModelProxy üzerinden
             bağlanıyor — bkz. DataGrid.Columns) HeaderTemplate'in DataContext'i otomatik olarak bu
             nesne olur. Ayrı bir huni ikonu YOK — kullanıcı isteğiyle kaldırıldı; başlığın
             HERHANGİ bir yerine sol tıklamak filtre dropdown'ını açar (Temizle/OK/Cancel ile).
             Aktif filtre göstergesi artık ikon rengi değil, başlık metninin kendisi (amber). -->
        <DataTemplate x:Key="FilterableColumnHeader" DataType="{x:Type models:ColumnFilterViewModel}">
            <Grid MinHeight="30">
                <Button x:Name="HeaderButton" Command="{Binding OpenCommand}" Cursor="Hand"
                        Background="Transparent" BorderThickness="0" Padding="4,0"
                        HorizontalContentAlignment="Left" ToolTip="Filtrele">
                    <TextBlock Text="{Binding HeaderText}" TextTrimming="CharacterEllipsis">
                        <TextBlock.Style>
                            <Style TargetType="TextBlock">
                                <Style.Triggers>
                                    <DataTrigger Binding="{Binding IsActive}" Value="True">
                                        <Setter Property="Foreground" Value="{StaticResource Brush.Accent.Amber}" />
                                    </DataTrigger>
                                </Style.Triggers>
                            </Style>
                        </TextBlock.Style>
                    </TextBlock>
                </Button>

                <Popup PlacementTarget="{Binding ElementName=HeaderButton}" IsOpen="{Binding IsPopupOpen}"
                       StaysOpen="False" Placement="Bottom" AllowsTransparency="True" PopupAnimation="Fade"
                       Opened="FilterPopup_Opened">
                    <!-- Width sabit (Width, MinWidth değil): önceden içerik (uzun değer metinleri)
                         genişliği büyütüyordu, bu yüzden her sütunun dropdown'ı farklı boyutta
                         görünüyordu — artık hepsi aynı sabit genişlikte, uzun değerler kırpılıp
                         "..." ile gösteriliyor (bkz. aşağıdaki TextTrimming). -->
                    <Border Background="{StaticResource Brush.Background.Elevated}"
                            BorderBrush="{StaticResource Brush.Border}" BorderThickness="1"
                            CornerRadius="4" Padding="6" Width="190" MaxHeight="360">
                        <DockPanel>
                            <!-- Kullanıcı isteği: "temizle ok cancel ı bir alt satıra alsan filtre
                                 alanının genişliği biraz daralır" — sıralama (↑A-Z/↓Z-A) ÜST satırda,
                                 Temizle/Hepsini Seç + OK/Cancel ALT satırda — 5 düğmeyi tek satıra
                                 sığdırmak için popup'ı geniş tutmaya gerek kalmadı (bkz. aşağıdaki
                                 Border Width, 230'dan düşürüldü). IsSearchOnly sütunlarda (Title/File)
                                 hiç yok — checkbox listesi olmadığından Temizle/OK/Cancel'ın bir işlevi
                                 kalmıyor. -->
                            <StackPanel DockPanel.Dock="Bottom" Margin="0,6,0,0">
                                <StackPanel.Style>
                                    <Style TargetType="StackPanel">
                                        <Style.Triggers>
                                            <DataTrigger Binding="{Binding IsSearchOnly}" Value="True">
                                                <Setter Property="Visibility" Value="Collapsed" />
                                            </DataTrigger>
                                        </Style.Triggers>
                                    </Style>
                                </StackPanel.Style>
                                <StackPanel Orientation="Horizontal" HorizontalAlignment="Left">
                                    <Button Content="↑A-Z" Click="SortAscending_Click" ToolTip="Sırala A-Z"
                                            FontSize="10" Padding="4,2" Margin="0,0,2,0" Cursor="Hand" />
                                    <Button Content="↓Z-A" Click="SortDescending_Click" ToolTip="Sırala Z-A"
                                            FontSize="10" Padding="4,2" Cursor="Hand" />
                                </StackPanel>
                                <StackPanel Orientation="Horizontal" HorizontalAlignment="Right" Margin="0,4,0,0">
                                    <Button Content="{Binding ToggleAllLabel}" Command="{Binding ToggleAllCommand}" FontSize="10" Margin="0,0,4,0" />
                                    <Button Content="OK" Command="{Binding ApplyFilterCommand}" FontSize="10" Margin="0,0,4,0" />
                                    <Button Content="Cancel" Command="{Binding CancelFilterCommand}" FontSize="10" />
                                </StackPanel>
                            </StackPanel>

                            <!-- Normal sütunlarda değer listesini daraltan arama kutusu; IsSearchOnly
                                 sütunlarda (Title/File) grid'i DOĞRUDAN filtreleyen tek kontrol bu.
                                 Arama her tuş vuruşunda DEĞİL, Enter'a basılınca uygulanır (bkz.
                                 ColumnFilterViewModel.SearchCommand) — IsSearchOnly sütunlarda her
                                 tuş vuruşunda 66 bin oyunu yeniden filtrelemek gecikme yaratıyordu. -->
                            <Grid DockPanel.Dock="Top" Margin="0,0,0,4">
                                <TextBox FontSize="11" Padding="4,2,20,2"
                                         Text="{Binding SearchText, UpdateSourceTrigger=PropertyChanged}">
                                    <TextBox.InputBindings>
                                        <KeyBinding Key="Return" Command="{Binding SearchCommand}" />
                                    </TextBox.InputBindings>
                                </TextBox>

                                <!-- Önceki aramayı Backspace/Delete ile tek tek silmek yerine tek
                                     tıkla temizler — Enter beklemeden hemen uygulanır (bkz.
                                     ColumnFilterViewModel.ClearSearchCommand). Sadece arama kutusunda
                                     metin varken görünür. -->
                                <Button Command="{Binding ClearSearchCommand}"
                                        HorizontalAlignment="Right" VerticalAlignment="Center"
                                        Padding="4,0" Margin="0,0,2,0" Cursor="Hand" ToolTip="Aramayı temizle">
                                    <!-- Genel Button şablonu hover'da arkaplanı dolduruyordu (bkz.
                                         ekran görüntüsü) — bu küçük "✕" için arkaplan hiç istenmiyor,
                                         sadece hover'da ikonun kendi rengi değişiyor. -->
                                    <Button.Template>
                                        <ControlTemplate TargetType="Button">
                                            <Border Background="Transparent">
                                                <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center" />
                                            </Border>
                                        </ControlTemplate>
                                    </Button.Template>
                                    <Button.Style>
                                        <Style TargetType="Button">
                                            <Setter Property="Visibility" Value="Visible" />
                                            <Style.Triggers>
                                                <DataTrigger Binding="{Binding SearchText.Length}" Value="0">
                                                    <Setter Property="Visibility" Value="Collapsed" />
                                                </DataTrigger>
                                            </Style.Triggers>
                                        </Style>
                                    </Button.Style>
                                    <TextBlock Text="✕" FontSize="9">
                                        <TextBlock.Style>
                                            <Style TargetType="TextBlock">
                                                <Setter Property="Foreground" Value="{StaticResource Brush.Text.Secondary}" />
                                                <Style.Triggers>
                                                    <Trigger Property="IsMouseOver" Value="True">
                                                        <Setter Property="Foreground" Value="{StaticResource Brush.Text.Primary}" />
                                                    </Trigger>
                                                </Style.Triggers>
                                            </Style>
                                        </TextBlock.Style>
                                    </TextBlock>
                                </Button>
                            </Grid>

                            <!-- 67 bin neredeyse hiç tekrarlamayan değer için checkbox listesi kurmak
                                 (67 bin CheckBox+TextBlock) popup açılışında donmaya yol açıyordu —
                                 IsSearchOnly sütunlarda bu liste hiç render edilmiyor (Options zaten
                                 boş, bkz. MainViewModel.BuildSearchOnlyColumnFilter). -->
                            <ScrollViewer VerticalScrollBarVisibility="Auto" MaxHeight="260">
                                <ScrollViewer.Style>
                                    <Style TargetType="ScrollViewer">
                                        <Style.Triggers>
                                            <DataTrigger Binding="{Binding IsSearchOnly}" Value="True">
                                                <Setter Property="Visibility" Value="Collapsed" />
                                            </DataTrigger>
                                        </Style.Triggers>
                                    </Style>
                                </ScrollViewer.Style>
                                <ItemsControl ItemsSource="{Binding OptionsView}" ItemTemplate="{StaticResource FilterOptionBadgeTemplate}" />
                            </ScrollViewer>
                        </DockPanel>
                    </Border>
                </Popup>
            </Grid>
        </DataTemplate>

        <DataTemplate x:Key="TitleColumnHeaderWithHealth" DataType="{x:Type models:ColumnFilterViewModel}">
            <!-- Kullanıcı isteği: "standart search bar ı logonun yanındaki barın üstüne alsak...
                 tıklayıp açılan search bar yerine tek onu kullansak" — üst araç çubuğundaki genel
                 arama kutusu (MainViewModel.SearchText) buraya taşındı; "Başlık" sütununun eski
                 tıkla-aç popup'ı (arama + A-Z/Z-A düğmeleri) tamamen kaldırıldı (kullanıcı onayı:
                 "başlık sütununda zaten a dan z ye geliyorsa direk" — sütun başlığına tıklayınca
                 zaten yerleşik DataGrid sıralaması çalışıyor, ayrı düğmeye gerek yok). Logo/health
                 satırının boyutları (120x22 logo, 64x5 bar) DEĞİŞTİRİLMEDİ, sadece üstüne yeni bir
                 satır eklendi. -->
            <Grid MinHeight="52">
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="Auto" />
                </Grid.RowDefinitions>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="Auto" />
                </Grid.ColumnDefinitions>

                <!-- WPF TextBox'ın yerleşik placeholder'ı olmadığından, eski üst araç çubuğu
                     kutusuyla AYNI "boşken ipucu göster" deseni (bkz. altta kaldırılan Grid). -->
                <Grid Grid.Row="0" Grid.Column="0" Grid.ColumnSpan="2" Height="22" Margin="2,0,4,4">
                    <TextBox VerticalContentAlignment="Center" FontSize="11" Padding="6,0"
                             Text="{Binding Data.SearchText, Source={StaticResource ViewModelProxy}, UpdateSourceTrigger=PropertyChanged}" />
                    <TextBlock Text="Ara... (Boş alan için)" IsHitTestVisible="False"
                               VerticalAlignment="Center" Margin="8,0,0,0" FontSize="11"
                               Foreground="{StaticResource Brush.Text.Secondary}">
                        <TextBlock.Style>
                            <Style TargetType="TextBlock">
                                <Setter Property="Visibility" Value="Collapsed" />
                                <Style.Triggers>
                                    <DataTrigger Binding="{Binding Data.SearchText, Source={StaticResource ViewModelProxy}}" Value="">
                                        <Setter Property="Visibility" Value="Visible" />
                                    </DataTrigger>
                                </Style.Triggers>
                            </Style>
                        </TextBlock.Style>
                    </TextBlock>
                </Grid>

                <!-- Seçili platformun logosu (All Platforms'ta RetroAudit'in kendi logosu, bkz.
                     MainViewModel.CurrentPlatformLogoPath) — artık tıklanabilir popup yok.
                     DÜZELTME: bir önceki deneme (HorizontalAlignment="Stretch") logoyu TÜM Column 0
                     genişliğine yayıyordu, sağdaki boşluğu (kullanıcının ileride bir şey koyacağı
                     alan) yiyordu ve orantısız dağılım çirkin duruyordu. Kullanıcı isteği aslında
                     sabit KÜÇÜK kutunun (120x22, önceki boyut) İÇİNİ doldurmaktı — Stretch="Fill" +
                     sabit Width/Height, kutunun kendisi büyümüyor/taşmıyor, sağda boşluk kalıyor. -->
                <Image Grid.Row="1" Grid.Column="0"
                       Source="{Binding Data.CurrentPlatformLogoPath, Source={StaticResource ViewModelProxy}, Mode=OneWay}"
                       Width="120" Height="22" Stretch="Fill"
                       HorizontalAlignment="Left" VerticalAlignment="Center"
                       RenderOptions.BitmapScalingMode="HighQuality" />

                <StackPanel Grid.Row="1" Grid.Column="1" Orientation="Horizontal" VerticalAlignment="Center" Margin="8,0,4,0">
                    <TextBlock VerticalAlignment="Center" Margin="0,0,6,0" FontSize="10" FontWeight="SemiBold"
                               Foreground="{StaticResource Brush.Text.Secondary}">
                        <Run Text="%" />
                        <Run Text="{Binding Data.CurrentPlatformHealthPercent, Source={StaticResource ViewModelProxy}, Mode=OneWay}" />
                    </TextBlock>
                    <Border Width="64" Height="5" CornerRadius="3" Background="{StaticResource Brush.Background.Base}"
                            VerticalAlignment="Center" ClipToBounds="True">
                        <Border Width="{Binding Data.CurrentPlatformHealthPercent, Source={StaticResource ViewModelProxy}, Mode=OneWay, Converter={StaticResource PercentageToWidth}, ConverterParameter=64}"
                                Height="5" HorizontalAlignment="Left" CornerRadius="3"
                                Background="{StaticResource Brush.Accent.SelectedBorder}" />
                    </Border>
                </StackPanel>
            </Grid>
        </DataTemplate>

        <!-- Birleşik "Actions" sütununun (Favori+Gizle+Ara/Başlat, bkz. ActionsColumn) başlığı —
             standart FilterableColumnHeader'dan farklı olarak: TEK popup'ta İKİ grup (Favori,
             Durum) birden gösterilir, arama kutusu YOK (sadece birkaç seçenek olduğu için gerek
             yok) ve sıralama düğmeleri YOK (bu sütun tek bir sıralanabilir değeri temsil etmiyor).
             "Gizle" için grup yok — bkz. ActionsColumnFilterViewModel yorumu. -->
        <DataTemplate x:Key="ActionsColumnFilterHeader" DataType="{x:Type models:ActionsColumnFilterViewModel}">
            <Grid MinHeight="30">
                <Button x:Name="ActionsHeaderButton" Command="{Binding OpenCommand}" Cursor="Hand"
                        Background="Transparent" BorderThickness="0" Padding="4,0"
                        HorizontalAlignment="Stretch" HorizontalContentAlignment="Center" ToolTip="Filtrele">
                    <TextBlock Text="Actions" TextTrimming="CharacterEllipsis">
                        <TextBlock.Style>
                            <Style TargetType="TextBlock">
                                <Style.Triggers>
                                    <DataTrigger Binding="{Binding IsActive}" Value="True">
                                        <Setter Property="Foreground" Value="{StaticResource Brush.Accent.Amber}" />
                                    </DataTrigger>
                                </Style.Triggers>
                            </Style>
                        </TextBlock.Style>
                    </TextBlock>
                </Button>

                <Popup PlacementTarget="{Binding ElementName=ActionsHeaderButton}" IsOpen="{Binding IsPopupOpen}"
                       StaysOpen="False" Placement="Bottom" AllowsTransparency="True" PopupAnimation="Fade">
                    <Border Background="{StaticResource Brush.Background.Elevated}"
                            BorderBrush="{StaticResource Brush.Border}" BorderThickness="1"
                            CornerRadius="4" Padding="6" Width="190">
                        <DockPanel>
                            <Grid DockPanel.Dock="Bottom" Margin="0,6,0,0">
                                <Button Content="Temizle" Command="{Binding ClearAllCommand}" FontSize="10"
                                        HorizontalAlignment="Left" />
                                <StackPanel Orientation="Horizontal" HorizontalAlignment="Right">
                                    <Button Content="OK" Command="{Binding ApplyFilterCommand}" FontSize="10" Margin="0,0,4,0" />
                                    <Button Content="Cancel" Command="{Binding CancelFilterCommand}" FontSize="10" />
                                </StackPanel>
                            </Grid>

                            <StackPanel>
                                <TextBlock Text="Favori" FontWeight="SemiBold" FontSize="10" Margin="0,0,0,2"
                                           Foreground="{StaticResource Brush.Text.Secondary}" />
                                <!-- DataContext bilerek FavoriteFilter'ın kendisine (ColumnFilterViewModel)
                                     çekiliyor — FilterOptionBadgeTemplate'in Button'ı ToggleOptionCommand'a
                                     AncestorType=ItemsControl ile ulaşıyor, bu yüzden ItemsControl'ün
                                     KENDİ DataContext'i (üstteki ActionsColumnFilterViewModel değil) doğrudan
                                     ilgili alt filtre olmalı. -->
                                <ItemsControl DataContext="{Binding FavoriteFilter}" ItemsSource="{Binding OptionsView}"
                                              ItemTemplate="{StaticResource FilterOptionBadgeTemplate}" Margin="0,0,0,6" />

                                <TextBlock Text="Durum" FontWeight="SemiBold" FontSize="10" Margin="0,0,0,2"
                                           Foreground="{StaticResource Brush.Text.Secondary}" />
                                <ItemsControl DataContext="{Binding HasLocalFileFilter}" ItemsSource="{Binding OptionsView}"
                                              ItemTemplate="{StaticResource FilterOptionBadgeTemplate}" />
                            </StackPanel>
                        </DockPanel>
                    </Border>
                </Popup>
            </Grid>
        </DataTemplate>

        <!-- Kapsül sağ tık menüsündeki her dairesel ikon düğmesi için ortak şablon: hover'da
             (Brush.Background.Hover) yuvarlak bir vurgu belirir — bkz. plan referans ekran görüntüsü. -->
        <Style x:Key="ContextMenuIconButton" TargetType="Button">
            <Setter Property="Background" Value="Transparent" />
            <Setter Property="BorderThickness" Value="0" />
            <Setter Property="Cursor" Value="Hand" />
            <!-- Kullanıcı isteği: "iconların aralarını biraz aç çok sıkışık sığmıyor textler
                 bazılarında" — 3px'ten 8px'e çıkarıldı, komşu düğmeler arasında etiket metninin
                 taşabileceği daha fazla boşluk bırakıyor. -->
            <Setter Property="Margin" Value="8,0" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <!-- Kullanıcı bulgusu: "Delete Perm." gibi uzun etiketler CornerRadius'un
                             oluşturduğu klip yüzünden baştan/sondan kırpılıyordu (Border, sabit
                             Width="40" + köşe yuvarlama birleşince içeriği 40px'lik daireye
                             kırpıyor) — sabit Width kaldırıldı, MinWidth="40" ile kısa etiketler
                             (Restore, Delete) hâlâ 40px'lik daire gibi görünürken uzun etiketler
                             içeriğe göre genişleyip oval bir hap şekline dönüşüyor, kırpma olmuyor. -->
                        <Border x:Name="Bg" CornerRadius="20" MinWidth="40" Height="40" Padding="6,0" Background="Transparent">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center" />
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="Bg" Property="Background" Value="{StaticResource Brush.Background.Hover}" />
                            </Trigger>
                            <Trigger Property="IsEnabled" Value="False">
                                <Setter Property="Opacity" Value="0.35" />
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <!-- Kullanıcı isteği: "bunların çıkmasına gerek yok geri dönüşüm kutusunda bence Restore
             ve Delete Pern yeterli" — kapsül menüsündeki DataContext zaten seçili Game olduğu için
             (bkz. Tekil mod StackPanel'in DataContext="{Binding ContextMenuGame}"), bu satırın
             IsDeleted'ı doğrudan bağlanabiliyor: Çöp Kutusu'ndaki bir oyun için Edit/Versions/
             Folder/Bağla/Re-match/Artwork/Playlist gibi (o bağlamda anlamsız) eylemler tamamen
             gizlenir, sadece Restore + Delete Perm. kalır. -->
        <Style x:Key="ContextMenuIconButtonHiddenInRecycleBin" TargetType="Button" BasedOn="{StaticResource ContextMenuIconButton}">
            <Style.Triggers>
                <DataTrigger Binding="{Binding IsDeleted}" Value="True">
                    <Setter Property="Visibility" Value="Collapsed" />
                </DataTrigger>
            </Style.Triggers>
        </Style>

        <!-- Kullanıcı bulgusu: "geri dönüşüm kutusunda toplu seçim yapınca menü böyle geliyor" —
             yukarıdaki tekil moddaki gizleme AYNI şekilde toplu moda hiç uygulanmamıştı: Bağla/
             Favorite/Playlist/Hide/Re-match/Artwork toplu panelde IsContextMenuSelectionAllDeleted
             durumuna bakılmaksızın hep görünüyordu. DataContext burada Window'un kendisi olduğu
             için (bkz. toplu StackPanel — {Binding ContextMenuGame} yok, doğrudan Window
             DataContext=MainViewModel) IsContextMenuSelectionAllDeleted doğrudan bağlanabiliyor. -->
        <Style x:Key="BulkContextMenuIconButtonHiddenInRecycleBin" TargetType="Button" BasedOn="{StaticResource ContextMenuIconButton}">
            <Style.Triggers>
                <DataTrigger Binding="{Binding IsContextMenuSelectionAllDeleted}" Value="True">
                    <Setter Property="Visibility" Value="Collapsed" />
                </DataTrigger>
            </Style.Triggers>
        </Style>

        <!-- Detay panelindeki Metadata rozetleri (Tür/Oyun Modu/Sürüm) — kullanıcı isteği: "Badge
             tasarımı: RetroAudit temasına uygun, hafif border, hafif koyu arka plan, 4-6px radius,
             hover efekti, el cursor, tıklanabilir görünüm". Tıklanabilir olanlar (Tür, Sürüm) Button,
             tıklanamayan (Oyun Modu — LaunchBox'ta gerçek bir "oyun modu" filtre boyutu yok, bkz.
             Game.GameModeIcon yorumu) düz bir Border ile AYNI görünümü paylaşır ama Cursor/hover yok
             (MetadataBadgeStatic) — kullanıcıyı yanlışlıkla "buraya tıklanabilir" diye yanıltmamak için. -->
        <Style x:Key="MetadataBadge" TargetType="Button">
            <Setter Property="Background" Value="{StaticResource Brush.Background.Elevated}" />
            <Setter Property="Foreground" Value="{StaticResource Brush.Text.Primary}" />
            <Setter Property="BorderBrush" Value="{StaticResource Brush.Border}" />
            <Setter Property="BorderThickness" Value="1" />
            <Setter Property="Padding" Value="8,4" />
            <Setter Property="FontSize" Value="11" />
            <Setter Property="Cursor" Value="Hand" />
            <Setter Property="HorizontalAlignment" Value="Left" />
            <Setter Property="HorizontalContentAlignment" Value="Center" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="Bg" Background="{TemplateBinding Background}" BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="{TemplateBinding BorderThickness}" CornerRadius="5" Padding="{TemplateBinding Padding}">
                            <!-- Kullanıcı isteği: "yazıyı sola yasla" (ALTERNATE NAMES satırı) —
                                 önceden burada sabit Center vardı, Button'daki HorizontalContentAlignment
                                 hiç etkisi olmuyordu. Artık TemplateBinding ile Button'ın kendi ayarına
                                 uyuyor (varsayılan Style'daki Center diğer rozetleri (Tür/Sürüm) etkilemez). -->
                            <ContentPresenter HorizontalAlignment="{TemplateBinding HorizontalContentAlignment}" VerticalAlignment="Center" />
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="Bg" Property="Background" Value="{StaticResource Brush.Background.Hover}" />
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="MetadataBadgeStatic" TargetType="Border">
            <Setter Property="Background" Value="{StaticResource Brush.Background.Elevated}" />
            <Setter Property="BorderBrush" Value="{StaticResource Brush.Border}" />
            <Setter Property="BorderThickness" Value="1" />
            <Setter Property="CornerRadius" Value="5" />
            <Setter Property="Padding" Value="8,4" />
            <Setter Property="HorizontalAlignment" Value="Left" />
        </Style>

        <!-- IconOnly modunda etiket metni gizlenir (bkz. Ayarlar > Arayüz, ContextMenuDisplayMode). -->
        <Style x:Key="ContextMenuLabelText" TargetType="TextBlock">
            <Setter Property="FontSize" Value="9" />
            <Setter Property="HorizontalAlignment" Value="Center" />
            <Setter Property="Margin" Value="0,2,0,0" />
            <Setter Property="Foreground" Value="{StaticResource Brush.Text.Secondary}" />
            <Style.Triggers>
                <DataTrigger Binding="{Binding DataContext.ContextMenuDisplayMode, RelativeSource={RelativeSource AncestorType=Window}}" Value="IconOnly">
                    <Setter Property="Visibility" Value="Collapsed" />
                </DataTrigger>
            </Style.Triggers>
        </Style>

        <Style x:Key="ContextMenuGlyphText" TargetType="TextBlock">
            <Setter Property="FontFamily" Value="Segoe MDL2 Assets" />
            <Setter Property="FontSize" Value="17" />
            <Setter Property="HorizontalAlignment" Value="Center" />
            <Setter Property="Foreground" Value="{StaticResource Brush.Text.Primary}" />
        </Style>

        <!-- Özel başlık çubuğundaki min/maks düğmeleri — Windows'un kendi native caption
             düğmeleriyle birebir aynı Segoe MDL2 glyph'leri (ChromeMinimize/ChromeMaximize/
             ChromeRestore/ChromeClose) ve hover davranışı (gri) kullanıyor, sadece Kapat
             kırmızı olacak şekilde ayrıca override ediliyor (bkz. TitleBarCloseButton). -->
        <Style x:Key="TitleBarButton" TargetType="Button">
            <Setter Property="Width" Value="46" />
            <Setter Property="Height" Value="32" />
            <Setter Property="Background" Value="Transparent" />
            <Setter Property="BorderThickness" Value="0" />
            <Setter Property="Foreground" Value="{StaticResource Brush.Text.Secondary}" />
            <Setter Property="Cursor" Value="Arrow" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="Bg" Background="{TemplateBinding Background}">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center" />
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="Bg" Property="Background" Value="{StaticResource Brush.Background.Hover}" />
                                <Setter Property="Foreground" Value="{StaticResource Brush.Text.Primary}" />
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="TitleBarCloseButton" TargetType="Button" BasedOn="{StaticResource TitleBarButton}">
            <Style.Triggers>
                <Trigger Property="IsMouseOver" Value="True">
                    <Setter Property="Background" Value="#E81123" />
                    <Setter Property="Foreground" Value="White" />
                </Trigger>
            </Style.Triggers>
        </Style>

        <!-- Sabitlenmiş (pinned) sütun bölgesinin sınırını göstermek için ince dikey çizgi —
             bkz. MainWindow.xaml.cs ApplyColumnPinningPositions. Sol sabitlemenin SON sütununa
             "Right" varyantı, sağ sabitlemenin İLK sütununa "Left" varyantı, sadece HÜCRELERE
             (başlığa değil — bkz. code-behind yorumu, "Actions" gibi özel HeaderTemplate'i olan
             sütunlarda HeaderStyle değişimi başlığı temasız/beyaz gösteriyordu) uygulanır. Hücre
             stili özel bir ControlTemplate kullanıyor (bkz. ObsidianDark.xaml varsayılan
             DataGridCell şablonu) çünkü o şablon BorderBrush/BorderThickness'ı hiç kullanmıyor —
             bu yüzden burada gerçek bir kenarlık çizen kendi şablonumuzu tanımlıyoruz. Renk VE
             kalınlık normal sütun ayraçlarıyla birebir aynı (Brush.Border, 1px) — vurgu (accent)
             rengi ve kalın çizgi dikkat dağıtıcı/kötü duruyordu. -->
        <Style x:Key="PinBoundaryRightCellStyle" TargetType="{x:Type DataGridCell}" BasedOn="{StaticResource {x:Type DataGridCell}}">
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="{x:Type DataGridCell}">
                        <Border Background="{TemplateBinding Background}" Padding="{TemplateBinding Padding}"
                                BorderBrush="{StaticResource Brush.Border}" BorderThickness="0,0,1,0"
                                SnapsToDevicePixels="True">
                            <ContentPresenter VerticalAlignment="Center" />
                        </Border>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
        <Style x:Key="PinBoundaryLeftCellStyle" TargetType="{x:Type DataGridCell}" BasedOn="{StaticResource {x:Type DataGridCell}}">
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="{x:Type DataGridCell}">
                        <Border Background="{TemplateBinding Background}" Padding="{TemplateBinding Padding}"
                                BorderBrush="{StaticResource Brush.Border}" BorderThickness="1,0,0,0"
                                SnapsToDevicePixels="True">
                            <ContentPresenter VerticalAlignment="Center" />
                        </Border>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <!-- Box/BG/SS/Oyuncu gibi kısa, tek değerli sütunların başlığını ortalamak için — standart
             FilterableColumnHeader tüm sütunlarda paylaşıldığı için (Title/Platform/... hâlâ sola
             yaslı kalmalı), ortalamayı şablonun kendisinde değil, sadece bu sütunların
             HeaderStyle'ında yapıyoruz. -->
        <Style x:Key="CenteredColumnHeaderStyle" TargetType="{x:Type DataGridColumnHeader}" BasedOn="{StaticResource {x:Type DataGridColumnHeader}}">
            <Setter Property="HorizontalContentAlignment" Value="Center" />
        </Style>
    </Window.Resources>

    <Grid x:Name="RootLayoutGrid" Background="{StaticResource Brush.Background.Base}">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
        </Grid.RowDefinitions>

        <!-- ===================== Özel başlık çubuğu ===================== -->
        <Border Grid.Row="0" Height="32" Background="{StaticResource Brush.Background.Panel}">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="Auto" />
                </Grid.ColumnDefinitions>

                <!-- Pencere ikonu yok (uygulamanın henüz özel bir .ico'su yok) — sadece başlık
                     metni. Bu alan (düğmeler hariç) WindowChrome.CaptionHeight sayesinde zaten
                     sürüklenebilir/çift-tıkla-büyüt/sağ-tıkla-sistem-menüsü davranışına sahip,
                     ayrıca bir event handler'a gerek yok. -->
                <TextBlock Grid.Column="0" Text="RetroAudit" VerticalAlignment="Center"
                           Margin="12,0,0,0" FontSize="12" Foreground="{StaticResource Brush.Text.Secondary}" />

                <StackPanel Grid.Column="1" Orientation="Horizontal">
                    <Button shell:WindowChrome.IsHitTestVisibleInChrome="True" Style="{StaticResource TitleBarButton}"
                            Click="MinimizeButton_Click" ToolTip="Simge durumuna küçült">
                        <TextBlock Text="&#xE921;" FontFamily="Segoe MDL2 Assets" FontSize="10" />
                    </Button>
                    <Button x:Name="MaximizeRestoreButton" shell:WindowChrome.IsHitTestVisibleInChrome="True"
                            Style="{StaticResource TitleBarButton}" Click="MaximizeRestoreButton_Click"
                            ToolTip="Ekranı kapla/geri yükle">
                        <TextBlock x:Name="MaximizeRestoreGlyph" Text="&#xE922;" FontFamily="Segoe MDL2 Assets" FontSize="10" />
                    </Button>
                    <Button shell:WindowChrome.IsHitTestVisibleInChrome="True" Style="{StaticResource TitleBarCloseButton}"
                            Click="CloseButton_Click" ToolTip="Kapat">
                        <TextBlock Text="&#xE8BB;" FontFamily="Segoe MDL2 Assets" FontSize="10" />
                    </Button>
                </StackPanel>
            </Grid>
        </Border>

        <!-- ===================== Toolbar ===================== -->
        <Border Grid.Row="1" Background="{StaticResource Brush.Background.Panel}"
                BorderBrush="{StaticResource Brush.Border}" BorderThickness="0,0,0,1" Padding="8">
            <DockPanel>
                <!-- USA/EU/Japan bayrak filtreleri (kullanıcı isteği: "sağ üste 3 seçenek koyarız
                     Bayraklı") — çoklu seçim, platform+playlist'ten SONRA gelen 3. süzgeç (bkz.
                     MainViewModel.GetFilterScopePopulation/RecomputeRegionDisplay). Sağa sabit,
                     DockPanel'de SOL taraftaki StackPanel'den ÖNCE tanımlı olmalı ki
                     LastChildFill=true varsayılanıyla o StackPanel kalan alanı doldursun, bu
                     sağa yaslı kalsın. -->
                <StackPanel DockPanel.Dock="Right" Orientation="Horizontal" VerticalAlignment="Center" Margin="10,0,0,0">
                    <!-- Bayrak emojileri (🇺🇸 gibi) kasıtlı olarak kullanılmıyor: WPF'in metin
                         motoru bu Regional Indicator Symbol çiftlerini Windows 10'da renkli bayrak
                         glyph'i olarak değil, düz harf çifti ("us") olarak render ediyor (renkli
                         emoji bayrak desteği esas olarak Windows 11'de geldi) — bkz. dev makine
                         Windows 10 22H2. Sade metin her sürümde tutarlı görünür. -->
                    <!-- Artık gerçek bayrak PNG'leri kullanılıyor (bkz. FlagResolver/UsaFlagPath vb.) —
                         emoji bayrak kaldırma gerekçesi (Windows 10'da düz harfe düşme) burada geçerli
                         değil, bunlar gerçek bitmap. -->
                    <ToggleButton IsChecked="{Binding ShowUsaRegion}" Margin="0,0,4,0"
                                  ToolTip="USA sürümü olan oyunları göster/gizle">
                        <StackPanel Orientation="Horizontal">
                            <Image Source="{Binding UsaFlagPath}" Width="14" Height="14" Margin="0,0,4,0" RenderOptions.BitmapScalingMode="HighQuality" />
                            <TextBlock Text="USA" />
                        </StackPanel>
                    </ToggleButton>
                    <ToggleButton IsChecked="{Binding ShowEuRegion}" Margin="0,0,4,0"
                                  ToolTip="Europe sürümü olan oyunları göster/gizle">
                        <StackPanel Orientation="Horizontal">
                            <Image Source="{Binding EuFlagPath}" Width="14" Height="14" Margin="0,0,4,0" RenderOptions.BitmapScalingMode="HighQuality" />
                            <TextBlock Text="EU" />
                        </StackPanel>
                    </ToggleButton>
                    <ToggleButton IsChecked="{Binding ShowJapanRegion}">
                        <StackPanel Orientation="Horizontal">
                            <Image Source="{Binding JapanFlagPath}" Width="14" Height="14" Margin="0,0,4,0" RenderOptions.BitmapScalingMode="HighQuality" />
                            <TextBlock Text="Japan" />
                        </StackPanel>
                    </ToggleButton>
                </StackPanel>

                <!-- Satır yüksekliği kaydırıcısı ve "Obsidyen" tema etiketi Ayarlar > Arayüz'e
                     taşındı (kullanıcı isteği: "Tema Ayarları ve Tablo Satır genişlik ayarları...
                     Ayarlar içine uygun kategori içine ekle") — RowHeight artık orada kalıcı
                     olarak ayarlanıp diske kaydediliyor, burada ayrıca tekrar göstermeye gerek yok. -->
                <StackPanel Orientation="Horizontal" VerticalAlignment="Center" ClipToBounds="True">
                    <Button Content="Import" Command="{Binding ImportCommand}" Margin="0,0,6,0" />
                    <Button Content="Temizle" Command="{Binding ClearFiltersCommand}" Margin="0,0,14,0" />

                    <!-- GEÇİCİ (kullanıcı isteği: "tabloda gözükenleri text olarak dışa aktarabileceğim
                         buton, notepad'de açsın, eşleşmeyenleri kontrol için toplu kopyalayıp
                         atabileyim") — kaldırmak için bu Button'ı ve MainWindow.xaml.cs'teki
                         ExportVisibleGamesButton_Click'i sil. -->
                    <Button Content="Dışa Aktar" Click="ExportVisibleGamesButton_Click" Margin="0,0,14,0" />
                    <Button Content="Media Pro" Command="{Binding OpenMediaProviderCommand}" Margin="0,0,6,0" />
                    <Button Content="Metadata Pro" Command="{Binding OpenMetadataProviderCommand}" Margin="0,0,6,0" />
                    <Button Content="Crop Editor" Command="{Binding OpenCropEditorCommand}" Margin="0,0,6,0" />

                    <!-- Kullanıcı isteği: "ayarlar menüsünü açan butonu Tools içinden ayır, kolay
                         erişim için ana ekrana ekle" — artık Tools açılır menüsünün bir öğesi değil,
                         yanında tek tıkla erişilen ayrı bir buton. -->
                    <Button Content="Ayarlar" Margin="0,0,14,0" Command="{Binding OpenSettingsCommand}" />

                    <!-- Kullanıcı isteği: "standart search bar ı logonun yanındaki barın üstüne
                         alsak... tek onu kullansak" — bu kutu "Başlık" sütun başlığına taşındı (bkz.
                         TitleColumnHeaderWithHealth), buradan kaldırıldı. -->

                    <ToggleButton Content="Released" IsChecked="{Binding ShowReleased}" Margin="0,0,4,0" />
                    <ToggleButton Content="Junk" IsChecked="{Binding ShowJunk}" Margin="0,0,14,0" />

                    <!-- Sütun seçici: hangi sütunun DataGrid'de görüneceğini seçer. Ayrı bir "Sütunlar"
                         düğmesi yok — herhangi bir sütun başlığına sağ tıklandığında bu popup açılır
                         (bkz. MainWindow.xaml.cs GamesGrid_PreviewMouseRightButtonUp, IsColumnPickerOpen).
                         DataGridColumn görsel ağacın parçası olmadığından XAML binding ile doğrudan
                         gizlenemiyor; her satırın IsVisible değişimi kod-arkasında ilgili sütunu bulup
                         Visibility'sini günceller. -->
                    <Popup IsOpen="{Binding IsColumnPickerOpen}"
                           StaysOpen="False" Placement="MousePoint" AllowsTransparency="True" PopupAnimation="Fade">
                        <Border Background="{StaticResource Brush.Background.Elevated}"
                                BorderBrush="{StaticResource Brush.Border}" BorderThickness="1"
                                CornerRadius="4" Padding="8" MinWidth="180">
                            <StackPanel>
                                <!-- Sağ tıklanan sütunu sabitler (bkz. MainWindow.xaml.cs
                                     _lastRightClickedColumn/PinColumn) — sola sabitleme gerçek bir
                                     yatay-kaydırmadan-bağışıklık (FrozenColumnCount), sağa sabitleme
                                     ise WPF DataGrid'in sağdan dondurma desteği olmadığı için sadece
                                     sütunu en sona taşır. -->
                                <StackPanel Orientation="Horizontal" Margin="0,0,0,6">
                                    <Button Content="◀ Sola Sabitle" FontSize="10" Padding="4,2" Margin="0,0,4,0"
                                            Click="PinColumnLeft_Click" />
                                    <Button Content="Sağa Sabitle ▶" FontSize="10" Padding="4,2" Margin="0,0,4,0"
                                            Click="PinColumnRight_Click" />
                                    <Button Content="✕" FontSize="10" Padding="4,2" ToolTip="Sabitlemeyi kaldır"
                                            Click="UnpinColumn_Click" />
                                </StackPanel>
                                <Separator Margin="0,0,0,6" Background="{StaticResource Brush.Border}" />
                                <!-- 19 sütunun hepsi listede olduğu için (bkz. MainViewModel.ColumnDefinitions)
                                     sabit bir MaxHeight + kaydırma şart — yoksa popup ekranın altına taşabilir. -->
                                <ScrollViewer MaxHeight="360" VerticalScrollBarVisibility="Auto">
                                    <ItemsControl ItemsSource="{Binding ColumnOptions}">
                                        <ItemsControl.ItemTemplate>
                                            <DataTemplate DataType="{x:Type models:ColumnVisibilityOption}">
                                                <!-- Kullanıcı isteği: "platform listede gözüküyor sadece bug gibi
                                                     duruyor o listedede gözükmesin ... all platform haricindekilerde"
                                                     — "Platform" sütunu zaten belirli bir platform seçiliyken
                                                     gizli (bkz. MainWindow.xaml.cs UpdatePlatformColumnVisibility),
                                                     bu checkbox'ın kendisi de aynı durumda listeden kayboluyor. -->
                                                <CheckBox Content="{Binding Header}" IsChecked="{Binding IsVisible}" Margin="2">
                                                    <CheckBox.Style>
                                                        <Style TargetType="CheckBox">
                                                            <Style.Triggers>
                                                                <MultiDataTrigger>
                                                                    <MultiDataTrigger.Conditions>
                                                                        <Condition Binding="{Binding Key}" Value="Platform" />
                                                                        <Condition Binding="{Binding DataContext.PlatformColumnVisibility, RelativeSource={RelativeSource AncestorType=Window}}" Value="Collapsed" />
                                                                    </MultiDataTrigger.Conditions>
                                                                    <Setter Property="Visibility" Value="Collapsed" />
                                                                </MultiDataTrigger>
                                                            </Style.Triggers>
                                                        </Style>
                                                    </CheckBox.Style>
                                                </CheckBox>
                                            </DataTemplate>
                                        </ItemsControl.ItemTemplate>
                                    </ItemsControl>
                                </ScrollViewer>
                            </StackPanel>
                        </Border>
                    </Popup>
                </StackPanel>
            </DockPanel>
        </Border>

        <!-- ===================== Stats bar ===================== -->
        <Border Grid.Row="2" Background="{StaticResource Brush.Background.Base}"
                BorderBrush="{StaticResource Brush.Border}" BorderThickness="0,0,0,1" Padding="10,4">
            <StackPanel Orientation="Horizontal">
                <TextBlock Foreground="{StaticResource Brush.Text.Secondary}" FontSize="11" VerticalAlignment="Center">
                    <Run Text="Görünen:" /><Run Text=" " /><Run Text="{Binding VisibleCount, Mode=OneWay}" />
                    <Run Text="  |  Toplam:" /><Run Text=" " /><Run Text="{Binding TotalCount, Mode=OneWay}" />
                </TextBlock>

                <!-- Kullanıcı isteği: "filtrelenenler şu 2. resimdeki görünenler toplam falan
                     diyorya o alanda gözüksün tıklanılabilir filtre kaldırılabilir şekilde
                     tıklandığında filtre kalkıcak ... ayrı ayrı badge olacak ben horror'u
                     kaldırmak istediğimde tıklayıp kaldırabilecem" — Türler rozetleriyle (bkz.
                     GenreBadgeButton) AYNI görsel dil; her rozet TEK bir değeri temsil eder (bkz.
                     MainViewModel.ActiveFilterChips/RefreshActiveFilterChips), tıklanınca SADECE o
                     değer kaldırılır. -->
                <ItemsControl ItemsSource="{Binding ActiveFilterChips}" Margin="14,0,0,0">
                    <ItemsControl.ItemsPanel>
                        <ItemsPanelTemplate>
                            <StackPanel Orientation="Horizontal" />
                        </ItemsPanelTemplate>
                    </ItemsControl.ItemsPanel>
                    <ItemsControl.ItemTemplate>
                        <DataTemplate DataType="{x:Type models:ActiveFilterChip}">
                            <Button Style="{StaticResource GenreBadgeButton}" Command="{Binding RemoveCommand}">
                                <TextBlock>
                                    <Run Text="{Binding Label, Mode=OneWay}" /><Run Text=" ✕" />
                                </TextBlock>
                            </Button>
                        </DataTemplate>
                    </ItemsControl.ItemTemplate>
                </ItemsControl>
            </StackPanel>
        </Border>

        <!-- ===================== Playlist chip şeridi ===================== -->
        <Border Grid.Row="3" Background="{StaticResource Brush.Background.Base}"
                BorderBrush="{StaticResource Brush.Border}" BorderThickness="0,0,0,1" Padding="10,6">
            <StackPanel Orientation="Horizontal">
            <ItemsControl ItemsSource="{Binding PlaylistChips}">
                <ItemsControl.ItemsPanel>
                    <ItemsPanelTemplate>
                        <StackPanel Orientation="Horizontal" />
                    </ItemsPanelTemplate>
                </ItemsControl.ItemsPanel>
                <ItemsControl.ItemTemplate>
                    <DataTemplate DataType="{x:Type models:PlaylistChip}">
                        <!-- Chip'e tıklamak SelectChipCommand'ı tetikler (aynı chip'e tekrar
                             tıklamak seçimi kaldırır — bkz. MainViewModel.SelectChip). Seçili
                             chip'in kenarlığı kendi rengiyle vurgulanır. -->
                        <Button Command="{Binding DataContext.SelectChipCommand, RelativeSource={RelativeSource AncestorType=Window}}"
                                CommandParameter="{Binding}" Margin="0,0,6,0" Cursor="Hand"
                                Background="Transparent" BorderThickness="0" Padding="0">
                            <Border CornerRadius="10" Padding="10,4" Background="{StaticResource Brush.Background.Elevated}">
                                <Border.Style>
                                    <Style TargetType="Border">
                                        <Setter Property="BorderThickness" Value="1" />
                                        <Setter Property="BorderBrush" Value="{StaticResource Brush.Border}" />
                                        <Style.Triggers>
                                            <DataTrigger Binding="{Binding IsSelected}" Value="True">
                                                <Setter Property="BorderBrush" Value="{Binding Color}" />
                                                <Setter Property="BorderThickness" Value="2" />
                                            </DataTrigger>
                                        </Style.Triggers>
                                    </Style>
                                </Border.Style>
                                <StackPanel Orientation="Horizontal">
                                    <!-- Renkli nokta: sadece kullanıcının kendi oluşturduğu playlist'lerde
                                         (Favorites/Hidden/Recycle Bin sabit ikon kullanıyor, aşağıda). -->
                                    <Ellipse Width="8" Height="8" Fill="{Binding Color}" VerticalAlignment="Center" Margin="0,0,5,0">
                                        <Ellipse.Style>
                                            <Style TargetType="Ellipse">
                                                <Setter Property="Visibility" Value="Visible" />
                                                <Style.Triggers>
                                                    <DataTrigger Binding="{Binding IsBuiltIn}" Value="True">
                                                        <Setter Property="Visibility" Value="Collapsed" />
                                                    </DataTrigger>
                                                </Style.Triggers>
                                            </Style>
                                        </Ellipse.Style>
                                    </Ellipse>

                                    <!-- Sabit chip'lerin ikonu — sağ tık menüsündekiyle aynı Segoe MDL2
                                         glyph'ler (Favorites=yıldız, Hidden=göz, Recycle Bin=çöp kutusu). -->
                                    <TextBlock FontFamily="Segoe MDL2 Assets" FontSize="12" Margin="0,0,5,0"
                                               VerticalAlignment="Center" Foreground="{Binding Color}">
                                        <TextBlock.Style>
                                            <Style TargetType="TextBlock">
                                                <Setter Property="Visibility" Value="Collapsed" />
                                                <Setter Property="Text" Value="&#xE734;" />
                                                <Style.Triggers>
                                                    <DataTrigger Binding="{Binding IsBuiltIn}" Value="True">
                                                        <Setter Property="Visibility" Value="Visible" />
                                                    </DataTrigger>
                                                    <DataTrigger Binding="{Binding Kind}" Value="Hidden">
                                                        <Setter Property="Text" Value="&#xE7B3;" />
                                                    </DataTrigger>
                                                    <DataTrigger Binding="{Binding Kind}" Value="RecycleBin">
                                                        <Setter Property="Text" Value="&#xE74D;" />
                                                    </DataTrigger>
                                                    <DataTrigger Binding="{Binding Kind}" Value="ReadyToPlay">
                                                        <Setter Property="Text" Value="&#xE768;" />
                                                    </DataTrigger>
                                                    <DataTrigger Binding="{Binding Kind}" Value="NeedsSearch">
                                                        <Setter Property="Text" Value="&#xE721;" />
                                                    </DataTrigger>
                                                </Style.Triggers>
                                            </Style>
                                        </TextBlock.Style>
                                    </TextBlock>

                                    <!-- "#" öneki de sadece kullanıcı playlist'lerinde. -->
                                    <TextBlock Text="#" FontSize="11" Foreground="{StaticResource Brush.Text.Primary}">
                                        <TextBlock.Style>
                                            <Style TargetType="TextBlock">
                                                <Setter Property="Visibility" Value="Visible" />
                                                <Style.Triggers>
                                                    <DataTrigger Binding="{Binding IsBuiltIn}" Value="True">
                                                        <Setter Property="Visibility" Value="Collapsed" />
                                                    </DataTrigger>
                                                </Style.Triggers>
                                            </Style>
                                        </TextBlock.Style>
                                    </TextBlock>
                                    <TextBlock Text="{Binding Name, Mode=OneWay}" FontSize="11" Foreground="{StaticResource Brush.Text.Primary}" />
                                </StackPanel>
                            </Border>
                        </Button>
                    </DataTemplate>
                </ItemsControl.ItemTemplate>
            </ItemsControl>

            <!-- "+ Yeni Playlist" — tıklanınca inline bir textbox'a dönüşür (bkz.
                 IsCreatingPlaylist/NewPlaylistName), Enter ile CommitCreatePlaylistCommand'ı
                 tetikler. Kullanıcı kararı: sabit playlist adı yok, hepsi burada oluşturuluyor. -->
            <Button Command="{Binding BeginCreatePlaylistCommand}" Cursor="Hand"
                    Background="Transparent" BorderThickness="0" Content="+ Yeni Playlist"
                    Foreground="{StaticResource Brush.Text.Secondary}" FontSize="11">
                <Button.Style>
                    <Style TargetType="Button" BasedOn="{StaticResource {x:Type Button}}">
                        <Setter Property="Visibility" Value="Visible" />
                        <Style.Triggers>
                            <DataTrigger Binding="{Binding IsCreatingPlaylist}" Value="True">
                                <Setter Property="Visibility" Value="Collapsed" />
                            </DataTrigger>
                        </Style.Triggers>
                    </Style>
                </Button.Style>
            </Button>
            <TextBox Width="120" FontSize="11" VerticalContentAlignment="Center"
                     Text="{Binding NewPlaylistName, UpdateSourceTrigger=PropertyChanged}">
                <TextBox.Style>
                    <Style TargetType="TextBox">
                        <Setter Property="Visibility" Value="Collapsed" />
                        <Style.Triggers>
                            <DataTrigger Binding="{Binding IsCreatingPlaylist}" Value="True">
                                <Setter Property="Visibility" Value="Visible" />
                            </DataTrigger>
                        </Style.Triggers>
                    </Style>
                </TextBox.Style>
                <TextBox.InputBindings>
                    <KeyBinding Key="Enter" Command="{Binding CommitCreatePlaylistCommand}" />
                </TextBox.InputBindings>
            </TextBox>
            </StackPanel>
        </Border>

        <!-- ===================== Body ===================== -->
        <!-- Bu satır (Row 4, Height="*") pencerenin gerçek sol/sağ/alt kenarlarına değen TEK katman —
             üstü (0-3) başlık çubuğu/araç çubukları. Maximized'ta WindowChrome'un klasik "görünmez
             resize/frame kenarlığı" telafisi (bkz. MainWindow.xaml.cs ApplyMaximizedBodyInset) BURAYA,
             tek seferde uygulanıyor — sol/sağ/alt Margin (üst YOK, çünkü bu satırın üstü zaten pencere
             kenarına değmiyor, başlık çubuğu değiyor). Bu, hem sol Platformlar panelini hem GamesGrid'i
             hem sağdaki detay panelini TEK PARÇA halinde pencere kenarından içeri çekiyor — aralarında
             yapay bir boşluk/dikiş OLUŞMUYOR (panel açık/kapalı farketmez, ikisi de aynı satırın
             çocukları). Background açıkça Base'e eşitlendi ki bu Margin'in açığa çıkardığı şerit
             DataGrid'in kendi arkaplanıyla birebir eşleşsin. -->
        <Grid x:Name="BodyGrid" Grid.Row="4" Background="{StaticResource Brush.Background.Base}">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="220" />
                <ColumnDefinition Width="Auto" />
                <ColumnDefinition Width="*" />
                <!-- Sürgülü sağ panel: IsDetailPanelExpanded false iken 0'a iner, açıkken sabit
                     DetailPanelWidth'e döner. Kullanıcı kararıyla GridSplitter (kenardan tutup
                     sürükleme) kaldırıldı — panel artık sadece toolbar'daki aç/kapa düğmesiyle
                     (DetailPanelToggleButton) küçültülüp büyütülüyor, genişliği elle
                     değiştirilemiyor. BİLİNÇLİ OLARAK bir {Binding} DEĞİL — MainWindow.xaml.cs
                     (ApplyDetailPanelWidth) IsDetailPanelExpanded/DetailPanelWidth PropertyChanged'ını
                     dinleyip Width'i kendisi, elle set ediyor. -->
                <ColumnDefinition x:Name="DetailPanelColumnDef" Width="340" />
            </Grid.ColumnDefinitions>

            <!-- Left: Platforms -->
            <Border Grid.Column="0" Background="{StaticResource Brush.Background.Panel}">
                <DockPanel>
                    <TextBlock DockPanel.Dock="Top" Text="Platforms" FontWeight="Bold" Margin="10,10,10,6"
                               Foreground="{StaticResource Brush.Text.Primary}" />

                    <!-- Tek bir ListBox içinde hem kategori başlıkları (CONSOLES/HANDHELDS/ARCADE/
                         COMPUTERS/CLASSIC/OTHERS) hem platform satırları var (bkz. PlatformListItem).
                         WPF'in doğal grup desteği "bir grubu kapalı, diğerlerini açık" göstermeye uygun
                         olmadığından, görünür satır listesi ViewModel'de (RebuildPlatformListItems)
                         elle kuruluyor: "OTHERS" kapalıyken o kategorinin platform satırları listeye
                         hiç eklenmiyor. ItemContainerStyle ile normal başlıklar tıklanamaz hale
                         getiriliyor; "OTHERS" başlığı ise DataTemplate içindeki bir buton üzerinden
                         ToggleOthersCommand'ı tetikliyor. -->
                    <ListBox ItemsSource="{Binding PlatformListItems}" SelectedItem="{Binding SelectedListItem}"
                             ScrollViewer.HorizontalScrollBarVisibility="Disabled">
                        <ListBox.ItemContainerStyle>
                            <Style TargetType="ListBoxItem" BasedOn="{StaticResource {x:Type ListBoxItem}}">
                                <Setter Property="Padding" Value="8,3" />
                                <Style.Triggers>
                                    <DataTrigger Binding="{Binding IsNonInteractiveHeader}" Value="True">
                                        <Setter Property="IsHitTestVisible" Value="False" />
                                        <Setter Property="Focusable" Value="False" />
                                    </DataTrigger>
                                </Style.Triggers>
                            </Style>
                        </ListBox.ItemContainerStyle>
                        <ListBox.ItemTemplate>
                            <DataTemplate DataType="{x:Type models:PlatformListItem}">
                                <Grid>
                                    <!-- Kategori başlığı satırı -->
                                    <Grid Margin="4,10,4,4">
                                        <Grid.Style>
                                            <Style TargetType="Grid">
                                                <Setter Property="Visibility" Value="Collapsed" />
                                                <Style.Triggers>
                                                    <DataTrigger Binding="{Binding IsHeader}" Value="True">
                                                        <Setter Property="Visibility" Value="Visible" />
                                                    </DataTrigger>
                                                </Style.Triggers>
                                            </Style>
                                        </Grid.Style>

                                        <!-- Sabit (tıklanamaz) başlık: CONSOLES/HANDHELDS/ARCADE/COMPUTERS/CLASSIC -->
                                        <TextBlock Text="{Binding HeaderText}" FontWeight="Bold" FontSize="10"
                                                   Foreground="{StaticResource Brush.Text.Secondary}">
                                            <TextBlock.Style>
                                                <Style TargetType="TextBlock">
                                                    <Setter Property="Visibility" Value="Visible" />
                                                    <Style.Triggers>
                                                        <DataTrigger Binding="{Binding IsCollapsibleHeader}" Value="True">
                                                            <Setter Property="Visibility" Value="Collapsed" />
                                                        </DataTrigger>
                                                    </Style.Triggers>
                                                </Style>
                                            </TextBlock.Style>
                                        </TextBlock>

                                        <!-- Tıklanabilir başlık: sadece OTHERS, aç/kapa oku ile -->
                                        <Button Background="Transparent" BorderThickness="0" Padding="0" Cursor="Hand"
                                                HorizontalContentAlignment="Stretch"
                                                Command="{Binding DataContext.ToggleOthersCommand, RelativeSource={RelativeSource AncestorType=Window}}">
                                            <Button.Style>
                                                <Style TargetType="Button" BasedOn="{StaticResource {x:Type Button}}">
                                                    <Setter Property="Visibility" Value="Collapsed" />
                                                    <Style.Triggers>
                                                        <DataTrigger Binding="{Binding IsCollapsibleHeader}" Value="True">
                                                            <Setter Property="Visibility" Value="Visible" />
                                                        </DataTrigger>
                                                    </Style.Triggers>
                                                </Style>
                                            </Button.Style>
                                            <Button.Template>
                                                <ControlTemplate TargetType="Button">
                                                    <Grid Background="Transparent">
                                                        <Grid.ColumnDefinitions>
                                                            <ColumnDefinition Width="*" />
                                                            <ColumnDefinition Width="Auto" />
                                                        </Grid.ColumnDefinitions>
                                                        <TextBlock Grid.Column="0" Text="{Binding HeaderText}" FontWeight="Bold" FontSize="10"
                                                                   Foreground="{StaticResource Brush.Text.Secondary}" />
                                                        <TextBlock Grid.Column="1" Text="{Binding ExpandGlyph}" FontSize="9"
                                                                   Foreground="{StaticResource Brush.Text.Secondary}" />
                                                    </Grid>
                                                </ControlTemplate>
                                            </Button.Template>
                                        </Button>
                                    </Grid>

                                    <!-- Platform satırı. Tut-sürükle ile manuel sıralama, sürüklerken CANLI
                                         konumlanır (bkz. MainWindow.xaml.cs PlatformRow_DragOver ->
                                         MainViewModel.MoveInPlatformListItems, her üstünden geçilen satırda anında
                                         yer değiştirir; kalıcı kayıt sürükleme bitince CommitPlatformOrder ile) —
                                         kategoriler açıkken sadece aynı kategori içinde taşınabilir. -->
                                    <Grid AllowDrop="True"
                                          PreviewMouseLeftButtonDown="PlatformRow_PreviewMouseLeftButtonDown"
                                          MouseMove="PlatformRow_MouseMove"
                                          DragOver="PlatformRow_DragOver">
                                        <Grid.Style>
                                            <Style TargetType="Grid">
                                                <Setter Property="Visibility" Value="Visible" />
                                                <Style.Triggers>
                                                    <DataTrigger Binding="{Binding IsHeader}" Value="True">
                                                        <Setter Property="Visibility" Value="Collapsed" />
                                                    </DataTrigger>
                                                </Style.Triggers>
                                            </Style>
                                        </Grid.Style>
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="26" />
                                            <ColumnDefinition Width="*" />
                                            <ColumnDefinition Width="Auto" />
                                        </Grid.ColumnDefinitions>
                                        <!-- Ayarlar > Arayüz > Platform Listesi'nde "Logo" seçiliyse ad metni gizlenir,
                                             tam ad bu rozetin ToolTip'inde hâlâ erişilebilir kalır. -->
                                        <Border Grid.Column="0" Width="22" Height="22" CornerRadius="4"
                                                Background="{StaticResource Brush.Background.Elevated}"
                                                ToolTip="{Binding Platform.DisplayName}">
                                            <TextBlock Text="{Binding Platform.IconGlyph}" FontSize="7" FontWeight="Bold"
                                                       HorizontalAlignment="Center" VerticalAlignment="Center"
                                                       Foreground="{StaticResource Brush.Text.Secondary}" />
                                        </Border>
                                        <TextBlock Grid.Column="1" Text="{Binding Platform.DisplayName}" VerticalAlignment="Center"
                                                   Margin="6,0,4,0" TextTrimming="CharacterEllipsis" ToolTip="{Binding Platform.Name}">
                                            <TextBlock.Style>
                                                <Style TargetType="TextBlock">
                                                    <Style.Triggers>
                                                        <DataTrigger Binding="{Binding DataContext.PlatformListDisplayMode, RelativeSource={RelativeSource AncestorType=Window}}" Value="Logo">
                                                            <Setter Property="Visibility" Value="Collapsed" />
                                                        </DataTrigger>
                                                    </Style.Triggers>
                                                </Style>
                                            </TextBlock.Style>
                                        </TextBlock>
                                        <Border Grid.Column="2" Background="{StaticResource Brush.Background.Elevated}"
                                                BorderBrush="{StaticResource Brush.Border}" BorderThickness="1"
                                                CornerRadius="8" Padding="6,1" VerticalAlignment="Center">
                                            <TextBlock Text="{Binding Platform.GameCount}" FontSize="10"
                                                       Foreground="{StaticResource Brush.Text.Secondary}" />
                                        </Border>
                                    </Grid>
                                </Grid>
                            </DataTemplate>
                        </ListBox.ItemTemplate>
                    </ListBox>
                </DockPanel>
            </Border>

            <GridSplitter Grid.Column="1" Width="1" HorizontalAlignment="Stretch"
                          Background="{StaticResource Brush.Border}" />

            <!-- Center: Game grid.
                 Sanallaştırma (virtualization) özellikleri, binlerce satırlık gerçek verilerle
                 kullanıldığında kaydırma sırasında kasmayı önlemek için bilinçli olarak açık:
                 sadece ekranda görünen satırlar için UI elemanı oluşturulur, kaydırırken
                 elemanlar oluşturulup atılmak yerine "Recycling" moduyla yeniden kullanılır.
                 Aradaki 4px boşluk kaldırıldı: scrollbar artık kendi (Elevated) arkaplanıyla zaten
                 net bir şekilde ayırt edilebiliyor (bkz. ObsidianDark.xaml ScrollBar Style), bu
                 yüzden sağ paneldeki aç/kapa tutamacıyla arasına ayrıca boşluk bırakmaya gerek
                 kalmadı — tutamaç artık scrollbar'a bitişik duruyor.

                 EnableColumnVirtualization="False": sütun sanallaştırması ~19 sütun için zaten bir
                 fayda sağlamıyor (asıl performans kazancı 67 bin SATIR için EnableRowVirtualization'da) —
                 kesin sebep olduğu doğrulanmasa da gereksiz karmaşıklık olduğu için kapalı bırakıldı.

                 SADECE pencere Maximized iken dikey scrollbar pencere kenarının bir kısmını aşıp
                 kırpılıyordu (normal pencerede hiç olmuyor) — WindowChrome'un klasik "maximize
                 taşması": WM_GETMINMAXINFO (bkz. WmGetMinMaxInfo) pencerenin DIŞ boyutunu work area'ya
                 birebir eşitliyor, ama Windows'un görünmez resize/frame kenarlığı (SystemParameters.
                 WindowResizeBorderThickness + WindowNonClientFrameThickness, DPI'a göre değişir) yine
                 de içerik tarafında hesaba katılmıyor. Düzeltme MainWindow.xaml.cs'te (StateChanged) —
                 sabit bir piksel sayısı yerine bu iki SystemParameters değerini TOPLAYIP GamesGrid'e
                 sağ Margin olarak uyguluyor, böylece farklı DPI ölçeklerinde de doğru kalıyor. -->
            <!-- Kullanıcı bulgusu: "hızlıca inmeye çalıştığımda kare kare iniyor" — ScrollUnit
                 belirtilmeyince VirtualizingPanel varsayılan olarak "Item" kullanır: her tekerlek/
                 sürükleme hareketi TAM SATIR adımlarıyla atlar, hızlı kaydırmayı "kare kare"
                 (basamaklı) hissettirir. "Pixel" sanallaştırmayı (Recycling) KORUYARAK akıcı, piksel
                 bazlı kaydırma sağlıyor.
                 CacheLength="1,1" (Page birimiyle): görünür alanın ÜSTÜNDE/ALTINDA birer "sayfa"
                 satır önceden hazırlanıp saklanıyor (varsayılan çok daha dar bir tampon kullanır) —
                 hızlı kaydırmada aynı anda çok fazla YENİ satırın tek bir layout/render geçişine
                 yığılmasını azaltıyor (bkz. dotnet-trace profilinde tekli 100-200ms'lik
                 UpdateLayout/RenderMessageHandlerCore geçişleri).
                 Kullanıcı bulgusu: "mouse ile scrollu taşırken eş zamanlı gelmiyor, scrollbar
                 geriden geliyor" — IsDeferredScrollingEnabled="True" denendi (sürükleme sırasında
                 içerik hiç kaymayıp SADECE fare bırakılınca bir kez atlıyordu) ama bu "önce hiçbir
                 şey olmuyor, sonra aniden zıplıyor" hissi orijinal (hafif gecikmeli ama SÜREKLİ takip
                 eden) davranıştan daha rahatsız ediciydi — geri alındı. -->
            <DataGrid x:Name="GamesGrid" Grid.Column="2"
                      ItemsSource="{Binding Games}"
                      SelectedItem="{Binding SelectedGame}"
                      RowHeight="{Binding RowHeight}"
                      CanUserSortColumns="False"
                      EnableRowVirtualization="True"
                      EnableColumnVirtualization="False"
                      VirtualizingPanel.IsVirtualizing="True"
                      VirtualizingPanel.VirtualizationMode="Recycling"
                      VirtualizingPanel.ScrollUnit="Pixel"
                      VirtualizingPanel.CacheLengthUnit="Page"
                      VirtualizingPanel.CacheLength="1,1"
                      ScrollViewer.CanContentScroll="True"
                      ScrollViewer.HorizontalScrollBarVisibility="Auto"
                      PreviewMouseRightButtonUp="GamesGrid_PreviewMouseRightButtonUp"
                      PreviewMouseWheel="GamesGrid_PreviewMouseWheel"
                      ColumnReordered="GamesGrid_ColumnReordered">
                <!-- ROM'u eksik satırlar soluklaştırılır ki Play/Search sütunundaki farkın dışında da
                     eksik olan satırlar gözle bir bakışta ayırt edilebilsin. Soluklaştırma ROW değil
                     HÜCRE seviyesinde uygulanıyor (bkz. ObsidianDark.xaml DataGridCell Style.Triggers) —
                     Opacity DataGridRow'a uygulanırsa, satırın varsayılan şablonundaki yatay ayırıcı
                     çizgi (BottomGridLine) de aynı satırın görsel ağacının parçası olduğu için onunla
                     birlikte soluyor, bu da satırdan satıra farklı renkte/tonda çizgilere yol açıyordu
                     ("yatay çizgilerin rengi değişkenlik yapıyor" hatası). Hücre seviyesinde uygulamak
                     çizgiyi (satır şablonunun bir parçası, hücrelerin DIŞINDA) tamamen etkilemeden
                     bırakıyor, sadece hücre içeriği (metin/ikon/resim) soluyor. -->
                <DataGrid.Columns>
                    <DataGridTemplateColumn x:Name="MatchedColumn" Header="{Binding Data.MatchedFilter, Source={StaticResource ViewModelProxy}}"
                                             HeaderTemplate="{StaticResource FilterableColumnHeader}" Width="34">
                        <DataGridTemplateColumn.CellTemplate>
                            <DataTemplate DataType="{x:Type models:Game}">
                                <!-- Kullanıcı isteği: "Manuel eklenenleride durum kısmında ayrı
                                     kategoriyle işaretle ünlem olabilir mesela" — manuel bağlı
                                     satırlarda StatusOk'un (verified/eşleşmedi) ✓/✗ ikonu YERİNE,
                                     ROM'un CRC doğrulanmış gibi SUNULMAMASI için ayrı bir üçüncü
                                     durum: amber "!" (bkz. Game.IsManuallyLinked). -->
                                <TextBlock FontFamily="Segoe MDL2 Assets" HorizontalAlignment="Center">
                                    <TextBlock.Style>
                                        <Style TargetType="TextBlock">
                                            <!-- Kullanıcı isteği: "libretronun metadatasını da entegre
                                                 edelim, 2'sinden biriyle eşleşirse eşleşmedi çıkmasın" —
                                                 StatusOk yerine IsEffectivelyMatched (bkz. Game.cs) —
                                                 gerçek metadata eşleşmesi olmasa bile herhangi bir
                                                 kaynaktan görsel bulunmuşsa artık ✓ gösteriliyor. -->
                                            <Setter Property="Text" Value="{Binding IsEffectivelyMatched, Converter={StaticResource BoolToStatusGlyph}}" />
                                            <Setter Property="Foreground" Value="{Binding IsEffectivelyMatched, Converter={StaticResource BoolToStatusBrush}}" />
                                            <Style.Triggers>
                                                <!-- Kullanıcı isteği (geri alındı): "3 ününde durum
                                                     kısmında ünlem çıkıyor hala çıkmasın eşleştiyse" —
                                                     amber "!" artık SADECE manuel bağlı VE hâlâ hiçbir
                                                     kaynaktan görsel/metadata bulunamamışsa gösteriliyor;
                                                     manuel bağlı olup IsEffectivelyMatched=true olan
                                                     satırlarda normal ✓ görünüyor (yukarıdaki Setter). -->
                                                <MultiDataTrigger>
                                                    <MultiDataTrigger.Conditions>
                                                        <Condition Binding="{Binding IsManuallyLinked}" Value="True" />
                                                        <Condition Binding="{Binding IsEffectivelyMatched}" Value="False" />
                                                    </MultiDataTrigger.Conditions>
                                                    <Setter Property="Text" Value="&#xE7BA;" />
                                                    <Setter Property="Foreground" Value="{StaticResource Brush.Accent.Amber}" />
                                                </MultiDataTrigger>
                                            </Style.Triggers>
                                        </Style>
                                    </TextBlock.Style>
                                </TextBlock>
                            </DataTemplate>
                        </DataGridTemplateColumn.CellTemplate>
                    </DataGridTemplateColumn>

                    <!-- Genişlik 44'ten 70'e çıkarıldı: Clear Logo'lar genelde geniş/yatay (kare
                         değil) görseller, eski dar 28x28 kare alanda çok küçülüp kötü görünüyordu
                         (kullanıcı geri bildirimi: "sığmıyor"). Stretch=Uniform kırpma yapmadan
                         orijinal en/boy oranını koruyor, sadece daha geniş alanda daha büyük çiziyor. -->
                    <DataGridTemplateColumn x:Name="LogoColumn" Header="Logo" Width="70">
                        <DataGridTemplateColumn.CellTemplate>
                            <DataTemplate DataType="{x:Type models:Game}">
                                <!-- Kullanıcı isteği: "tabloda clear logosu olmayanlarda da bizim logo.png
                                     gözükecek" — artık boş bir placeholder Border yerine ClearLogoThumbnailPath
                                     (gerçek logo yoksa Logo.png) her zaman gösteriliyor. -->
                                <Grid Width="64" Height="28">
                                    <!-- RenderOptions.BitmapScalingMode="HighQuality": genişlik sorunu değil,
                                         WPF'in varsayılan ölçekleme modu büyük kaynak görselleri küçük bir
                                         hücreye sığdırırken bulanık/pikselli çiziyordu (kullanıcı geri
                                         bildirimi: LaunchBox'ta net görünen logolar burada bulanık).
                                         ThumbnailImage converter: kaynak dosya tam çözünürlükte (600px'e
                                         kadar) decode edilip SONRA küçültülmek yerine, decoder'a baştan
                                         küçük hedef genişlik veriliyor — hızlı kaydırırken (Recycling
                                         virtualization, her yeni satır kendi decode'unu tetikliyor) gözle
                                         görülür bir performans sorununa yol açıyordu (kullanıcı geri
                                         bildirimi). ConverterParameter=128: 64px'lik hücre için 2x (HiDPI). -->
                                    <!-- Kullanıcı bulgusu: "hızlı kaydırırken bazı noktalarda takılma" —
                                         IsAsync=True denendi ama görseller bir an boş gelip SONRA
                                         "pop" ederek beliriyordu ("orjinalliği gidiyor" — cilasız/
                                         yamalı hissettiriyordu), bu yüzden geri alındı. Asıl çözüm
                                         gerçek bir ÖN BELLEKLEME: kütüphane yüklendikten sonra tüm
                                         logo görselleri arka planda (düşük öncelikli) önceden decode
                                         edilip ThumbnailImageConverter'ın önbelleğine yazılıyor (bkz.
                                         MainViewModel.PrewarmThumbnailCache) — kullanıcı o satıra
                                         kaydırdığında görsel ZATEN önbellekte, senkron/anlık gösteriliyor. -->
                                    <Image Stretch="Uniform" Source="{Binding ClearLogoThumbnailPath, Converter={StaticResource ThumbnailImage}, ConverterParameter=128}"
                                           RenderOptions.BitmapScalingMode="HighQuality" />
                                </Grid>
                            </DataTemplate>
                        </DataGridTemplateColumn.CellTemplate>
                    </DataGridTemplateColumn>

                    <!-- Gizle/Göster artık AYRI, her zaman en solda sabit bir sütun (kullanıcı isteği:
                         "en sola sabitle onu değişmesin yeri") — normal sağ-tık ile pinleme/kaldırma
                         mekanizmasına HİÇ girmiyor, MainWindow.xaml.cs ApplyColumnPinningPositions
                         her çağrıda bunu zorla _pinnedLeftKeys listesinin başına koyuyor, kullanıcı
                         sağ-tıklayıp "Sabitlemeyi Kaldır" dese bile bir sonraki uygulamada geri
                         zorlanıyor. Header düz metin ("Gizle") — filtresi yok. -->
                    <DataGridTemplateColumn x:Name="HideColumn" Header=""
                                             HeaderStyle="{StaticResource CenteredColumnHeaderStyle}" Width="40">
                        <DataGridTemplateColumn.CellTemplate>
                            <DataTemplate DataType="{x:Type models:Game}">
                                <Button HorizontalAlignment="Center">
                                    <Button.Style>
                                        <Style TargetType="Button" BasedOn="{StaticResource ActionsIconButton}">
                                            <Setter Property="Command" Value="{Binding DataContext.HideGameCommand, RelativeSource={RelativeSource AncestorType=Window}}" />
                                            <Setter Property="CommandParameter" Value="{Binding}" />
                                            <Setter Property="ToolTip" Value="Gizle" />
                                            <Style.Triggers>
                                                <DataTrigger Binding="{Binding IsHidden}" Value="True">
                                                    <Setter Property="Command" Value="{Binding DataContext.UnhideGameCommand, RelativeSource={RelativeSource AncestorType=Window}}" />
                                                    <Setter Property="ToolTip" Value="Göster" />
                                                </DataTrigger>
                                            </Style.Triggers>
                                        </Style>
                                    </Button.Style>
                                    <TextBlock Text="&#xE7B3;" FontFamily="Segoe MDL2 Assets" FontSize="13" VerticalAlignment="Center">
                                        <TextBlock.Style>
                                            <Style TargetType="TextBlock">
                                                <Setter Property="Foreground" Value="{StaticResource Brush.Text.Secondary}" />
                                                <Style.Triggers>
                                                    <DataTrigger Binding="{Binding IsHidden}" Value="True">
                                                        <Setter Property="Foreground" Value="{StaticResource Brush.Accent.Amber}" />
                                                    </DataTrigger>
                                                </Style.Triggers>
                                            </Style>
                                        </TextBlock.Style>
                                    </TextBlock>
                                </Button>
                            </DataTemplate>
                        </DataGridTemplateColumn.CellTemplate>
                    </DataGridTemplateColumn>

                    <!-- Favori/Ara(Play) tek "Actions" sütununda birleştirildi (kullanıcı isteği) —
                         Gizle artık ayrı bir sütun (yukarıda, HideColumn). Filtreleri de (Favori,
                         Dosya) TEK bir popup'tan yönetiliyor (bkz. Window.Resources
                         ActionsColumnFilterHeader, MainViewModel.ActionsFilter,
                         Models/ActionsColumnFilterViewModel). -->
                    <DataGridTemplateColumn x:Name="ActionsColumn" Header="{Binding Data.ActionsFilter, Source={StaticResource ViewModelProxy}}"
                                             HeaderTemplate="{StaticResource ActionsColumnFilterHeader}"
                                             HeaderStyle="{StaticResource CenteredColumnHeaderStyle}" Width="95">
                        <DataGridTemplateColumn.CellTemplate>
                            <DataTemplate DataType="{x:Type models:Game}">
                                <StackPanel Orientation="Horizontal" HorizontalAlignment="Center">
                                    <!-- Favori: düz Unicode karakter (emoji değil), dolu (★)/boş (☆). Star
                                         glyph'i çoğu fontta em kutusunun ALTINA yakın çiziliyor (üstte
                                         boşluk kalıyor) — bu yüzden container tam ortalasa bile gözle
                                         "aşağıda kalmış" görünüyordu; -2px'lik üst Margin bunu telafi
                                         ediyor. -->
                                    <Button Style="{StaticResource ActionsIconButton}"
                                            Command="{Binding DataContext.ToggleFavoriteCommand, RelativeSource={RelativeSource AncestorType=Window}}"
                                            CommandParameter="{Binding}" Margin="0,0,10,0" ToolTip="Favorilere ekle/çıkar">
                                        <TextBlock FontSize="15" VerticalAlignment="Center" Margin="0,-2,0,0">
                                            <TextBlock.Style>
                                                <Style TargetType="TextBlock">
                                                    <Setter Property="Text" Value="☆" />
                                                    <Setter Property="Foreground" Value="{StaticResource Brush.Text.Secondary}" />
                                                    <Style.Triggers>
                                                        <DataTrigger Binding="{Binding IsFavorite}" Value="True">
                                                            <Setter Property="Text" Value="★" />
                                                            <Setter Property="Foreground" Value="{StaticResource Brush.Accent.Amber}" />
                                                        </DataTrigger>
                                                    </Style.Triggers>
                                                </Style>
                                            </TextBlock.Style>
                                        </TextBlock>
                                    </Button>

                                    <!-- Görsel Getir: Box/Background/Screenshot/Logo görsellerini arayıp
                                         indirir (bkz. MainViewModel.FetchArtworkCommand). Eşleşmiş bir
                                         metadata kaydı yoksa (HasArtworkSource=False) aranacak bir şey
                                         olmadığı için devre dışı. Kullanıcı geri bildirimi: "bütün
                                         resimler indirildiğinde deaktif gözükmesin ... o çerçeve
                                         gözükmesin" — tüm görseller zaten varsa (HasMissingArtwork=
                                         False) soluk/devre dışı göstermek yerine gizleniyor; SONRA
                                         gelen geri bildirim: "artwork alanı boşalınca play iconu sola
                                         kaymasın" — Collapsed (bkz. BoolToVisibility) layout alanını
                                         TAMAMEN kaldırıp sonraki ikonun (Başlat) sola kaymasına yol
                                         açıyordu; Hidden ile boyut/hizalama korunuyor, sadece boyanmıyor
                                         (Collapsed'a göre hâlâ ölçülüyor ama satır hizası bozulmuyor). -->
                                    <Button Command="{Binding DataContext.FetchArtworkCommand, RelativeSource={RelativeSource AncestorType=Window}}"
                                            CommandParameter="{Binding}" Margin="0,0,10,0"
                                            IsEnabled="{Binding CanFetchArtwork}"
                                            ToolTip="Görsel getir">
                                        <Button.Style>
                                            <Style TargetType="Button" BasedOn="{StaticResource ActionsIconButton}">
                                                <Style.Triggers>
                                                    <DataTrigger Binding="{Binding HasMissingArtwork}" Value="False">
                                                        <Setter Property="Visibility" Value="Hidden" />
                                                    </DataTrigger>
                                                </Style.Triggers>
                                            </Style>
                                        </Button.Style>
                                        <TextBlock Text="&#xE91B;" FontFamily="Segoe MDL2 Assets" FontSize="13"
                                                   Foreground="{StaticResource Brush.Text.Secondary}" />
                                    </Button>

                                    <!-- Ara (eksik ROM) / Başlat (ROM mevcut) — ikisi de aynı hücrede,
                                         HasLocalFile'a göre karşılıklı Visibility ile. -->
                                    <Grid>
                                        <Button Command="{Binding DataContext.SearchWebCommand, RelativeSource={RelativeSource AncestorType=Window}}"
                                                CommandParameter="{Binding}" ToolTip="Eksik ROM'u web'de ara">
                                            <Button.Style>
                                                <Style TargetType="Button" BasedOn="{StaticResource ActionsIconButton}">
                                                    <Setter Property="Visibility" Value="Collapsed" />
                                                    <Style.Triggers>
                                                        <DataTrigger Binding="{Binding HasLocalFile}" Value="False">
                                                            <Setter Property="Visibility" Value="Visible" />
                                                        </DataTrigger>
                                                    </Style.Triggers>
                                                </Style>
                                            </Button.Style>
                                            <Grid Width="14" Height="14">
                                                <Ellipse Width="9" Height="9" Stroke="{StaticResource Brush.Text.Secondary}"
                                                         StrokeThickness="1.5" HorizontalAlignment="Left" VerticalAlignment="Top" />
                                                <Line X1="8" Y1="8" X2="13" Y2="13" Stroke="{StaticResource Brush.Text.Secondary}" StrokeThickness="1.5" />
                                            </Grid>
                                        </Button>

                                        <Button Command="{Binding DataContext.LaunchGameCommand, RelativeSource={RelativeSource AncestorType=Window}}"
                                                CommandParameter="{Binding}">
                                            <Button.Style>
                                                <Style TargetType="Button" BasedOn="{StaticResource ActionsIconButton}">
                                                    <Setter Property="Visibility" Value="Collapsed" />
                                                    <Style.Triggers>
                                                        <DataTrigger Binding="{Binding HasLocalFile}" Value="True">
                                                            <Setter Property="Visibility" Value="Visible" />
                                                        </DataTrigger>
                                                    </Style.Triggers>
                                                </Style>
                                            </Button.Style>
                                            <!-- Kullanıcı isteği: "manuel bağlanan kayıtlar ... ana
                                                 tabloda açıkça rozet gösterilsin" — CRC doğrulanmış
                                                 normal eşleşme mavi, manuel bağlantı Amber (bkz.
                                                 Game.IsManuallyLinked). Ayrı bir sütun DEĞİL, zaten
                                                 var olan Başlat ikonunun rengi/tooltip'i. -->
                                            <Button.ToolTip>
                                                <TextBlock>
                                                    <TextBlock.Style>
                                                        <Style TargetType="TextBlock">
                                                            <Setter Property="Text" Value="Oyunu başlat" />
                                                            <Style.Triggers>
                                                                <DataTrigger Binding="{Binding IsManuallyLinked}" Value="True">
                                                                    <Setter Property="Text" Value="Oyunu başlat — Manuel Bağlantı (Linked, doğrulanmamış)" />
                                                                </DataTrigger>
                                                            </Style.Triggers>
                                                        </Style>
                                                    </TextBlock.Style>
                                                </TextBlock>
                                            </Button.ToolTip>
                                            <TextBlock Text="&#xE768;" FontFamily="Segoe MDL2 Assets" FontSize="13">
                                                <TextBlock.Style>
                                                    <Style TargetType="TextBlock">
                                                        <Setter Property="Foreground" Value="{StaticResource Brush.Accent.SelectedBorder}" />
                                                        <Style.Triggers>
                                                            <DataTrigger Binding="{Binding IsManuallyLinked}" Value="True">
                                                                <Setter Property="Foreground" Value="{StaticResource Brush.Accent.Amber}" />
                                                            </DataTrigger>
                                                        </Style.Triggers>
                                                    </Style>
                                                </TextBlock.Style>
                                            </TextBlock>
                                        </Button>
                                    </Grid>
                                </StackPanel>
                            </DataTemplate>
                        </DataGridTemplateColumn.CellTemplate>
                    </DataGridTemplateColumn>

                    <!-- Sütunlar artık oransal (*) değil sabit piksel genişlikte — DataGrid'in
                         kendi yatay kaydırma çubuğunun devreye girmesi (sütunların sıkışıp
                         küçülmesi yerine) için bu şart: "*" ile genişlik her zaman mevcut alana
                         göre yeniden dağıtılır ve taşma/scroll hiç oluşmaz. -->
                    <DataGridTextColumn x:Name="TitleColumn" Header="{Binding Data.TitleFilter, Source={StaticResource ViewModelProxy}}"
                                         HeaderTemplate="{StaticResource TitleColumnHeaderWithHealth}"
                                         Binding="{Binding Title}" SortMemberPath="Title" Width="220" />

                    <DataGridTemplateColumn x:Name="BoxColumn" Header="{Binding Data.BoxFilter, Source={StaticResource ViewModelProxy}}"
                                             HeaderTemplate="{StaticResource FilterableColumnHeader}"
                                             HeaderStyle="{StaticResource CenteredColumnHeaderStyle}" Width="40">
                        <DataGridTemplateColumn.CellTemplate>
                            <DataTemplate DataType="{x:Type models:Game}">
                                <Ellipse Width="10" Height="10" HorizontalAlignment="Center" Fill="{Binding HasBox, Converter={StaticResource BoolToStatusBrush}}" />
                            </DataTemplate>
                        </DataGridTemplateColumn.CellTemplate>
                    </DataGridTemplateColumn>

                    <DataGridTemplateColumn x:Name="ScreenshotColumn" Header="{Binding Data.ScreenshotFilter, Source={StaticResource ViewModelProxy}}"
                                             HeaderTemplate="{StaticResource FilterableColumnHeader}"
                                             HeaderStyle="{StaticResource CenteredColumnHeaderStyle}" Width="40">
                        <DataGridTemplateColumn.CellTemplate>
                            <DataTemplate DataType="{x:Type models:Game}">
                                <Ellipse Width="10" Height="10" HorizontalAlignment="Center" Fill="{Binding HasScreenshot, Converter={StaticResource BoolToStatusBrush}}" />
                            </DataTemplate>
                        </DataGridTemplateColumn.CellTemplate>
                    </DataGridTemplateColumn>

                    <DataGridTextColumn x:Name="FileColumn" Header="{Binding Data.FileFilter, Source={StaticResource ViewModelProxy}}"
                                         HeaderTemplate="{StaticResource FilterableColumnHeader}"
                                         Binding="{Binding File}" SortMemberPath="File" Width="200" />
                    <!-- Düz metin (kullanıcı kararı: tabloda logo değil metin, logo sadece detay
                         panelinde gösterilsin — bkz. aşağıda "Platform" satırı).
                         Kullanıcı isteği: "platform sütununu all platform harici kaldıralım all
                         platformda gözüksün sadece zaten seçilende yukarda eşşek kadar yazıyor" —
                         belirli bir platform seçiliyken adı zaten "Başlık" sütun başlığındaki logoda
                         büyük gösteriliyor, bu sütun o durumda gereksiz tekrar oluyor (bkz.
                         MainViewModel.PlatformColumnVisibility). DataGridColumn görsel ağacın
                         parçası olmadığı için Visibility XAML'de DOĞRUDAN bağlanamıyor (bkz.
                         MainWindow.xaml.cs WireColumnVisibility yorumu) — o yüzden burada binding
                         YOK, kod-arkasında (UpdatePlatformColumnVisibility) hem "Sütunlar"
                         checkbox'ıyla hem SelectedPlatform'la birlikte yönetiliyor. -->
                    <DataGridTextColumn x:Name="PlatformColumn" Header="{Binding Data.PlatformFilter, Source={StaticResource ViewModelProxy}}" HeaderTemplate="{StaticResource FilterableColumnHeader}"
                                         Binding="{Binding PlatformDisplayName}" SortMemberPath="PlatformDisplayName" Width="160" />
                    <!-- Kullanıcı isteği: "tablodaki türleri 1. resimdeki gibi tıklanıp
                         filtrelenebilir badge yapabilirmisin ... emulator ayarlarındaki platform
                         listesinin badgeleri" — düz metin yerine her tür token'ı için ayrı, tıklanınca
                         GenresFilter'ı o türe göre uygulayan (bkz. MainViewModel.
                         FilterByGenreTokenCommand) bir rozet (bkz. Themes/ObsidianDark.xaml
                         GenreBadgeButton, PlatformNameBadge ile AYNI görsel dil). -->
                    <DataGridTemplateColumn x:Name="GenresColumn" Header="{Binding Data.GenresFilter, Source={StaticResource ViewModelProxy}}" HeaderTemplate="{StaticResource FilterableColumnHeader}"
                                             SortMemberPath="Genres" Width="220">
                        <DataGridTemplateColumn.CellTemplate>
                            <DataTemplate DataType="{x:Type models:Game}">
                                <!-- Kullanıcı bulgusu: "kaydırırken takılma" — profilleme (dotnet-trace)
                                     satır geri dönüşümünün en pahalı kısmının görsel ağaç boyutuyla
                                     orantılı olduğunu gösterdi; GenreTokensPreview (bkz. Game.cs) en
                                     fazla 4 rozet üretiyor, taşkın "+N" düz metinle özetleniyor. -->
                                <WrapPanel Orientation="Horizontal" VerticalAlignment="Center">
                                    <ItemsControl ItemsSource="{Binding GenreTokensPreview}" Focusable="False">
                                        <ItemsControl.ItemsPanel>
                                            <ItemsPanelTemplate>
                                                <WrapPanel Orientation="Horizontal" />
                                            </ItemsPanelTemplate>
                                        </ItemsControl.ItemsPanel>
                                        <ItemsControl.ItemTemplate>
                                            <DataTemplate>
                                                <Button Style="{StaticResource GenreBadgeButton}"
                                                        Command="{Binding DataContext.FilterByGenreTokenCommand, RelativeSource={RelativeSource AncestorType=Window}}"
                                                        CommandParameter="{Binding}" Content="{Binding}" />
                                            </DataTemplate>
                                        </ItemsControl.ItemTemplate>
                                    </ItemsControl>
                                    <TextBlock Text="{Binding GenreOverflowLabel}" VerticalAlignment="Center"
                                               FontSize="10" Margin="2,0,0,0" Foreground="{StaticResource Brush.Text.Secondary}"
                                               Visibility="{Binding HasGenreOverflow, Converter={StaticResource BoolToVisibility}}" />
                                </WrapPanel>
                            </DataTemplate>
                        </DataGridTemplateColumn.CellTemplate>
                    </DataGridTemplateColumn>

                    <!-- Aşağıdaki sütunlar varsayılan gizli (bkz. ColumnOptions) — "Sütunlar" düğmesiyle
                         açılıp kapanır, kod-arkası (MainWindow.xaml.cs) x:Name üzerinden yönetir. -->
                    <!-- Detay panelindeki gibi altın/amber renkli yıldız gösterimi (bkz. Game.
                         CommunityRatingDisplay) — düz DataGridTextColumn'da metin varsayılan
                         renkte kalıyordu, TemplateColumn ile Foreground uygulanabiliyor. -->
                    <DataGridTemplateColumn x:Name="CommunityRatingColumn" Header="{Binding Data.CommunityRatingFilter, Source={StaticResource ViewModelProxy}}"
                                             HeaderTemplate="{StaticResource FilterableColumnHeader}"
                                             SortMemberPath="CommunityRating" Width="110" Visibility="Collapsed">
                        <DataGridTemplateColumn.CellTemplate>
                            <DataTemplate DataType="{x:Type models:Game}">
                                <TextBlock Text="{Binding CommunityRatingDisplay}" VerticalAlignment="Center"
                                           Foreground="{StaticResource Brush.Accent.Amber}" />
                            </DataTemplate>
                        </DataGridTemplateColumn.CellTemplate>
                    </DataGridTemplateColumn>
                    <DataGridTextColumn x:Name="PublisherColumn" Header="{Binding Data.PublisherFilter, Source={StaticResource ViewModelProxy}}"
                                         HeaderTemplate="{StaticResource FilterableColumnHeader}"
                                         Binding="{Binding Publisher}" SortMemberPath="Publisher" Width="140" Visibility="Collapsed" />
                    <DataGridTextColumn x:Name="MaxPlayersColumn" Header="{Binding Data.MaxPlayersFilter, Source={StaticResource ViewModelProxy}}"
                                         HeaderTemplate="{StaticResource FilterableColumnHeader}"
                                         HeaderStyle="{StaticResource CenteredColumnHeaderStyle}"
                                         Binding="{Binding MaxPlayersDisplay}" SortMemberPath="MaxPlayers" Width="90" Visibility="Collapsed">
                        <DataGridTextColumn.ElementStyle>
                            <Style TargetType="TextBlock">
                                <Setter Property="HorizontalAlignment" Value="Center" />
                                <Setter Property="TextAlignment" Value="Center" />
                            </Style>
                        </DataGridTextColumn.ElementStyle>
                    </DataGridTextColumn>
                    <!-- Kullanıcı isteği: "tablodaki Region'da Bayrak Text / Text Bayrak / Bayrak /
                         Sadece Text seçeneği koy" (bkz. Ayarlar > Arayüz, AppSettings.
                         RegionColumnDisplayMode). Dört mod da AYNI Grid içinde, hangisinin
                         görüneceği DataTrigger ile MainViewModel.RegionColumnDisplayMode'a göre
                         belirleniyor — ContextMenuLabelText'teki AYNI RelativeSource=Window deseni. -->
                    <DataGridTemplateColumn x:Name="RegionColumn" Header="{Binding Data.RegionFilter, Source={StaticResource ViewModelProxy}}"
                                             HeaderTemplate="{StaticResource FilterableColumnHeader}"
                                             SortMemberPath="Region" Width="90" Visibility="Collapsed">
                        <DataGridTemplateColumn.CellTemplate>
                            <DataTemplate DataType="{x:Type models:Game}">
                                <!-- Grid (StackPanel değil) KASITLI: "Text + Bayrak" modunda sırayı
                                     GERÇEKTEN değiştirmek (sadece Visibility ile değil) için Image/
                                     TextBlock'un Grid.Column'ı DataTrigger ile takas ediliyor. -->
                                <Grid VerticalAlignment="Center">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="Auto" />
                                        <ColumnDefinition Width="Auto" />
                                    </Grid.ColumnDefinitions>
                                    <Image Grid.Column="0" Width="14" Height="14" Margin="0,0,5,0" VerticalAlignment="Center"
                                           RenderOptions.BitmapScalingMode="HighQuality"
                                           Source="{Binding Region, Converter={StaticResource RegionToFlag}}">
                                        <Image.Style>
                                            <Style TargetType="Image">
                                                <Setter Property="Visibility" Value="Visible" />
                                                <Style.Triggers>
                                                    <DataTrigger Binding="{Binding DataContext.RegionColumnDisplayMode, RelativeSource={RelativeSource AncestorType=Window}}" Value="TextOnly">
                                                        <Setter Property="Visibility" Value="Collapsed" />
                                                    </DataTrigger>
                                                    <DataTrigger Binding="{Binding DataContext.RegionColumnDisplayMode, RelativeSource={RelativeSource AncestorType=Window}}" Value="TextAndFlag">
                                                        <Setter Property="Grid.Column" Value="1" />
                                                        <Setter Property="Margin" Value="5,0,0,0" />
                                                    </DataTrigger>
                                                </Style.Triggers>
                                            </Style>
                                        </Image.Style>
                                    </Image>
                                    <TextBlock Grid.Column="1" Text="{Binding Region}" VerticalAlignment="Center">
                                        <TextBlock.Style>
                                            <Style TargetType="TextBlock">
                                                <Setter Property="Visibility" Value="Visible" />
                                                <Style.Triggers>
                                                    <DataTrigger Binding="{Binding DataContext.RegionColumnDisplayMode, RelativeSource={RelativeSource AncestorType=Window}}" Value="FlagOnly">
                                                        <Setter Property="Visibility" Value="Collapsed" />
                                                    </DataTrigger>
                                                    <DataTrigger Binding="{Binding DataContext.RegionColumnDisplayMode, RelativeSource={RelativeSource AncestorType=Window}}" Value="TextAndFlag">
                                                        <Setter Property="Grid.Column" Value="0" />
                                                    </DataTrigger>
                                                </Style.Triggers>
                                            </Style>
                                        </TextBlock.Style>
                                    </TextBlock>
                                </Grid>
                            </DataTemplate>
                        </DataGridTemplateColumn.CellTemplate>
                    </DataGridTemplateColumn>
                    <DataGridTextColumn x:Name="SourceColumn" Header="{Binding Data.SourceFilter, Source={StaticResource ViewModelProxy}}"
                                         HeaderTemplate="{StaticResource FilterableColumnHeader}"
                                         Binding="{Binding SourceDat}" SortMemberPath="SourceDat" Width="90" Visibility="Collapsed" />
                    <DataGridTextColumn x:Name="MatchMethodColumn" Header="{Binding Data.MatchMethodFilter, Source={StaticResource ViewModelProxy}}"
                                         HeaderTemplate="{StaticResource FilterableColumnHeader}"
                                         Binding="{Binding MatchMethod}" SortMemberPath="MatchMethod" Width="130" Visibility="Collapsed" />
                </DataGrid.Columns>
            </DataGrid>

            <!-- Tabloyu tam genişliğe getirme (sağ detay panelini gizleme/gösterme) ikonu.
                 DataGrid'in kendi köşesinde, sütun başlıklarının bittiği ile dikey scrollbar'ın
                 başladığı yerde zaten boş/kullanılmayan küçük bir alan var (klasik DataGrid köşe
                 hücresi) — ayrı bir sütun/satır açmadan, aynı Grid hücresine (Grid.Column="2")
                 DataGrid'den SONRA eklenip üstüne bindiriliyor, o boş köşeye tam oturuyor.
                 Arkaplanı başlık rengiyle eşleştirme denemesi (Border + Elevated) geri alındı —
                 gerçek başlık yüksekliğini bilmeden bir sızıntı kalmadan tam oturtmak mümkün
                 olmadı; düğme arkaplansız (Transparent) bırakıldı. -->
            <!-- Kullanıcı bulgusu: "tam ekrandayken panel kapalıyken (tablo tam genişlikteyken)
                 butona basınca panel geri açılmıyor, ama satıra tıklayınca açılıyor" — panel
                 kapalıyken (DetailPanelColumnDef Width=0) bu düğme, Column 2 ("*") tam pencere
                 kenarına kadar genişlediği için TAM pencere kenarına, WindowChrome'un
                 ResizeBorderThickness="6" ile ayırdığı görünmez resize şeridinin İÇİNE denk
                 geliyordu — DWM mouse-move'u (hover) yine de WPF'e iletiyordu ama tıklamayı
                 non-client resize hareketi sayıp yutuyordu (panel AÇIKKEN düğme 340px içeride
                 kaldığı için bu hiç yaşanmıyordu). İlk denemede Margin ile düğmeyi kenardan içeri
                 çekmiştim ama bu, köşedeki scrollbar/başlık şeridiyle arasında boşluk/çizgi
                 bırakıyordu — onun yerine başlık çubuğu düğmeleriyle (bkz. CustomTitleBarButton)
                 AYNI teknik: IsHitTestVisibleInChrome="True", düğmeyi tam köşede/kenarda TUTARKEN
                 tıklamaların resize kenarlığı tarafından yutulmasını engelliyor. -->
            <!-- Kullanıcı bulgusu: "bu buton tam ekranda gene çalışmıyor" — kök neden "Başlık"
                 sütun başlığına arama kutusu eklenince (bkz. TitleColumnHeaderWithHealth) header
                 satırı MinHeight=30'dan 52'ye çıktı, ama bu köşe-örtme düğmesinin Height'i hâlâ
                 eski 40'ta kalmıştı — büyümüş köşe boşluğunun altında ~12-22px kapatılmamış bir
                 şerit kaldı, orada tekrar resize kenarlığı tıklamayı yutuyordu. Height, yeni header
                 yüksekliğiyle AYNI oranda (header+10) büyütüldü. -->
            <Button x:Name="DetailPanelToggleButton" Grid.Column="2" Command="{Binding ToggleDetailPanelCommand}"
                    shell:WindowChrome.IsHitTestVisibleInChrome="True"
                    Width="14" Height="62" HorizontalAlignment="Right" VerticalAlignment="Top"
                    Background="Transparent" Padding="0" Cursor="Hand"
                    ToolTip="Tabloyu tam genişliğe getir / geri al">
                <!-- Arkaplan hover'ı (rengi değişen bir kutu) bu küçük köşe hücresinde her zaman
                     "yarım" duruyordu — hücre sınırlarıyla tam örtüşmüyor, komşu scrollbar
                     arkaplanıyla hizası bozuk görünüyordu. Onun yerine arkaplan hiç değişmiyor,
                     sadece ikonun kendisi (aşağıdaki TextBlock) hover'da renk değiştiriyor. -->
                <Button.Template>
                    <ControlTemplate TargetType="{x:Type Button}">
                        <Border Background="{TemplateBinding Background}">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center" />
                        </Border>
                    </ControlTemplate>
                </Button.Template>
                <TextBlock FontFamily="Segoe MDL2 Assets" FontSize="10"
                           HorizontalAlignment="Center" VerticalAlignment="Center">
                    <TextBlock.Style>
                        <Style TargetType="TextBlock">
                            <Setter Property="Text" Value="&#xE740;" />
                            <Setter Property="Foreground" Value="{StaticResource Brush.Text.Secondary}" />
                            <Style.Triggers>
                                <DataTrigger Binding="{Binding IsDetailPanelExpanded}" Value="False">
                                    <Setter Property="Text" Value="&#xE73F;" />
                                </DataTrigger>
                                <DataTrigger Binding="{Binding IsMouseOver, ElementName=DetailPanelToggleButton}" Value="True">
                                    <Setter Property="Foreground" Value="{StaticResource Brush.Text.Primary}" />
                                </DataTrigger>
                            </Style.Triggers>
                        </Style>
                    </TextBlock.Style>
                </TextBlock>
            </Button>

            <!-- ===================== Kapsül sağ tık menüsü ===================== -->
            <!-- MainWindow.xaml.cs GamesGrid_PreviewMouseRightButtonDown ile açılır (satırı bulup
                 ContextMenuGame'i ayarlar). Placement="MousePoint" fare imlecinin üstünde açılmasını
                 sağlar. Popup normal görsel ağacın bir parçası olduğu için (DataGridColumn.Header'ın
                 aksine) DataContext'i doğrudan Window'dan miras alıyor, ekstra bir BindingProxy'ye
                 gerek yok. -->
            <Popup x:Name="ContextMenuPopup" Placement="MousePoint" IsOpen="{Binding IsContextMenuOpen}"
                   StaysOpen="False" AllowsTransparency="True" PopupAnimation="None">
                <Border x:Name="ContextMenuBorder" CornerRadius="24" Padding="8,6"
                        Background="{StaticResource Brush.Background.Elevated}"
                        BorderBrush="{StaticResource Brush.Border}" BorderThickness="1"
                        RenderTransformOrigin="0.5,0.5">
                    <Border.Effect>
                        <DropShadowEffect BlurRadius="16" ShadowDepth="2" Opacity="0.4" Color="Black" />
                    </Border.Effect>
                    <Border.RenderTransform>
                        <ScaleTransform ScaleX="1" ScaleY="1" />
                    </Border.RenderTransform>
                    <!-- Border tek çocuk kabul ettiği için tekil/toplu mod StackPanel'leri (aşağıda,
                         mutually exclusive Visibility ile) bu Grid'in içinde üst üste duruyor. -->
                    <Grid>
                    <!-- Tekil mod: bir tek oyuna özel eylemler. Birden fazla satır seçiliyken
                         (bkz. IsBulkContextMenu) tamamen gizlenir — Edit/Versions/Folder/Re-match/
                         Search Web gibi eylemler toplu seçimde ya anlamsız ya da çakışır. -->
                    <StackPanel Orientation="Horizontal" DataContext="{Binding ContextMenuGame}">
                        <StackPanel.Style>
                            <Style TargetType="StackPanel">
                                <Setter Property="Visibility" Value="Visible" />
                                <Style.Triggers>
                                    <DataTrigger Binding="{Binding DataContext.IsBulkContextMenu, RelativeSource={RelativeSource AncestorType=Window}}" Value="True">
                                        <Setter Property="Visibility" Value="Collapsed" />
                                    </DataTrigger>
                                </Style.Triggers>
                            </Style>
                        </StackPanel.Style>
                        <Button Style="{StaticResource ContextMenuIconButtonHiddenInRecycleBin}"
                                Command="{Binding DataContext.EditMetadataCommand, RelativeSource={RelativeSource AncestorType=Window}}"
                                CommandParameter="{Binding}" ToolTip="Edit Metadata">
                            <StackPanel>
                                <TextBlock Text="&#xE70F;" Style="{StaticResource ContextMenuGlyphText}" />
                                <TextBlock Text="Edit" Style="{StaticResource ContextMenuLabelText}" />
                            </StackPanel>
                        </Button>

                        <Button Style="{StaticResource ContextMenuIconButtonHiddenInRecycleBin}"
                                Command="{Binding DataContext.FocusVersionsCommand, RelativeSource={RelativeSource AncestorType=Window}}"
                                ToolTip="Versions">
                            <StackPanel>
                                <TextBlock Text="&#xE8F1;" Style="{StaticResource ContextMenuGlyphText}" />
                                <TextBlock Text="Versions" Style="{StaticResource ContextMenuLabelText}" />
                            </StackPanel>
                        </Button>

                        <Button Style="{StaticResource ContextMenuIconButtonHiddenInRecycleBin}"
                                Command="{Binding DataContext.OpenFileLocationCommand, RelativeSource={RelativeSource AncestorType=Window}}"
                                CommandParameter="{Binding}" IsEnabled="{Binding HasLocalFile}" ToolTip="Open File Location">
                            <StackPanel>
                                <TextBlock Text="&#xE838;" Style="{StaticResource ContextMenuGlyphText}" />
                                <TextBlock Text="Folder" Style="{StaticResource ContextMenuLabelText}" />
                            </StackPanel>
                        </Button>

                        <!-- Kullanıcı isteği: "tablodan bağlama yapmak istediğimde klasörden değil
                             tablodaki oyunların listesinden seçmeli" — bu satırın dosyasını
                             tablodaki BAŞKA bir oyuna taşır (bkz. MainViewModel.
                             LinkGameFileToGameAsync — AYNI FilePathOverrides/MatchMethods.
                             ManualLink mekanizması, hedef oyuna yeni bir sürüm kartı olarak eklenir). -->
                        <Button Style="{StaticResource ContextMenuIconButtonHiddenInRecycleBin}"
                                Command="{Binding DataContext.RequestLinkToGameCommand, RelativeSource={RelativeSource AncestorType=Window}}"
                                CommandParameter="{Binding}" ToolTip="Başka Bir Oyuna Bağla">
                            <StackPanel>
                                <TextBlock Text="&#xE71B;" Style="{StaticResource ContextMenuGlyphText}" />
                                <TextBlock Text="Bağla" Style="{StaticResource ContextMenuLabelText}" />
                            </StackPanel>
                        </Button>

                        <!-- Kullanıcı bulgusu: "Wanpaku Duck Yume Bouken" (gerçekte resmi DuckTales)
                             LaunchBox'ın belirsiz bir alternatif isim çakışması yüzünden yanlışlıkla
                             Junk'a düşmüştü — kullanıcı kararı: "istenilen oyunu junk'a atabilelim
                             veya junktaki bi oyunu release'e çekebilelim ... tek tuş toggle gibi
                             kapsülde sabit koy" — HER ZAMAN görünen (sadece çöp kutusunda gizli) tek
                             düğme, mevcut Version'a göre ikon/etiketi VE eylemi karşıtına çeviriyor
                             (bkz. MainViewModel.ToggleJunkStatusCommand). Etiketler kısa tutuldu
                             ("Delete Perm." ile aynı uzunluk sınırı) — önceki "Junk'tan Çıkar" kapsül
                             genişliğine sığmayıp kırpılıyordu. -->
                        <Button Style="{StaticResource ContextMenuIconButtonHiddenInRecycleBin}"
                                Command="{Binding DataContext.ToggleJunkStatusCommand, RelativeSource={RelativeSource AncestorType=Window}}"
                                CommandParameter="{Binding}">
                            <StackPanel>
                                <TextBlock>
                                    <TextBlock.Style>
                                        <Style TargetType="TextBlock" BasedOn="{StaticResource ContextMenuGlyphText}">
                                            <Setter Property="Text" Value="&#xE7BA;" />
                                            <Style.Triggers>
                                                <DataTrigger Binding="{Binding Version}" Value="Junk">
                                                    <Setter Property="Text" Value="&#xE73E;" />
                                                </DataTrigger>
                                            </Style.Triggers>
                                        </Style>
                                    </TextBlock.Style>
                                </TextBlock>
                                <TextBlock>
                                    <TextBlock.Style>
                                        <Style TargetType="TextBlock" BasedOn="{StaticResource ContextMenuLabelText}">
                                            <Setter Property="Text" Value="Junk Yap" />
                                            <Style.Triggers>
                                                <DataTrigger Binding="{Binding Version}" Value="Junk">
                                                    <Setter Property="Text" Value="Released Yap" />
                                                </DataTrigger>
                                            </Style.Triggers>
                                        </Style>
                                    </TextBlock.Style>
                                </TextBlock>
                            </StackPanel>
                            <Button.ToolTip>
                                <TextBlock>
                                    <TextBlock.Style>
                                        <Style TargetType="TextBlock">
                                            <Setter Property="Text" Value="Junk'a At" />
                                            <Style.Triggers>
                                                <DataTrigger Binding="{Binding Version}" Value="Junk">
                                                    <Setter Property="Text" Value="Junk'tan Çıkar (Released Say)" />
                                                </DataTrigger>
                                            </Style.Triggers>
                                        </Style>
                                    </TextBlock.Style>
                                </TextBlock>
                            </Button.ToolTip>
                        </Button>

                        <!-- Delete / Restore: Recycle Bin dışında Delete (çöp kutusuna taşı), Recycle
                             Bin chip'i içindeyken Restore. Kullanıcı isteği: "Restore için ayrı icon
                             kullan" — Delete'in çöp kutusu glifiyle (E74D) karışmasın diye Restore'da
                             AYRI bir glif. Kullanıcı bulgusu: "RESTORE'un iconu kafa karıştırıyor,
                             geri dönüşüm iconu koyabilirsin" — E777 ("Undo", genel bir geri-al oku
                             gibi görünüyordu) yerine E72C ("Refresh" — dairesel/geri döngü oku,
                             "restore" için daha açık bir görsel dil) kullanılıyor. Kalıcı silme ayrı
                             bir düğme (sadece çöp kutusundayken görünür), onay
                             PermanentDeleteConfirmationDialog ile alınır. -->
                        <Button ToolTip="Delete/Restore">
                            <StackPanel>
                                <TextBlock>
                                    <TextBlock.Style>
                                        <Style TargetType="TextBlock" BasedOn="{StaticResource ContextMenuGlyphText}">
                                            <Setter Property="Text" Value="&#xE74D;" />
                                            <Style.Triggers>
                                                <DataTrigger Binding="{Binding IsDeleted}" Value="True">
                                                    <Setter Property="Text" Value="&#xE72C;" />
                                                </DataTrigger>
                                            </Style.Triggers>
                                        </Style>
                                    </TextBlock.Style>
                                </TextBlock>
                                <TextBlock>
                                    <TextBlock.Style>
                                        <Style TargetType="TextBlock" BasedOn="{StaticResource ContextMenuLabelText}">
                                            <Setter Property="Text" Value="Delete" />
                                            <Style.Triggers>
                                                <DataTrigger Binding="{Binding IsDeleted}" Value="True">
                                                    <Setter Property="Text" Value="Restore" />
                                                </DataTrigger>
                                            </Style.Triggers>
                                        </Style>
                                    </TextBlock.Style>
                                </TextBlock>
                            </StackPanel>
                            <Button.Style>
                                <Style TargetType="Button" BasedOn="{StaticResource ContextMenuIconButton}">
                                    <Setter Property="Command" Value="{Binding DataContext.DeleteGameCommand, RelativeSource={RelativeSource AncestorType=Window}}" />
                                    <Setter Property="CommandParameter" Value="{Binding}" />
                                    <Style.Triggers>
                                        <DataTrigger Binding="{Binding IsDeleted}" Value="True">
                                            <Setter Property="Command" Value="{Binding DataContext.RestoreGameCommand, RelativeSource={RelativeSource AncestorType=Window}}" />
                                        </DataTrigger>
                                    </Style.Triggers>
                                </Style>
                            </Button.Style>
                        </Button>

                        <Button Command="{Binding DataContext.RequestPermanentDeleteCommand, RelativeSource={RelativeSource AncestorType=Window}}"
                                CommandParameter="{Binding}" ToolTip="Delete Permanently">
                            <Button.Style>
                                <Style TargetType="Button" BasedOn="{StaticResource ContextMenuIconButton}">
                                    <Setter Property="Visibility" Value="Collapsed" />
                                    <Style.Triggers>
                                        <DataTrigger Binding="{Binding IsDeleted}" Value="True">
                                            <Setter Property="Visibility" Value="Visible" />
                                        </DataTrigger>
                                    </Style.Triggers>
                                </Style>
                            </Button.Style>
                            <StackPanel>
                                <TextBlock Text="&#xE74D;" Style="{StaticResource ContextMenuGlyphText}" Foreground="Firebrick" />
                                <TextBlock Text="Delete Perm." Style="{StaticResource ContextMenuLabelText}" />
                            </StackPanel>
                        </Button>

                        <!-- Overflow (>): Re-match Metadata + Add to Playlist gibi daha az kullanılan
                             eylemleri artık ayrı bir overflow popup'ında değil, doğrudan ana
                             satırda gösteriliyor (kullanıcı isteği: "o listeyi kaldır direk
                             gözüksün menüde"). -->
                        <Button Style="{StaticResource ContextMenuIconButtonHiddenInRecycleBin}"
                                Command="{Binding DataContext.ReMatchMetadataCommand, RelativeSource={RelativeSource AncestorType=Window}}"
                                CommandParameter="{Binding}" ToolTip="Re-match Metadata">
                            <StackPanel>
                                <TextBlock Text="&#xE72C;" Style="{StaticResource ContextMenuGlyphText}" />
                                <TextBlock Text="Re-match" Style="{StaticResource ContextMenuLabelText}" />
                            </StackPanel>
                        </Button>

                        <!-- Kullanıcı geri bildirimi: "super star force için 'eşleşmiş bir metadata
                             kaydı yok' diyor" — HasArtworkSource (LaunchBox eşleşmesi) artık şart
                             değil, 2. kaynak (bkz. ArtworkService.DownloadFromLibretroThumbnailsAsync)
                             LaunchBox eşleşmesi olmadan da çalışıyor. -->
                        <Button Style="{StaticResource ContextMenuIconButtonHiddenInRecycleBin}"
                                Command="{Binding DataContext.FetchArtworkCommand, RelativeSource={RelativeSource AncestorType=Window}}"
                                CommandParameter="{Binding}" IsEnabled="{Binding HasMissingArtwork}" ToolTip="Görsel getir">
                            <StackPanel>
                                <TextBlock Text="&#xE91B;" Style="{StaticResource ContextMenuGlyphText}" />
                                <TextBlock Text="Artwork" Style="{StaticResource ContextMenuLabelText}" />
                            </StackPanel>
                        </Button>

                        <Button Style="{StaticResource ContextMenuIconButtonHiddenInRecycleBin}"
                                Command="{Binding DataContext.ToggleAddToPlaylistPopupCommand, RelativeSource={RelativeSource AncestorType=Window}}"
                                ToolTip="Add to Playlist">
                            <StackPanel>
                                <TextBlock Text="&#xE710;" Style="{StaticResource ContextMenuGlyphText}" />
                                <TextBlock Text="Playlist" Style="{StaticResource ContextMenuLabelText}" />
                            </StackPanel>
                        </Button>

                        <Separator Width="1" Margin="4,6" Background="{StaticResource Brush.Border}">
                            <Separator.Style>
                                <Style TargetType="Separator">
                                    <Style.Triggers>
                                        <DataTrigger Binding="{Binding IsDeleted}" Value="True">
                                            <Setter Property="Visibility" Value="Collapsed" />
                                        </DataTrigger>
                                    </Style.Triggers>
                                </Style>
                            </Separator.Style>
                        </Separator>

                        <Button Style="{StaticResource ContextMenuIconButtonHiddenInRecycleBin}"
                                Command="{Binding DataContext.SearchWebCommand, RelativeSource={RelativeSource AncestorType=Window}}"
                                CommandParameter="{Binding}" ToolTip="Search Web">
                            <TextBlock Text="&#xE721;" Style="{StaticResource ContextMenuGlyphText}" />
                        </Button>
                    </StackPanel>

                    <!-- Toplu mod: birden fazla satır seçiliyken sadece bunlar görünür (kullanıcı
                         kararı: "sadece silme ve gizleme ve playlist oluşturma playliste ekleme
                         favoriye ekleme gözüksün"). -->
                    <StackPanel Orientation="Horizontal">
                        <StackPanel.Style>
                            <Style TargetType="StackPanel">
                                <Setter Property="Visibility" Value="Collapsed" />
                                <Style.Triggers>
                                    <DataTrigger Binding="{Binding IsBulkContextMenu}" Value="True">
                                        <Setter Property="Visibility" Value="Visible" />
                                    </DataTrigger>
                                </Style.Triggers>
                            </Style>
                        </StackPanel.Style>

                        <!-- Kullanıcı isteği: "toplu seçimde sağ tıktan bağlaya bastığımda otomatik
                             bağlamalı" — pencere açmadan, seçili oyunlardan "asıl" olanı otomatik
                             seçip diğerlerinin dosyalarını ona sürüm olarak taşır (bkz.
                             MainViewModel.BulkLinkAsync). -->
                        <Button Style="{StaticResource BulkContextMenuIconButtonHiddenInRecycleBin}"
                                Command="{Binding BulkLinkCommand}" ToolTip="Başka Bir Oyuna Bağla">
                            <StackPanel>
                                <TextBlock Text="&#xE71B;" Style="{StaticResource ContextMenuGlyphText}" />
                                <TextBlock Text="Bağla" Style="{StaticResource ContextMenuLabelText}" />
                            </StackPanel>
                        </Button>

                        <Button Style="{StaticResource BulkContextMenuIconButtonHiddenInRecycleBin}"
                                Command="{Binding BulkAddToFavoritesCommand}" ToolTip="Favorilere Ekle">
                            <StackPanel>
                                <TextBlock Text="&#xE734;" Style="{StaticResource ContextMenuGlyphText}" />
                                <TextBlock Text="Favorite" Style="{StaticResource ContextMenuLabelText}" />
                            </StackPanel>
                        </Button>

                        <Button Style="{StaticResource BulkContextMenuIconButtonHiddenInRecycleBin}"
                                Command="{Binding ToggleAddToPlaylistPopupCommand}" ToolTip="Add to Playlist">
                            <StackPanel>
                                <TextBlock Text="&#xE710;" Style="{StaticResource ContextMenuGlyphText}" />
                                <TextBlock Text="Playlist" Style="{StaticResource ContextMenuLabelText}" />
                            </StackPanel>
                        </Button>

                        <Button Style="{StaticResource BulkContextMenuIconButtonHiddenInRecycleBin}"
                                Command="{Binding BulkHideCommand}" ToolTip="Hide">
                            <StackPanel>
                                <TextBlock Text="&#xE7B3;" Style="{StaticResource ContextMenuGlyphText}" />
                                <TextBlock Text="Hide" Style="{StaticResource ContextMenuLabelText}" />
                            </StackPanel>
                        </Button>

                        <Button Style="{StaticResource BulkContextMenuIconButtonHiddenInRecycleBin}"
                                Command="{Binding BulkReMatchMetadataCommand}" ToolTip="Re-match Metadata">
                            <StackPanel>
                                <TextBlock Text="&#xE72C;" Style="{StaticResource ContextMenuGlyphText}" />
                                <TextBlock Text="Re-match" Style="{StaticResource ContextMenuLabelText}" />
                            </StackPanel>
                        </Button>

                        <Button Style="{StaticResource BulkContextMenuIconButtonHiddenInRecycleBin}"
                                Command="{Binding BulkFetchArtworkCommand}" IsEnabled="{Binding CanBulkFetchArtwork}"
                                ToolTip="Görsel getir">
                            <StackPanel>
                                <TextBlock Text="&#xE91B;" Style="{StaticResource ContextMenuGlyphText}" />
                                <TextBlock Text="Artwork" Style="{StaticResource ContextMenuLabelText}" />
                            </StackPanel>
                        </Button>

                        <!-- Kullanıcı geri bildirimi: "çöp kutusunda toplu silmede delete butonu
                             çıkıyor delete perma butonu çıkmıyor ... delete butonu geri dönüşüm
                             kutusuna gönderiyordu, çöp kutusu içinde tekrar çıkmasının anlamı yok" —
                             tekil moddaki Delete/Restore + Delete Perm. ile AYNI mantık, sadece
                             TÜM seçim zaten silinmişse (bkz. IsContextMenuSelectionAllDeleted). -->
                        <Button Command="{Binding BulkDeleteCommand}" ToolTip="Delete">
                            <Button.Style>
                                <Style TargetType="Button" BasedOn="{StaticResource ContextMenuIconButton}">
                                    <Style.Triggers>
                                        <DataTrigger Binding="{Binding IsContextMenuSelectionAllDeleted}" Value="True">
                                            <Setter Property="Visibility" Value="Collapsed" />
                                        </DataTrigger>
                                    </Style.Triggers>
                                </Style>
                            </Button.Style>
                            <StackPanel>
                                <TextBlock Text="&#xE74D;" Style="{StaticResource ContextMenuGlyphText}" />
                                <TextBlock Text="Delete" Style="{StaticResource ContextMenuLabelText}" />
                            </StackPanel>
                        </Button>

                        <Button Command="{Binding BulkRestoreCommand}" ToolTip="Restore">
                            <Button.Style>
                                <Style TargetType="Button" BasedOn="{StaticResource ContextMenuIconButton}">
                                    <Setter Property="Visibility" Value="Collapsed" />
                                    <Style.Triggers>
                                        <DataTrigger Binding="{Binding IsContextMenuSelectionAllDeleted}" Value="True">
                                            <Setter Property="Visibility" Value="Visible" />
                                        </DataTrigger>
                                    </Style.Triggers>
                                </Style>
                            </Button.Style>
                            <StackPanel>
                                <TextBlock Text="&#xE72C;" Style="{StaticResource ContextMenuGlyphText}" />
                                <TextBlock Text="Restore" Style="{StaticResource ContextMenuLabelText}" />
                            </StackPanel>
                        </Button>

                        <Button Command="{Binding RequestBulkPermanentDeleteCommand}" ToolTip="Delete Permanently">
                            <Button.Style>
                                <Style TargetType="Button" BasedOn="{StaticResource ContextMenuIconButton}">
                                    <Setter Property="Visibility" Value="Collapsed" />
                                    <Style.Triggers>
                                        <DataTrigger Binding="{Binding IsContextMenuSelectionAllDeleted}" Value="True">
                                            <Setter Property="Visibility" Value="Visible" />
                                        </DataTrigger>
                                    </Style.Triggers>
                                </Style>
                            </Button.Style>
                            <StackPanel>
                                <TextBlock Text="&#xE74D;" Style="{StaticResource ContextMenuGlyphText}" Foreground="Firebrick" />
                                <TextBlock Text="Delete Perm." Style="{StaticResource ContextMenuLabelText}" />
                            </StackPanel>
                        </Button>
                    </StackPanel>
                    </Grid>
                </Border>
            </Popup>

            <!-- "Playlist'e Ekle" alt popup'ı: mevcut playlist'lerin checklist'i (chip filtre
                 dropdown'larıyla aynı görsel dil). -->
            <Popup Placement="MousePoint" IsOpen="{Binding IsAddToPlaylistPopupOpen}" StaysOpen="False"
                   AllowsTransparency="True" VerticalOffset="52">
                <Border CornerRadius="8" Padding="8" MinWidth="170" Background="{StaticResource Brush.Background.Elevated}"
                        BorderBrush="{StaticResource Brush.Border}" BorderThickness="1">
                    <StackPanel>
                        <ItemsControl ItemsSource="{Binding PlaylistChips}">
                            <ItemsControl.ItemTemplate>
                                <DataTemplate DataType="{x:Type models:PlaylistChip}">
                                    <Button Command="{Binding DataContext.AddGameToPlaylistCommand, RelativeSource={RelativeSource AncestorType=Window}}"
                                            CommandParameter="{Binding}"
                                            Background="Transparent" BorderThickness="0" HorizontalContentAlignment="Left"
                                            Padding="4,3" Cursor="Hand">
                                        <Button.Style>
                                            <Style TargetType="Button" BasedOn="{StaticResource {x:Type Button}}">
                                                <Setter Property="Visibility" Value="Visible" />
                                                <Style.Triggers>
                                                    <DataTrigger Binding="{Binding Kind}" Value="Hidden">
                                                        <Setter Property="Visibility" Value="Collapsed" />
                                                    </DataTrigger>
                                                    <DataTrigger Binding="{Binding Kind}" Value="RecycleBin">
                                                        <Setter Property="Visibility" Value="Collapsed" />
                                                    </DataTrigger>
                                                    <DataTrigger Binding="{Binding Kind}" Value="ReadyToPlay">
                                                        <Setter Property="Visibility" Value="Collapsed" />
                                                    </DataTrigger>
                                                    <DataTrigger Binding="{Binding Kind}" Value="NeedsSearch">
                                                        <Setter Property="Visibility" Value="Collapsed" />
                                                    </DataTrigger>
                                                </Style.Triggers>
                                            </Style>
                                        </Button.Style>
                                        <StackPanel Orientation="Horizontal">
                                            <Ellipse Width="8" Height="8" Fill="{Binding Color}" VerticalAlignment="Center" Margin="0,0,6,0" />
                                            <TextBlock Text="{Binding Name}" FontSize="11" Foreground="{StaticResource Brush.Text.Primary}" />
                                        </StackPanel>
                                    </Button>
                                </DataTemplate>
                            </ItemsControl.ItemTemplate>
                        </ItemsControl>

                        <!-- "+ Yeni Playlist": oluşturur ve o anki seçimi (tekil/toplu) hemen içine
                             ekler — bkz. MainViewModel.CreatePlaylistAndAddSelectionCommand. -->
                        <Separator Margin="0,4" Background="{StaticResource Brush.Border}" />
                        <Grid Margin="2">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*" />
                                <ColumnDefinition Width="Auto" />
                            </Grid.ColumnDefinitions>
                            <TextBox Grid.Column="0" FontSize="11" Margin="0,0,4,0"
                                     Text="{Binding NewPlaylistName, UpdateSourceTrigger=PropertyChanged}">
                                <TextBox.InputBindings>
                                    <KeyBinding Key="Enter" Command="{Binding CreatePlaylistAndAddSelectionCommand}" />
                                </TextBox.InputBindings>
                            </TextBox>
                            <Button Grid.Column="1" Content="+ Yeni" FontSize="10" Padding="6,2"
                                    Command="{Binding CreatePlaylistAndAddSelectionCommand}" />
                        </Grid>
                    </StackPanel>
                </Border>
            </Popup>

            <!-- Kapsüldeki "Versions" düğmesiyle açılır — kullanıcı isteği: sağ detay paneline
                 gitmek yerine kapsülün kendi altında görünsün (bkz. MainViewModel.FocusVersions,
                 aynı "Playlist'e Ekle" alt-popup deseni: MousePoint + VerticalOffset). Kart
                 görünümü sağ paneldeki Sürümler listesiyle aynı (bkz. Window.Resources
                 VersionCardItemContainerStyle/VersionCardItemTemplate) — tek/çift tık davranışı da
                 aynı MouseDoubleClick handler'ını paylaşıyor. -->
            <Popup Placement="MousePoint" IsOpen="{Binding IsVersionsPopupOpen}" StaysOpen="False"
                   AllowsTransparency="True" VerticalOffset="52">
                <Border CornerRadius="8" Padding="8" MinWidth="320" MaxWidth="380"
                        Background="{StaticResource Brush.Background.Elevated}"
                        BorderBrush="{StaticResource Brush.Border}" BorderThickness="1">
                    <Border.Effect>
                        <DropShadowEffect BlurRadius="16" ShadowDepth="2" Opacity="0.4" Color="Black" />
                    </Border.Effect>
                    <!-- Kullanıcı geri bildirimi: "kartları açtığımdaki açılır listede kaydırmıyor
                         yani arkasındaki detaylar panelini kaydırıyor" — Popup KENDİ ScrollViewer'ı
                         olsa da tekerlek olayı bir şekilde ALTTAKİ pencereye (GameDetailScrollViewer)
                         sızıyordu. Aynı "PreviewMouseWheel ile burada dur" çözümü bu popup'ın KENDİ
                         ScrollViewer'ına da uygulanıyor. -->
                    <ScrollViewer MaxHeight="420" VerticalScrollBarVisibility="Auto"
                                  PreviewMouseWheel="PopupScrollViewer_PreviewMouseWheel">
                        <ListBox ItemsSource="{Binding SelectedGameVersions}"
                                 Background="Transparent" BorderThickness="0"
                                 ScrollViewer.VerticalScrollBarVisibility="Disabled"
                                 ItemContainerStyle="{StaticResource VersionCardItemContainerStyle}"
                                 ItemTemplate="{StaticResource VersionCardItemTemplate}"
                                 MouseDoubleClick="VersionsList_MouseDoubleClick" />
                    </ScrollViewer>
                </Border>
            </Popup>

            <!-- Right: Detail pane. Aç/kapa üst istatistik çubuğundaki tam ekran ikonuyla yapılıyor.
                 Visibility ayrıca IsDetailPanelExpanded VE SelectedGame'e bağlı: sadece genişliği
                 0'a indirmek (bkz. ColumnDefinition) teorik olarak yeterli olsa da, kapalıyken bu
                 Border'ın (Brush.Background.Panel — ana Base renginden farklı) kenarda ince bir
                 şerit olarak sızmasını kesin olarak engellemek için Collapsed de yapılıyor.
                 SelectedGame null kontrolü: platform listesinde gezinirken (henüz oyun seçilmemiş)
                 boş bir panel gösterilmesin diye (kullanıcı geri bildirimi). -->
            <Border Grid.Column="3" Background="{StaticResource Brush.Background.Panel}">
                <Border.Style>
                    <Style TargetType="Border">
                        <Setter Property="Visibility" Value="Visible" />
                        <Style.Triggers>
                            <DataTrigger Binding="{Binding IsDetailPanelExpanded}" Value="False">
                                <Setter Property="Visibility" Value="Collapsed" />
                            </DataTrigger>
                            <DataTrigger Binding="{Binding SelectedGame}" Value="{x:Null}">
                                <Setter Property="Visibility" Value="Collapsed" />
                            </DataTrigger>
                        </Style.Triggers>
                    </Style>
                </Border.Style>
                <Grid Margin="12">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="*" />
                        <RowDefinition Height="Auto" />
                        <!-- BAŞLAT/YouTube/Wikipedia butonları artık bu alanın içinde (bkz. aşağıdaki
                             Grid.Row="4"), eskiden ayrı bir satırdaki (Grid.Row="5") BAŞLAT'ın
                             kapladığı yükseklik buraya eklendi. -->
                        <RowDefinition Height="260" />
                    </Grid.RowDefinitions>

                    <!-- Fanart (Background) kaldırıldı (kullanıcı isteği: "fanart ı kaldır şimdilik o
                         alana yazalım detayları") — büyük arka plan görseli yerine solda kompakt bir
                         Box art kartı (+ üzerinde platform logosu/Top rozeti/puan, eskisiyle aynı
                         konumlarda), sağında ise Başlık + Tür/Mod/Sürüm rozetleri + Yayıncı/Yıl/Dosya
                         (eskiden aşağıdaki ScrollViewer'ın en üstündeydi, buraya taşındı). Eskiden
                         Border'a sabit Height="240" veriliyordu (fanart'ı doldursun diye) — o sabit
                         yükseklik kaldırıldı, satır zaten "Auto" olduğu için artık içeriğe (Box art
                         160px'lik kart vs. başlık+rozetler) göre kendiliğinden boyutlanıyor. -->
                    <Grid Grid.Row="0" Margin="0,0,0,10">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="Auto" />
                            <ColumnDefinition Width="14" />
                            <ColumnDefinition Width="*" />
                        </Grid.ColumnDefinitions>

                        <!-- Kullanıcı isteği (geri alındı — "kapak alanını hiçbir şekilde aşağı yukarı
                                 oynamıcak şekilde ayarla"): Box art'ı sağ sütunun (Yayıncı/Steam AppID
                                 gibi bazı satırları oyuna göre görünür/gizli olan, dolayısıyla yüksekliği
                                 oyundan oyuna değişebilen) yüksekliğine göre Stretch ile büyütmek daha
                                 önce "aynı orandaki uzama" için eklenmişti, ama Detaylar sütunundaki HER
                                 satırın yüksekliğini teker teker sabitlemek yerine (kırılgan, yeni bir
                                 satır eklendikçe tekrar bozulur) Box art'ı TAMAMEN SABİT (Height="160")
                                 yapmak çok daha sağlam: artık sağ sütun ne kadar uzasa da kısalsa da
                                 Box art asla değişmiyor. -->
                        <!-- Kullanıcı isteği: "topluluk ratingi de kapağın üstüne değil de altındaki
                                 boş alana al" — kapağın üzerindeki yarı saydam overlay yerine, Box
                                 art'ın hemen altına (Row 0 sağ sütun kadar uzayan boş alana) düz metin
                                 olarak taşındı. Box art StackPanel'e alındı ki rating altına eklenebilsin
                                 (kendisi hâlâ sabit Height="160", StackPanel bunu değiştirmiyor). -->
                        <StackPanel Grid.Column="0" VerticalAlignment="Top">
                            <!-- Kullanıcı isteği: "kapağa sol tık kapağı büyütür media provider tool u
                                 açar kırpma kesme pixel küçültme işleri yapılır ordan ... sağ tık kapsül
                                 menüsünü açar resmin klasörüne gitme butonu koy". Sol tık gerçek Crop
                                 Editor'ü (bkz. CropEditorViewModel — artık gerçek kırpma/pixel küçültme/
                                 kaydetme yapıyor) sadece GERÇEK bir Box art varsa açar (yer tutucu
                                 Cover.png'yi kırpmak anlamsız/zararlı olurdu, o paylaşılan bir dosya).
                                 Sağ tık küçük bir kapsül menüsü (bkz. MainWindow.xaml.cs
                                 BoxArt_MouseLeftButtonDown/BoxArtFolder_Click) — "Klasöre Git". -->
                            <Border Width="140" Height="160" CornerRadius="4" ClipToBounds="True"
                                    Background="{StaticResource Brush.Background.Elevated}"
                                    Cursor="Hand" ToolTip="Kırpmak için tıkla"
                                    MouseLeftButtonDown="BoxArt_MouseLeftButtonDown">
                                <Border.ContextMenu>
                                    <ContextMenu Style="{StaticResource CapsuleContextMenu}">
                                        <MenuItem Header="Klasöre Git" Style="{StaticResource DarkMenuItem}"
                                                  Command="{Binding OpenBoxArtFolderCommand}" CommandParameter="{Binding SelectedGame}">
                                            <MenuItem.Icon>
                                                <TextBlock Text="&#xE838;" FontFamily="Segoe MDL2 Assets" FontSize="14"
                                                           Foreground="{StaticResource Brush.Text.Primary}" />
                                            </MenuItem.Icon>
                                        </MenuItem>
                                         <MenuItem Header="Görseli Sil" Style="{StaticResource DarkMenuItem}"
                                                   Command="{Binding DeleteBoxArtCommand}" CommandParameter="{Binding SelectedGame}">
                                             <MenuItem.Icon>
                                                 <TextBlock Text="&#xE74D;" FontFamily="Segoe MDL2 Assets" FontSize="14"
                                                            Foreground="{StaticResource Brush.Text.Primary}" />
                                             </MenuItem.Icon>
                                         </MenuItem>
                                    </ContextMenu>
                                </Border.ContextMenu>
                                <Grid>
                                    <!-- Kullanıcı testi: "Final Stretch"/"Final Fight" gibi yatay/atipik
                                         oranlı ("3D Cart" tarzı) kapaklarda UniformToFill (kutuyu tam
                                         doldurup taşanı ortadan kırpma) Uniform'dan (kutunun ortasında
                                         küçük kalıp çoğu yeri boş bırakma) daha iyi göründüğü onaylandı —
                                         tüm kapaklar için kalıcı hale getirildi. -->
                                    <Image Source="{Binding SelectedGame.BoxDisplayPath, Converter={StaticResource ThumbnailImage}, ConverterParameter=600}" Stretch="UniformToFill" Margin="8" />

                                    <!-- Top 25/100/250 rozeti (bkz. MainViewModel.ComputeTopRankBadges) —
                                         hiç kazanmadıysa hiç görünmüyor. -->
                                    <Image Source="{Binding SelectedGame.TopRankBadgePath}" Stretch="Uniform"
                                           Width="36" Height="36" Margin="6"
                                           HorizontalAlignment="Right" VerticalAlignment="Top"
                                           RenderOptions.BitmapScalingMode="HighQuality"
                                           Visibility="{Binding SelectedGame.HasTopRankBadge, Converter={StaticResource BoolToVisibility}}">
                                        <Image.Effect>
                                            <DropShadowEffect BlurRadius="6" ShadowDepth="1" Opacity="0.5" />
                                        </Image.Effect>
                                    </Image>
                                </Grid>
                            </Border>

                            <!-- Topluluk Puanı — artık Box art'ın altında, düz metin (üstteki yarı
                                 saydam overlay kaldırıldı). -->
                            <TextBlock Text="{Binding SelectedGame.CommunityRatingDisplay}" FontSize="11"
                                       HorizontalAlignment="Center" Margin="0,4,0,0"
                                       Foreground="{StaticResource Brush.Accent.Amber}"
                                       Visibility="{Binding SelectedGame.HasCommunityRating, Converter={StaticResource BoolToVisibility}}" />
                        </StackPanel>

                        <StackPanel Grid.Column="2" VerticalAlignment="Top">
                            <!-- Platform logosu — kullanıcı isteği: Box art kartının üzerinden kalkıp
                                 oyun adının ÜSTÜNE taşındı. Tıklanabilir: platformun ROM klasörünü açar
                                 (bkz. MainWindow.xaml.cs PlatformLogoBadge_MouseLeftButtonDown,
                                 MainViewModel.OpenPlatformFolderCommand). Logo yoksa (ör. PC-FX) hiç
                                 görünmüyor. -->
                            <Grid Margin="0,0,0,6">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*" />
                                    <ColumnDefinition Width="Auto" />
                                </Grid.ColumnDefinitions>
                                <Border Grid.Column="0" Width="60" Height="36" CornerRadius="4" Cursor="Hand"
                                        HorizontalAlignment="Left"
                                        Background="{StaticResource Brush.Background.Elevated}"
                                        BorderBrush="{StaticResource Brush.Border}" BorderThickness="1"
                                        ToolTip="ROM klasörünü aç"
                                        MouseLeftButtonDown="PlatformLogoBadge_MouseLeftButtonDown"
                                        Visibility="{Binding SelectedGame.HasPlatformLogo, Converter={StaticResource BoolToVisibility}}">
                                    <Image Source="{Binding SelectedGame.PlatformLogoPath}" Stretch="Uniform" Margin="4"
                                           RenderOptions.BitmapScalingMode="HighQuality" />
                                </Border>
                                <StackPanel Grid.Column="1" Orientation="Horizontal" VerticalAlignment="Center">
                                    <!-- İndirme butonu: Sadece eksik bir görsel olduğunda görünür -->
                                    <Button Style="{StaticResource ActionsIconButton}" Width="28" Height="28" Margin="0,0,4,0"
                                            ToolTip="Eksik görselleri otomatik indir"
                                            Command="{Binding FetchMissingArtworkCommand}" CommandParameter="{Binding SelectedGame}"
                                            Visibility="{Binding SelectedGame.HasMissingArtwork, Converter={StaticResource BoolToVisibility}}">
                                        <TextBlock Text="&#xE896;" FontFamily="Segoe MDL2 Assets" FontSize="15" Foreground="{StaticResource Brush.Text.Primary}" />
                                    </Button>
                                    <!-- Arama butonu: Her zaman aktif ve görünür -->
                                    <Button x:Name="ArtworkSearchBadge" Style="{StaticResource ActionsIconButton}" Width="28" Height="28"
                                            ToolTip="Görsel ara" Click="ArtworkSearchBadge_Click">
                                        <Button.ContextMenu>
                                            <ContextMenu Style="{StaticResource CapsuleContextMenu}">
                                                <MenuItem Header="Kapak" Style="{StaticResource DarkMenuItem}"
                                                          Command="{Binding SearchBoxArtCommand}" CommandParameter="{Binding SelectedGame}" />
                                                <MenuItem Header="Logo" Style="{StaticResource DarkMenuItem}"
                                                          Command="{Binding SearchClearLogoArtCommand}" CommandParameter="{Binding SelectedGame}" />
                                                <MenuItem Header="Gameplay" Style="{StaticResource DarkMenuItem}"
                                                          Command="{Binding SearchScreenshotArtCommand}" CommandParameter="{Binding SelectedGame}" />
                                                <MenuItem Header="Video" Style="{StaticResource DarkMenuItem}"
                                                          Command="{Binding SearchVideoCommand}" CommandParameter="{Binding SelectedGame}" />
                                            </ContextMenu>
                                        </Button.ContextMenu>
                                        <TextBlock Text="&#xE721;" FontFamily="Segoe MDL2 Assets" FontSize="15" Foreground="{StaticResource Brush.Text.Primary}" />
                                    </Button>
                                </StackPanel>
                            </Grid>

                            <!-- Başlık + YouTube/Wikipedia (eskiden aşağıdaki ScrollViewer'ın en üstündeydi). -->
                            <Grid Margin="0,0,0,8">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*" />
                                    <ColumnDefinition Width="Auto" />
                                </Grid.ColumnDefinitions>
                                <Grid.RowDefinitions>
                                    <RowDefinition Height="Auto" />
                                    <RowDefinition Height="Auto" />
                                </Grid.RowDefinitions>
                                <!-- Kullanıcı isteği: "2 satırlık sabit boşluk bırak kayma olmasın" —
                                     Alternate Names'teki aynı sabit-yükseklik düzeltmesi burada da:
                                     bazı başlıklar 1 satır bazıları 2 satır sürdüğü için MinHeight
                                     olmadan oyunlar arası geçişte sağ sütun (ve ona Stretch ile bağlı
                                     sol Box art) zıplıyordu. -->
                                <!-- Kullanıcı isteği: "oyun adları kopyalanabilsin" — Alternate Names'teki
                                     aynı CopyTextCommand deseni burada da, sağ tık kapsül menüsüyle. -->
                                <TextBlock Grid.Column="0" Text="{Binding SelectedGame.Title}" FontSize="16" FontWeight="Bold"
                                           TextWrapping="Wrap" VerticalAlignment="Top" MinHeight="40">
                                    <TextBlock.ContextMenu>
                                        <ContextMenu Style="{StaticResource CapsuleContextMenu}">
                                            <MenuItem Header="Kopyala" Style="{StaticResource DarkMenuItem}"
                                                      Command="{Binding CopyTextCommand}" CommandParameter="{Binding SelectedGame.Title}">
                                                <MenuItem.Icon>
                                                    <TextBlock Text="&#xE8C8;" FontFamily="Segoe MDL2 Assets" FontSize="14"
                                                               Foreground="{StaticResource Brush.Text.Primary}" />
                                                </MenuItem.Icon>
                                            </MenuItem>
                                        </ContextMenu>
                                    </TextBlock.ContextMenu>
                                </TextBlock>
                                <StackPanel Grid.Column="1" Orientation="Horizontal" VerticalAlignment="Top" Margin="6,0,0,0">
                                    <!-- Kullanıcı isteği: "buton youtube link olsa da olmasa da orda,
                                         link yoksa pasif renk olsun tıklanamaz gibi" — artık dış
                                         tarayıcı DEĞİL, gameplay alanındaki embedded player'ı açar
                                         (bkz. MainViewModel.PlayVideoCommand, MainWindow.xaml
                                         Grid.Row="4"). -->
                                    <Button Style="{StaticResource ActionsIconButton}" Width="28" Height="28" Margin="0,0,4,0"
                                            ToolTip="YouTube'da İzle"
                                            Command="{Binding PlayVideoCommand}" CommandParameter="{Binding SelectedGame}"
                                            IsEnabled="{Binding SelectedGame.HasYouTubeEmbed}">
                                        <Path Data="{StaticResource Icon.YouTube}" Fill="{StaticResource Brush.Text.Primary}"
                                              Width="18" Height="18" Stretch="Uniform" />
                                    </Button>
                                    <Button Style="{StaticResource ActionsIconButton}" Width="28" Height="28"
                                            ToolTip="Wikipedia"
                                            Command="{Binding OpenWikipediaUrlCommand}" CommandParameter="{Binding SelectedGame}"
                                            Visibility="{Binding SelectedGame.HasWikipediaUrl, Converter={StaticResource BoolToVisibility}}">
                                        <Path Data="{StaticResource Icon.Wikipedia}" Fill="{StaticResource Brush.Text.Primary}"
                                              Width="18" Height="18" Stretch="Uniform" />
                                    </Button>
                                </StackPanel>
                            </Grid>

                            <!-- Tür rozeti: tek tür varsa tıklanınca doğrudan o türe göre filtreler
                                 (GenresFilter üzerinden — bkz. MainViewModel.FilterByGenreToken),
                                 birden fazla tür varsa "▾" ile açılır menü gösterir (ContextMenu,
                                 bkz. MainWindow.xaml.cs GenreBadge_Click). Hiç türü olmayan
                                 oyunlarda rozet tamamen gizlenir. -->
                            <StackPanel Orientation="Horizontal" Margin="0,0,0,8">
                                <Button x:Name="GenreBadge" Style="{StaticResource MetadataBadge}" Margin="0,0,6,0"
                                        Visibility="{Binding SelectedGame.HasGenres, Converter={StaticResource BoolToVisibility}}"
                                        Click="GenreBadge_Click">
                                    <!-- Renkler: Background/Foreground'a hiç dokunulmamıştı, WPF'in
                                         varsayılan (beyaz) sistem menü renklerine düşüyordu — Alternate
                                         Names açılır menüsündeki aynı düzeltme burada da uygulandı. -->
                                    <Button.ContextMenu>
                                        <ContextMenu ItemsSource="{Binding PlacementTarget.DataContext.SelectedGame.GenreTokens, RelativeSource={RelativeSource Self}}"
                                                     Style="{StaticResource CapsuleContextMenu}">
                                            <ContextMenu.ItemContainerStyle>
                                                <Style TargetType="MenuItem" BasedOn="{StaticResource DarkMenuItem}">
                                                    <Setter Property="Header" Value="{Binding}" />
                                                    <Setter Property="Command" Value="{Binding PlacementTarget.DataContext.FilterByGenreTokenCommand, RelativeSource={RelativeSource AncestorType=ContextMenu}}" />
                                                    <Setter Property="CommandParameter" Value="{Binding}" />
                                                </Style>
                                            </ContextMenu.ItemContainerStyle>
                                        </ContextMenu>
                                    </Button.ContextMenu>
                                    <StackPanel Orientation="Horizontal">
                                        <TextBlock Text="🎮" Margin="0,0,5,0" />
                                        <TextBlock Text="{Binding SelectedGame.PrimaryGenre}" />
                                        <TextBlock Text=" ▾" Visibility="{Binding SelectedGame.HasMultipleGenres, Converter={StaticResource BoolToVisibility}}" />
                                    </StackPanel>
                                </Button>

                                <!-- Oyun modu rozeti: tıklanamaz — LaunchBox'ta bu boyutta gerçek bir
                                     filtre yok, sadece bilgi amaçlı gösterim. -->
                                <Border Style="{StaticResource MetadataBadgeStatic}" Margin="0,0,6,0">
                                    <StackPanel Orientation="Horizontal">
                                        <TextBlock Text="{Binding SelectedGame.GameModeIcon}" Margin="0,0,5,0" />
                                        <TextBlock Text="{Binding SelectedGame.GameModeLabel}" />
                                    </StackPanel>
                                </Border>

                                <!-- Sürüm rozeti: Released/Junk toolbar toggle'larıyla AYNI durumu
                                     kullanır (bkz. MainViewModel.FilterByVersion). -->
                                <Button Style="{StaticResource MetadataBadge}"
                                        Command="{Binding FilterByVersionCommand}" CommandParameter="{Binding SelectedGame.Version}">
                                    <StackPanel Orientation="Horizontal">
                                        <TextBlock Text="🏷" Margin="0,0,5,0" />
                                        <TextBlock Text="{Binding SelectedGame.Version}" />
                                    </StackPanel>
                                </Button>
                            </StackPanel>

                            <!-- Yayıncı + Yıl aynı satırda — Geliştirici burada YOK (veri Game.Developer'da
                                 hâlâ duruyor, silinmedi). Tam tarih tooltip'te. -->
                            <StackPanel Orientation="Horizontal" Margin="0,0,0,6">
                                <StackPanel Orientation="Horizontal" Margin="0,0,16,0">
                                    <TextBlock Text="🛠" Margin="0,0,5,0" />
                                    <TextBlock Text="{Binding SelectedGame.PublisherDisplay}" />
                                </StackPanel>
                                <StackPanel Orientation="Horizontal" ToolTip="{Binding SelectedGame.ReleaseDateDisplay}">
                                    <TextBlock Text="📅" Margin="0,0,5,0" />
                                    <TextBlock Text="{Binding SelectedGame.ReleaseYearDisplay}" />
                                </StackPanel>
                            </StackPanel>

                            <!-- ALTERNATE NAMES: kullanıcı isteği — ilk 2 alternatif isim HER ZAMAN
                                 doğrudan (statik satırlar olarak) gösterilir ("minimum satır gösterme
                                 sınırını 2 satır yap"), 2'den fazlaysa geri kalanlar "▾" ile açılan bir
                                 listede (bkz. MainViewModel.VisibleAlternateNames/OverflowAlternateNames/
                                 HasOverflowAlternateNames). Her satır tıklanınca kopyalanır (bkz.
                                 CopyTextCommand). Hiç alternatif ismi olmayan oyunlarda
                                 CountToVisibility ile tamamen gizlenir. Dosya adı satırı KALDIRILDI
                                 (kullanıcı isteği: "zaten versionda yazıyor" — Sürümler kartında zaten
                                 gösteriliyor). ItemsControl'e SABİT MinHeight="36" verildi (kullanıcı
                                 isteği: "sabit 2 satırlık aralık ver, 1 satır dolu olsa bile 2 satırlık
                                 alan kullansın") — 1 tek isim olan oyunlarda alan yine de 2 satırlık yer
                                 kaplar, oyunlar arası geçişte Box art'ın (VerticalAlignment=Stretch ile
                                 bu sütuna göre boyutlanan) zıplamasını önler. "▾ diğerleri" düğmesi
                                 3. bir satır DEĞİL, başlığın yanında (kullanıcı isteği). -->
                            <!-- Kullanıcı isteği: "alternative name i olmayanlarda kayıyor ufalıyor
                                 şuanda" — CountToVisibility ile tamamen gizlemek, alternatif ismi
                                 olmayan oyunlarda bu bloğun YÜKSEKLİĞİNİ SIFIRLIYORDU (Box art'ın
                                 Stretch ile bağlı olduğu sağ sütun kısalıp Box art küçülüyordu).
                                 Artık HİÇ gizlenmiyor — alternatif ismi olmasa bile başlık + 2 satırlık
                                 boş alan (MinHeight="36") her zaman aynı yeri kaplıyor. -->
                            <StackPanel Margin="0,8,0,0">
                                <Grid Margin="0,0,0,3">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="*" />
                                        <ColumnDefinition Width="Auto" />
                                    </Grid.ColumnDefinitions>
                                    <TextBlock Grid.Column="0" Text="ALTERNATE NAMES" FontSize="9" FontWeight="SemiBold"
                                               Foreground="{StaticResource Brush.Text.Secondary}" VerticalAlignment="Center" />
                                    <!-- İlk 2'nin ötesindeki alternatif isimler için açılır liste
                                         (sağ-tık kapsül menüsündeki popup'larla aynı renk paleti). -->
                                    <Button x:Name="AlternateNamesOverflowToggle" Grid.Column="1" Style="{StaticResource MetadataBadge}"
                                            Background="Transparent" BorderThickness="0" Padding="0" FontSize="10"
                                            Content="▾ diğerleri"
                                            Visibility="{Binding HasOverflowAlternateNames, Converter={StaticResource BoolToVisibility}}"
                                            Click="AlternateNamesOverflowToggle_Click">
                                    <Button.ContextMenu>
                                        <ContextMenu ItemsSource="{Binding PlacementTarget.DataContext.OverflowAlternateNames, RelativeSource={RelativeSource Self}}"
                                                     Style="{StaticResource CapsuleContextMenu}">
                                            <ContextMenu.ItemContainerStyle>
                                                <Style TargetType="MenuItem" BasedOn="{StaticResource DarkMenuItem}">
                                                    <Setter Property="Header" Value="{Binding}" />
                                                    <Setter Property="HeaderTemplate">
                                                        <Setter.Value>
                                                            <DataTemplate DataType="{x:Type models:GameAlternateName}">
                                                                <StackPanel Orientation="Horizontal">
                                                                    <Image Source="{Binding Region, Converter={StaticResource RegionToFlag}}"
                                                                           Width="12" Height="12" Margin="0,0,4,0" VerticalAlignment="Center"
                                                                           RenderOptions.BitmapScalingMode="HighQuality" />
                                                                    <TextBlock Text="{Binding Region}" FontSize="10"
                                                                               Foreground="{StaticResource Brush.Text.Secondary}" Margin="0,0,6,0" />
                                                                    <TextBlock Text="{Binding Name}" FontSize="11" />
                                                                </StackPanel>
                                                            </DataTemplate>
                                                        </Setter.Value>
                                                    </Setter>
                                                    <Setter Property="Command" Value="{Binding PlacementTarget.DataContext.CopyTextCommand, RelativeSource={RelativeSource AncestorType=ContextMenu}}" />
                                                    <Setter Property="CommandParameter" Value="{Binding Name}" />
                                                </Style>
                                            </ContextMenu.ItemContainerStyle>
                                        </ContextMenu>
                                    </Button.ContextMenu>
                                </Button>
                                </Grid>
                                <!-- MinHeight burada Grid'e taşındı (kullanıcı isteği: "2 satırlık gene
                                     alanı") — alternatif ismi olmayan oyunlarda ItemsControl boş
                                     kalıyor ama "-" TextBlock'u (bkz. HasNoAlternateNames) aynı 2
                                     satırlık alanda görünür ("Alternate name yazsın gene - işareti
                                     olsun sadece"). -->
                                <Grid MinHeight="36">
                                    <ItemsControl ItemsSource="{Binding VisibleAlternateNames}">
                                        <ItemsControl.ItemTemplate>
                                            <DataTemplate DataType="{x:Type models:GameAlternateName}">
                                                <StackPanel Orientation="Horizontal" Margin="0,1" Cursor="Hand" ToolTip="Kopyalamak için tıkla">
                                                    <StackPanel.InputBindings>
                                                        <MouseBinding MouseAction="LeftClick"
                                                                      Command="{Binding DataContext.CopyTextCommand, RelativeSource={RelativeSource AncestorType=ItemsControl}}"
                                                                      CommandParameter="{Binding Name}" />
                                                    </StackPanel.InputBindings>
                                                    <TextBlock Text="•" Margin="0,0,6,0" Foreground="{StaticResource Brush.Text.Secondary}" />
                                                    <Image Source="{Binding Region, Converter={StaticResource RegionToFlag}}"
                                                           Width="12" Height="12" Margin="0,0,4,0" VerticalAlignment="Center"
                                                           RenderOptions.BitmapScalingMode="HighQuality" />
                                                    <TextBlock Text="{Binding Region}" FontSize="11" Width="42"
                                                               Foreground="{StaticResource Brush.Text.Secondary}" />
                                                    <TextBlock Text="{Binding Name}" FontSize="11" TextWrapping="Wrap" />
                                                </StackPanel>
                                            </DataTemplate>
                                        </ItemsControl.ItemTemplate>
                                    </ItemsControl>
                                    <TextBlock Text="-" FontSize="11" Margin="12,1,0,0"
                                               Foreground="{StaticResource Brush.Text.Secondary}"
                                               Visibility="{Binding HasNoAlternateNames, Converter={StaticResource BoolToVisibility}}" />
                                </Grid>
                            </StackPanel>

                            <!-- Steam AppID: LaunchBox'ın Steam mağaza sayfası kimliği — sadece değer
                                 varsa gösterilir. -->
                            <StackPanel Orientation="Horizontal" Margin="0,6,0,0"
                                        Visibility="{Binding SelectedGame.HasSteamAppId, Converter={StaticResource BoolToVisibility}}">
                                <Label Content="Steam AppID" Padding="0" Margin="0,0,6,0" Foreground="{StaticResource Brush.Text.Secondary}" />
                                <TextBlock Text="{Binding SelectedGame.SteamAppId}" />
                            </StackPanel>
                        </StackPanel>
                    </Grid>

                    <!-- Kullanıcı geri bildirimi: "kartın üstündeyken çalışmıyor" — alttaki Sürümler
                         ListBox'ının ÇOCUK öğeleri (ListBoxItem/sanal panel) tekerlek olayını
                         DAHA AŞAĞIDA tüketip yukarı hiç çıkarmıyordu; ListBox seviyesinde önlem almak
                         (CanContentScroll=False vb.) yetmedi. En SAĞLAM çözüm: bu DIŞTAKİ gerçek
                         ScrollViewer'ın KENDİSİNE bir PreviewMouseWheel koymak — tünelleme (Preview)
                         olayı yukarıdan aşağıya inerken BURADA, İÇERİDEKİ HERHANGİ bir elemana
                         ulaşmadan ÖNCE yakalanıp elle kaydırılıyor, altta ne olursa olsun. -->
                    <ScrollViewer x:Name="GameDetailScrollViewer" Grid.Row="2" VerticalScrollBarVisibility="Auto"
                                  PreviewMouseWheel="GameDetailScrollViewer_PreviewMouseWheel">
                        <StackPanel>
                            <!-- Sürümler artık tam genişlik (kullanıcı isteği: "alternate names metadata
                                 alanında olsun sürümlerin yanında değil" — Alternate Names yukarıya,
                                 Metadata alanına taşındı). -->
                            <!-- Ayarlar > Arayüz > Detay Paneli'nden seçilen tercihe göre İKİ ALTERNATİF
                                 gösterim (bkz. AppSettings.ShowVersionsAsSingleCard) — aynı anda sadece
                                 biri görünür. -->

                            <!-- 1) Tek kart + (birden fazlaysa) sağ-tık kapsül menüsündekiyle AYNI
                                 popup'tan seçim (kullanıcı isteği: "sürümlerde tek kart gözükecek
                                 şekilde yapalım... kart açılsın aşağı kapsüldeki gibi"). -->
                            <StackPanel Margin="0,0,0,8"
                                        Visibility="{Binding ShowVersionsAsSingleCard, Converter={StaticResource BoolToVisibility}}">
                                <Grid Margin="0,0,0,4">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="*" />
                                        <ColumnDefinition Width="Auto" />
                                    </Grid.ColumnDefinitions>
                                    <TextBlock Grid.Column="0" Text="Sürümler (Region)" FontWeight="Bold"
                                               Foreground="{StaticResource Brush.Text.Secondary}" FontSize="11" />
                                    <ToggleButton x:Name="VersionCardDropdownToggle" Grid.Column="1"
                                                  IsChecked="{Binding IsVersionCardMenuOpen, Mode=TwoWay}"
                                                  Visibility="{Binding HasMultipleVersionCards, Converter={StaticResource BoolToVisibility}}"
                                                  Background="Transparent" BorderThickness="0" Padding="4,0" Cursor="Hand"
                                                  Foreground="{StaticResource Brush.Text.Secondary}" Content="▾" />
                                </Grid>
                                <ListBox x:Name="VersionsList" ItemsSource="{Binding SingleVersionCard}"
                                         Background="Transparent" BorderThickness="0"
                                         ScrollViewer.VerticalScrollBarVisibility="Disabled"
                                         ItemContainerStyle="{StaticResource VersionCardItemContainerStyle}"
                                         ItemTemplate="{StaticResource VersionCardItemTemplate}"
                                         MouseDoubleClick="VersionsList_MouseDoubleClick" />

                                <!-- Kapsüldeki "Versions" popup'ıyla BİREBİR AYNI görünüm (bkz.
                                     yukarıdaki IsVersionsPopupOpen Popup'ı) — sadece PlacementTarget/
                                     Placement farklı (o MousePoint kullanıyor, bu "kart açılsın aşağı"
                                     isteği gereği Bottom). Seçilen kart tek-kart alanına taşınır (bkz.
                                     MainWindow.xaml.cs OtherVersionsList_SelectionChanged,
                                     MainViewModel.SelectVersionCardCommand) ve popup kapanır. -->
                                <Popup PlacementTarget="{Binding ElementName=VersionCardDropdownToggle}"
                                       Placement="Bottom" IsOpen="{Binding IsVersionCardMenuOpen, Mode=TwoWay}"
                                       StaysOpen="False" AllowsTransparency="True">
                                    <Border CornerRadius="8" Padding="8" MinWidth="320" MaxWidth="380"
                                            Background="{StaticResource Brush.Background.Elevated}"
                                            BorderBrush="{StaticResource Brush.Border}" BorderThickness="1">
                                        <Border.Effect>
                                            <DropShadowEffect BlurRadius="16" ShadowDepth="2" Opacity="0.4" Color="Black" />
                                        </Border.Effect>
                                        <ScrollViewer x:Name="VersionCardMenuScrollViewer" MaxHeight="420" VerticalScrollBarVisibility="Auto"
                                                      PreviewMouseWheel="PopupScrollViewer_PreviewMouseWheel">
                                            <ListBox ItemsSource="{Binding OtherVersionCards}"
                                                     Background="Transparent" BorderThickness="0"
                                                     ScrollViewer.VerticalScrollBarVisibility="Disabled"
                                                     ItemContainerStyle="{StaticResource VersionCardItemContainerStyle}"
                                                     ItemTemplate="{StaticResource VersionCardItemTemplate}"
                                                     MouseDoubleClick="VersionsList_MouseDoubleClick"
                                                     SelectionChanged="OtherVersionsList_SelectionChanged" />
                                        </ScrollViewer>
                                    </Border>
                                </Popup>
                            </StackPanel>

                            <!-- 2) Tam liste — eskisi gibi tüm sürümler alt alta (bkz. Ayarlar). -->
                            <StackPanel Margin="0,0,0,8"
                                        Visibility="{Binding ShowVersionsAsSingleCard, Converter={StaticResource BoolToVisibility}, ConverterParameter=Invert}">
                                <TextBlock Text="Sürümler (Region)" FontWeight="Bold" Margin="0,0,0,4"
                                           Foreground="{StaticResource Brush.Text.Secondary}" FontSize="11" />
                                <!-- Kart seçilebilir (tek tık, mavi çerçeveyle belli olur) ve çift
                                     tıklayınca o SÜRÜMÜN dosyasını doğrudan tanımlı emülatörle
                                     başlatır (bkz. MainWindow.xaml.cs VersionsList_MouseDoubleClick,
                                     MainViewModel.LaunchVersionCommand). Kart görünümü kapsüldeki
                                     "Versions" popup'ıyla AYNI, tam (dosya adı dahil) şablon.
                                     ScrollViewer.VerticalScrollBarVisibility="Disabled": ListBox'ın
                                     kendi iç kaydırıcısını kapatıp dıştaki tek ScrollViewer'a bırakıyor. -->
                                <!-- Kullanıcı geri bildirimi: "scroll mouse u scrollbar a getirince
                                     çalışıyor" (yani kartların ÜSTÜNDE tekerlek çalışmıyor, sadece
                                     scrollbar'ı sürüklemek çalışıyor) — ListBox varsayılan olarak
                                     VirtualizingStackPanel'in KENDİ IScrollInfo'sunu kullanır
                                     (ScrollViewer.CanContentScroll=True varsayılan), bu da tekerlek
                                     olayını dıştaki gerçek ScrollViewer'a hiç ulaştırmadan İÇERDE
                                     yutuyordu — kod arkasındaki yeniden yönlendirme (bkz.
                                     VersionsList_PreviewMouseWheel) BUNU engelleyemiyordu çünkü olay
                                     ListBox'a hiç "Handled" olarak dönmeden önce sanal panel
                                     tarafından tüketiliyordu. CanContentScroll="False", ListBox'ı bu
                                     iç kaydırmayı KULLANMAMAYA zorluyor (sanallaştırma performans
                                     kaybı burada önemsiz, liste küçük) — artık tekerlek olayı normal
                                     şekilde dıştaki ScrollViewer'a kadar geliyor. -->
                                <ListBox ItemsSource="{Binding SelectedGameVersions}"
                                         Background="Transparent" BorderThickness="0"
                                         ScrollViewer.VerticalScrollBarVisibility="Disabled"
                                         ScrollViewer.CanContentScroll="False"
                                         VirtualizingPanel.IsVirtualizing="False"
                                         ItemContainerStyle="{StaticResource VersionCardItemContainerStyle}"
                                         ItemTemplate="{StaticResource VersionCardItemTemplate}"
                                         MouseDoubleClick="VersionsList_MouseDoubleClick"
                                         PreviewMouseWheel="VersionsList_PreviewMouseWheel" />
                            </StackPanel>

                            <TextBlock Text="{Binding SelectedGame.Description}" TextWrapping="Wrap" Margin="0,14,0,0"
                                       Foreground="{StaticResource Brush.Text.Secondary}" FontSize="11" />
                        </StackPanel>
                    </ScrollViewer>

                    <!-- Clear Logo: Gameplay alanının hemen üstünde ayrı bir kart (kullanıcı kararı:
                         başlığın altındaki denemeden buraya taşındı, "en iyisi" burası). Logo yoksa
                         (bkz. Game.HasClearLogo) Border tamamen gizleniyor — RowDefinition Auto
                         olduğu için satır da 0'a inip boşta yer kaplamıyor (kullanıcı isteği). -->
                    <!-- Kullanıcı isteği: "arkaplan ve borderı kaldır boyutu %10 büyült gameplayle
                         aradaki boşluğu hafif azalt" — kart görünümü (Background/Padding) kaldırıldı,
                         Image yüksekliği 60 -> 66 (%10), alt boşluk 10 -> 6. Clear Logo VE gameplay
                         screenshot İKİSİ DE yoksa alan tamamen gizlenir (bkz. Game.ShowClearLogoArea,
                         kullanıcı isteği: "2'si de yok, clear logoda bişey göstermemesi lazım");
                         ikisinden en az biri varsa Game.ClearLogoDisplayPath gerçek logo/Logo.png/
                         Background.png arasında seçim yapıyor. -->
                    <!-- Kullanıcı isteği: "clear logo içinde aynı şekilde" (Box art'taki sol/sağ tık
                         davranışı). Sol tık sadece GERÇEK bir Clear Logo varsa Crop Editor'ü açar
                         (Logo.png/Background.png yer tutucularını kırpmak anlamsız/zararlı olurdu). -->
                    <Border Grid.Row="3" Margin="0,0,0,6" Cursor="Hand" ToolTip="Kırpmak için tıkla"
                            Visibility="{Binding SelectedGame.ShowClearLogoArea, Converter={StaticResource BoolToVisibility}}"
                            MouseLeftButtonDown="ClearLogo_MouseLeftButtonDown">
                        <Border.ContextMenu>
                            <ContextMenu Style="{StaticResource CapsuleContextMenu}">
                                <MenuItem Header="Klasöre Git" Style="{StaticResource DarkMenuItem}"
                                          Command="{Binding OpenClearLogoFolderCommand}" CommandParameter="{Binding SelectedGame}">
                                    <MenuItem.Icon>
                                        <TextBlock Text="&#xE838;" FontFamily="Segoe MDL2 Assets" FontSize="14"
                                                   Foreground="{StaticResource Brush.Text.Primary}" />
                                    </MenuItem.Icon>
                                </MenuItem>
                                <MenuItem Header="Görseli Sil" Style="{StaticResource DarkMenuItem}"
                                          Command="{Binding DeleteClearLogoCommand}" CommandParameter="{Binding SelectedGame}">
                                    <MenuItem.Icon>
                                        <TextBlock Text="&#xE74D;" FontFamily="Segoe MDL2 Assets" FontSize="14"
                                                   Foreground="{StaticResource Brush.Text.Primary}" />
                                    </MenuItem.Icon>
                                </MenuItem>
                            </ContextMenu>
                        </Border.ContextMenu>
                        <Grid>
                            <Image Source="{Binding SelectedGame.ClearLogoDisplayPath, Converter={StaticResource ThumbnailImage}, ConverterParameter=300}" Stretch="Uniform" Height="66"
                                   RenderOptions.BitmapScalingMode="HighQuality" />

                            <!-- Kullanıcı geri bildirimi: "buton gözükmüyor altta kalıyor olabilir"
                                 — WebView2 (gameplay alanındaki YouTubePlayer) kendi native penceresi
                                 olan bir kontrol ("airspace" sorunu): WPF Z-sırasından BAĞIMSIZ olarak
                                 HER ZAMAN diğer tüm WPF içeriğinin ÜSTÜNDE render edilir, bu yüzden
                                 gameplay çerçevesinin üstüne bindirilen butonlar görünmüyordu.
                                 Kullanıcı isteği: "clear logonun olduğu yere sağ köşeye ... clear
                                 logonun yeri kaymasın" — WebView2'yle hiç ÇAKIŞMAYAN bu alana (Grid
                                 overlay, Image'ın kendi layout'unu ETKİLEMEZ) taşındı; Kapat/geri +
                                 Snapshot butonları sadece video oynarken görünür. Video arkaplanına
                                 karşı okunaklı kalmaları için ActionsIconButton yerine kendi (beyaz
                                 üstünde yarı saydam siyah) şablonları var. -->
                            <StackPanel Orientation="Horizontal" HorizontalAlignment="Right" VerticalAlignment="Top"
                                        Visibility="{Binding IsPlayingVideo, Converter={StaticResource BoolToVisibility}}">
                                <!-- Kullanıcı isteği: "videodan gameplay resmi snapshot alıp
                                     kaydedebilirmiyiz" — WebView2'nin o anki render edilmiş
                                     görüntüsünü (bkz. MainWindow.xaml.cs
                                     CaptureVideoSnapshot_Click, CoreWebView2.CapturePreviewAsync)
                                     yakalayıp oyunun SS (Ekran Görüntüsü) olarak kaydeder. -->
                                <Button Width="26" Height="26" Margin="6,6,0,6" Cursor="Hand" ToolTip="Bu Kareyi Ekran Görüntüsü Olarak Kaydet"
                                        Click="CaptureVideoSnapshot_Click">
                                    <Button.Template>
                                        <ControlTemplate TargetType="Button">
                                            <Border x:Name="Bg" CornerRadius="13" Background="#99000000">
                                                <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center" />
                                            </Border>
                                            <ControlTemplate.Triggers>
                                                <Trigger Property="IsMouseOver" Value="True">
                                                    <Setter TargetName="Bg" Property="Background" Value="#CC000000" />
                                                </Trigger>
                                            </ControlTemplate.Triggers>
                                        </ControlTemplate>
                                    </Button.Template>
                                    <TextBlock Text="&#xE722;" FontFamily="Segoe MDL2 Assets" FontSize="13" Foreground="White" />
                                </Button>
                                <Button Width="26" Height="26" Margin="6" Cursor="Hand" ToolTip="Kapat"
                                        Command="{Binding CloseVideoCommand}">
                                    <Button.Template>
                                        <ControlTemplate TargetType="Button">
                                            <Border x:Name="Bg" CornerRadius="13" Background="#99000000">
                                                <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center" />
                                            </Border>
                                            <ControlTemplate.Triggers>
                                                <Trigger Property="IsMouseOver" Value="True">
                                                    <Setter TargetName="Bg" Property="Background" Value="#CC000000" />
                                                </Trigger>
                                            </ControlTemplate.Triggers>
                                        </ControlTemplate>
                                    </Button.Template>
                                    <TextBlock Text="✕" FontSize="13" Foreground="White" />
                                </Button>
                            </StackPanel>
                        </Grid>
                    </Border>

                    <!-- Gameplay Screenshot (bkz. "Görsel Getir") varsa alanı doldurur; yoksa
                         Game.ScreenshotDisplayPath Images/NoImage/Background.png'ye düşer.
                         Stretch=Fill (kullanıcı kararı: gerdir) — hem gerçek screenshot hem
                         yer tutucu, boşluk/kırpma kaygısı olmadan alanı tam doldursun diye. -->
                    <Border Grid.Row="4" CornerRadius="4" ClipToBounds="True" Background="{StaticResource Brush.Background.Elevated}" Margin="0,10">
                        <Border.ContextMenu>
                            <ContextMenu Style="{StaticResource CapsuleContextMenu}">
                                <MenuItem Header="Klas&#246;re Git" Style="{StaticResource DarkMenuItem}"
                                          Command="{Binding OpenScreenshotFolderCommand}" CommandParameter="{Binding SelectedGame}">
                                    <MenuItem.Icon>
                                        <TextBlock Text="&#xE838;" FontFamily="Segoe MDL2 Assets" FontSize="14"
                                                   Foreground="{StaticResource Brush.Text.Primary}" />
                                    </MenuItem.Icon>
                                </MenuItem>
                                 <MenuItem Header="Görseli Sil" Style="{StaticResource DarkMenuItem}"
                                           Command="{Binding DeleteScreenshotCommand}" CommandParameter="{Binding SelectedGame}">
                                     <MenuItem.Icon>
                                         <TextBlock Text="&#xE74D;" FontFamily="Segoe MDL2 Assets" FontSize="14"
                                                    Foreground="{StaticResource Brush.Text.Primary}" />
                                     </MenuItem.Icon>
                                 </MenuItem>
                            </ContextMenu>
                        </Border.ContextMenu>
                        <Grid>
                            <Image Source="{Binding SelectedGame.ScreenshotDisplayPath, Converter={StaticResource ThumbnailImage}, ConverterParameter=600}" Stretch="Fill" />

                            <!-- Embedded YouTube player — kullanıcı isteği: "video indirilmeyecek,
                                 sadece YouTube embed olarak oynatılacak", dış tarayıcı AÇILMAYACAK.
                                 Sadece IsPlayingVideo true iken görünür; navigasyon/durdurma
                                 MainWindow.xaml.cs'te yapılıyor (bkz. PlayYouTubeEmbedAsync,
                                 StopYouTubeEmbed) çünkü WebView2.Navigate imperatif bir çağrı,
                                 saf XAML binding ile ifade edilemiyor. -->
                            <wv2:WebView2 x:Name="YouTubePlayer"
                                          Visibility="{Binding IsPlayingVideo, Converter={StaticResource BoolToVisibility}}" />

                            <!-- Play overlay: sadece bir YouTube linki VE video henüz oynatılmıyorken
                                 (bkz. MainViewModel.ShowPlayOverlay). -->
                            <Button Command="{Binding PlayVideoCommand}" CommandParameter="{Binding SelectedGame}"
                                    Visibility="{Binding ShowPlayOverlay, Converter={StaticResource BoolToVisibility}}"
                                    HorizontalAlignment="Center" VerticalAlignment="Center"
                                    Cursor="Hand" ToolTip="YouTube'da İzle">
                                <Button.Template>
                                    <ControlTemplate TargetType="Button">
                                        <Border CornerRadius="28" Width="56" Height="56" Background="#99000000">
                                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center" />
                                        </Border>
                                    </ControlTemplate>
                                </Button.Template>
                                <Path Data="{StaticResource Icon.YouTube}" Fill="White" Width="30" Height="30" Stretch="Uniform" />
                            </Button>

                            <!-- Embed navigasyonu başarısız olursa (bkz. VideoEmbedFailed) SADECE bu
                                 durumda dış tarayıcıya düşen fallback — aksi halde kullanıcının
                                 izleyecek hiçbir yolu kalmaz. -->
                            <Button Content="Open on YouTube" Command="{Binding OpenVideoUrlCommand}" CommandParameter="{Binding SelectedGame}"
                                    Visibility="{Binding VideoEmbedFailed, Converter={StaticResource BoolToVisibility}}"
                                    HorizontalAlignment="Center" VerticalAlignment="Center" Padding="12,6" />

                            <StackPanel Orientation="Horizontal" HorizontalAlignment="Center" VerticalAlignment="Bottom" Margin="0,0,0,10"
                                        Visibility="{Binding IsPlayingVideo, Converter={StaticResource BoolToVisibility}, ConverterParameter=Invert}">
                                <Button Content="BAŞLAT" Style="{StaticResource LaunchButton}" Width="110"
                                        Command="{Binding LaunchCommand}" />
                            </StackPanel>
                        </Grid>
                    </Border>
                </Grid>
            </Border>

            <!-- "Görsel Getir" (tekli/toplu) sırasında pencerenin altında beliren ince ilerleme
                 çubuğu (kullanıcı isteği: "% gösteren ilerleyen bir gösterge bar"). Tüm sütunları
                 kaplayıp en son eklendiği için z-sırasında üstte — indirme bitince tekrar gizleniyor. -->
            <Border Grid.Column="0" Grid.ColumnSpan="4" VerticalAlignment="Bottom"
                    Background="{StaticResource Brush.Background.Panel}"
                    BorderBrush="{StaticResource Brush.Border}" BorderThickness="0,1,0,0" Padding="10,6"
                    Visibility="{Binding ShowMainArtworkProgressBar, Converter={StaticResource BoolToVisibility}}">
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="Auto" />
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="Auto" />
                        <ColumnDefinition Width="Auto" />
                    </Grid.ColumnDefinitions>
                    <TextBlock Grid.Column="0" Text="Görsel indiriliyor..." VerticalAlignment="Center"
                               FontSize="11" Foreground="{StaticResource Brush.Text.Secondary}" Margin="0,0,10,0" />
                    <ProgressBar Grid.Column="1" Minimum="0" Maximum="100" VerticalAlignment="Center"
                                 Value="{Binding ArtworkDownloadProgress, Mode=OneWay}" />
                    <TextBlock Grid.Column="2" VerticalAlignment="Center" FontSize="11" Width="34" TextAlignment="Right"
                               Margin="10,0,0,0" Foreground="{StaticResource Brush.Text.Secondary}"
                               Text="{Binding ArtworkDownloadProgress, StringFormat={}{0:0}%}" />
                    <!-- Durdur: kullanıcı isteği ("durduramıyoz şuanda") — CancelArtworkDownloadCommand
                         MainViewModel'deki CancellationTokenSource'u tetikler (bkz. FetchArtwork/
                         BulkFetchArtwork). -->
                    <Button Grid.Column="3" Content="Durdur" Margin="10,0,0,0" Padding="10,3" FontSize="11"
                            Command="{Binding CancelArtworkDownloadCommand}" />
                </Grid>
            </Border>
        </Grid>
    </Grid>
</Window>
