<Window x:Class="RetroAudit.Views.SettingsWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:vm="clr-namespace:RetroAudit.ViewModels"
        xmlns:models="clr-namespace:RetroAudit.Models"
        xmlns:conv="clr-namespace:RetroAudit.Converters"
        Title="Ayarlar / Admin Paneli" Height="700" Width="880" WindowStartupLocation="CenterOwner">

    <Window.DataContext>
        <vm:SettingsViewModel />
    </Window.DataContext>

    <Window.Resources>
        <!-- Komutlar sekmesindeki listeyi Category alanına göre gruplu göstermek için:
             tek düz liste yerine "Veri Yönetimi / Medya / Organizasyon / Oynatma" başlıkları altında
             ayrı ayrı gösteriliyor (kullanıcı isteği: "hepsi ayrı ayrı sınıflandırılacak"). -->
        <CollectionViewSource x:Key="CommandsGrouped" Source="{Binding Commands}">
            <CollectionViewSource.GroupDescriptions>
                <PropertyGroupDescription PropertyName="Category" />
            </CollectionViewSource.GroupDescriptions>
        </CollectionViewSource>
        <conv:EnumToBoolConverter x:Key="EnumToBool" />
        <conv:InverseBooleanConverter x:Key="InverseBoolean" />
    </Window.Resources>

    <Grid Background="{StaticResource Brush.Background.Base}">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
            <RowDefinition Height="Auto" />
        </Grid.RowDefinitions>

        <StackPanel Grid.Row="0" Margin="16,14,16,0">
            <TextBlock Text="Ayarlar / Admin Paneli" FontSize="18" FontWeight="Bold" />
            <TextBlock Text="Buradaki her alan JSON olarak dışa/içe aktarılabilir; günlük kullanımda kod değiştirmek gerekmez."
                       Foreground="{StaticResource Brush.Text.Secondary}" FontSize="11" Margin="0,4,0,0" />
        </StackPanel>

        <TabControl Grid.Row="1" Margin="16,10,16,10">

            <!-- ===================== Genel ===================== -->
            <TabItem Header="Genel">
                <ScrollViewer VerticalScrollBarVisibility="Auto">
                <StackPanel Margin="4,16,4,4">
                    <TextBlock Text="Veri Klasörü" FontWeight="Bold" Margin="0,0,0,4" />
                    <TextBlock Text="Games (romlar), Images (görseller) ve Metadata (veritabanları) her zaman uygulamanın kendi klasörünün yanında saklanır — taşınabilirlik için bu konum değiştirilemez."
                               Foreground="{StaticResource Brush.Text.Secondary}" FontSize="11" TextWrapping="Wrap" Margin="0,0,0,8" />
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="Auto" />
                        </Grid.ColumnDefinitions>
                        <TextBox Grid.Column="0" Text="{Binding DataRootPath, Mode=OneWay}" IsReadOnly="True"
                                 VerticalContentAlignment="Center" Margin="0,0,8,0" />
                        <Button Grid.Column="1" Content="Klasörü Aç" Width="90" Command="{Binding OpenDataFolderCommand}" />
                    </Grid>

                    <TextBlock Text="Görsel İndirme Boyutu" FontWeight="Bold" Margin="0,16,0,4" />
                    <TextBlock Text="'Görsel Getir' ile indirilen Box/BG/Screenshot görsellerinin en uzun kenarı bu boyuta küçültülür — uygulama hiçbir yerde bundan büyük göstermediği için netlik kaybı gözle görülmez, sadece dosya boyutu azalır."
                               Foreground="{StaticResource Brush.Text.Secondary}" FontSize="11" TextWrapping="Wrap" Margin="0,0,0,8" />
                    <RadioButton Margin="0,0,0,8" GroupName="ArtworkMaxDimension" IsChecked="{Binding ArtworkMaxDimension, Converter={StaticResource EnumToBool}, ConverterParameter=Px600}">
                        <StackPanel Margin="4,0,0,0">
                            <TextBlock Text="600px (Önerilen)" />
                            <TextBlock Text="En küçük dosya boyutu — uygulamadaki gösterim alanları için fazlasıyla yeterli netlik."
                                       Foreground="{StaticResource Brush.Text.Secondary}" FontSize="10" />
                        </StackPanel>
                    </RadioButton>
                    <RadioButton Margin="0,0,0,8" GroupName="ArtworkMaxDimension" IsChecked="{Binding ArtworkMaxDimension, Converter={StaticResource EnumToBool}, ConverterParameter=Px800}">
                        <StackPanel Margin="4,0,0,0">
                            <TextBlock Text="800px" />
                            <TextBlock Text="Biraz daha büyük dosyalar, pencere büyütülüp yakınlaştırılırsa fazladan netlik payı bırakır."
                                       Foreground="{StaticResource Brush.Text.Secondary}" FontSize="10" />
                        </StackPanel>
                    </RadioButton>
                    <RadioButton Margin="0,0,0,8" GroupName="ArtworkMaxDimension" IsChecked="{Binding ArtworkMaxDimension, Converter={StaticResource EnumToBool}, ConverterParameter=Original}">
                        <StackPanel Margin="4,0,0,0">
                            <TextBlock Text="Original Size (küçültme yok)" />
                            <TextBlock Text="Kaynak dosya boyutu aynen korunur — çok daha büyük dosyalar kaplar."
                                       Foreground="{StaticResource Brush.Text.Secondary}" FontSize="10" />
                        </StackPanel>
                    </RadioButton>

                    <TextBlock Text="LaunchBox.Metadata.db" FontWeight="Bold" Margin="0,16,0,4" />
                    <TextBlock Text="Sağ tık menüsündeki 'Re-match Metadata' komutu için — Builder'ın kullandığı aynı dosya, RetroAudit.db'ye yazılmaz, sadece burada tek bir oyunu yeniden eşleştirmek için okunur."
                               Foreground="{StaticResource Brush.Text.Secondary}" FontSize="11" TextWrapping="Wrap" Margin="0,0,0,8" />
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="Auto" />
                        </Grid.ColumnDefinitions>
                        <TextBox Grid.Column="0" Text="{Binding LaunchBoxDbPath, UpdateSourceTrigger=PropertyChanged}"
                                 VerticalContentAlignment="Center" Margin="0,0,8,0" />
                        <Button Grid.Column="1" Content="Gözat..." Width="90" Command="{Binding BrowseLaunchBoxDbCommand}" />
                    </Grid>
                </StackPanel>
                </ScrollViewer>
            </TabItem>

            <!-- ===================== Arayüz ===================== -->
            <TabItem Header="Arayüz">
                <ScrollViewer VerticalScrollBarVisibility="Auto">
                <StackPanel Margin="4,16,4,4">
                    <TextBlock Text="Sağ Tık Menüsü" FontWeight="Bold" Margin="0,0,0,4" />
                    <TextBlock Text="Oyun satırına sağ tıklandığında açılan kapsül menünün görünüm modu."
                               Foreground="{StaticResource Brush.Text.Secondary}" FontSize="11" TextWrapping="Wrap" Margin="0,0,0,8" />
                    <RadioButton Content="Icon + Text (ikon altında etiket metni)" Margin="0,0,0,6" GroupName="ContextMenuDisplayMode"
                                 IsChecked="{Binding ContextMenuDisplayMode, Converter={StaticResource EnumToBool}, ConverterParameter=IconAndText}" />
                    <RadioButton Content="Icon Only (sadece ikon, daha kompakt)" GroupName="ContextMenuDisplayMode"
                                 IsChecked="{Binding ContextMenuDisplayMode, Converter={StaticResource EnumToBool}, ConverterParameter=IconOnly}" />

                    <!-- Önceden ana penceredeki araç çubuğunda bir kaydırıcıydı ve hiç kalıcı
                         değildi (her açılışta 30'a sıfırlanıyordu) — kullanıcı isteğiyle buraya
                         taşındı, artık diğer Arayüz alanları gibi otomatik kaydedilip hatırlanıyor. -->
                    <TextBlock Text="Tablo Görünümü" FontWeight="Bold" Margin="0,20,0,4" />
                    <TextBlock Text="Oyun tablosundaki satır yüksekliği."
                               Foreground="{StaticResource Brush.Text.Secondary}" FontSize="11" TextWrapping="Wrap" Margin="0,0,0,8" />
                    <StackPanel Orientation="Horizontal">
                        <Slider Minimum="20" Maximum="60" Width="200" VerticalAlignment="Center" Value="{Binding RowHeight}" />
                        <TextBlock Text="{Binding RowHeight, StringFormat={}{0:0}}" Width="24" VerticalAlignment="Center" Margin="8,0,0,0" />
                    </StackPanel>

                    <!-- Kullanıcı isteği: "detaylardaki sürümleri ister bu şekilde açılır liste
                         isterse full açık olarak gösterebilme ayarı olsun". -->
                    <TextBlock Text="Detay Paneli" FontWeight="Bold" Margin="0,20,0,4" />
                    <TextBlock Text="Detay panelindeki 'Sürümler (Region)' bölümünün gösterim biçimi."
                               Foreground="{StaticResource Brush.Text.Secondary}" FontSize="11" TextWrapping="Wrap" Margin="0,0,0,8" />
                    <RadioButton Content="Tek kart (birden fazlaysa açılır listeden seç)" Margin="0,0,0,6" GroupName="ShowVersionsAsSingleCard"
                                 IsChecked="{Binding ShowVersionsAsSingleCard}" />
                    <RadioButton Content="Tam liste (tüm sürümler alt alta)" GroupName="ShowVersionsAsSingleCard"
                                 IsChecked="{Binding ShowVersionsAsSingleCard, Converter={StaticResource InverseBoolean}}" />

                    <!-- Şu an değiştirilebilir bir tema seçici yok (tek tema var) — bu sadece
                         bilgilendirme amaçlı; ileride birden fazla tema eklenirse buraya bir
                         seçici konabilir. -->
                    <TextBlock Text="Tema" FontWeight="Bold" Margin="0,20,0,4" />
                    <TextBlock Text="Obsidyen (koyu tema, sabit)"
                               Foreground="{StaticResource Brush.Text.Secondary}" FontSize="11" FontStyle="Italic" />

                    <!-- Sol paneldeki platform listesinin görünümü — grup/kategori ve satır görünümü
                         (yazı/logo) tercihleri, ana pencerede sürükle-bırak ile ayarlanan sıralamadan
                         (bkz. MainWindow.xaml.cs PlatformRow_Drop) ayrı ama onunla birlikte çalışır:
                         kategoriler AÇIKKEN sıralama sadece aynı kategori içinde yapılabilir. -->
                    <TextBlock Text="Platform Listesi" FontWeight="Bold" Margin="0,20,0,4" />
                    <TextBlock Text="Ana penceredeki soldaki platform listesinin görünümü. Sürükleyip bırakarak sıralamayı platform listesinin kendisinden değiştirebilirsiniz."
                               Foreground="{StaticResource Brush.Text.Secondary}" FontSize="11" TextWrapping="Wrap" Margin="0,0,0,8" />
                    <CheckBox Content="Kategorilere göre grupla (Konsollar, El Konsolları, ...)"
                              IsChecked="{Binding GroupPlatformsByCategory}" Margin="0,0,0,10" />

                    <TextBlock Text="Satır Görünümü" FontWeight="SemiBold" FontSize="11" Margin="0,0,0,4" />
                    <RadioButton Content="Yazı (platform adı)" Margin="0,0,0,4" GroupName="PlatformListDisplayMode"
                                 IsChecked="{Binding PlatformListDisplayMode, Converter={StaticResource EnumToBool}, ConverterParameter=Text}" />
                    <RadioButton Content="Logo (sadece kısa ikon, adı üzerine gelince görünür)" Margin="0,0,0,10" GroupName="PlatformListDisplayMode"
                                 IsChecked="{Binding PlatformListDisplayMode, Converter={StaticResource EnumToBool}, ConverterParameter=Logo}" />

                    <!-- Kullanıcı isteği: "tablodaki Region'da Bayrak Text / Text Bayrak / Bayrak /
                         Sadece Text seçeneği koy seçilebilsin". -->
                    <TextBlock Text="Tablodaki Bölge Sütunu Görünümü" FontWeight="SemiBold" FontSize="11" Margin="0,0,0,4" />
                    <RadioButton Content="Bayrak + Text" Margin="0,0,0,4" GroupName="RegionColumnDisplayMode"
                                 IsChecked="{Binding RegionColumnDisplayMode, Converter={StaticResource EnumToBool}, ConverterParameter=FlagAndText}" />
                    <RadioButton Content="Text + Bayrak" Margin="0,0,0,4" GroupName="RegionColumnDisplayMode"
                                 IsChecked="{Binding RegionColumnDisplayMode, Converter={StaticResource EnumToBool}, ConverterParameter=TextAndFlag}" />
                    <RadioButton Content="Sadece Bayrak" Margin="0,0,0,4" GroupName="RegionColumnDisplayMode"
                                 IsChecked="{Binding RegionColumnDisplayMode, Converter={StaticResource EnumToBool}, ConverterParameter=FlagOnly}" />
                    <RadioButton Content="Sadece Text" Margin="0,0,0,10" GroupName="RegionColumnDisplayMode"
                                 IsChecked="{Binding RegionColumnDisplayMode, Converter={StaticResource EnumToBool}, ConverterParameter=TextOnly}" />

                    <TextBlock Text="Görünür Kategoriler" FontWeight="SemiBold" FontSize="11" Margin="0,0,0,4">
                        <TextBlock.Style>
                            <Style TargetType="TextBlock">
                                <Setter Property="Opacity" Value="1" />
                                <Style.Triggers>
                                    <DataTrigger Binding="{Binding GroupPlatformsByCategory}" Value="False">
                                        <Setter Property="Opacity" Value="0.5" />
                                    </DataTrigger>
                                </Style.Triggers>
                            </Style>
                        </TextBlock.Style>
                    </TextBlock>
                    <ItemsControl ItemsSource="{Binding CategoryOptions}" IsEnabled="{Binding GroupPlatformsByCategory}">
                        <ItemsControl.ItemTemplate>
                            <DataTemplate DataType="{x:Type models:ColumnVisibilityOption}">
                                <CheckBox Content="{Binding Header}" IsChecked="{Binding IsVisible}" Margin="0,0,0,4" />
                            </DataTemplate>
                        </ItemsControl.ItemTemplate>
                    </ItemsControl>
                </StackPanel>
                </ScrollViewer>
            </TabItem>

            <!-- ===================== Emülatörler ===================== -->
            <TabItem Header="Emülatörler">
                <StackPanel Margin="4,16,4,4">
                    <TextBlock Text="Emülatör Ayarları" FontWeight="Bold" Margin="0,0,0,4" />
                    <TextBlock Text="Her platform için önerilen emülatör core'u (ve varsa alternatifi), kendi makinenizdeki gerçek .exe yolu ve başlatma parametrelerini burada tanımlayın. Sağ alttaki BAŞLAT butonu ileride bu tabloyu kullanacak; %ROM% seçili oyunun dosya yolu ile değiştirilecek yer tutucudur."
                               Foreground="{StaticResource Brush.Text.Secondary}" FontSize="11" TextWrapping="Wrap" Margin="0,0,0,8" />

                    <!-- Hücre şablonlarındaki butonların DataContext'i satırdaki EmulatorConfig olduğu için,
                         ViewModel komutlarına ulaşmak amacıyla RelativeSource AncestorType=Window ile
                         Window.DataContext (SettingsViewModel) üzerinden komut aranıyor; CommandParameter
                         olarak da satırın kendisi (EmulatorConfig) veriliyor. -->
                    <DataGrid ItemsSource="{Binding Emulators}" SelectedItem="{Binding SelectedEmulator}"
                              AutoGenerateColumns="False" CanUserAddRows="False" Height="330" Margin="0,0,0,8">
                        <DataGrid.Columns>
                            <DataGridTextColumn Header="Platform" Binding="{Binding PlatformName}" Width="1.6*" />
                            <DataGridTextColumn Header="Tercih Edilen Core" Binding="{Binding PreferredCore}" Width="1.1*" />
                            <DataGridTextColumn Header="Alternatif Core" Binding="{Binding AlternativeCore}" Width="1.1*" />
                            <DataGridTextColumn Header="Emülatör Yolu (.exe)" Binding="{Binding ExecutablePath}" Width="1.8*" />
                            <DataGridTextColumn Header="Parametreler" Binding="{Binding Parameters}" Width="1*" />
                            <DataGridTemplateColumn Header="" Width="80">
                                <DataGridTemplateColumn.CellTemplate>
                                    <DataTemplate>
                                        <Button Content="Gözat..."
                                                Command="{Binding DataContext.BrowseEmulatorPathCommand, RelativeSource={RelativeSource AncestorType=Window}}"
                                                CommandParameter="{Binding}" />
                                    </DataTemplate>
                                </DataGridTemplateColumn.CellTemplate>
                            </DataGridTemplateColumn>
                            <DataGridTemplateColumn Header="" Width="60">
                                <DataGridTemplateColumn.CellTemplate>
                                    <DataTemplate>
                                        <Button Content="Sil"
                                                Command="{Binding DataContext.RemoveEmulatorCommand, RelativeSource={RelativeSource AncestorType=Window}}"
                                                CommandParameter="{Binding}" />
                                    </DataTemplate>
                                </DataGridTemplateColumn.CellTemplate>
                            </DataGridTemplateColumn>
                        </DataGrid.Columns>
                    </DataGrid>
                    <Button Content="+ Emülatör Ekle" HorizontalAlignment="Left" Command="{Binding AddEmulatorCommand}" />
                </StackPanel>
            </TabItem>

            <!-- ===================== Bölge Önceliği ===================== -->
            <TabItem Header="Bölge Önceliği">
                <StackPanel Margin="4,16,4,4">
                    <TextBlock Text="Bölge Önceliği" FontWeight="Bold" Margin="0,0,0,4" />
                    <TextBlock Text="Aynı oyunun birden fazla bölge sürümü (ör. USA/EU/JP) bulunduğunda hangisinin tercih edileceğini belirler. Listenin en üstündeki bölge en yüksek önceliğe sahiptir; sıralamayı Yukarı/Aşağı ile değiştirebilirsiniz."
                               Foreground="{StaticResource Brush.Text.Secondary}" FontSize="11" TextWrapping="Wrap" Margin="0,0,0,8" />
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="Auto" />
                        </Grid.ColumnDefinitions>
                        <ListBox Grid.Column="0" ItemsSource="{Binding RegionPriority}" SelectedItem="{Binding SelectedRegion}" Height="150" />
                        <StackPanel Grid.Column="1" Margin="8,0,0,0" VerticalAlignment="Center">
                            <Button Content="Yukarı" Width="80" Margin="0,0,0,6"
                                    Command="{Binding MoveRegionUpCommand}" CommandParameter="{Binding SelectedRegion}" />
                            <Button Content="Aşağı" Width="80"
                                    Command="{Binding MoveRegionDownCommand}" CommandParameter="{Binding SelectedRegion}" />
                        </StackPanel>
                    </Grid>
                </StackPanel>
            </TabItem>

            <!-- ===================== Komutlar ===================== -->
            <TabItem Header="Komutlar">
                <DockPanel Margin="4,16,4,4">
                    <StackPanel DockPanel.Dock="Top" Margin="0,0,0,8">
                        <TextBlock Text="Toolbar Komutları" FontWeight="Bold" Margin="0,0,0,4" />
                        <TextBlock TextWrapping="Wrap" Foreground="{StaticResource Brush.Text.Secondary}" FontSize="11">
                            Ana penceredeki araç çubuğu butonlarının ne yaptığının açıklaması ve (varsa) parametresi.
                            Bu aşamada komutların çoğu henüz gerçek bir işlev yapmıyor (UI iskeleti); ancak ileride
                            gerçek mantık eklendiğinde buradaki Parametre değerlerini okuyacak şekilde bağlanacak —
                            yani davranışı değiştirmek için kod yazmak yerine burayı düzenlemek yeterli olacak.
                        </TextBlock>
                    </StackPanel>

                    <ScrollViewer VerticalScrollBarVisibility="Auto">
                        <ItemsControl ItemsSource="{Binding Source={StaticResource CommandsGrouped}}">
                            <ItemsControl.GroupStyle>
                                <GroupStyle>
                                    <GroupStyle.HeaderTemplate>
                                        <DataTemplate>
                                            <TextBlock Text="{Binding Name}" FontWeight="Bold" FontSize="13"
                                                       Foreground="{StaticResource Brush.Accent.SelectedBorder}"
                                                       Margin="0,14,0,6" />
                                        </DataTemplate>
                                    </GroupStyle.HeaderTemplate>
                                </GroupStyle>
                            </ItemsControl.GroupStyle>
                            <ItemsControl.ItemTemplate>
                                <DataTemplate DataType="{x:Type models:CommandSetting}">
                                    <Border Background="{StaticResource Brush.Background.Panel}" CornerRadius="4"
                                            Padding="10" Margin="0,0,0,6">
                                        <Grid>
                                            <Grid.ColumnDefinitions>
                                                <ColumnDefinition Width="160" />
                                                <ColumnDefinition Width="*" />
                                                <ColumnDefinition Width="220" />
                                            </Grid.ColumnDefinitions>
                                            <TextBlock Grid.Column="0" Text="{Binding CommandName}" FontWeight="SemiBold" VerticalAlignment="Center" />
                                            <TextBlock Grid.Column="1" Text="{Binding Description}" TextWrapping="Wrap"
                                                       Foreground="{StaticResource Brush.Text.Secondary}" FontSize="11"
                                                       VerticalAlignment="Center" Margin="8,0" />
                                            <TextBox Grid.Column="2" Text="{Binding Parameter, UpdateSourceTrigger=PropertyChanged}"
                                                     VerticalContentAlignment="Center" />
                                        </Grid>
                                    </Border>
                                </DataTemplate>
                            </ItemsControl.ItemTemplate>
                        </ItemsControl>
                    </ScrollViewer>
                </DockPanel>
            </TabItem>

        </TabControl>

        <!-- Kaydet / Export / Import Config: tüm sekmelerdeki ayarları kapsadığı için sekmelerin
             dışında, pencerenin altında sabit duruyor. Kaydet: kullanıcı kararıyla eklendi — ayarlar
             artık her değişiklikte sessizce değil, sadece bu düğmeye (veya Export'a) basıldığında
             diske yazılıyor (bkz. SettingsViewModel.SaveSettings). -->
        <Border Grid.Row="2" Background="{StaticResource Brush.Background.Panel}"
                BorderBrush="{StaticResource Brush.Border}" BorderThickness="0,1,0,0" Padding="16,10">
            <StackPanel Orientation="Horizontal" HorizontalAlignment="Right">
                <Button Content="Import Config (JSON)" Width="150" Margin="0,0,8,0" Command="{Binding ImportConfigCommand}" />
                <Button Content="Export Config (JSON)" Width="150" Margin="0,0,8,0" Command="{Binding ExportConfigCommand}" />
                <Button Content="Kaydet" Width="110" Style="{StaticResource LaunchButton}" Command="{Binding SaveSettingsCommand}" />
            </StackPanel>
        </Border>
    </Grid>
</Window>
