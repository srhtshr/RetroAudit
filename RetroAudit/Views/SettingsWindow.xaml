<Window x:Class="RetroAudit.Views.SettingsWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:vm="clr-namespace:RetroAudit.ViewModels"
        Title="Ayarlar / Admin Paneli" Height="680" Width="820" WindowStartupLocation="CenterOwner">

    <Window.DataContext>
        <vm:SettingsViewModel />
    </Window.DataContext>

    <Grid Background="{StaticResource Brush.Background.Base}">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
            <RowDefinition Height="Auto" />
        </Grid.RowDefinitions>

        <TextBlock Grid.Row="0" Text="Ayarlar / Admin Paneli" FontSize="18" FontWeight="Bold" Margin="16,14,16,0" />

        <ScrollViewer Grid.Row="1" Margin="16,10,16,10" VerticalScrollBarVisibility="Auto">
            <StackPanel>

                <!-- LaunchBox kök dizini -->
                <TextBlock Text="LaunchBox Ana Dizini" FontWeight="Bold" Margin="0,0,0,6" />
                <Grid Margin="0,0,0,20">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="Auto" />
                    </Grid.ColumnDefinitions>
                    <TextBox Grid.Column="0" Text="{Binding LaunchBoxRootPath, UpdateSourceTrigger=PropertyChanged}"
                             VerticalContentAlignment="Center" Margin="0,0,8,0" />
                    <Button Grid.Column="1" Content="Gözat..." Width="90" Command="{Binding BrowseLaunchBoxPathCommand}" />
                </Grid>

                <!-- Emülatör listesi -->
                <TextBlock Text="Emülatör Ayarları (Platform → Çalıştırılabilir Dosya + Parametreler)"
                           FontWeight="Bold" Margin="0,0,0,6" />
                <!-- Hücre şablonlarındaki butonların DataContext'i satırdaki EmulatorConfig olduğu için,
                     ViewModel komutlarına ulaşmak amacıyla RelativeSource AncestorType=Window ile
                     Window.DataContext (SettingsViewModel) üzerinden komut aranıyor; CommandParameter
                     olarak da satırın kendisi (EmulatorConfig) veriliyor. -->
                <DataGrid ItemsSource="{Binding Emulators}" SelectedItem="{Binding SelectedEmulator}"
                          AutoGenerateColumns="False" CanUserAddRows="False" Height="220" Margin="0,0,0,8">
                    <DataGrid.Columns>
                        <DataGridTextColumn Header="Platform" Binding="{Binding PlatformName}" Width="1.4*" />
                        <DataGridTextColumn Header="Emülatör Yolu" Binding="{Binding ExecutablePath}" Width="2.2*" />
                        <DataGridTextColumn Header="Parametreler" Binding="{Binding Parameters}" Width="1.2*" />
                        <DataGridTemplateColumn Header="" Width="80">
                            <DataGridTemplateColumn.CellTemplate>
                                <DataTemplate>
                                    <Button Content="Gözat..."
                                            Command="{Binding DataContext.BrowseEmulatorPathCommand, RelativeSource={RelativeSource AncestorType=Window}}"
                                            CommandParameter="{Binding}" />
                                </DataTemplate>
                            </DataGridTemplateColumn.CellTemplate>
                        </DataGridTemplateColumn>
                        <DataGridTemplateColumn Header="" Width="60">
                            <DataGridTemplateColumn.CellTemplate>
                                <DataTemplate>
                                    <Button Content="Sil"
                                            Command="{Binding DataContext.RemoveEmulatorCommand, RelativeSource={RelativeSource AncestorType=Window}}"
                                            CommandParameter="{Binding}" />
                                </DataTemplate>
                            </DataGridTemplateColumn.CellTemplate>
                        </DataGridTemplateColumn>
                    </DataGrid.Columns>
                </DataGrid>
                <Button Content="+ Emülatör Ekle" HorizontalAlignment="Left" Command="{Binding AddEmulatorCommand}" Margin="0,0,0,20" />

                <!-- Bölge önceliği -->
                <TextBlock Text="Bölge Önceliği (üstteki bölge daha yüksek öncelikli)" FontWeight="Bold" Margin="0,0,0,6" />
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="Auto" />
                    </Grid.ColumnDefinitions>
                    <ListBox Grid.Column="0" ItemsSource="{Binding RegionPriority}" SelectedItem="{Binding SelectedRegion}" Height="110" />
                    <StackPanel Grid.Column="1" Margin="8,0,0,0" VerticalAlignment="Center">
                        <Button Content="Yukarı" Width="80" Margin="0,0,0,6"
                                Command="{Binding MoveRegionUpCommand}" CommandParameter="{Binding SelectedRegion}" />
                        <Button Content="Aşağı" Width="80"
                                Command="{Binding MoveRegionDownCommand}" CommandParameter="{Binding SelectedRegion}" />
                    </StackPanel>
                </Grid>

            </StackPanel>
        </ScrollViewer>

        <!-- Export / Import Config -->
        <Border Grid.Row="2" Background="{StaticResource Brush.Background.Panel}"
                BorderBrush="{StaticResource Brush.Border}" BorderThickness="0,1,0,0" Padding="16,10">
            <StackPanel Orientation="Horizontal" HorizontalAlignment="Right">
                <Button Content="Import Config (JSON)" Width="150" Margin="0,0,8,0" Command="{Binding ImportConfigCommand}" />
                <Button Content="Export Config (JSON)" Width="150" Style="{StaticResource LaunchButton}" Command="{Binding ExportConfigCommand}" />
            </StackPanel>
        </Border>
    </Grid>
</Window>
