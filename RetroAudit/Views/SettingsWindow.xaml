<Window x:Class="RetroAudit.Views.SettingsWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:vm="clr-namespace:RetroAudit.ViewModels"
        xmlns:models="clr-namespace:RetroAudit.Models"
        Title="Ayarlar / Admin Paneli" Height="700" Width="880" WindowStartupLocation="CenterOwner">

    <Window.DataContext>
        <vm:SettingsViewModel />
    </Window.DataContext>

    <Window.Resources>
        <!-- Komutlar sekmesindeki listeyi Category alanına göre gruplu göstermek için:
             tek düz liste yerine "Veri Yönetimi / Medya / Organizasyon / Oynatma" başlıkları altında
             ayrı ayrı gösteriliyor (kullanıcı isteği: "hepsi ayrı ayrı sınıflandırılacak"). -->
        <CollectionViewSource x:Key="CommandsGrouped" Source="{Binding Commands}">
            <CollectionViewSource.GroupDescriptions>
                <PropertyGroupDescription PropertyName="Category" />
            </CollectionViewSource.GroupDescriptions>
        </CollectionViewSource>
    </Window.Resources>

    <Grid Background="{StaticResource Brush.Background.Base}">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
            <RowDefinition Height="Auto" />
        </Grid.RowDefinitions>

        <StackPanel Grid.Row="0" Margin="16,14,16,0">
            <TextBlock Text="Ayarlar / Admin Paneli" FontSize="18" FontWeight="Bold" />
            <TextBlock Text="Buradaki her alan JSON olarak dışa/içe aktarılabilir; günlük kullanımda kod değiştirmek gerekmez."
                       Foreground="{StaticResource Brush.Text.Secondary}" FontSize="11" Margin="0,4,0,0" />
        </StackPanel>

        <TabControl Grid.Row="1" Margin="16,10,16,10">

            <!-- ===================== Genel ===================== -->
            <TabItem Header="Genel">
                <StackPanel Margin="4,16,4,4">
                    <TextBlock Text="RetroAudit Data Dizini" FontWeight="Bold" Margin="0,0,0,4" />
                    <TextBlock Text="Romlar, medya dosyaları ve RetroAudit.db bu klasör altında aranacak (gerçek tarama mantığı henüz bağlı değil, bu alan ileriki aşama için hazırlık)."
                               Foreground="{StaticResource Brush.Text.Secondary}" FontSize="11" TextWrapping="Wrap" Margin="0,0,0,8" />
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="Auto" />
                        </Grid.ColumnDefinitions>
                        <TextBox Grid.Column="0" Text="{Binding RetroAuditDataPath, UpdateSourceTrigger=PropertyChanged}"
                                 VerticalContentAlignment="Center" Margin="0,0,8,0" />
                        <Button Grid.Column="1" Content="Gözat..." Width="90" Command="{Binding BrowseDataPathCommand}" />
                    </Grid>
                </StackPanel>
            </TabItem>

            <!-- ===================== Emülatörler ===================== -->
            <TabItem Header="Emülatörler">
                <StackPanel Margin="4,16,4,4">
                    <TextBlock Text="Emülatör Ayarları" FontWeight="Bold" Margin="0,0,0,4" />
                    <TextBlock Text="Her platform için önerilen emülatör core'u (ve varsa alternatifi), kendi makinenizdeki gerçek .exe yolu ve başlatma parametrelerini burada tanımlayın. Sağ alttaki BAŞLAT butonu ileride bu tabloyu kullanacak; %ROM% seçili oyunun dosya yolu ile değiştirilecek yer tutucudur."
                               Foreground="{StaticResource Brush.Text.Secondary}" FontSize="11" TextWrapping="Wrap" Margin="0,0,0,8" />

                    <!-- Hücre şablonlarındaki butonların DataContext'i satırdaki EmulatorConfig olduğu için,
                         ViewModel komutlarına ulaşmak amacıyla RelativeSource AncestorType=Window ile
                         Window.DataContext (SettingsViewModel) üzerinden komut aranıyor; CommandParameter
                         olarak da satırın kendisi (EmulatorConfig) veriliyor. -->
                    <DataGrid ItemsSource="{Binding Emulators}" SelectedItem="{Binding SelectedEmulator}"
                              AutoGenerateColumns="False" CanUserAddRows="False" Height="330" Margin="0,0,0,8">
                        <DataGrid.Columns>
                            <DataGridTextColumn Header="Platform" Binding="{Binding PlatformName}" Width="1.6*" />
                            <DataGridTextColumn Header="Tercih Edilen Core" Binding="{Binding PreferredCore}" Width="1.1*" />
                            <DataGridTextColumn Header="Alternatif Core" Binding="{Binding AlternativeCore}" Width="1.1*" />
                            <DataGridTextColumn Header="Emülatör Yolu (.exe)" Binding="{Binding ExecutablePath}" Width="1.8*" />
                            <DataGridTextColumn Header="Parametreler" Binding="{Binding Parameters}" Width="1*" />
                            <DataGridTemplateColumn Header="" Width="80">
                                <DataGridTemplateColumn.CellTemplate>
                                    <DataTemplate>
                                        <Button Content="Gözat..."
                                                Command="{Binding DataContext.BrowseEmulatorPathCommand, RelativeSource={RelativeSource AncestorType=Window}}"
                                                CommandParameter="{Binding}" />
                                    </DataTemplate>
                                </DataGridTemplateColumn.CellTemplate>
                            </DataGridTemplateColumn>
                            <DataGridTemplateColumn Header="" Width="60">
                                <DataGridTemplateColumn.CellTemplate>
                                    <DataTemplate>
                                        <Button Content="Sil"
                                                Command="{Binding DataContext.RemoveEmulatorCommand, RelativeSource={RelativeSource AncestorType=Window}}"
                                                CommandParameter="{Binding}" />
                                    </DataTemplate>
                                </DataGridTemplateColumn.CellTemplate>
                            </DataGridTemplateColumn>
                        </DataGrid.Columns>
                    </DataGrid>
                    <Button Content="+ Emülatör Ekle" HorizontalAlignment="Left" Command="{Binding AddEmulatorCommand}" />
                </StackPanel>
            </TabItem>

            <!-- ===================== Bölge Önceliği ===================== -->
            <TabItem Header="Bölge Önceliği">
                <StackPanel Margin="4,16,4,4">
                    <TextBlock Text="Bölge Önceliği" FontWeight="Bold" Margin="0,0,0,4" />
                    <TextBlock Text="Aynı oyunun birden fazla bölge sürümü (ör. USA/EU/JP) bulunduğunda hangisinin tercih edileceğini belirler. Listenin en üstündeki bölge en yüksek önceliğe sahiptir; sıralamayı Yukarı/Aşağı ile değiştirebilirsiniz."
                               Foreground="{StaticResource Brush.Text.Secondary}" FontSize="11" TextWrapping="Wrap" Margin="0,0,0,8" />
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="Auto" />
                        </Grid.ColumnDefinitions>
                        <ListBox Grid.Column="0" ItemsSource="{Binding RegionPriority}" SelectedItem="{Binding SelectedRegion}" Height="150" />
                        <StackPanel Grid.Column="1" Margin="8,0,0,0" VerticalAlignment="Center">
                            <Button Content="Yukarı" Width="80" Margin="0,0,0,6"
                                    Command="{Binding MoveRegionUpCommand}" CommandParameter="{Binding SelectedRegion}" />
                            <Button Content="Aşağı" Width="80"
                                    Command="{Binding MoveRegionDownCommand}" CommandParameter="{Binding SelectedRegion}" />
                        </StackPanel>
                    </Grid>
                </StackPanel>
            </TabItem>

            <!-- ===================== Komutlar ===================== -->
            <TabItem Header="Komutlar">
                <DockPanel Margin="4,16,4,4">
                    <StackPanel DockPanel.Dock="Top" Margin="0,0,0,8">
                        <TextBlock Text="Toolbar Komutları" FontWeight="Bold" Margin="0,0,0,4" />
                        <TextBlock TextWrapping="Wrap" Foreground="{StaticResource Brush.Text.Secondary}" FontSize="11">
                            Ana penceredeki araç çubuğu butonlarının ne yaptığının açıklaması ve (varsa) parametresi.
                            Bu aşamada komutların çoğu henüz gerçek bir işlev yapmıyor (UI iskeleti); ancak ileride
                            gerçek mantık eklendiğinde buradaki Parametre değerlerini okuyacak şekilde bağlanacak —
                            yani davranışı değiştirmek için kod yazmak yerine burayı düzenlemek yeterli olacak.
                        </TextBlock>
                    </StackPanel>

                    <ScrollViewer VerticalScrollBarVisibility="Auto">
                        <ItemsControl ItemsSource="{Binding Source={StaticResource CommandsGrouped}}">
                            <ItemsControl.GroupStyle>
                                <GroupStyle>
                                    <GroupStyle.HeaderTemplate>
                                        <DataTemplate>
                                            <TextBlock Text="{Binding Name}" FontWeight="Bold" FontSize="13"
                                                       Foreground="{StaticResource Brush.Accent.SelectedBorder}"
                                                       Margin="0,14,0,6" />
                                        </DataTemplate>
                                    </GroupStyle.HeaderTemplate>
                                </GroupStyle>
                            </ItemsControl.GroupStyle>
                            <ItemsControl.ItemTemplate>
                                <DataTemplate DataType="{x:Type models:CommandSetting}">
                                    <Border Background="{StaticResource Brush.Background.Panel}" CornerRadius="4"
                                            Padding="10" Margin="0,0,0,6">
                                        <Grid>
                                            <Grid.ColumnDefinitions>
                                                <ColumnDefinition Width="160" />
                                                <ColumnDefinition Width="*" />
                                                <ColumnDefinition Width="220" />
                                            </Grid.ColumnDefinitions>
                                            <TextBlock Grid.Column="0" Text="{Binding CommandName}" FontWeight="SemiBold" VerticalAlignment="Center" />
                                            <TextBlock Grid.Column="1" Text="{Binding Description}" TextWrapping="Wrap"
                                                       Foreground="{StaticResource Brush.Text.Secondary}" FontSize="11"
                                                       VerticalAlignment="Center" Margin="8,0" />
                                            <TextBox Grid.Column="2" Text="{Binding Parameter, UpdateSourceTrigger=PropertyChanged}"
                                                     VerticalContentAlignment="Center" />
                                        </Grid>
                                    </Border>
                                </DataTemplate>
                            </ItemsControl.ItemTemplate>
                        </ItemsControl>
                    </ScrollViewer>
                </DockPanel>
            </TabItem>

        </TabControl>

        <!-- Export / Import Config: tüm sekmelerdeki ayarları kapsadığı için sekmelerin dışında,
             pencerenin altında sabit duruyor. -->
        <Border Grid.Row="2" Background="{StaticResource Brush.Background.Panel}"
                BorderBrush="{StaticResource Brush.Border}" BorderThickness="0,1,0,0" Padding="16,10">
            <StackPanel Orientation="Horizontal" HorizontalAlignment="Right">
                <Button Content="Import Config (JSON)" Width="150" Margin="0,0,8,0" Command="{Binding ImportConfigCommand}" />
                <Button Content="Export Config (JSON)" Width="150" Style="{StaticResource LaunchButton}" Command="{Binding ExportConfigCommand}" />
            </StackPanel>
        </Border>
    </Grid>
</Window>
