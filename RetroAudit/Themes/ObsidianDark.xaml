<!-- Uygulama genelindeki "Obsidian" koyu tema. App.xaml içinde tek merkezi kaynak sözlüğü
     olarak birleştirilir; tüm pencereler (isimli bir Style vermeden) buradaki implicit
     (TargetType tabanlı) stilleri otomatik alır. Renk değiştirmek istendiğinde sadece
     aşağıdaki Palette bölümündeki Color değerlerini güncellemek yeterlidir. -->
<ResourceDictionary xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
                    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
                    xmlns:sys="clr-namespace:System;assembly=mscorlib">

    <!-- ===================== Palette ===================== -->
    <Color x:Key="Color.Background.Base">#FF1E1E1E</Color>
    <Color x:Key="Color.Background.Panel">#FF252526</Color>
    <Color x:Key="Color.Background.Elevated">#FF2D2D30</Color>
    <Color x:Key="Color.Background.Hover">#FF3A3D41</Color>
    <Color x:Key="Color.Border">#FF3F3F46</Color>
    <Color x:Key="Color.Text.Primary">#FFE6E6E6</Color>
    <Color x:Key="Color.Text.Secondary">#FF9D9D9D</Color>
    <Color x:Key="Color.Accent.Selected">#FF094771</Color>
    <Color x:Key="Color.Accent.SelectedBorder">#FF3399FF</Color>
    <Color x:Key="Color.Accent.Amber">#FFD9932B</Color>
    <Color x:Key="Color.Accent.AmberText">#FF1E1E1E</Color>
    <Color x:Key="Color.Status.Ok">#FFA855F7</Color>
    <Color x:Key="Color.Status.Missing">#FFE5484D</Color>
    <Color x:Key="Color.Accent.Launch">#FF1E4C7A</Color>
    <Color x:Key="Color.Accent.LaunchHover">#FF2A62A0</Color>

    <SolidColorBrush x:Key="Brush.Background.Base" Color="{StaticResource Color.Background.Base}" />
    <SolidColorBrush x:Key="Brush.Background.Panel" Color="{StaticResource Color.Background.Panel}" />
    <SolidColorBrush x:Key="Brush.Background.Elevated" Color="{StaticResource Color.Background.Elevated}" />
    <SolidColorBrush x:Key="Brush.Background.Hover" Color="{StaticResource Color.Background.Hover}" />
    <SolidColorBrush x:Key="Brush.Border" Color="{StaticResource Color.Border}" />
    <SolidColorBrush x:Key="Brush.Text.Primary" Color="{StaticResource Color.Text.Primary}" />
    <SolidColorBrush x:Key="Brush.Text.Secondary" Color="{StaticResource Color.Text.Secondary}" />
    <SolidColorBrush x:Key="Brush.Accent.Selected" Color="{StaticResource Color.Accent.Selected}" />
    <SolidColorBrush x:Key="Brush.Accent.SelectedBorder" Color="{StaticResource Color.Accent.SelectedBorder}" />
    <SolidColorBrush x:Key="Brush.Accent" Color="{StaticResource Color.Accent.SelectedBorder}" />
    <SolidColorBrush x:Key="Brush.Accent.Amber" Color="{StaticResource Color.Accent.Amber}" />
    <SolidColorBrush x:Key="Brush.Accent.AmberText" Color="{StaticResource Color.Accent.AmberText}" />
    <SolidColorBrush x:Key="Brush.Status.Ok" Color="{StaticResource Color.Status.Ok}" />
    <SolidColorBrush x:Key="Brush.Status.Missing" Color="{StaticResource Color.Status.Missing}" />
    <SolidColorBrush x:Key="Brush.Accent.Launch" Color="{StaticResource Color.Accent.Launch}" />
    <SolidColorBrush x:Key="Brush.Accent.LaunchHover" Color="{StaticResource Color.Accent.LaunchHover}" />

    <!-- ===================== Base text/scroll defaults ===================== -->
    <Style TargetType="{x:Type Window}">
        <Setter Property="Background" Value="{StaticResource Brush.Background.Base}" />
        <Setter Property="Foreground" Value="{StaticResource Brush.Text.Primary}" />
        <Setter Property="FontFamily" Value="Segoe UI" />
        <Setter Property="FontSize" Value="12" />
    </Style>

    <Style TargetType="{x:Type TextBlock}">
        <Setter Property="Foreground" Value="{StaticResource Brush.Text.Primary}" />
    </Style>

    <Style TargetType="{x:Type Label}">
        <Setter Property="Foreground" Value="{StaticResource Brush.Text.Secondary}" />
        <Setter Property="Padding" Value="0" />
    </Style>

    <!-- ===================== ScrollBar ===================== -->
    <Style x:Key="ScrollThumb" TargetType="{x:Type Thumb}">
        <Setter Property="Template">
            <Setter.Value>
                <ControlTemplate TargetType="{x:Type Thumb}">
                    <Border Background="{StaticResource Brush.Background.Hover}" CornerRadius="3" Margin="1" />
                </ControlTemplate>
            </Setter.Value>
        </Setter>
    </Style>

    <Style TargetType="{x:Type ScrollBar}">
        <Style.Resources>
            <sys:Double x:Key="{x:Static SystemParameters.VerticalScrollBarButtonHeightKey}">120</sys:Double>
            <sys:Double x:Key="{x:Static SystemParameters.HorizontalScrollBarButtonWidthKey}">120</sys:Double>
        </Style.Resources>
        <Setter Property="Background" Value="Transparent" />
        <Setter Property="VerticalAlignment" Value="Stretch" />
        <Setter Property="HorizontalAlignment" Value="Stretch" />
        <Setter Property="Template">
            <Setter.Value>
                <ControlTemplate TargetType="{x:Type ScrollBar}">
                    <!-- Track/RepeatButton alanları (Thumb hariç) Transparent'tı, yani scrollbar'ın
                         kendi alanı komşu elemanlarla (ör. sağ panel aç/kapa tutamacının bulunduğu
                         sütun) aynı arkaplanı gösteriyor ve ikisi görsel olarak "tek bir alan" gibi
                         birleşiyordu. Kök Grid'e sabit, hafif bir arkaplan vererek scrollbar'ın
                         kapladığı alan (thumb'ın etrafındaki boşluk dahil) net bir sınırla ayrılıyor. -->
                    <Grid Background="{StaticResource Brush.Background.Elevated}">
                        <Track Name="PART_Track"
                               Minimum="{TemplateBinding Minimum}"
                               Maximum="{TemplateBinding Maximum}"
                               Value="{TemplateBinding Value}"
                               ViewportSize="{TemplateBinding ViewportSize}"
                               Orientation="{TemplateBinding Orientation}">
                            <Track.Thumb>
                                <Thumb x:Name="Thumb" Style="{StaticResource ScrollThumb}" />
                            </Track.Thumb>
                            <Track.DecreaseRepeatButton>
                                <RepeatButton Command="ScrollBar.PageUpCommand" OverridesDefaultStyle="True" Focusable="False" IsTabStop="False">
                                    <RepeatButton.Template>
                                        <ControlTemplate TargetType="{x:Type RepeatButton}">
                                            <Border Background="Transparent" Height="{TemplateBinding Height}" Width="{TemplateBinding Width}" />
                                        </ControlTemplate>
                                    </RepeatButton.Template>
                                </RepeatButton>
                            </Track.DecreaseRepeatButton>
                            <Track.IncreaseRepeatButton>
                                <RepeatButton Command="ScrollBar.PageDownCommand" OverridesDefaultStyle="True" Focusable="False" IsTabStop="False">
                                    <RepeatButton.Template>
                                        <ControlTemplate TargetType="{x:Type RepeatButton}">
                                            <Border Background="Transparent" Height="{TemplateBinding Height}" Width="{TemplateBinding Width}" />
                                        </ControlTemplate>
                                    </RepeatButton.Template>
                                </RepeatButton>
                            </Track.IncreaseRepeatButton>
                        </Track>
                    </Grid>
                    <ControlTemplate.Triggers>
                        <Trigger Property="Orientation" Value="Horizontal">
                            <Setter TargetName="PART_Track" Property="IsDirectionReversed" Value="False" />
                            <Setter TargetName="Thumb" Property="MinWidth" Value="60" />
                        </Trigger>
                        <Trigger Property="Orientation" Value="Vertical">
                            <Setter TargetName="PART_Track" Property="IsDirectionReversed" Value="True" />
                            <Setter TargetName="Thumb" Property="MinHeight" Value="60" />
                        </Trigger>
                    </ControlTemplate.Triggers>
                </ControlTemplate>
            </Setter.Value>
        </Setter>
        <Style.Triggers>
            <Trigger Property="Orientation" Value="Horizontal">
                <Setter Property="Width" Value="Auto" />
                <Setter Property="Height" Value="14" />
            </Trigger>
            <Trigger Property="Orientation" Value="Vertical">
                <Setter Property="Width" Value="14" />
                <Setter Property="Height" Value="Auto" />
            </Trigger>
        </Style.Triggers>
    </Style>

    <!-- ===================== Buttons ===================== -->
    <Style TargetType="{x:Type Button}">
        <Setter Property="Background" Value="{StaticResource Brush.Background.Elevated}" />
        <Setter Property="Foreground" Value="{StaticResource Brush.Text.Primary}" />
        <Setter Property="BorderBrush" Value="{StaticResource Brush.Border}" />
        <Setter Property="BorderThickness" Value="1" />
        <Setter Property="Padding" Value="10,5" />
        <Setter Property="Cursor" Value="Hand" />
        <Setter Property="Template">
            <Setter.Value>
                <ControlTemplate TargetType="{x:Type Button}">
                    <Border x:Name="border"
                            Background="{TemplateBinding Background}"
                            BorderBrush="{TemplateBinding BorderBrush}"
                            BorderThickness="{TemplateBinding BorderThickness}"
                            CornerRadius="3">
                        <ContentPresenter HorizontalAlignment="Center"
                                           VerticalAlignment="Center"
                                           Margin="{TemplateBinding Padding}" />
                    </Border>
                    <ControlTemplate.Triggers>
                        <Trigger Property="IsMouseOver" Value="True">
                            <Setter TargetName="border" Property="Background" Value="{StaticResource Brush.Background.Hover}" />
                        </Trigger>
                        <Trigger Property="IsEnabled" Value="False">
                            <Setter Property="Opacity" Value="0.5" />
                        </Trigger>
                    </ControlTemplate.Triggers>
                </ControlTemplate>
            </Setter.Value>
        </Setter>
    </Style>

    <!-- ===================== ProgressBar ===================== -->
    <!-- "Görsel Getir" indirme ilerlemesi için (bkz. MainWindow.xaml alt durum çubuğu). Varsayılan
         WPF ProgressBar'ı (beyaz Aero şeridi) koyu temaya hiç uymuyordu. PART_Indicator ismi WPF'in
         kendi ProgressBar mantığı tarafından aranıyor — Value/Minimum/Maximum'a göre genişliğini
         otomatik hesaplıyor, burada sadece görünümü (düz renkli, köşeleri yuvarlak) özelleştiriliyor.
         Kullanıcı isteği: "ilerleme çubuğu gözüküyor ama ilerleme olmuyor dümdüz duruyor" — kök neden:
         bu şablon IsIndeterminate için HİÇ bir Trigger/animasyon tanımlamıyordu (arşiv açma aşamasında
         Emülatörler ekranı IsIndeterminate=true kullanıyor, bkz. StandaloneEmulatorInstallerService) —
         WPF'in varsayılan indeterminate animasyonu bu ÖZEL şablonda çalışmıyordu, PART_Indicator
         olduğu yerde sabit kalıyordu. Şimdi AYRI bir "kayan şerit" göstergesi + sonsuz döngü animasyonu var. -->
    <Style TargetType="{x:Type ProgressBar}">
        <Setter Property="Background" Value="{StaticResource Brush.Background.Elevated}" />
        <Setter Property="Foreground" Value="{StaticResource Brush.Accent.SelectedBorder}" />
        <Setter Property="Height" Value="6" />
        <Setter Property="Template">
            <Setter.Value>
                <ControlTemplate TargetType="{x:Type ProgressBar}">
                    <!-- Kullanıcı geri bildirimi: "% yazıyor ama bar ilerlemiyor, bar sabit
                         duruyor" — kök neden: WPF'in dahili ProgressBar mantığı, PART_Indicator'ın
                         genişliğini yeniden hesaplarken PART_Track'in ActualWidth'ine bakıyor;
                         PART_Track hiç YOKSA bu hesaplama SESSİZCE atlanıyor (metin binding'i
                         bağımsız çalıştığı için % yazısı doğru güncelleniyordu, sadece bar'ın
                         KENDİSİ hiç yeniden boyutlanmıyordu). Grid'i PART_Track olarak adlandırmak
                         yeterli düzeltme — ayrıca bir kod değişikliği gerekmiyor. -->
                    <Border Background="{TemplateBinding Background}" CornerRadius="3" ClipToBounds="True">
                        <Grid x:Name="PART_Track">
                            <Decorator x:Name="PART_Indicator" HorizontalAlignment="Left">
                                <Border Background="{TemplateBinding Foreground}" CornerRadius="3" />
                            </Decorator>
                            <Border x:Name="IndeterminateIndicator" Background="{TemplateBinding Foreground}"
                                    CornerRadius="3" Width="60" HorizontalAlignment="Left" Visibility="Collapsed">
                                <Border.RenderTransform>
                                    <TranslateTransform x:Name="IndeterminateTransform" X="-60" />
                                </Border.RenderTransform>
                            </Border>
                        </Grid>
                    </Border>
                    <ControlTemplate.Triggers>
                        <Trigger Property="IsIndeterminate" Value="True">
                            <Setter TargetName="PART_Indicator" Property="Visibility" Value="Collapsed" />
                            <Setter TargetName="IndeterminateIndicator" Property="Visibility" Value="Visible" />
                            <Trigger.EnterActions>
                                <BeginStoryboard x:Name="IndeterminateStoryboard">
                                    <Storyboard>
                                        <DoubleAnimation Storyboard.TargetName="IndeterminateTransform"
                                                         Storyboard.TargetProperty="X"
                                                         From="-60" To="400" Duration="0:0:1.2" RepeatBehavior="Forever" />
                                    </Storyboard>
                                </BeginStoryboard>
                            </Trigger.EnterActions>
                            <Trigger.ExitActions>
                                <StopStoryboard BeginStoryboardName="IndeterminateStoryboard" />
                            </Trigger.ExitActions>
                        </Trigger>
                    </ControlTemplate.Triggers>
                </ControlTemplate>
            </Setter.Value>
        </Setter>
    </Style>

    <!-- Varsayılan WPF ToolTip'i (beyaz arka plan, siyah yazı) koyu temaya hiç uymuyordu — hem
         elle Tooltip="..." verilen düğmelerde hem DataGrid'in kısaltılmış (ellipsis) hücreler için
         otomatik gösterdiği tooltip'lerde aynı sorun görülüyordu; tek bir global stil ikisini de
         düzeltiyor. -->
    <Style TargetType="{x:Type ToolTip}">
        <Setter Property="Background" Value="{StaticResource Brush.Background.Elevated}" />
        <Setter Property="Foreground" Value="{StaticResource Brush.Text.Primary}" />
        <Setter Property="BorderBrush" Value="{StaticResource Brush.Border}" />
        <Setter Property="BorderThickness" Value="1" />
        <Setter Property="Padding" Value="6,4" />
        <Setter Property="Template">
            <Setter.Value>
                <ControlTemplate TargetType="{x:Type ToolTip}">
                    <Border Background="{TemplateBinding Background}" BorderBrush="{TemplateBinding BorderBrush}"
                            BorderThickness="{TemplateBinding BorderThickness}" CornerRadius="4">
                        <ContentPresenter Margin="{TemplateBinding Padding}" />
                    </Border>
                </ControlTemplate>
            </Setter.Value>
        </Setter>
    </Style>

    <!-- Primary "BAŞLAT" launch button -->
    <Style x:Key="LaunchButton" TargetType="{x:Type Button}" BasedOn="{StaticResource {x:Type Button}}">
        <Setter Property="Background" Value="{StaticResource Brush.Accent.Launch}" />
        <Setter Property="FontWeight" Value="Bold" />
        <Setter Property="FontSize" Value="14" />
        <Setter Property="Padding" Value="0,10" />
        <Setter Property="Template">
            <Setter.Value>
                <ControlTemplate TargetType="{x:Type Button}">
                    <Border x:Name="border" Background="{TemplateBinding Background}" CornerRadius="4">
                        <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center" Margin="{TemplateBinding Padding}" />
                    </Border>
                    <ControlTemplate.Triggers>
                        <Trigger Property="IsMouseOver" Value="True">
                            <Setter TargetName="border" Property="Background" Value="{StaticResource Brush.Accent.LaunchHover}" />
                        </Trigger>
                    </ControlTemplate.Triggers>
                </ControlTemplate>
            </Setter.Value>
        </Setter>
    </Style>

    <!-- Platform adı/Core Adı rozetleriyle AYNI görsel dil (bkz. SettingsWindow.xaml
         PlatformNameBadge) — paylaşılan tema dosyasına taşındı ki MainWindow'daki Türler
         rozetleri (kullanıcı isteği: "1. resimdekiler emulator ayarlarındaki platform listesinin
         badgeleri ... tasarım olarak aynısını istiyom") de AYNI stili kullanabilsin. -->
    <Style x:Key="PlatformNameBadge" TargetType="Border">
        <Setter Property="Background" Value="{StaticResource Brush.Accent.Launch}" />
        <Setter Property="CornerRadius" Value="10" />
        <Setter Property="Padding" Value="10,3" />
    </Style>

    <!-- Kullanıcı isteği: "tablodaki türleri 1. resimdeki gibi tıklanıp filtrelenebilir badge
         yapabilirmisin" — PlatformNameBadge ile AYNI görünüm (Brush.Accent.Launch, CornerRadius
         10) ama gerçek bir Button (tıklanabilir + hover, LaunchButton'daki AYNI hover deseni) —
         MainWindow'daki Türler sütunu hücrelerinde her tür token'ı için (bkz.
         MainViewModel.FilterByGenreTokenCommand). -->
    <Style x:Key="GenreBadgeButton" TargetType="{x:Type Button}" BasedOn="{StaticResource {x:Type Button}}">
        <Setter Property="Background" Value="{StaticResource Brush.Accent.Launch}" />
        <Setter Property="Foreground" Value="White" />
        <Setter Property="FontWeight" Value="Bold" />
        <Setter Property="FontSize" Value="10" />
        <Setter Property="Cursor" Value="Hand" />
        <Setter Property="Padding" Value="8,2" />
        <Setter Property="Margin" Value="0,1,4,1" />
        <!-- Kullanıcı bulgusu: "tam ekranken daha çok yapıyor ... türlerdeki badge'lerde etkiler mi"
             — tam ekranda aynı anda çok daha fazla satır (ve dolayısıyla çok daha fazla tür rozeti
             Button'ı) görünür oluyor; her Button varsayılan olarak Focusable/IsTabStop, WPF'in
             klavye gezinme (KeyboardNavigation) ve odak kapsamı hesaplarına dahil ediliyor — sadece
             fareyle tıklanan küçük bir rozet için gereksiz. Kapatmak satır başına ölçülebilir bir
             ek yükü ortadan kaldırıyor, tıklama davranışını ETKİLEMİYOR. -->
        <Setter Property="Focusable" Value="False" />
        <Setter Property="IsTabStop" Value="False" />
        <Setter Property="Template">
            <Setter.Value>
                <ControlTemplate TargetType="{x:Type Button}">
                    <Border x:Name="border" Background="{TemplateBinding Background}" CornerRadius="10">
                        <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center" Margin="{TemplateBinding Padding}" />
                    </Border>
                    <ControlTemplate.Triggers>
                        <Trigger Property="IsMouseOver" Value="True">
                            <Setter TargetName="border" Property="Background" Value="{StaticResource Brush.Accent.LaunchHover}" />
                        </Trigger>
                    </ControlTemplate.Triggers>
                </ControlTemplate>
            </Setter.Value>
        </Setter>
    </Style>

    <!-- ===================== ToggleButton (filter chips) ===================== -->
    <Style TargetType="{x:Type ToggleButton}">
        <Setter Property="Background" Value="{StaticResource Brush.Background.Elevated}" />
        <Setter Property="Foreground" Value="{StaticResource Brush.Text.Primary}" />
        <Setter Property="BorderBrush" Value="{StaticResource Brush.Border}" />
        <Setter Property="BorderThickness" Value="1" />
        <Setter Property="Padding" Value="10,4" />
        <Setter Property="Cursor" Value="Hand" />
        <Setter Property="Template">
            <Setter.Value>
                <ControlTemplate TargetType="{x:Type ToggleButton}">
                    <Border x:Name="border"
                            Background="{TemplateBinding Background}"
                            BorderBrush="{TemplateBinding BorderBrush}"
                            BorderThickness="{TemplateBinding BorderThickness}"
                            CornerRadius="3">
                        <ContentPresenter HorizontalAlignment="Center"
                                           VerticalAlignment="Center"
                                           Margin="{TemplateBinding Padding}" />
                    </Border>
                    <ControlTemplate.Triggers>
                        <Trigger Property="IsChecked" Value="True">
                            <Setter TargetName="border" Property="Background" Value="{StaticResource Brush.Accent.Amber}" />
                            <Setter Property="Foreground" Value="{StaticResource Brush.Accent.AmberText}" />
                        </Trigger>
                        <Trigger Property="IsMouseOver" Value="True">
                            <Setter TargetName="border" Property="Background" Value="{StaticResource Brush.Background.Hover}" />
                        </Trigger>
                    </ControlTemplate.Triggers>
                </ControlTemplate>
            </Setter.Value>
        </Setter>
    </Style>

    <!-- ===================== TextBox (search box) ===================== -->
    <Style TargetType="{x:Type TextBox}">
        <Setter Property="Background" Value="{StaticResource Brush.Background.Elevated}" />
        <Setter Property="Foreground" Value="{StaticResource Brush.Text.Primary}" />
        <Setter Property="CaretBrush" Value="{StaticResource Brush.Text.Primary}" />
        <Setter Property="BorderBrush" Value="{StaticResource Brush.Border}" />
        <Setter Property="BorderThickness" Value="1" />
        <Setter Property="Padding" Value="6,4" />
        <Setter Property="Template">
            <Setter.Value>
                <ControlTemplate TargetType="{x:Type TextBox}">
                    <Border Background="{TemplateBinding Background}"
                            BorderBrush="{TemplateBinding BorderBrush}"
                            BorderThickness="{TemplateBinding BorderThickness}"
                            CornerRadius="3">
                        <ScrollViewer x:Name="PART_ContentHost" Margin="{TemplateBinding Padding}" VerticalAlignment="Center" />
                    </Border>
                </ControlTemplate>
            </Setter.Value>
        </Setter>
    </Style>

    <!-- ===================== ComboBox (Tools / Filter dropdowns) ===================== -->
    <Style TargetType="{x:Type ComboBoxItem}">
        <Setter Property="Background" Value="{StaticResource Brush.Background.Elevated}" />
        <Setter Property="Foreground" Value="{StaticResource Brush.Text.Primary}" />
        <Setter Property="Padding" Value="8,4" />
        <Setter Property="Template">
            <Setter.Value>
                <ControlTemplate TargetType="{x:Type ComboBoxItem}">
                    <Border x:Name="border" Background="{TemplateBinding Background}" Padding="{TemplateBinding Padding}">
                        <ContentPresenter />
                    </Border>
                    <ControlTemplate.Triggers>
                        <Trigger Property="IsHighlighted" Value="True">
                            <Setter TargetName="border" Property="Background" Value="{StaticResource Brush.Accent.Selected}" />
                        </Trigger>
                    </ControlTemplate.Triggers>
                </ControlTemplate>
            </Setter.Value>
        </Setter>
    </Style>

    <Style TargetType="{x:Type ComboBox}">
        <Setter Property="Background" Value="{StaticResource Brush.Background.Elevated}" />
        <Setter Property="Foreground" Value="{StaticResource Brush.Text.Primary}" />
        <Setter Property="BorderBrush" Value="{StaticResource Brush.Border}" />
        <Setter Property="BorderThickness" Value="1" />
        <Setter Property="Padding" Value="8,4" />
        <Setter Property="Template">
            <Setter.Value>
                <ControlTemplate TargetType="{x:Type ComboBox}">
                    <Grid>
                        <ToggleButton x:Name="ToggleButton"
                                      Background="{TemplateBinding Background}"
                                      BorderBrush="{TemplateBinding BorderBrush}"
                                      BorderThickness="{TemplateBinding BorderThickness}"
                                      IsChecked="{Binding IsDropDownOpen, RelativeSource={RelativeSource TemplatedParent}, Mode=TwoWay}"
                                      ClickMode="Press">
                            <ToggleButton.Template>
                                <ControlTemplate TargetType="{x:Type ToggleButton}">
                                    <Border Background="{TemplateBinding Background}"
                                            BorderBrush="{TemplateBinding BorderBrush}"
                                            BorderThickness="{TemplateBinding BorderThickness}"
                                            CornerRadius="3">
                                        <Grid>
                                            <Grid.ColumnDefinitions>
                                                <ColumnDefinition Width="*" />
                                                <ColumnDefinition Width="16" />
                                            </Grid.ColumnDefinitions>
                                            <ContentPresenter Grid.Column="0"
                                                               Content="{Binding Path=SelectionBoxItem, RelativeSource={RelativeSource AncestorType=ComboBox}}"
                                                               Margin="8,4" VerticalAlignment="Center" />
                                            <Path Grid.Column="1" Data="M0,0 L4,4 L8,0 Z" Fill="{StaticResource Brush.Text.Secondary}"
                                                  HorizontalAlignment="Center" VerticalAlignment="Center" />
                                        </Grid>
                                    </Border>
                                </ControlTemplate>
                            </ToggleButton.Template>
                        </ToggleButton>
                        <Popup x:Name="Popup" IsOpen="{TemplateBinding IsDropDownOpen}" Placement="Bottom" AllowsTransparency="True" Focusable="False" PopupAnimation="Slide">
                            <Border Background="{StaticResource Brush.Background.Elevated}" BorderBrush="{StaticResource Brush.Border}" BorderThickness="1" MinWidth="{TemplateBinding ActualWidth}">
                                <ScrollViewer Margin="2" SnapsToDevicePixels="True">
                                    <ItemsPresenter />
                                </ScrollViewer>
                            </Border>
                        </Popup>
                    </Grid>
                </ControlTemplate>
            </Setter.Value>
        </Setter>
    </Style>

    <!-- ===================== Slider (row height) ===================== -->
    <Style TargetType="{x:Type Slider}">
        <Setter Property="Foreground" Value="{StaticResource Brush.Accent.SelectedBorder}" />
        <Setter Property="Height" Value="20" />
    </Style>

    <!-- ===================== ListBoxItem (platform list) ===================== -->
    <Style TargetType="{x:Type ListBoxItem}">
        <Setter Property="Padding" Value="8,6" />
        <Setter Property="Foreground" Value="{StaticResource Brush.Text.Primary}" />
        <Setter Property="HorizontalContentAlignment" Value="Stretch" />
        <Setter Property="Template">
            <Setter.Value>
                <ControlTemplate TargetType="{x:Type ListBoxItem}">
                    <Border x:Name="border" Background="Transparent" Padding="{TemplateBinding Padding}" BorderThickness="0,0,3,0" BorderBrush="Transparent">
                        <ContentPresenter />
                    </Border>
                    <ControlTemplate.Triggers>
                        <Trigger Property="IsSelected" Value="True">
                            <Setter TargetName="border" Property="Background" Value="{StaticResource Brush.Accent.Selected}" />
                            <Setter TargetName="border" Property="BorderBrush" Value="{StaticResource Brush.Accent.SelectedBorder}" />
                        </Trigger>
                        <Trigger Property="IsMouseOver" Value="True">
                            <Setter TargetName="border" Property="Background" Value="{StaticResource Brush.Background.Hover}" />
                        </Trigger>
                    </ControlTemplate.Triggers>
                </ControlTemplate>
            </Setter.Value>
        </Setter>
    </Style>

    <Style TargetType="{x:Type ListBox}">
        <Setter Property="Background" Value="Transparent" />
        <Setter Property="BorderThickness" Value="0" />
    </Style>

    <!-- ===================== DataGrid (game grid) ===================== -->
    <Style TargetType="{x:Type DataGrid}">
        <Setter Property="Background" Value="{StaticResource Brush.Background.Base}" />
        <Setter Property="Foreground" Value="{StaticResource Brush.Text.Primary}" />
        <Setter Property="BorderThickness" Value="0" />
        <Setter Property="RowBackground" Value="{StaticResource Brush.Background.Base}" />
        <Setter Property="AlternatingRowBackground" Value="{StaticResource Brush.Background.Panel}" />
        <!-- Sadece satırlar arasında ince yatay ayırıcı çizgi kullanılıyor; dikey (sütunlar arası)
             çizgiler kasıtlı olarak kapalı — tablo çok "kafesli" görünmesin diye. -->
        <Setter Property="GridLinesVisibility" Value="Horizontal" />
        <Setter Property="HeadersVisibility" Value="Column" />
        <Setter Property="AutoGenerateColumns" Value="False" />
        <Setter Property="CanUserAddRows" Value="False" />
        <Setter Property="CanUserDeleteRows" Value="False" />
        <Setter Property="CanUserReorderColumns" Value="True" />
        <Setter Property="CanUserResizeRows" Value="False" />
        <!-- Extended: Ctrl+tık tekil satır ekler/çıkarır, Shift+tık aralık seçer (WPF'in normal
             çoklu seçim davranışı). Daha önce yanlışlıkla "Single" idi — bu, sağ tık menüsündeki
             toplu (bulk) mod dahil, satır bazlı hiçbir çoklu seçimi mümkün kılmıyordu. -->
        <Setter Property="SelectionMode" Value="Extended" />
        <Setter Property="SelectionUnit" Value="FullRow" />
        <Setter Property="RowHeaderWidth" Value="0" />
        <Setter Property="VerticalGridLinesBrush" Value="{StaticResource Brush.Border}" />
        <Setter Property="HorizontalGridLinesBrush" Value="{StaticResource Brush.Border}" />
    </Style>

    <Style TargetType="{x:Type DataGridColumnHeader}">
        <Setter Property="Background" Value="{StaticResource Brush.Background.Elevated}" />
        <Setter Property="Foreground" Value="{StaticResource Brush.Text.Secondary}" />
        <Setter Property="Padding" Value="6,6" />
        <Setter Property="BorderBrush" Value="{StaticResource Brush.Border}" />
        <Setter Property="BorderThickness" Value="0,0,1,1" />
        <Setter Property="FontWeight" Value="SemiBold" />
    </Style>

    <Style TargetType="{x:Type DataGridRow}">
        <Setter Property="Background" Value="{Binding RelativeSource={RelativeSource Self}, Path=(DataGrid.RowBackground)}" />
        <Style.Triggers>
            <!-- IsMouseOver ÖNCE gelmeli: iki Trigger da aynı Background'ı set ettiğinde, ikisi de
                 aktifken (Ctrl/Shift ile seçtiğin satırın üzerinde fare dururken) SONRA tanımlanan
                 kazanıyordu. Sıra IsSelected->IsMouseOver iken, seçili bir satırın üstünde fare
                 durduğu sürece hover rengi seçili (mavi) rengi eziyordu — Ctrl/Shift ile birden
                 fazla satır seçildiğinde, üzerinde durulan satır seçilmemiş gibi görünüyor, bu da
                 "toplu seçim çalışmıyor" izlenimi veriyordu (seçim aslında doğruydu, sadece görünmüyordu).
                 IsSelected şimdi SONRA tanımlı, bu yüzden ikisi de aktifken her zaman kazanıyor. -->
            <Trigger Property="IsMouseOver" Value="True">
                <Setter Property="Background" Value="{StaticResource Brush.Background.Hover}" />
            </Trigger>
            <Trigger Property="IsSelected" Value="True">
                <Setter Property="Background" Value="{StaticResource Brush.Accent.Selected}" />
            </Trigger>
        </Style.Triggers>
    </Style>

    <Style TargetType="{x:Type DataGridCell}">
        <Setter Property="Background" Value="Transparent" />
        <Setter Property="BorderThickness" Value="0" />
        <Setter Property="Padding" Value="6,2" />
        <Setter Property="Template">
            <Setter.Value>
                <ControlTemplate TargetType="{x:Type DataGridCell}">
                    <Border Background="{TemplateBinding Background}" Padding="{TemplateBinding Padding}" SnapsToDevicePixels="True">
                        <ContentPresenter VerticalAlignment="Center" />
                    </Border>
                </ControlTemplate>
            </Setter.Value>
        </Setter>
        <!-- ROM'u eksik oyunların hücre içeriğini soluklaştırır (bkz. MainWindow.xaml GamesGrid
             yorumu — kasıtlı olarak SATIR değil HÜCRE seviyesinde, satırın yatay ayırıcı çizgisi
             tüm satırlarda aynı tonda kalsın diye). DataGridCell'in DataContext'i her zaman satırın
             veri öğesi (Game) olduğu için hücrenin içeriği DataGridBoundColumn veya
             DataGridTemplateColumn olsun fark etmiyor. MultiDataTrigger daha SONRA tanımlı, bu
             yüzden ikisi de aktifken (ROM da yok, eşleşme de yok) o kazanıp daha silik (0.25) rengi
             uyguluyor. -->
        <Style.Triggers>
            <DataTrigger Binding="{Binding HasLocalFile}" Value="False">
                <Setter Property="Opacity" Value="0.45" />
            </DataTrigger>
            <MultiDataTrigger>
                <MultiDataTrigger.Conditions>
                    <Condition Binding="{Binding HasLocalFile}" Value="False" />
                    <Condition Binding="{Binding StatusOk}" Value="False" />
                </MultiDataTrigger.Conditions>
                <Setter Property="Opacity" Value="0.25" />
            </MultiDataTrigger>
        </Style.Triggers>
    </Style>

    <!-- ===================== TabControl (Ayarlar penceresindeki kategori sekmeleri) ===================== -->
    <Style TargetType="{x:Type TabItem}">
        <Setter Property="Foreground" Value="{StaticResource Brush.Text.Secondary}" />
        <Setter Property="Padding" Value="14,8" />
        <Setter Property="Template">
            <Setter.Value>
                <ControlTemplate TargetType="{x:Type TabItem}">
                    <Border x:Name="border" Background="{StaticResource Brush.Background.Panel}"
                            BorderBrush="{StaticResource Brush.Accent.SelectedBorder}" BorderThickness="0,0,0,2"
                            Padding="{TemplateBinding Padding}" Margin="0,0,2,0">
                        <!-- ContentSource="Header" şart: belirtilmezse ContentPresenter varsayılan olarak
                             TabItem.Content'i (sekme sayfasının gövdesi) göstermeye çalışır, Header'ı değil —
                             bu yüzden sekme başlıkları (Genel/Emülatörler/...) hiç görünmüyordu. -->
                        <ContentPresenter ContentSource="Header" HorizontalAlignment="Center" VerticalAlignment="Center" />
                    </Border>
                    <ControlTemplate.Triggers>
                        <Trigger Property="IsSelected" Value="True">
                            <Setter TargetName="border" Property="Background" Value="{StaticResource Brush.Background.Elevated}" />
                            <Setter Property="Foreground" Value="{StaticResource Brush.Text.Primary}" />
                        </Trigger>
                        <Trigger Property="IsSelected" Value="False">
                            <Setter TargetName="border" Property="BorderBrush" Value="Transparent" />
                        </Trigger>
                    </ControlTemplate.Triggers>
                </ControlTemplate>
            </Setter.Value>
        </Setter>
    </Style>

    <Style TargetType="{x:Type TabControl}">
        <Setter Property="Background" Value="{StaticResource Brush.Background.Base}" />
        <Setter Property="BorderThickness" Value="0" />
        <Setter Property="Padding" Value="0" />
    </Style>

</ResourceDictionary>
